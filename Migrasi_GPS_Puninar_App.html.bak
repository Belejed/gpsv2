              <span className="stat-sub">GPS Migration</span>
              <div className="stat-indicator" style={{background: 'var(--accent)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Terjadwal</span>
              <span className="stat-value" style={{color: 'var(--color-plan)'}}>{stats.plan}</span>
              <span className="stat-sub">{stats.total ? Math.round(stats.plan/stats.total*100) : 0}% ter-plan</span>
              <div className="stat-indicator" style={{background: 'var(--color-plan)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Belum Plan</span>
              <span className="stat-value" style={{color: 'var(--color-unplan)'}}>{stats.unplan}</span>
              <span className="stat-sub">Menunggu jadwal</span>
              <div className="stat-indicator" style={{background: 'var(--color-unplan)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Selesai (Done)</span>
              <span className="stat-value" style={{color: 'var(--color-done)'}}>{stats.done}</span>
              <span className="stat-sub">{pct}% Selesai</span>
              <div className="stat-indicator" style={{background: 'var(--color-done)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Verifikasi IT</span>
              <span className="stat-value" style={{color: '#8b5cf6'}}>{stats.verified}</span>
              <span className="stat-sub">System OK</span>
              <div className="stat-indicator" style={{background: '#8b5cf6'}} />
            </div>
          </div>

          <div className="progress-panel">
            <div className="progress-header">
              <span className="progress-title">Progress Pemasangan Kumulatif</span>
              <span className="progress-stats">{stats.done} / {stats.total} Unit ({pct}%)</span>
            </div>
            <div className="progress-bar-container">
              <div className="progress-bar-fill" style={{ width: `${pct}%` }} />
            </div>
            <div className="legend-container">
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-done)'}} /> Done ({stats.done})</div>
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-progress)'}} /> On Progress ({stats.prog})</div>
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-delay)'}} /> Delay ({stats.delay})</div>
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-unplan)'}} /> Belum Dijadwalkan ({stats.unplan})</div>
            </div>
          </div>

          <div className="dashboard-layout-grid">
            <div className="panel-card">
              <div className="panel-title"><i className="ti ti-map-pin"></i> Unit per Lokasi</div>
              <BarChart data={locData} keys={[{key: 'Total', label: 'Total', color: 'var(--accent-light)'}, {key: 'Done', label: 'Done', color: 'var(--color-done)'}]} />
              <div style={{display:'flex', gap:12, marginTop: 16, justifyContent: 'center'}}>
                <span style={{fontSize:10, color:'var(--text-secondary)', display:'flex', alignItems:'center', gap:4}}>
                  <span style={{width:10, height:10, borderRadius:2, background:'var(--accent-light)'}}/>Total Unit
                </span>
                <span style={{fontSize:10, color:'var(--text-secondary)', display:'flex', alignItems:'center', gap:4}}>
                  <span style={{width:10, height:10, borderRadius:2, background:'var(--color-done)'}}/>Selesai Terpasang
                </span>
              </div>

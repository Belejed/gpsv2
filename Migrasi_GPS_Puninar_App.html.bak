          { name: 'Done', value: stats.done, color: 'var(--color-done)' },
          { name: 'On Progress', value: stats.prog, color: 'var(--color-progress)' },
          { name: 'Delay', value: stats.delay, color: 'var(--color-delay)' },
          { name: 'Unplan/Belum', value: stats.total - stats.done - stats.prog - stats.delay, color: 'var(--color-unplan)' },
        ].filter(d => d.value > 0);
      }, [stats]);

      const recent = useMemo(() => {

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Migrasi GPS Puninar Logistics</title>
  <!-- Google Fonts: Plus Jakarta Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- Tabler Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/2.47.0/iconfont/tabler-icons.min.css">
  
  <style>
    :root {
      /* Color Palette - Slate & Blue (Light Mode default) */
      --bg-primary: #f8fafc;
      --bg-secondary: #f1f5f9;
      --bg-card: #ffffff;
      --bg-glass: rgba(255, 255, 255, 0.75);
      --text-primary: #0f172a;
      --text-secondary: #475569;
      --text-tertiary: #94a3b8;
      --border-color: #e2e8f0;
      --border-focus: #3b82f6;
      
      --accent: #2563eb;
      --accent-hover: #1d4ed8;
      --accent-light: #eff6ff;
      
      /* Status Colors */
      --color-plan: #2563eb;
      --color-plan-bg: #eff6ff;
      --color-unplan: #64748b;
      --color-unplan-bg: #f8fafc;
      --color-done: #10b981;
      --color-done-bg: #ecfdf5;
      --color-progress: #f59e0b;
      --color-progress-bg: #fffbeb;
      --color-delay: #ef4444;
      --color-delay-bg: #fef2f2;
      --color-reschedule: #8b5cf6;
      --color-reschedule-bg: #f5f3ff;
      
      --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.07), 0 4px 6px -4px rgba(0, 0, 0, 0.07);
      
      --font-sans: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 16px;
      
      --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    [data-theme="dark"] {
      --bg-primary: #090d16;
      --bg-secondary: #0f172a;
      --bg-card: #1e293b;
      --bg-glass: rgba(30, 41, 59, 0.7);
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --text-tertiary: #64748b;
      --border-color: #334155;
      --border-focus: #60a5fa;
      
      --accent: #3b82f6;
      --accent-hover: #2563eb;
      --accent-light: rgba(59, 130, 246, 0.1);
      
      --color-unplan-bg: #1e293b;
      
      --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.2), 0 2px 4px -2px rgba(0, 0, 0, 0.2);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -4px rgba(0, 0, 0, 0.3);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      margin: 0;
      font-family: var(--font-sans);
      background: var(--bg-primary);
      color: var(--text-primary);
      transition: var(--transition);
      overflow-x: hidden;
    }

    select, input, button, textarea {
      font-family: var(--font-sans);
      outline: none;
      transition: var(--transition);
    }

    /* Scrollbars */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg-primary);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--border-color);
      border-radius: var(--radius-sm);
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--text-tertiary);
    }

    /* Animations */
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes modalFadeIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes slideInRight {
      from { transform: translateX(100%); }
      to { transform: translateX(0); }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    .fade-in {
      animation: fadeIn 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    /* Toast Container */
    .toast-container {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
      pointer-events: none;
    }
    .toast {
      pointer-events: auto;
      min-width: 280px;
      max-width: 400px;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-lg);
      padding: 14px 18px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--text-primary);
      animation: fadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      border-left: 4px solid var(--accent);
    }
    .toast.success { border-left-color: var(--color-done); }
    .toast.error { border-left-color: var(--color-delay); }
    .toast.info { border-left-color: var(--accent); }
    .toast-close {
      margin-left: auto;
      background: none;
      border: none;
      color: var(--text-tertiary);
      cursor: pointer;
    }
    .toast-close:hover { color: var(--text-primary); }

    /* Login Gate Layout */
    .login-container {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--bg-primary);
      position: relative;
      padding: 16px;
    }
    .login-container::before {
      content: '';
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #4f46e5);
      filter: blur(120px);
      opacity: 0.15;
      top: 10%;
      left: 15%;
    }
    .login-container::after {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--color-done), var(--accent));
      filter: blur(100px);
      opacity: 0.12;
      bottom: 15%;
      right: 15%;
    }
    .login-card {
      background: var(--bg-glass);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      padding: 40px 32px;
      width: 100%;
      max-width: 420px;
      box-shadow: var(--shadow-lg);
      z-index: 10;
      animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .login-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 54px;
      height: 54px;
      border-radius: var(--radius-md);
      background: var(--accent-light);
      color: var(--accent);
      margin: 0 auto 20px auto;
      font-size: 24px;
    }
    .login-title {
      font-size: 22px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 6px;
      letter-spacing: -0.5px;
    }
    .login-subtitle {
      font-size: 13px;
      color: var(--text-secondary);
      text-align: center;
      margin-bottom: 28px;
    }
    .input-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 20px;
      position: relative;
    }
    .input-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-secondary);
      letter-spacing: 0.3px;
    }
    .input-field {
      width: 100%;
      padding: 11px 14px;
      border: 1px solid var(--border-color);
      background: var(--bg-card);
      color: var(--text-primary);
      border-radius: var(--radius-md);
      font-size: 14px;
      transition: var(--transition);
    }
    .input-field:focus {
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--accent-light);
    }
    .password-toggle {
      position: absolute;
      right: 12px;
      bottom: 10px;
      background: none;
      border: none;
      color: var(--text-tertiary);
      cursor: pointer;
      display: flex;
      align-items: center;
    }
    .password-toggle:hover {
      color: var(--text-primary);
    }
    .login-btn {
      width: 100%;
      padding: 12px;
      border: none;
      background: var(--accent);
      color: #ffffff;
      font-size: 14px;
      font-weight: 600;
      border-radius: var(--radius-md);
      cursor: pointer;
      box-shadow: var(--shadow-sm);
      margin-top: 10px;
    }
    .login-btn:hover {
      background: var(--accent-hover);
      transform: translateY(-1px);
    }
    .login-btn:active {
      transform: translateY(0);
    }

    /* Main App Layout */
    .app-wrapper {
      display: flex;
      min-height: 100vh;
      background: var(--bg-primary);
      color: var(--text-primary);
    }

    /* Sidebar Navigation */
    .sidebar {
      width: 260px;
      background: var(--bg-card);
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      z-index: 100;
      position: sticky;
      top: 0;
      height: 100vh;
      transition: var(--transition);
    }
    .sidebar-header {
      padding: 20px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid var(--border-color);
    }
    .sidebar-logo-icon {
      width: 32px;
      height: 32px;
      background: var(--accent);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-sm);
      font-size: 16px;
    }
    .sidebar-brand {
      font-size: 15px;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.3px;
    }
    .sidebar-brand span {
      display: block;
      font-size: 10px;
      font-weight: 500;
      color: var(--text-secondary);
      letter-spacing: 0;
      margin-top: 2px;
    }
    .sidebar-user {
      padding: 16px 24px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .sidebar-avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--bg-secondary);
      color: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 14px;
      border: 1px solid var(--border-color);
    }
    .sidebar-user-info {
      flex: 1;
      min-width: 0;
    }
    .sidebar-username {
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sidebar-role {
      font-size: 11px;
      color: var(--text-secondary);
      text-transform: capitalize;
      margin-top: 1px;
    }
    .sidebar-menu {
      padding: 16px 14px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 4px;
      overflow-y: auto;
    }
    .menu-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-secondary);
      background: none;
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      text-align: left;
      width: 100%;
    }
    .menu-item:hover {
      background: var(--bg-secondary);
      color: var(--text-primary);
    }
    .menu-item.active {
      background: var(--accent-light);
      color: var(--accent);
      font-weight: 600;
    }
    .menu-item i {
      font-size: 16px;
    }
    .sidebar-footer {
      padding: 16px;
      border-top: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .theme-toggle-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 8px;
      font-size: 12px;
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      cursor: pointer;
      border-radius: var(--radius-sm);
    }
    .theme-toggle-btn:hover {
      color: var(--text-primary);
    }
    .logout-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 8px;
      font-size: 12px;
      background: none;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      cursor: pointer;
      border-radius: var(--radius-sm);
    }
    .logout-btn:hover {
      background: var(--color-delay-bg);
      color: var(--color-delay);
      border-color: rgba(239, 68, 68, 0.2);
    }

    /* Main Content Area */
    .main-layout {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      position: relative;
    }

    /* Top Bar */
    .topbar {
      height: 58px;
      background: var(--bg-card);
      border-bottom: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      position: sticky;
      top: 0;
      z-index: 90;
    }
    .topbar-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .menu-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--text-primary);
      font-size: 20px;
      cursor: pointer;
    }
    .topbar-title-sec {
      font-size: 16px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .sync-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-secondary);
      background: var(--bg-secondary);
      padding: 4px 10px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-color);
    }
    .sync-status.syncing i {
      animation: spin 1s linear infinite;
    }
    .sync-status.success i { color: var(--color-done); }
    .sync-status.error i { color: var(--color-delay); }
    
    .refresh-icon-btn {
      background: none;
      border: none;
      color: var(--text-secondary);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 6px;
      border-radius: 50%;
    }
    .refresh-icon-btn:hover {
      background: var(--bg-secondary);
      color: var(--text-primary);
    }
    
    /* View Body */
    .view-content {
      padding: 24px;
      flex: 1;
      overflow-y: auto;
    }

    /* Role Alert Banner */
    .role-banner {
      padding: 12px 16px;
      border-radius: var(--radius-md);
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-left: 4px solid var(--accent);
    }
    .role-banner.planner { border-left-color: var(--color-plan); background: var(--color-plan-bg); color: var(--color-plan); }
    .role-banner.teknisi { border-left-color: var(--color-done); background: var(--color-done-bg); color: var(--color-done); }
    .role-banner.verifikasi { border-left-color: var(--color-progress); background: var(--color-progress-bg); color: var(--color-progress); }
    .role-banner.admin { border-left-color: var(--color-reschedule); background: var(--color-reschedule-bg); color: var(--color-reschedule); }

    /* Dashboard Layout & Widgets */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 14px 16px;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition: var(--transition);
    }
    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    .stat-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }
    .stat-value {
      font-size: 22px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.1;
    }
    .stat-sub {
      font-size: 11px;
      color: var(--text-tertiary);
      margin-top: 4px;
    }
    .stat-indicator {
      position: absolute;
      top: 0;
      right: 0;
      width: 4px;
      height: 100%;
      background: var(--border-color);
    }

    /* Overall Progress Panel */
    .progress-panel {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 20px;
      box-shadow: var(--shadow-sm);
      margin-bottom: 20px;
    }
    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    .progress-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
    }
    .progress-stats {
      font-size: 12px;
      font-weight: 700;
    }
    .progress-bar-container {
      height: 10px;
      background: var(--bg-secondary);
      border-radius: 5px;
      overflow: hidden;
      margin-bottom: 12px;
    }
    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--color-done), #34d399);
      border-radius: 5px;
      transition: width 0.6s ease-in-out;
    }
    .legend-container {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-secondary);
    }
    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    /* Grid for Charts & Lists */
    .dashboard-layout-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }
    @media (max-width: 1024px) {
      .dashboard-layout-grid {
        grid-template-columns: 1fr;
      }
    }
    .panel-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 18px;
      box-shadow: var(--shadow-sm);
    }
    .panel-title {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 14px;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* Badges */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.2px;
      white-space: nowrap;
    }
    .badge.plan { background: var(--color-plan-bg); color: var(--color-plan); }
    .badge.unplan { background: var(--color-unplan-bg); color: var(--color-unplan); border: 1px solid var(--border-color); }
    .badge.done { background: var(--color-done-bg); color: var(--color-done); }
    .badge.progress { background: var(--color-progress-bg); color: var(--color-progress); }
    .badge.delay { background: var(--color-delay-bg); color: var(--color-delay); }
    .badge.reschedule { background: var(--color-reschedule-bg); color: var(--color-reschedule); }

    /* Filters & Search Controls */
    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
      align-items: center;
    }
    .search-input-wrapper {
      position: relative;
      flex: 1;
      min-width: 200px;
    }
    .search-input-wrapper i {
      position: absolute;
      left: 11px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-tertiary);
      font-size: 14px;
    }
    .search-input {
      width: 100%;
      padding: 8px 12px 8px 32px;
      font-size: 13px;
      border: 1px solid var(--border-color);
      background: var(--bg-card);
      color: var(--text-primary);
      border-radius: var(--radius-sm);
    }
    .search-input:focus {
      border-color: var(--border-focus);
    }
    .filter-select {
      padding: 8px 12px;
      font-size: 13px;
      border: 1px solid var(--border-color);
      background: var(--bg-card);
      color: var(--text-primary);
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .filter-select:focus {
      border-color: var(--border-focus);
    }
    .unit-count-tag {
      font-size: 12px;
      color: var(--text-secondary);
      margin-left: auto;
      font-weight: 500;
    }

    /* Tables */
    .table-container {
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      overflow-x: auto;
      background: var(--bg-card);
      box-shadow: var(--shadow-sm);
      margin-bottom: 12px;
    }
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      text-align: left;
    }
    .data-table th {
      background: var(--bg-secondary);
      padding: 10px 14px;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border-color);
      white-space: nowrap;
    }
    .data-table td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border-color);
      vertical-align: middle;
      color: var(--text-primary);
    }
    .data-table tbody tr:last-child td {
      border-bottom: none;
    }
    .data-table tbody tr:hover {
      background: var(--bg-secondary);
    }
    .text-center { text-align: center; }
    .text-muted { color: var(--text-secondary); }

    /* Buttons */
    .btn {
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 600;
      border-radius: var(--radius-sm);
      cursor: pointer;
      border: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }
    .btn-sm { padding: 4px 8px; font-size: 11px; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-secondary { background: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border-color); }
    .btn-secondary:hover { background: var(--border-color); }
    .btn-danger { background: var(--color-delay-bg); color: var(--color-delay); }
    .btn-danger:hover { background: var(--color-delay); color: #fff; }
    .btn-success { background: var(--color-done-bg); color: var(--color-done); }
    .btn-success:hover { background: var(--color-done); color: #fff; }

    /* Modals / Dialogs */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 16px;
      animation: fadeIn 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .modal-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      width: 100%;
      max-width: 520px;
      display: flex;
      flex-direction: column;
      max-height: 90vh;
      overflow: hidden;
      animation: modalFadeIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    .modal-header {
      padding: 18px 24px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .modal-title {
      font-size: 15px;
      font-weight: 700;
    }
    .modal-close {
      background: none;
      border: none;
      color: var(--text-tertiary);
      cursor: pointer;
      font-size: 18px;
    }
    .modal-close:hover {
      color: var(--text-primary);
    }
    .modal-body {
      padding: 24px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .modal-footer {
      padding: 14px 24px;
      border-top: 1px solid var(--border-color);
      background: var(--bg-secondary);
      display: flex;
      justify-content: flex-end;
      gap: 8px;
    }

    /* Pager */
    .pager-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 10px;
      padding: 0 4px;
    }
    .pager-info {
      font-size: 12px;
      color: var(--text-secondary);
    }
    .pager-controls {
      display: flex;
      gap: 6px;
    }

    /* Apps Script Code Instructions Drawer */
    .instruction-box {
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      margin-top: 20px;
      overflow: hidden;
    }
    .instruction-header {
      padding: 12px 18px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .instruction-body {
      padding: 18px;
      border-top: 1px solid var(--border-color);
      background: var(--bg-card);
      font-size: 12px;
      line-height: 1.6;
    }
    .code-snippet {
      background: #0f172a;
      color: #38bdf8;
      font-family: Consolas, Monaco, monospace;
      padding: 12px;
      border-radius: var(--radius-sm);
      overflow-x: auto;
      margin: 10px 0;
      font-size: 11px;
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    /* Switch Option Button Styles (For field checklists) */
    .option-switch-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    
    /* Segmented Control Styling */
    .segmented-control {
      display: flex;
      background: var(--bg-secondary);
      padding: 3px;
      border-radius: var(--radius-md);
      border: 1px solid var(--border-color);
      width: 100%;
    }
    .segmented-btn {
      flex: 1;
      padding: 8px 10px;
      font-size: 12px;
      font-weight: 700;
      border: none;
      background: none;
      color: var(--text-secondary);
      border-radius: 8px;
      cursor: pointer;
      text-align: center;
      transition: var(--transition);
    }
    .segmented-btn:hover:not(.active) {
      color: var(--text-primary);
    }
    .segmented-btn.active.success {
      background: var(--color-done);
      color: #ffffff;
      box-shadow: var(--shadow-sm);
    }
    .segmented-btn.active.danger {
      background: var(--color-delay);
      color: #ffffff;
      box-shadow: var(--shadow-sm);
    }

    /* Style Kartu Teknisi Accordion */
    .teknisi-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      padding: 16px;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 12px;
      cursor: pointer;
      transition: var(--transition);
      border-left: 5px solid var(--border-color);
      position: relative;
    }
    .teknisi-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    .teknisi-card.active-card {
      border-left-color: var(--accent);
      box-shadow: var(--shadow-md);
      background: var(--bg-card);
    }
    .teknisi-card.done-card { border-left-color: var(--color-done); }
    .teknisi-card.progress-card { border-left-color: var(--color-progress); }
    .teknisi-card.delay-card { border-left-color: var(--color-delay); }
    
    /* Inline Form Wrapper */
    .inline-form {
      border-top: 1px dashed var(--border-color);
      padding-top: 16px;
      margin-top: 8px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      cursor: default; /* Prevent collapse trigger on click */
    }

    /* Checklist Progress Indicators */
    .progress-pill-indicator {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 600;
      color: var(--text-secondary);
      background: var(--bg-secondary);
      padding: 3px 8px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    /* Admin Panel styles */
    .user-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 14px;
      margin-bottom: 20px;
    }
    .user-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
    }
    .user-card-actions {
      margin-left: auto;
      display: flex;
      gap: 6px;
    }

    /* ---------------------------------------------------- */
    /* MOBILE LAYOUT & VIEW STYLES */
    /* ---------------------------------------------------- */
    .mobile-nav-bar {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: var(--bg-card);
      border-top: 1px solid var(--border-color);
      z-index: 900;
      grid-template-columns: repeat(auto-fit, minmax(60px, 1fr));
    }
    
    .mobile-nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: var(--text-secondary);
      background: none;
      border: none;
      cursor: pointer;
      gap: 4px;
    }
    .mobile-nav-item.active {
      color: var(--accent);
      font-weight: 600;
    }
    .mobile-nav-item i {
      font-size: 18px;
    }

    /* Mobile Unit Cards */
    .mobile-unit-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .mobile-unit-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 14px;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 8px;
      position: relative;
    }
    .mobile-unit-nopol {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: -0.2px;
    }
    .mobile-unit-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
    }
    .mobile-unit-badges {
      display: flex;
      gap: 6px;
      margin-top: 4px;
      flex-wrap: wrap;
    }

    .sidebar-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(2px);
      z-index: 1040;
    }
    .sidebar-overlay.open {
      display: block;
    }
    .sidebar-close-btn {
      display: none;
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 20px;
      cursor: pointer;
      padding: 4px;
      margin-left: auto;
    }
    
    /* Responsive overrides */
    @media (max-width: 768px) {
      .sidebar {
        display: flex !important;
        position: fixed !important;
        top: 0 !important;
        left: -260px !important;
        z-index: 1050 !important;
        height: 100vh !important;
        width: 260px !important;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        box-shadow: none !important;
      }
      .sidebar.open {
        left: 0 !important;
        box-shadow: var(--shadow-lg) !important;
      }
      .sidebar-close-btn {
        display: block;
      }
      .menu-toggle {
        display: block; /* Show hamburger button */
      }
      .topbar {
        padding: 0 16px;
      }
      .view-content {
        padding: 16px;
        padding-bottom: 85px !important; /* Spacer for mobile bottom navigation */
      }
      .mobile-nav-bar {
        display: grid; /* Show bottom navigation */
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%) !important;
        width: 100% !important;
        max-width: 480px !important;
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
      }
      .dashboard-layout-grid {
        grid-template-columns: 1fr;
      }
      .stat-grid {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      .sync-status {
        display: none !important;
      }
      .refresh-icon-btn {
        display: none !important;
      }
      /* Move technician tabs to bottom on mobile screens */
      .teknisi-tabs {
        position: fixed;
        bottom: 0;
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%) !important;
        width: 100% !important;
        max-width: 480px !important;
        height: 72px;
        background: var(--bg-card);
        border-top: 1px solid var(--border-color);
        border-bottom: none;
        margin-bottom: 0;
        padding: 8px 16px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        z-index: 950;
        box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.10);
        gap: 4px;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
      }
      .teknisi-tab-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        padding: 6px 4px;
        border: none;
        background: none;
        color: var(--text-tertiary);
        font-size: 9px;
        font-weight: 600;
        cursor: pointer;
        border-radius: 12px;
        transition: var(--transition);
        position: relative;
        letter-spacing: 0.3px;
        text-transform: uppercase;
      }
      .teknisi-tab-btn:hover {
        color: var(--text-secondary);
      }
      .teknisi-tab-btn .tab-icon-wrap {
        width: 36px;
        height: 28px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        position: relative;
      }
      .teknisi-tab-btn.active .tab-icon-wrap {
        background: var(--accent);
      }
      .teknisi-tab-btn.active {
        color: var(--accent);
      }
      .teknisi-tab-btn i {
        font-size: 20px;
        transition: var(--transition);
      }
      .teknisi-tab-btn.active i {
        color: #ffffff;
        font-size: 20px;
      }
      .tab-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #ef4444;
        color: #fff;
        font-size: 9px;
        font-weight: 700;
        min-width: 16px;
        height: 16px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 3px;
        border: 2px solid var(--bg-card);
        line-height: 1;
      }
    }

      /* Mobile-First preview container for field technicians on desktop */
      .app-wrapper.mobile-only {
        max-width: 480px;
        width: 100%;
        margin: 0 auto;
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
        box-shadow: var(--shadow-lg);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: var(--bg-primary);
        position: relative;
      }
      
      .mobile-only .sidebar { display: none !important; }
      .mobile-only .menu-toggle { display: none !important; }
      .mobile-only .topbar { display: none !important; }
      .mobile-only .view-content { padding: 0 !important; padding-bottom: 0 !important; }
      .mobile-only .mobile-nav-bar { display: none !important; }
      .mobile-only .dashboard-layout-grid { grid-template-columns: 1fr !important; }
      .mobile-only .stat-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .mobile-only .sync-status { display: none !important; }
      .mobile-only .refresh-icon-btn { display: none !important; }

      .mobile-only .teknisi-tabs {
        position: fixed;
        bottom: 0;
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%) !important;
        width: 100% !important;
        max-width: 480px !important;
        height: 72px;
        background: var(--bg-card);
        border-top: 1px solid var(--border-color);
        border-bottom: none;
        margin-bottom: 0;
        padding: 8px 16px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        z-index: 950;
        box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.10);
        gap: 4px;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
      }
      .mobile-only .teknisi-tab-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        padding: 6px 4px;
        border: none;
        background: none;
        color: var(--text-tertiary);
        font-size: 9px;
        font-weight: 600;
        cursor: pointer;
        border-radius: 12px;
        transition: var(--transition);
        position: relative;
        letter-spacing: 0.3px;
        text-transform: uppercase;
      }
      .mobile-only .teknisi-tab-btn:hover {
        color: var(--text-secondary);
      }
      .mobile-only .teknisi-tab-btn .tab-icon-wrap {
        width: 36px;
        height: 28px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        position: relative;
      }
      .mobile-only .teknisi-tab-btn.active .tab-icon-wrap {
        background: var(--accent);
      }
      .mobile-only .teknisi-tab-btn.active {
        color: var(--accent);
      }
      .mobile-only .teknisi-tab-btn i {
        font-size: 20px;
        transition: var(--transition);
      }
      .mobile-only .teknisi-tab-btn.active i {
        color: #ffffff;
        font-size: 20px;
      }

      /* Keep modals and toasts inside the centered mobile frame */
      .mobile-only .modal-overlay {
        position: absolute !important;
        padding: 12px !important;
      }
      .mobile-only .modal-card {
        max-width: 100% !important;
        border-radius: var(--radius-md) !important;
      }
      .mobile-only .toast-container {
        position: absolute !important;
        bottom: 16px !important;
        right: 16px !important;
        left: 16px !important;
      }

      /* Import CSV Modal & Component Styles */
      .csv-dropzone {
        border: 2px dashed var(--border-color);
        border-radius: var(--radius-md);
        padding: 24px;
        text-align: center;
        background: var(--bg-secondary);
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
      }
      .csv-dropzone:hover, .csv-dropzone.drag-active {
        border-color: var(--primary-color);
        background: var(--accent-light);
      }
      .csv-dropzone i {
        font-size: 32px;
        color: var(--primary-color);
      }
      .csv-dropzone-text {
        font-size: 13px;
        color: var(--text-secondary);
      }
      .csv-dropzone-subtext {
        font-size: 11px;
        color: var(--text-tertiary);
      }
      
      .import-preview-container {
        margin-top: 16px;
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
      }
      .import-preview-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
      }
      .import-preview-table th {
        background: var(--bg-secondary);
        position: sticky;
        top: 0;
        z-index: 2;
        padding: 6px 8px;
        text-align: left;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-secondary);
      }
      .import-preview-table td {
        padding: 6px 8px;
        border-bottom: 1px solid var(--border-color);
      }
      .import-preview-table tr:last-child td {
        border-bottom: none;
      }
      
      .badge.baru { background: var(--color-done-bg); color: var(--color-done); }
      .badge.update { background: var(--color-progress-bg); color: var(--color-progress); }
      .badge.invalid { background: var(--color-reschedule-bg); color: var(--color-reschedule); }

      .import-instruction-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px 16px;
        background: var(--bg-secondary);
        padding: 12px;
        border-radius: var(--radius-sm);
        margin: 10px 0;
        font-size: 11px;
      }
      .import-instruction-item {
        display: flex;
        gap: 6px;
        color: var(--text-secondary);
      }
      .import-instruction-item i {
        color: var(--primary-color);
        margin-top: 2px;
      }

      /* Field Technician Workspace Tab Styles (desktop) */
      .teknisi-tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 20px;
        padding: 4px;
        background: var(--bg-secondary);
        border-radius: var(--radius-md);
        border: 1px solid var(--border-color);
      }
      .teknisi-tab-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 10px 8px;
        border-radius: 8px;
        background: transparent;
        border: none;
        color: var(--text-secondary);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        position: relative;
      }
      .teknisi-tab-btn:hover {
        background: var(--bg-card);
        color: var(--text-primary);
      }
      .teknisi-tab-btn.active {
        background: var(--bg-card);
        color: var(--accent);
        box-shadow: var(--shadow-sm);
      }
      .teknisi-tab-btn i {
        font-size: 16px;
      }
      /* Desktop tabs don't use tab-icon-wrap or tab-badge */
      .teknisi-tab-btn .tab-icon-wrap {
        display: contents;
      }

      /* Planner Workspace Tab Styles */
      .planner-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
        border-bottom: 1.5px solid var(--border-color);
        padding-bottom: 10px;
      }
      .planner-tab-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: var(--radius-md);
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
      }
      .planner-tab-btn:hover {
        background: var(--bg-secondary);
        color: var(--text-primary);
      }
      .planner-tab-btn.active {
        background: var(--accent-light);
        border-color: var(--accent);
        color: var(--accent);
      }
      .planner-tab-btn i {
        font-size: 16px;
      }

      /* Progress Matrix Indikator Styles */
      .progress-dot {
        display: block;
        margin: 0 auto;
        border-radius: 50%;
        transition: var(--transition);
      }
      .progress-dot.active {
        width: 14px;
        height: 14px;
        border: 2px solid var(--bg-card);
        outline: 2px solid var(--accent);
        background: var(--accent);
      }
      .progress-dot.primary.animate-pulse {
        width: 14px;
        height: 14px;
        border: 2px solid var(--bg-card);
        outline: 2px solid var(--accent);
        background: var(--accent);
        animation: pulse 2s infinite;
      }
      .progress-dot.warning.animate-pulse {
        width: 14px;
        height: 14px;
        border: 2px solid var(--bg-card);
        outline: 2px solid var(--color-delay);
        background: var(--color-delay);
        animation: pulse 2s infinite;
      }
      .progress-dot.success {
        width: 14px;
        height: 14px;
        border: 2px solid var(--bg-card);
        outline: 2px solid var(--color-done);
        background: var(--color-done);
      }
      .progress-dot.past {
        width: 10px;
        height: 10px;
        background: rgba(16, 185, 129, 0.4);
      }
      .progress-dot.future {
        width: 8px;
        height: 8px;
        background: var(--border-color);
      }

      @keyframes pulse {
        0%, 100% {
          transform: scale(1);
          opacity: 1;
        }
        50% {
          transform: scale(1.15);
          opacity: 0.7;
        }
      }

      /* Step-by-Step Wizard Styles */
      .wizard-container {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 24px;
        box-shadow: var(--shadow-md);
        margin-bottom: 24px;
      }
      .wizard-steps-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        position: relative;
        padding: 0 10px;
      }
      .wizard-steps-header::before {
        content: '';
        position: absolute;
        top: 18px;
        left: 30px;
        right: 30px;
        height: 2px;
        background: var(--border-color);
        z-index: 0;
      }
      .wizard-step-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
        background: var(--bg-card);
        padding: 0 8px;
      }
      .wizard-step-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        background: var(--bg-secondary);
        border: 2px solid var(--border-color);
        color: var(--text-secondary);
        transition: var(--transition);
      }
      .wizard-step-node.active .wizard-step-circle {
        background: var(--accent);
        border-color: var(--accent);
        color: #ffffff;
        box-shadow: 0 0 12px rgba(59, 130, 246, 0.4);
      }
      .wizard-step-node.completed .wizard-step-circle {
        background: var(--color-done);
        border-color: var(--color-done);
        color: #ffffff;
      }
      .wizard-step-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-secondary);
      }
      .wizard-step-node.active .wizard-step-label {
        color: var(--accent);
      }
      .wizard-step-node.completed .wizard-step-label {
        color: var(--color-done);
      }

      /* Photo Upload Components */
      .photo-upload-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-bottom: 20px;
      }
      @media (max-width: 480px) {
        .photo-upload-grid {
          grid-template-columns: 1fr;
        }
      }
      .photo-upload-card {
        background: var(--bg-secondary);
        border: 2px dashed var(--border-color);
        border-radius: var(--radius-md);
        padding: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 140px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
      }
      .photo-upload-card:hover {
        border-color: var(--accent);
        background: var(--bg-card);
      }
      .photo-upload-card.has-image {
        border-style: solid;
        padding: 0;
      }
      .photo-upload-card img {
        width: 100%;
        height: 140px;
        object-fit: cover;
      }
      .photo-upload-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        width: 100%;
        height: 100%;
        justify-content: center;
        color: var(--text-secondary);
        font-size: 11px;
        font-weight: 600;
      }
      .photo-upload-label i {
        font-size: 24px;
        color: var(--text-tertiary);
      }
      .photo-delete-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(15, 23, 42, 0.75);
        color: #ffffff;
        border: none;
        width: 28px;
        height: 28px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: var(--transition);
        z-index: 2;
      }
      .photo-delete-btn:hover {
        background: rgba(239, 68, 68, 0.9);
      }
      .photo-simulate-btn {
        margin-top: 8px;
        background: transparent;
        border: 1px solid var(--accent);
        color: var(--accent);
        padding: 4px 10px;
        border-radius: var(--radius-sm);
        font-size: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
      }
      .photo-simulate-btn:hover {
        background: var(--accent);
        color: #ffffff;
      }

      /* Detail view and general cards */
      .task-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 0;
        margin-bottom: 14px;
        box-shadow: var(--shadow-md);
        transition: var(--transition);
        overflow: hidden;
        position: relative;
      }
      .task-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        border-color: rgba(59, 130, 246, 0.3);
      }
      .task-card-accent {
        height: 4px;
        background: linear-gradient(90deg, var(--accent), #7c3aed);
        width: 100%;
      }
      .task-card-accent.on-progress {
        background: linear-gradient(90deg, var(--color-progress), #fb923c);
        animation: shimmer 2s infinite linear;
        background-size: 200%;
      }
      @keyframes shimmer {
        0% { background-position: 0% 50%; }
        100% { background-position: 200% 50%; }
      }
      .task-card-body {
        padding: 16px;
      }
      .task-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
      }
      .task-card-title {
        font-size: 20px;
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.5px;
        line-height: 1.1;
      }
      .task-card-subtitle {
        font-size: 11px;
        color: var(--text-tertiary);
        margin-top: 3px;
        font-weight: 500;
      }
      .task-card-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        white-space: nowrap;
      }
      .task-card-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 14px;
      }
      .task-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-secondary);
      }
      .task-chip i { font-size: 12px; }
      .task-chip.accent { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
      .task-chip.warning { background: var(--color-progress-bg); border-color: var(--color-progress); color: var(--color-progress); }
      .task-chip.success { background: var(--color-done-bg); border-color: var(--color-done); color: var(--color-done); }
      .task-card-note {
        background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(124,58,237,0.06));
        border-left: 3px solid var(--accent);
        border-radius: 0 8px 8px 0;
        padding: 10px 12px;
        font-size: 12px;
        color: var(--text-primary);
        margin-bottom: 14px;
        font-style: italic;
      }
      .task-card-note-label {
        font-size: 10px;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 3px;
        font-style: normal;
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .task-cta-btn {
        width: 100%;
        padding: 14px;
        border-radius: var(--radius-md);
        border: none;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: var(--transition);
        letter-spacing: 0.2px;
      }
      .task-cta-btn.primary {
        background: linear-gradient(135deg, var(--accent), #4f46e5);
        color: #ffffff;
        box-shadow: 0 4px 12px rgba(37,99,235,0.35);
      }
      .task-cta-btn.primary:hover:not(:disabled) {
        background: linear-gradient(135deg, var(--accent-hover), #4338ca);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(37,99,235,0.45);
      }
      .task-cta-btn.active-resume {
        background: linear-gradient(135deg, var(--color-progress), #f97316);
        color: #ffffff;
        box-shadow: 0 4px 12px rgba(245,158,11,0.35);
      }
      .task-cta-btn.active-resume:hover:not(:disabled) {
        transform: translateY(-1px);
      }
      .task-cta-btn.locked {
        background: var(--bg-secondary);
        color: var(--text-tertiary);
        border: 1px solid var(--border-color);
        cursor: not-allowed;
      }
      .task-card-info-row {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        margin-top: 6px;
        color: var(--text-secondary);
      }
      .task-card-info-label {
        color: var(--text-tertiary);
      }
      .task-card-info-value {
        font-weight: 600;
      }

      /* Teknisi Hero Header */
      .teknisi-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #312e81 50%, #4c1d95 100%);
        border-radius: var(--radius-lg);
        padding: 18px 20px;
        margin-bottom: 16px;
        color: #fff;
        position: relative;
        overflow: hidden;
      }
      .teknisi-hero::before {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 120px;
        height: 120px;
        background: rgba(255,255,255,0.06);
        border-radius: 50%;
      }
      .teknisi-hero::after {
        content: '';
        position: absolute;
        bottom: -20px;
        left: 40px;
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.04);
        border-radius: 50%;
      }
      .teknisi-hero-greeting {
        font-size: 12px;
        opacity: 0.75;
        font-weight: 500;
        margin-bottom: 2px;
      }
      .teknisi-hero-name {
        font-size: 18px;
        font-weight: 800;
        letter-spacing: -0.3px;
        margin-bottom: 10px;
      }
      .teknisi-hero-stats {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .teknisi-hero-stat {
        background: rgba(255,255,255,0.12);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 5px;
        backdrop-filter: blur(4px);
      }
      .teknisi-hero-stat.active-pill {
        background: rgba(245,158,11,0.3);
        border: 1px solid rgba(245,158,11,0.5);
        color: #fde68a;
      }

      /* Wizard Redesign */
      .wizard-sticky-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--bg-card);
        padding: 14px 20px 0;
        margin: -24px -24px 0;
        border-bottom: 1px solid var(--border-color);
      }
      .wizard-vehicle-badge {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 12px;
      }
      .wizard-vehicle-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #4f46e5);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 18px;
        flex-shrink: 0;
      }
      .wizard-vehicle-nopol {
        font-size: 16px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.2;
      }
      .wizard-vehicle-sub {
        font-size: 11px;
        color: var(--text-tertiary);
      }
      .wizard-step-bar {
        display: flex;
        padding: 0 0 12px;
        gap: 0;
        position: relative;
      }
      .wizard-step-bar-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
      }
      .wizard-step-bar-item:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 14px;
        left: 60%;
        right: -40%;
        height: 2px;
        background: var(--border-color);
        z-index: 0;
      }
      .wizard-step-bar-item.completed:not(:last-child)::after {
        background: var(--color-done);
      }
      .wizard-step-dot {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 2px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-tertiary);
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        position: relative;
        transition: var(--transition);
      }
      .wizard-step-bar-item.active .wizard-step-dot {
        border-color: var(--accent);
        background: var(--accent);
        color: #fff;
        box-shadow: 0 0 0 4px rgba(59,130,246,0.18);
      }
      .wizard-step-bar-item.completed .wizard-step-dot {
        border-color: var(--color-done);
        background: var(--color-done);
        color: #fff;
      }
      .wizard-step-bar-label {
        font-size: 9px;
        font-weight: 600;
        margin-top: 4px;
        color: var(--text-tertiary);
        text-align: center;
      }
      .wizard-step-bar-item.active .wizard-step-bar-label { color: var(--accent); font-weight: 700; }
      .wizard-step-bar-item.completed .wizard-step-bar-label { color: var(--color-done); }

      /* Form field style improvement */
      .input-group { display: flex; flex-direction: column; gap: 6px; }
      .input-label { font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.4px; }
      .input-field { 
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid var(--border-color);
        border-radius: var(--radius-md);
        background: var(--bg-card);
        color: var(--text-primary);
        font-size: 14px;
        font-family: var(--font-sans);
        transition: border-color 0.2s;
        outline: none;
      }
      .input-field:focus { border-color: var(--border-focus); box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }

      /* Photo upload tiles - larger for mobile */
      .photo-upload-card {
        background: var(--bg-secondary);
        border: 2px dashed var(--border-color);
        border-radius: var(--radius-md);
        padding: 20px 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 160px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
      }
      .photo-upload-card:hover {
        border-color: var(--accent);
        background: var(--accent-light);
      }
      .photo-upload-card.has-image {
        border-style: solid;
        padding: 0;
        border-color: var(--color-done);
      }
      .photo-upload-card img {
        width: 100%;
        height: 160px;
        object-fit: cover;
      }
      .photo-upload-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        width: 100%;
        height: 100%;
        justify-content: center;
        color: var(--text-secondary);
        font-size: 11px;
        font-weight: 600;
      }
      .photo-upload-label i {
        font-size: 28px;
        color: var(--text-tertiary);
      }

      /* ==========================================
         REDESIGN: Field Technician Dark UI Style
         ========================================== */
      .teknisi-dashboard-dark {
        --bg-primary: #050B1A;
        --bg-secondary: #081224;
        --bg-card: #0F172A;
        --bg-glass: rgba(15, 23, 42, 0.7);
        --text-primary: #FFFFFF;
        --text-secondary: #CBD5E1;
        --text-muted: #94A3B8;
        --border-color: rgba(255, 255, 255, 0.08);
        --border-focus: #7C5CFF;
        
        --accent: #6366F1;
        --accent-hover: #7C5CFF;
        --accent-light: rgba(99, 102, 241, 0.1);
        
        --color-done: #22C55E;
        --color-done-bg: rgba(34, 197, 94, 0.15);
        --color-progress: #7C5CFF;
        --color-progress-bg: rgba(124, 92, 255, 0.15);
        --color-delay: #F59E0B;
        --color-delay-bg: rgba(245, 158, 11, 0.15);

        background: linear-gradient(180deg, #050B1A 0%, #081224 100%) !important;
        color: #FFFFFF !important;
        min-height: 100vh;
        font-family: var(--font-sans);
        padding: 16px 16px 90px 16px;
        box-sizing: border-box;
      }

      .teknisi-dashboard-dark * {
        box-sizing: border-box;
      }

      /* Premium Top Header */
      .premium-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 4px 16px 4px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        margin-bottom: 24px;
      }

      .hdr-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .avatar-container {
        position: relative;
        width: 46px;
        height: 46px;
      }

      .avatar-circle {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: linear-gradient(135deg, #7C5CFF 0%, #6366F1 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 700;
        color: #FFFFFF;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
      }

      .online-indicator {
        position: absolute;
        bottom: 1px;
        right: 1px;
        width: 11px;
        height: 11px;
        background-color: #22C55E;
        border: 2px solid #050B1A;
        border-radius: 50%;
      }

      .user-info {
        display: flex;
        flex-direction: column;
      }

      .user-name {
        font-size: 15px;
        font-weight: 700;
        color: #FFFFFF;
        line-height: 1.2;
      }

      .user-role {
        font-size: 11px;
        color: #94A3B8;
        font-weight: 500;
        margin-top: 1px;
      }

      .hdr-right {
        display: flex;
        gap: 8px;
      }

      .hdr-icon-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 50%;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #CBD5E1;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .hdr-icon-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #FFFFFF;
        transform: translateY(-1px);
      }

      .hdr-icon-btn:active {
        transform: translateY(0);
      }

      /* Glassmorphism Title Card */
      .glass-title-card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 24px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
      }

      .glass-title {
        font-size: 20px;
        font-weight: 600;
        color: #FFFFFF;
        margin-bottom: 6px;
      }

      .glass-subtitle {
        font-size: 13px;
        color: #CBD5E1;
        line-height: 1.4;
      }

      /* Premium Active Task Card */
      .premium-task-card {
        background: #0F172A;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 20px;
        position: relative;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
        overflow: hidden;
        margin-bottom: 24px;
      }

      .premium-task-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #7C5CFF 0%, #6366F1 100%);
      }

      .premium-task-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
      }

      .premium-task-label {
        font-size: 12px;
        font-weight: 500;
        color: #94A3B8;
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }

      .location-badge {
        background: rgba(99, 102, 241, 0.15);
        border: 1px solid rgba(99, 102, 241, 0.3);
        color: #FFFFFF;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
      }

      .vehicle-plate {
        font-size: 28px;
        font-weight: 800;
        color: #FFFFFF;
        letter-spacing: 0.5px;
        margin-top: 2px;
        margin-bottom: 4px;
      }

      .vehicle-info {
        font-size: 14px;
        color: #CBD5E1;
        margin-bottom: 16px;
      }

      /* Outlined Planner Box */
      .outlined-planner-box {
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(8, 18, 36, 0.4);
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #CBD5E1;
        line-height: 1.5;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .outlined-planner-box-label {
        font-size: 10px;
        font-weight: 700;
        color: #7C5CFF;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      /* Purple Gradient CTA Button */
      .purple-cta-btn {
        width: 100%;
        background: linear-gradient(135deg, #7C5CFF 0%, #6366F1 100%);
        color: #FFFFFF;
        border: none;
        border-radius: 16px;
        padding: 14px 20px;
        font-size: 14px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        cursor: pointer;
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        height: 52px;
      }

      .purple-cta-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.5);
        filter: brightness(1.15);
      }

      .purple-cta-btn:active:not(:disabled) {
        transform: translateY(0);
      }

      .purple-cta-btn:disabled {
        background: #1E293B !important;
        border: 1px solid rgba(255,255,255,0.05);
        color: #64748B !important;
        cursor: not-allowed;
        box-shadow: none;
      }

      /* Bottom Navigation Bar */
      .fixed-bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 72px;
        background: #0F172A;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: space-around;
        padding: 0 16px;
        z-index: 1000;
        box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.4);
      }

      .mobile-only .fixed-bottom-nav {
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%) !important;
        width: 100% !important;
        max-width: 480px !important;
        border-left: 1px solid rgba(255, 255, 255, 0.08);
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
      }

      .bottom-nav-item {
        background: transparent;
        border: none;
        outline: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        color: #94A3B8;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        flex: 1;
        height: 100%;
        text-decoration: none;
      }

      .bottom-nav-item i {
        font-size: 20px;
        transition: all 0.2s ease;
      }

      .bottom-nav-item.active {
        color: #7C5CFF;
      }

      .bottom-nav-item.active i {
        color: #7C5CFF;
        transform: translateY(-2px);
      }

      .bottom-nav-item:active {
        transform: scale(0.95);
      }

      /* Stats Popover Cards */
      .stats-grid-popup {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 20px;
      }

      .stat-card-popup {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        padding: 12px 8px;
        text-align: center;
      }

      .stat-val-popup {
        font-size: 20px;
        font-weight: 800;
        color: #FFFFFF;
        line-height: 1;
      }

      .stat-label-popup {
        font-size: 10px;
        color: #94A3B8;
        margin-top: 4px;
        font-weight: 600;
        text-transform: uppercase;
      }

      /* Vertical Workflow Chart */
      .workflow-timeline {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 12px;
      }

      .workflow-item {
        display: flex;
        gap: 12px;
        position: relative;
      }

      .workflow-item::before {
        content: '';
        position: absolute;
        top: 24px;
        left: 11px;
        width: 2px;
        height: calc(100% - 8px);
        background: rgba(255,255,255,0.08);
        z-index: 1;
      }

      .workflow-item:last-child::before {
        display: none;
      }

      .workflow-dot {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #1E293B;
        border: 2px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #94A3B8;
        z-index: 2;
        flex-shrink: 0;
      }

      .workflow-item.active .workflow-dot {
        background: rgba(124, 92, 255, 0.15);
        border-color: #7C5CFF;
        color: #7C5CFF;
        box-shadow: 0 0 8px rgba(124, 92, 255, 0.4);
      }

      .workflow-item.done .workflow-dot {
        background: rgba(34, 197, 94, 0.15);
        border-color: #22C55E;
        color: #22C55E;
      }

      .workflow-content {
        flex: 1;
        padding-top: 3px;
      }

      .workflow-title {
        font-size: 13px;
        font-weight: 700;
        color: #FFFFFF;
      }

      .workflow-desc {
        font-size: 11px;
        color: #CBD5E1;
        margin-top: 2px;
      }

      /* ==========================================
         SIMPLIFIED TECHNICIAN DASHBOARD CUSTOM STYLES (VANILLA CSS)
         ========================================== */
      .teknisi-wrapper {
        background-color: #0A0D14;
        color: #E2E8F0;
        min-height: 100vh;
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
        padding: 16px;
        padding-bottom: 80px;
        box-sizing: border-box;
      }
      .teknisi-wrapper * {
        box-sizing: border-box;
      }
      
      /* Constrain the entire page container to center like a mobile app mockup on larger desktop viewports */
      @media (min-width: 768px) {
        .teknisi-wrapper {
          max-width: 480px;
          margin: 0 auto;
          border-left: 1px solid rgba(255,255,255,0.08);
          border-right: 1px solid rgba(255,255,255,0.08);
          box-shadow: 0 0 32px rgba(0,0,0,0.5);
          position: relative;
        }
      }

      .teknisi-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        margin-top: 10px;
      }
      .teknisi-profile {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .teknisi-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #1F2937;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #FFF;
        font-size: 14px;
        border: 1px solid rgba(255,255,255,0.08);
      }
      .teknisi-profile-info {
        display: flex;
        flex-direction: column;
      }
      .teknisi-name {
        font-size: 14px;
        font-weight: 700;
        color: #FFF;
      }
      .teknisi-role {
        font-size: 10px;
        color: #94A3B8;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }
      .teknisi-header-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .teknisi-status-pill {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 20px;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        font-size: 10px;
        font-weight: 700;
        color: #10B981;
      }
      .teknisi-header-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #111827;
        border: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94A3B8;
        cursor: pointer;
        font-size: 15px;
      }
      .teknisi-hero-card {
        background: #111827;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 16px;
      }
      .teknisi-hero-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #5850EC;
        margin-bottom: 6px;
      }
      .teknisi-hero-desc {
        font-size: 11px;
        color: #94A3B8;
        line-height: 1.5;
        margin: 0;
      }
      .teknisi-vehicle-card {
        background: #111827;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 16px;
        position: relative;
      }
      .teknisi-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
      }
      .teknisi-card-label {
        font-size: 9px;
        font-weight: 700;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .teknisi-pool-badge {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 8px;
        border-radius: 12px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        font-size: 9px;
        color: #94A3B8;
        font-weight: 600;
      }
      .teknisi-vehicle-nopol {
        font-size: 20px;
        font-weight: 800;
        color: #FFF;
        margin-bottom: 10px;
        letter-spacing: -0.2px;
      }
      .teknisi-quote-box {
        background: rgba(255,255,255,0.01);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 11px;
        color: #94A3B8;
        font-style: italic;
        margin-bottom: 14px;
      }
      .teknisi-btn-play {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        width: 100%;
        height: 40px;
        border-radius: 10px;
        background: #5850EC;
        border: none;
        color: #FFF;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
      }
      .teknisi-btn-play:hover {
        background: #4F46E5;
      }
      .teknisi-nav-bar {
        display: flex;
        justify-content: space-around;
        align-items: center;
        background: #0B0F19;
        border-top: 1px solid rgba(255,255,255,0.08);
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        width: 100%;
        height: 64px;
        z-index: 999;
        box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.4);
        padding-bottom: env(safe-area-inset-bottom, 0px);
      }
      @media (min-width: 768px) {
        .teknisi-nav-bar {
          width: 100%;
          max-width: 480px;
          left: 50%;
          right: auto;
          transform: translateX(-50%);
          border-left: 1px solid rgba(255,255,255,0.1);
          border-right: 1px solid rgba(255,255,255,0.1);
          border-radius: 16px 16px 0 0;
        }
      }
      .teknisi-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        background: transparent;
        border: none;
        color: #94A3B8;
        font-size: 9px;
        font-weight: 700;
        cursor: pointer;
        flex: 1;
        height: 100%;
        transition: color 0.15s ease;
        -webkit-tap-highlight-color: transparent;
        text-decoration: none;
        white-space: nowrap;
      }
      .teknisi-nav-item.active {
        color: #6366F1;
      }
      .teknisi-nav-item i {
        font-size: 20px;
      }

      /* Form view specific dark styles */
      .teknisi-wrapper select,
      .teknisi-wrapper input,
      .teknisi-wrapper textarea {
        background-color: #0B0F19 !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
        color: #FFFFFF !important;
        border-radius: 8px;
        padding: 9px 12px;
        outline: none;
        width: 100%;
        box-sizing: border-box;
        font-size: 13px;
        transition: border-color 0.2s;
      }
      .teknisi-wrapper select:focus,
      .teknisi-wrapper input:focus,
      .teknisi-wrapper textarea:focus {
        border-color: #5850EC !important;
      }
      .teknisi-wrapper .input-label {
        color: #94A3B8;
        font-size: 10px;
        font-weight: 700;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }
      .teknisi-wrapper .form-section {
        margin-top: 16px;
        padding-top: 14px;
        border-top: 1px solid rgba(255,255,255,0.06);
      }
      .teknisi-wrapper .form-section-title {
        font-size: 12px;
        font-weight: 700;
        color: #5850EC;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }
      .teknisi-wrapper .ping-bar-bg {
        background: #111827;
        border-radius: 4px;
        height: 8px;
        overflow: hidden;
        margin: 8px 0;
        border: 1px solid rgba(255,255,255,0.08);
      }
      .teknisi-wrapper .ping-bar-fill {
        background: #5850EC;
        height: 100%;
        width: 0%;
        transition: width 0.1s linear;
      }
      .teknisi-wrapper .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
        gap: 12px;
        margin-top: 8px;
      }
      .teknisi-wrapper .photo-card {
        border: 1px dashed rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 10px;
        text-align: center;
        background: #111827;
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 110px;
        transition: all 0.2s ease;
      }
      .teknisi-wrapper .photo-card:hover {
        border-color: #5850EC;
        background: rgba(88,80,236,0.05);
      }
      .teknisi-wrapper .photo-card img {
        width: 100%;
        height: 80px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.08);
      }
      </style>
</head>
<body>
  <div id="root"></div>

  <!-- Load React and Babel -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.5/babel.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>

  <!-- React Application Script -->
  <script type="text/babel" data-presets="react">
    const { useState, useMemo, useEffect, createContext, useContext } = React;

    const LOCS = ['NAGRAK', 'CILEGON', 'PANDAAN', 'OSOWILANGUN', 'MEDAN', 'CAKUNGFUELLER'];
    const POOLS = ['TRAILER', 'WINGBOX', 'SMALLTRUCK', 'MOTORCARRIER'];
    const LOKASI_OPTS = LOCS.map(l => 'POOL ' + l);
    const TEKNISI_OPTS = ['SMA TEAM', 'PUNINAR TEAM'];
    const DEV_OPTS = ['TERPASANG', 'TIDAK TERPASANG'];
    const SYS_OPTS = ['OK', 'NOT OK'];
    const SUSPEND_OPTS = ['BELUM SUSPEND', 'PROSES SUSPEND', 'SUDAH SUSPEND'];
    const PASANG_OPTS = ['ON PROGRESS', 'DONE', 'RESCHEDULE'];
    const EASYGO_OPTS = ['BELUM', 'SUDAH'];
    const GPS_MODEL_OPTS = ['GEOTAB', 'SMA-TRACK'];

    // Google Apps Script URL
    const WEBAPP_URL = 'https://script.google.com/macros/s/AKfycbz6dpQovaZLLUSVi5FPsELRFK8PSxDExhrzGaIimSebqpzJceVQ4cr5p8KSPHD9_B9g/exec';

    // ----------------------------------------------------
    // TOAST NOTIFICATION HELPERS
    // ----------------------------------------------------
    let globalAddToast = () => {};

    // Helper functions
    function mapFromSheet(json) {
      if (!json || !Array.isArray(json.data)) return [];
      return json.data.map((u, i) => ({
        id: i + 1,
        rowIndex: u.rowIndex,
        nopol: u.NOPOL, 
        merk: u.MERK, 
        model: u.MODEL,
        location: u.LOCATION, 
        pool: u.POOL, 
        dedicate: u.DEDICATE,
        easygoDicopot: u.STATUS_EASYGO_DICOPOT || '',
        planDate: u.PLAN_TGL || '',
        lokasiPasang: u.LOKASI_PASANG || '',
        keteranganPlanner: u.KETERANGAN_PLANNER || '',
        teknisi: u.TEKNISI || '',
        teknisiPelaksana: u.TEKNISI_PELAKSANA || '',
        statusPlan: u.statusPlan || (u.PLAN_TGL ? 'PLAN' : 'UNPLAN'),
        statusPasang: u.STATUS_PASANG || 'BELUM DIPASANG',
        modelGpsBaru: u.MODEL_GPS_BARU || '',
        gps: u.GPS || '', 
        buzzer: u.BUZZER || '', 
        sos: u.SOS || '', 
        sensorWing: u.SENSOR_WING || '',
        statusSystem: u.STATUS_SYSTEM || '', 
        statusSuspend: u.STATUS_SUSPEND || '',
        noGpsLama: u.NO_GPS_LAMA || '',
        updatedAt: u.LAST_UPDATE || '',
        gpsSerialBaru: u.GPS_SERIAL_BARU || '',
        gpsImeiBaru: u.GPS_IMEI_BARU || '',
        nomorSIM: u.NOMOR_SIM || '',
        provider: u.PROVIDER || '',
        catatanPasang: u.CATATAN_PASANG || '',
        latitudeCheckin: u.LATITUDE_CHECKIN || '',
        longitudeCheckin: u.LONGITUDE_CHECKIN || '',
        waktuCheckin: u.WAKTU_CHECKIN || '',
        fotoKendaraan: u.FOTO_KENDARAAN || '',
        fotoGPSLama: u.FOTO_GPS_LAMA || '',
        fotoGPSBaru: u.FOTO_GPS_BARU || '',
        fotoHasilInstalasi: u.FOTO_HASIL_INSTALASI || ''
      }));
    }

    // Date converter helpers
    function toISODate(dateVal) {
      if (!dateVal) return '';
      const strVal = String(dateVal).trim();
      if (strVal.includes('T')) {
        return strVal.split('T')[0];
      }
      if (strVal.match(/^\d{4}-\d{2}-\d{2}$/)) {
        return strVal;
      }
      const p = strVal.split(/[-/]/);
      if (p.length === 3) {
        if (p[0].length === 4) return `${p[0]}-${String(p[1]).padStart(2, '0')}-${String(p[2]).padStart(2, '0')}`;
        return `${p[2]}-${String(p[1]).padStart(2, '0')}-${String(p[0]).padStart(2, '0')}`;
      }
      return '';
    }
    function fromISODate(yyyymmdd) {
      if (!yyyymmdd) return '';
      const strVal = String(yyyymmdd).trim();
      const p = strVal.split('-');
      if (p.length !== 3) return '';
      if (p[0].length === 2 && p[2].length === 4) return strVal;
      return `${p[2]}-${p[1]}-${p[0]}`;
    }

    const exportToCSV = (dataList, filename) => {
      const headers = [
        'NOPOL', 'MERK', 'MODEL', 'LOKASI SITE', 'POOL', 'DEDICATE',
        'EASYGO DICOPOT', 'TANGGAL RENCANA', 'LOKASI PASANG', 'KETERANGAN PLANNER', 'TEKNISI', 'TEKNISI PELAKSANA',
        'NO GPS LAMA', 'STATUS PLAN', 'STATUS PASANG', 'MODEL GPS BARU', 'GPS', 'BUZZER',
        'SOS', 'SENSOR WING', 'STATUS SYSTEM', 'STATUS SUSPEND', 'LAST UPDATE',
        'GPS SERIAL BARU', 'GPS IMEI BARU', 'NOMOR SIM', 'PROVIDER', 'CATATAN PASANG',
        'LATITUDE CHECKIN', 'LONGITUDE CHECKIN', 'WAKTU CHECKIN',
        'FOTO KENDARAAN', 'FOTO GPS LAMA', 'FOTO GPS BARU', 'FOTO HASIL INSTALASI'
      ];
      
      const escapeCSV = (val) => {
        if (val === null || val === undefined) return '';
        const str = String(val);
        if (str.includes(',') || str.includes('"') || str.includes('\n') || str.includes('\r')) {
          return `"${str.replace(/"/g, '""')}"`;
        }
        return str;
      };

      const rows = dataList.map(u => [
        u.nopol, u.merk, u.model, u.location, u.pool, u.dedicate,
        u.easygoDicopot, u.planDate, u.lokasiPasang, u.keteranganPlanner, u.teknisi, u.teknisiPelaksana,
        u.noGpsLama, u.statusPlan, u.statusPasang, u.modelGpsBaru, u.gps, u.buzzer,
        u.sos, u.sensorWing, u.statusSystem, u.statusSuspend, u.updatedAt,
        u.gpsSerialBaru, u.gpsImeiBaru, u.nomorSIM, u.provider, u.catatanPasang,
        u.latitudeCheckin, u.longitudeCheckin, u.waktuCheckin,
        u.fotoKendaraan, u.fotoGPSLama, u.fotoGPSBaru, u.fotoHasilInstalasi
      ].map(escapeCSV));

      const csvContent = "\uFEFF" + [headers.join(','), ...rows.map(r => r.join(','))].join('\n');
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", filename);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    };

    const PAGE_LIMIT = 15;

    // ----------------------------------------------------
    // AUTHENTICATION CONTEXT & PROVIDER
    // ----------------------------------------------------
    const AuthContext = createContext(null);

    const DEFAULT_USERS = [
      { id: 1, username: 'admin', password: 'adminpassword', name: 'System Admin', role: 'admin' },
      { id: 2, username: 'planner1', password: 'plannerpassword', name: 'Budi (Planner)', role: 'planner' },
      { id: 3, username: 'teknisi1', password: 'teknisipassword', name: 'Agus (Teknisi)', role: 'teknisi' },
      { id: 4, username: 'verifikator1', password: 'verifikasipassword', name: 'Doni (Verifikator)', role: 'verifikasi' }
    ];

    function AuthProvider({ children }) {
      const [user, setUser] = useState(null);
      const [users, setUsers] = useState([]);

      useEffect(() => {
        // Load users database with safety validation
        const storedUsers = localStorage.getItem('puninar_gps_users');
        let parsedUsers = [];
        try {
          if (storedUsers) {
            parsedUsers = JSON.parse(storedUsers);
          }
        } catch (e) {}

        if (!Array.isArray(parsedUsers) || parsedUsers.length === 0 || !parsedUsers.some(u => u.username === 'admin')) {
          localStorage.setItem('puninar_gps_users', JSON.stringify(DEFAULT_USERS));
          setUsers(DEFAULT_USERS);
        } else {
          setUsers(parsedUsers);
        }

        // Load active session
        try {
          const storedSession = sessionStorage.getItem('gps_user_session');
          if (storedSession) {
            setUser(JSON.parse(storedSession));
          }
        } catch (e) {}
      }, []);

      const login = (username, password) => {
        const foundUser = users.find(u => u.username === username && u.password === password);
        if (foundUser) {
          setUser(foundUser);
          sessionStorage.setItem('gps_user_session', JSON.stringify(foundUser));
          return { success: true };
        }
        return { success: false, message: 'Username atau password salah!' };
      };

      const logout = () => {
        setUser(null);
        sessionStorage.removeItem('gps_user_session');
      };

      const updateUsersList = (newUsersList) => {
        setUsers(newUsersList);
        localStorage.setItem('puninar_gps_users', JSON.stringify(newUsersList));
      };

      return (
        <AuthContext.Provider value={{ user, users, login, logout, updateUsers: updateUsersList }}>
          {children}
        </AuthContext.Provider>
      );
    }

    // ----------------------------------------------------
    // SHARED REUSABLE COMPONENTS
    // ----------------------------------------------------
    function ToastContainer() {
      const [toasts, setToasts] = useState([]);

      useEffect(() => {
        globalAddToast = (text, type = 'info') => {
          const id = Date.now();
          setToasts(prev => [...prev, { id, text, type }]);
          setTimeout(() => {
            setToasts(prev => prev.filter(t => t.id !== id));
          }, 3500);
        };
      }, []);

      return (
        <div className="toast-container">
          {toasts.map(t => (
            <div key={t.id} className={`toast ${t.type}`}>
              <i className={`ti ${t.type === 'success' ? 'ti-circle-check' : t.type === 'error' ? 'ti-alert-circle' : 'ti-info-circle'}`} style={{fontSize: 18}}></i>
              <div style={{fontSize: 12, fontWeight: 500}}>{t.text}</div>
              <button className="toast-close" onClick={() => setToasts(prev => prev.filter(x => x.id !== t.id))}>
                <i className="ti ti-x"></i>
              </button>
            </div>
          ))}
        </div>
      );
    }

    function Badge({ val }) {
      const trimmed = val ? String(val).trim() : '';
      if (!trimmed) return <span style={{ color: 'var(--text-tertiary)', fontSize: 11 }}>—</span>;
      let cl = 'unplan';
      const cleanVal = trimmed.toUpperCase();
      if (cleanVal === 'PLAN') cl = 'plan';
      else if (cleanVal === 'DONE' || cleanVal === 'TERPASANG' || cleanVal === 'OK' || cleanVal === 'SUDAH' || cleanVal === 'SUDAH SUSPEND') cl = 'done';
      else if (cleanVal === 'ON PROGRESS' || cleanVal === 'PROSES SUSPEND') cl = 'progress';
      else if (cleanVal === 'DELAY' || cleanVal === 'CANCEL' || cleanVal === 'TIDAK TERPASANG' || cleanVal === 'NOT OK') cl = 'delay';
      else if (cleanVal === 'RESCHEDULE' || cleanVal === 'PERLU REVISIT') cl = 'reschedule';

      return <span className={`badge ${cl}`}>{trimmed}</span>;
    }

    function FilterRow({ children }) {
      return <div className="filter-bar">{children}</div>;
    }

    function Pager({ page, total, onChange }) {
      return (
        <div className="pager-container">
          <div className="pager-info">Halaman <strong>{page}</strong> dari <strong>{total || 1}</strong></div>
          <div className="pager-controls">
            <button className="btn btn-secondary btn-sm" onClick={() => onChange(page - 1)} disabled={page <= 1}>
              <i className="ti ti-chevron-left"></i>
            </button>
            <button className="btn btn-secondary btn-sm" onClick={() => onChange(page + 1)} disabled={page >= total}>
              <i className="ti ti-chevron-right"></i>
            </button>
          </div>
        </div>
      );
    }

    // SVG Micro Charts
    function BarChart({ data, keys }) {
      const max = Math.max(1, ...data.flatMap(d => keys.map(k => d[k.key] || 0)));
      return (
        <div style={{ display: 'flex', alignItems: 'flex-end', gap: 14, height: 160, padding: '10px 4px 4px 4px' }}>
          {data.map((d, i) => (
            <div key={i} style={{ flex: 1, display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 6, height: '100%', justifyContent: 'flex-end' }}>
              <div style={{ display: 'flex', gap: 3, alignItems: 'flex-end', height: '100%', width: '100%', justifyContent: 'center' }}>
                {keys.map(k => {
                  const val = d[k.key] || 0;
                  const pct = (val / max) * 100;
                  return (
                    <div key={k.key} title={`${k.label}: ${val}`} style={{
                      width: '45%',
                      height: `${Math.max(4, pct)}%`,
                      background: k.color,
                      borderRadius: '3px 3px 0 0',
                      transition: 'height 0.3s ease'
                    }} />
                  );
                })}
              </div>
              <span style={{ fontSize: 9, color: 'var(--text-secondary)', textAlign: 'center', fontWeight: 600, width: '100%', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                {d.label}
              </span>
            </div>
          ))}
        </div>
      );
    }

    function DonutChart({ data, size = 120 }) {
      const total = data.reduce((s, d) => s + d.value, 0) || 1;
      let acc = 0;
      const r = size / 2 - 8;
      const c = size / 2;
      
      const segments = data.map(d => {
        const start = (acc / total) * 2 * Math.PI - Math.PI / 2;
        acc += d.value;
        const end = (acc / total) * 2 * Math.PI - Math.PI / 2;
        const x1 = c + r * Math.cos(start), y1 = c + r * Math.sin(start);
        const x2 = c + r * Math.cos(end), y2 = c + r * Math.sin(end);
        const large = (end - start) > Math.PI ? 1 : 0;
        return {
          path: `M${c},${c} L${x1},${y1} A${r},${r} 0 ${large} 1 ${x2},${y2} Z`,
          color: d.color
        };
      });

      return (
        <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
          {segments.map((s, i) => <path key={i} d={s.path} fill={s.color} />)}
          <circle cx={c} cy={c} r={r * 0.58} fill="var(--bg-card)" />
        </svg>
      );
    }

    // ----------------------------------------------------
    // AUTHENTICATED VIEWS
    // ----------------------------------------------------

    // 1. Dashboard View
    function DashboardView({ units, isMobile }) {
      const stats = useMemo(() => {
        const total = units.length;
        const plan = units.filter(u => u.statusPlan === 'PLAN').length;
        const done = units.filter(u => u.statusPasang === 'DONE').length;
        const prog = units.filter(u => u.statusPasang === 'ON PROGRESS').length;
        const delay = units.filter(u => u.statusPasang === 'DELAY').length;
        const verified = units.filter(u => u.statusSystem === 'OK').length;
        const geotab = units.filter(u => u.statusPasang === 'DONE' && u.modelGpsBaru === 'GEOTAB').length;
        const smatrack = units.filter(u => u.statusPasang === 'DONE' && u.modelGpsBaru === 'SMA-TRACK').length;
        return { total, plan, unplan: total - plan, done, prog, delay, verified, geotab, smatrack };
      }, [units]);

      const pct = stats.total ? Math.round((stats.done / stats.total) * 100) : 0;

      const locData = useMemo(() => {
        return LOCS.map(loc => ({
          label: loc.length > 8 ? loc.slice(0, 8) + '…' : loc,
          Total: units.filter(u => u.location === loc).length,

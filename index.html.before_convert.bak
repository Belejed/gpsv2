          '    </td>\n' +
          '    <td style="border: none; text-align: center; width: 50%;">\n' +
          '      <p style="color: #64748b; margin-bottom: 35px; font-size: 8.5pt;">Menyetujui (Supervisor)</p>\n' +
          '      <p style="font-weight: bold; border-bottom: 1px solid #94a3b8; display: inline-block; min-width: 120px; font-size: 8.5pt;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>\n' +
          '    </td>\n' +
          '  </tr>\n' +
          '</table>';
      }

      // Extract variables to avoid any interpolation logic inside htmlContent
      const nopol = u.nopol || '—';
      const statusText = u.statusPasang === 'DONE' ? 'SELESAI (DONE)' : (u.statusPasang || 'CONFIRM');
      const paddingBody = isFull ? '20px' : '10px';
      const marginBottomTable = isFull ? '20px' : '10px';
      const paddingCell = isFull ? '8px' : '4px';
      const fontSizeCell = isFull ? '10pt' : '9pt';
      const fontSizeHeader = isFull ? '12pt' : '10.5pt';
      const paddingHeader = isFull ? '6px' : '4px';
      const marginTopHeader = isFull ? '15px' : '8px';
      const marginBottomHeader = isFull ? '10px' : '6px';
      const paddingPhoto = isFull ? '5px' : '3px';
      const paddingFallback = isFull ? '20px' : '10px';
      const fontSizeFallback = isFull ? '10pt' : '8.5pt';
      const fontSizeTitle = isFull ? '16pt' : '13pt';
      const ownership = u.ownership || '—';
      const merk = u.merk || '—';
      const year = u.year || '—';
      const assetType = u.assetType || '—';
      const location = u.location || '—';
      const pool = u.pool || '—';
      const dedicate = u.dedicate || '—';
      const planDate = u.planDate || '—';
      const lokasiPasang = u.lokasiPasang || '—';
      const teknisiPelaksana = u.teknisiPelaksana || '—';
      const modelGpsBaru = u.modelGpsBaru || '—';
      const gpsSerialBaru = u.gpsSerialBaru || '—';
      const gpsImeiBaru = u.gpsImeiBaru || '—';
      const nomorSIM = u.nomorSIM || '—';
      const provider = u.provider || '—';
      const gpsSerialLama = u.gpsSerialLama || '—';
      const gps = u.gps || '—';
      const buzzer = u.buzzer || '—';
      const sos = u.sos || '—';
      const sensorWing = u.sensorWing || '—';
      const camera = u.camera || '—';
      const marginTopSignature = isFull ? '40px' : '15px';

      // Build htmlContent using a clean, single-level ES6 template literal
      const htmlContent = `
        <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
        <head>
          <title>Laporan Migrasi GPS - ${nopol}</title>
          <style>
            body { font-family: 'Arial', sans-serif; color: #1e293b; background: #ffffff; padding: ${paddingBody}; }
            table { width: 100%; border-collapse: collapse; margin-bottom: ${marginBottomTable}; }
            th, td { border: 1px solid #cbd5e1; padding: ${paddingCell}; font-size: ${fontSizeCell}; text-align: left; }
            th { background-color: #f1f5f9; font-weight: bold; color: #1e293b; }
            .section-header { font-size: ${fontSizeHeader}; font-weight: bold; background-color: #e2e8f0; padding: ${paddingHeader}; margin-top: ${marginTopHeader}; margin-bottom: ${marginBottomHeader}; border-left: 5px solid #3b82f6; }
            .photo-box { border: 1px solid #cbd5e1; padding: ${paddingPhoto}; text-align: center; background-color: #f8fafc; }
            .photo-fallback { border: 1px dashed #94a3b8; padding: ${paddingFallback}; text-align: center; color: #94a3b8; font-weight: bold; font-size: ${fontSizeFallback}; }
          </style>
        </head>
        <body>
          <h2 style="text-align: center; color: #1e293b; border-bottom: 2px solid #3b82f6; padding-bottom: 10px; font-size: ${fontSizeTitle}; margin-top: 0; margin-bottom: 8px;">LAPORAN MIGRASI & VERIFIKASI GPS</h2>
          <p style="text-align: right; font-size: 8pt; color: #64748b; margin-bottom: 8px;">Status: <b>${statusText}</b></p>
          
          <div class="section-header">1. DETAIL KENDARAAN</div>
          <table>
            <tr>
              <td style="font-weight: bold; width: 25%;">Nomor Polisi</td>
              <td style="font-weight: bold; width: 25%; font-size: ${fontSizeCell}; font-family: 'Arial';">${nopol}</td>
              <td style="font-weight: bold; width: 25%;">Ownership</td>
              <td style="width: 25%;">${ownership}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Merk / Tahun</td>
              <td>${merk} / ${year}</td>
              <td style="font-weight: bold;">Asset Type</td>
              <td>${assetType}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Lokasi / Pool</td>
              <td>${location} / ${pool}</td>
              <td style="font-weight: bold;">Dedicate</td>
              <td>${dedicate}</td>
            </tr>
          </table>
          
          <div class="section-header">2. LAPORAN PEMASANGAN GPS (TEKNISI)</div>
          <table>
            <tr>
              <td style="font-weight: bold; width: 25%;">Jadwal Pasang</td>
              <td style="width: 25%;">${planDate}</td>
              <td style="font-weight: bold; width: 25%;">Lokasi Pasang</td>
              <td style="width: 25%;">${lokasiPasang}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Teknisi Pelaksana</td>
              <td style="font-weight: bold;">${teknisiPelaksana}</td>
              <td style="font-weight: bold;">Tipe GPS Baru</td>
              <td>${modelGpsBaru}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Serial GPS Baru</td>
              <td>${gpsSerialBaru}</td>
              <td style="font-weight: bold;">IMEI GPS Baru</td>
              <td>${gpsImeiBaru}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Nomor SIM Card</td>
              <td>${nomorSIM}</td>
              <td style="font-weight: bold;">Provider SIM</td>
              <td>${provider}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Serial GPS Lama</td>
              <td>${gpsSerialLama}</td>
              <td style="font-weight: bold;">Status GPS</td>
              <td>${gps}</td>
            </tr>
            <tr>
              <td style="font-weight: bold;">Buzzer / SOS</td>
              <td>${buzzer} / ${sos}</td>
              <td style="font-weight: bold;">Sensor Wing / Camera</td>
              <td>${sensorWing} / ${camera}</td>
            </tr>
          </table>
          
          <div style="font-weight: bold; font-size: 9pt; margin-top: 10px; margin-bottom: 5px;">Dokumentasi Pemasangan (Teknisi):</div>
          <table>
            <tr>
              <td style="width: 20%; text-align: center; vertical-align: top;">
                ${fotoKendaraanHtml}
              </td>
              <td style="width: 20%; text-align: center; vertical-align: top;">
                ${fotoGPSLamaHtml}
              </td>
              <td style="width: 20%; text-align: center; vertical-align: top;">
                ${fotoGPSBaruHtml}
              </td>
              <td style="width: 20%; text-align: center; vertical-align: top;">
                ${fotoHasilInstalasiHtml}
              </td>
              <td style="width: 20%; text-align: center; vertical-align: top;">
                ${fotoOdometerHtml}
              </td>
            </tr>
          </table>
          
          ${verificationHtml}
          
          <div style="margin-top: ${marginTopSignature};"></div>
          ${signatureHtml}
          
          <p style="text-align: center; font-size: 8pt; color: #94a3b8; margin-top: 20px; border-top: 1px solid #cbd5e1; padding-top: 8px;">
            Dokumen ini diunduh secara otomatis dari Portal Migrasi GPS Puninar Logistics.
          </p>
        </body>
        </html>
      `;

      const blob = new Blob(['\ufeff' + htmlContent], { type: 'application/msword' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'Laporan_Migrasi_GPS_' + nopol + '.doc';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    };const exportToCSV = (dataList, filename) => {
      const headers = [
        'NO', 'OWNERSHIP', 'NOPOL', 'YEAR', 'MERK', 'ASSET TYPE', 'BUSINESS LOCATION', 'BUSINESS POOL', 'BUSINESS DEDICATE',
        'PLAN PASANG', 'LOKASI PASANG', 'PIC LAPANGAN', 'TEKNISI PELAKSANA', 'TIPE GPS BARU', 'SN GPS BARU', 'IMEI GPS BARU',
        'NOMOR KARTU GPS BARU', 'PROVIDER SIM GPS BARU', 'GPS', 'BUZZER', 'SOS', 'SENSOR WING', 'CAMERA',
        'FOTO KENDARAAN (NOPOL)', 'FOTO SERIAL GPS LAMA (DICABUT)', 'FOTO GPS BARU (SN TERLIHAT)', 'FOTO HASIL INSTALASI', 'STATUS REGISTRASI',
        'CEK FISIK GPS LAMA', 'CEK FISIK GPS BARU', 'CEK KONDISI UNIT SELESAI INSTALASI', 'CEK FITUR (SENSOR, SOS, CAMERA)', 'FOTO BUKTI PENYERAHAN GPS LAMA',
        'CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT', 'FOTO INTEGRASI DATA GPS KE PUNINAR', 'FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR',
        'CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT', 'FOTO TERIMA FISIK GPS LAMA', 'FOTO BUKTI TERMINASI GPS LAMA', 'LAST_UPDATE'
      ];
      
      const escapeCSV = (val) => {
        if (val === null || val === undefined) return '';
        const str = String(val);
        if (str.includes(',') || str.includes('"') || str.includes('\n') || str.includes('\r')) {
          return `"${str.replace(/"/g, '""')}"`;
        }
        return str;
      };

      const rows = dataList.map((u, i) => [
        i + 1, u.ownership, u.nopol, u.year, u.merk, u.assetType, u.location, u.pool, u.dedicate,
        u.planDate, u.lokasiPasang, u.picLapangan, u.teknisiPelaksana, u.modelGpsBaru, u.gpsSerialBaru, u.gpsImeiBaru,
        u.nomorSIM, u.provider, u.gps, u.buzzer, u.sos, u.sensorWing, u.camera,
        u.fotoKendaraan, u.fotoGPSLama, u.fotoGPSBaru, u.fotoHasilInstalasi, u.statusPasang,
        u.picCekFisikLama, u.picCekFisikBaru, u.picCekKondisiSelesai, u.picCekFitur, u.picFotoSerahTerima,
        u.itCekAplikasi, u.itFotoIntegrasi, u.itFotoAbnormality,
        u.cmtCekAplikasi, u.cmtFotoTerimaFisik, u.cmtFotoTerminasi, u.updatedAt
      ].map(escapeCSV));

      const csvContent = "\uFEFF" + [headers.join(','), ...rows.map(r => r.join(','))].join('\n');
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", filename);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    };

    const PAGE_LIMIT = 15;

    // ----------------------------------------------------
    // AUTHENTICATION CONTEXT & PROVIDER
    // ----------------------------------------------------
    const AuthContext = createContext(null);

    function AuthProvider({ children }) {
      const [user, setUser] = useState(null);
      const [users, setUsers] = useState([]);
      const [loadingUsers, setLoadingUsers] = useState(true);

      const fetchUsers = async () => {
        try {
          const { data, error } = await supabaseClient
            .from('users')
            .select('*')
            .order('id', { ascending: true });
          if (!error && data) {
            setUsers(data);
          }
        } catch (e) {
          console.error("Gagal memuat user dari Supabase:", e);
        } finally {
          setLoadingUsers(false);
        }
      };

      useEffect(() => {
        fetchUsers();

        // Load active session
        try {
          const storedSession = sessionStorage.getItem('gps_user_session');
          if (storedSession) {
            setUser(JSON.parse(storedSession));
          }
        } catch (e) {}
      }, []);

      const login = async (username, password) => {
        try {
          const { data, error } = await supabaseClient
            .from('users')
            .select('*')
            .eq('username', username)
            .eq('password', password);
          
          if (error) {
            return { success: false, message: 'Koneksi ke database gagal!' };
          }
          
          if (data && data.length > 0) {
            const foundUser = data[0];
            setUser(foundUser);
            sessionStorage.setItem('gps_user_session', JSON.stringify(foundUser));
            return { success: true };
          }
          return { success: false, message: 'Username atau password salah!' };
        } catch (err) {
          return { success: false, message: 'Koneksi gagal: ' + String(err) };
        }
      };

      const logout = () => {
        setUser(null);
        sessionStorage.removeItem('gps_user_session');
      };

      // CRUD Operations on Supabase
      const handleCreateUser = async (newUser) => {
        const { id, ...insertData } = newUser; // let Supabase serial ID handle it
        const { error } = await supabaseClient.from('users').insert([insertData]);
        if (error) {
          globalAddToast('Gagal menambahkan user ke database: ' + error.message, 'danger');
          return false;
        }
        await fetchUsers();
        return true;
      };

      const handleDeleteUser = async (id) => {
        const { error } = await supabaseClient.from('users').delete().eq('id', id);
        if (error) {
          globalAddToast('Gagal menghapus user dari database: ' + error.message, 'danger');
          return false;
        }
        await fetchUsers();
        return true;
      };

      const handleUpdateUser = async (updatedUser) => {
        const { id, username, password, name, role } = updatedUser;
        const { error } = await supabaseClient.from('users').update({ password, name, role }).eq('id', id);
        if (error) {
          globalAddToast('Gagal mengupdate user di database: ' + error.message, 'danger');
          return false;
        }
        await fetchUsers();
        return true;
      };

      const handleRestoreUsers = async (userList) => {
        // Remove IDs to avoid serial conflict, then insert
        const cleanedList = userList.map(({ id, ...u }) => u);
        const { error } = await supabaseClient.from('users').insert(cleanedList);
        if (error) {
          globalAddToast('Gagal restore users: ' + error.message, 'danger');
          return false;
        }
        await fetchUsers();
        return true;
      };

      return (
        <AuthContext.Provider value={{ 
          user, 
          users, 
          login, 
          logout, 
          createUser: handleCreateUser, 
          deleteUser: handleDeleteUser, 
          updateUser: handleUpdateUser, 
          restoreUsers: handleRestoreUsers,
          loadingUsers 
        }}>
          {children}
        </AuthContext.Provider>
      );
    }

    // ----------------------------------------------------
    // SHARED REUSABLE COMPONENTS
    // ----------------------------------------------------
    function ToastContainer() {
      const [toasts, setToasts] = useState([]);

      useEffect(() => {
        globalAddToast = (text, type = 'info') => {
          const id = Date.now();
          setToasts(prev => [...prev, { id, text, type }]);
          setTimeout(() => {
            setToasts(prev => prev.filter(t => t.id !== id));
          }, 3500);
        };
      }, []);

      return (
        <div className="toast-container">
          {toasts.map(t => (
            <div key={t.id} className={`toast ${t.type}`}>
              <i className={`bi ${t.type === 'success' ? 'bi-check-circle-fill' : t.type === 'error' ? 'bi-exclamation-circle-fill' : t.type === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-info-circle-fill'}`} style={{fontSize: 18, color: t.type === 'success' ? '#22C55E' : t.type === 'error' ? '#EF4444' : t.type === 'warning' ? '#F59E0B' : '#60A5FA', flexShrink: 0}}></i>
              <div style={{fontSize: 12, fontWeight: 500}}>{t.text}</div>
              <button className="toast-close" onClick={() => setToasts(prev => prev.filter(x => x.id !== t.id))}>
                <i className="bi bi-x"></i>
              </button>
            </div>
          ))}
        </div>
      );
    }

    function Badge({ val }) {
      const trimmed = val ? String(val).trim() : '';
      if (!trimmed) return <span style={{ color: 'var(--text-tertiary)', fontSize: 11 }}>—</span>;
      let cl = 'unplan';
      const cleanVal = trimmed.toUpperCase();
      if (cleanVal === 'PLAN' || cleanVal === 'BELUM DIPASANG') cl = 'plan';
      else if (cleanVal === 'DONE' || cleanVal === 'TERPASANG' || cleanVal === 'OK' || cleanVal === 'SUDAH' || cleanVal === 'SUDAH SUSPEND') cl = 'done';
      else if (cleanVal === 'ON PROGRESS' || cleanVal === 'IT VERIFIED' || cleanVal === 'PROSES SUSPEND') cl = 'progress';
      else if (cleanVal === 'DELAY' || cleanVal === 'CANCEL' || cleanVal === 'TIDAK TERPASANG' || cleanVal === 'NOT OK' || cleanVal === 'TEKNISI SUBMITTED') cl = 'delay';
      else if (cleanVal === 'RESCHEDULE' || cleanVal === 'PERLU REVISIT' || cleanVal === 'PIC VERIFIED') cl = 'reschedule';

      return <span className={`badge ${cl}`}>{trimmed}</span>;
    }

    function FilterRow({ children }) {
      return <div className="filter-bar">{children}</div>;
    }

    function Pager({ page, total, onChange }) {
      return (
        <div className="pager-container">
          <div className="pager-info">Halaman <strong>{page}</strong> dari <strong>{total || 1}</strong></div>
          <div className="pager-controls">
            <button className="btn btn-secondary btn-sm" onClick={() => onChange(page - 1)} disabled={page <= 1}>
              <i className="bi bi-chevron-left"></i>
            </button>
            <button className="btn btn-secondary btn-sm" onClick={() => onChange(page + 1)} disabled={page >= total}>
              <i className="bi bi-chevron-right"></i>
            </button>
          </div>
        </div>
      );
    }

    // SVG Micro Charts
    function BarChart({ data, keys }) {
      const max = Math.max(1, ...data.flatMap(d => keys.map(k => d[k.key] || 0)));
      return (
        <div style={{ display: 'flex', alignItems: 'flex-end', gap: 14, height: 160, padding: '10px 4px 4px 4px' }}>
          {data.map((d, i) => (
            <div key={i} style={{ flex: 1, display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 6, height: '100%', justifyContent: 'flex-end' }}>
              <div style={{ display: 'flex', gap: 3, alignItems: 'flex-end', height: '100%', width: '100%', justifyContent: 'center' }}>
                {keys.map(k => {
                  const val = d[k.key] || 0;
                  const pct = (val / max) * 100;
                  return (
                    <div key={k.key} title={`${k.label}: ${val}`} style={{
                      width: '45%',
                      height: `${Math.max(4, pct)}%`,
                      background: k.color,
                      borderRadius: '3px 3px 0 0',
                      transition: 'height 0.3s ease'
                    }} />
                  );
                })}
              </div>
              <span style={{ fontSize: 9, color: 'var(--text-secondary)', textAlign: 'center', fontWeight: 600, width: '100%', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                {d.label}
              </span>
            </div>
          ))}
        </div>
      );
    }

    function DonutChart({ data, size = 120 }) {
      const total = data.reduce((s, d) => s + d.value, 0) || 1;
      let acc = 0;
      const r = size / 2 - 8;
      const c = size / 2;
      
      const segments = data.map(d => {
        const start = (acc / total) * 2 * Math.PI - Math.PI / 2;
        acc += d.value;
        const end = (acc / total) * 2 * Math.PI - Math.PI / 2;
        const x1 = c + r * Math.cos(start), y1 = c + r * Math.sin(start);
        const x2 = c + r * Math.cos(end), y2 = c + r * Math.sin(end);
        const large = (end - start) > Math.PI ? 1 : 0;
        return {
          path: `M${c},${c} L${x1},${y1} A${r},${r} 0 ${large} 1 ${x2},${y2} Z`,
          color: d.color
        };
      });

      return (
        <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
          {segments.map((s, i) => <path key={i} d={s.path} fill={s.color} />)}
          <circle cx={c} cy={c} r={r * 0.58} fill="var(--bg-card)" />
        </svg>
      );
    }

    // ----------------------------------------------------
    // AUTHENTICATED VIEWS
    // ----------------------------------------------------

    // 1. Dashboard View
    function DashboardView({ units, isMobile }) {
      const stats = useMemo(() => {
        const total = units.length;
        const unplanned = units.filter(u => !u.planDate).length;
        const planned = units.filter(u => u.planDate && u.statusPasang === 'BELUM DIPASANG').length;
        const progress = units.filter(u => u.statusPasang === 'ON PROGRESS').length;
        const teknisiSubmitted = units.filter(u => u.statusPasang === 'TEKNISI SUBMITTED').length;
        const picVerified = units.filter(u => u.statusPasang === 'PIC VERIFIED').length;
        const itVerified = units.filter(u => u.statusPasang === 'IT VERIFIED').length;
        const cmtPending = units.filter(u => u.statusPasang === 'CMT PENDING').length;
        const done = units.filter(u => u.statusPasang === 'DONE').length;
        const pendingVerif = teknisiSubmitted + picVerified + itVerified + cmtPending;
        
        return { total, unplanned, planned, progress, teknisiSubmitted, picVerified, itVerified, cmtPending, done, pendingVerif };
      }, [units]);

      const pct = stats.total ? Math.round((stats.done / stats.total) * 100) : 0;

      const locData = useMemo(() => {
        return LOCS.map(loc => ({
          label: loc.length > 8 ? loc.slice(0, 8) + '…' : loc,
          Total: units.filter(u => u.location === loc).length,
          Done: units.filter(u => u.location === loc && u.statusPasang === 'DONE').length,
        }));
      }, [units]);

      const pieData = useMemo(() => {
        return [
          { name: 'Complete (Done)', value: stats.done, color: 'var(--color-done)' },
          { name: 'On Progress', value: stats.progress, color: 'var(--color-progress)' },
          { name: 'Pending Verif', value: stats.pendingVerif, color: 'var(--color-delay)' },
          { name: 'Planned', value: stats.planned, color: 'var(--color-plan)' },
          { name: 'Unplanned', value: stats.unplanned, color: 'var(--color-unplan)' },
        ].filter(d => d.value > 0);
      }, [stats]);

      const recent = useMemo(() => {
        return units.filter(u => u.updatedAt).sort((a,b) => b.updatedAt.localeCompare(a.updatedAt)).slice(0, 5);
      }, [units]);

      return (
        <div className="fade-in" style={{ display: 'flex', flexDirection: 'column', gap: 20 }}>
          <div className="stat-grid">
            <div className="stat-card">
              <span className="stat-label">Total Unit</span>
              <span className="stat-value">{stats.total}</span>
              <span className="stat-sub">GPS Migration</span>
              <div className="stat-indicator" style={{background: 'var(--accent)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Terjadwal (Plan)</span>
              <span className="stat-value" style={{color: 'var(--color-plan)'}}>{stats.total - stats.unplanned}</span>
              <span className="stat-sub">{stats.total ? Math.round((stats.total - stats.unplanned)/stats.total*100) : 0}% ter-plan</span>
              <div className="stat-indicator" style={{background: 'var(--color-plan)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Belum Plan</span>
              <span className="stat-value" style={{color: 'var(--color-unplan)'}}>{stats.unplanned}</span>
              <span className="stat-sub">Menunggu jadwal</span>
              <div className="stat-indicator" style={{background: 'var(--color-unplan)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Selesai (Done)</span>
              <span className="stat-value" style={{color: 'var(--color-done)'}}>{stats.done}</span>
              <span className="stat-sub">{pct}% Migrasi Selesai</span>
              <div className="stat-indicator" style={{background: 'var(--color-done)'}} />
            </div>
            <div className="stat-card">
              <span className="stat-label">Pending Verifikasi</span>
              <span className="stat-value" style={{color: 'var(--color-delay)'}}>{stats.pendingVerif}</span>
              <span className="stat-sub">PIC, IT, dan CMT</span>
              <div className="stat-indicator" style={{background: 'var(--color-delay)'}} />
            </div>
          </div>


          {/* GPS Installation Status List */}
          {(() => {
            const installedUnits = units.filter(u => u.statusPasang && u.statusPasang !== 'BELUM DIPASANG' && u.statusPasang !== 'ON PROGRESS' && u.statusPasang !== '');
            const onProgressUnits = units.filter(u => u.statusPasang === 'ON PROGRESS');
            const belumUnits = units.filter(u => !u.statusPasang || u.statusPasang === 'BELUM DIPASANG');
            if (units.length === 0) return null;
            return (
              <div style={{ background: 'var(--bg-card)', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-md)', overflow: 'hidden' }}>
                {/* Header */}
                <div style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '12px 16px', borderBottom: '1px solid var(--border-color)', background: 'rgba(255,255,255,0.02)' }}>
                  <i className="bi bi-broadcast" style={{ fontSize: 18, color: '#22C55E' }}></i>
                  <span style={{ fontWeight: 700, fontSize: 13, color: 'var(--text-primary)', flex: 1 }}>Status Pemasangan GPS Per Unit</span>
                  <div style={{ display: 'flex', gap: 8 }}>
                    <span style={{ fontSize: 11, padding: '3px 10px', borderRadius: 20, background: 'rgba(34,197,94,0.12)', color: '#22C55E', fontWeight: 600 }}>
                      <i className="bi bi-check-circle-fill" style={{ marginRight: 4 }}></i>{installedUnits.length} Terpasang
                    </span>
                    {onProgressUnits.length > 0 && (
                      <span style={{ fontSize: 11, padding: '3px 10px', borderRadius: 20, background: 'rgba(245,158,11,0.12)', color: '#F59E0B', fontWeight: 600 }}>
                        <i className="bi bi-tools" style={{ marginRight: 4 }}></i>{onProgressUnits.length} Progress
                      </span>
                    )}
                    <span style={{ fontSize: 11, padding: '3px 10px', borderRadius: 20, background: 'rgba(239,68,68,0.1)', color: '#EF4444', fontWeight: 600 }}>
                      <i className="bi bi-clock" style={{ marginRight: 4 }}></i>{belumUnits.length} Belum
                    </span>
                  </div>
                </div>
                {/* Two-column list */}
                <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : '1fr 1fr', gap: 0 }}>
                  {/* LEFT: Terpasang */}
                  <div style={{ borderRight: isMobile ? 'none' : '1px solid var(--border-color)', borderBottom: isMobile ? '1px solid var(--border-color)' : 'none' }}>
                    <div style={{ padding: '8px 14px', background: 'rgba(34,197,94,0.06)', borderBottom: '1px solid var(--border-color)', fontSize: 11, fontWeight: 700, color: '#22C55E', display: 'flex', alignItems: 'center', gap: 6 }}>
                      <i className="bi bi-check-circle-fill"></i> GPS SUDAH TERPASANG ({installedUnits.length + onProgressUnits.length})
                    </div>
                    <div style={{ maxHeight: 200, overflowY: 'auto', padding: '6px 0' }}>
                      {[...installedUnits, ...onProgressUnits].length === 0 ? (
                        <div style={{ textAlign: 'center', padding: '16px 0', color: 'var(--text-tertiary)', fontSize: 11 }}>Belum ada unit terpasang</div>
                      ) : [...installedUnits, ...onProgressUnits].map((u, idx) => (
                        <div key={u.id} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 14px', borderBottom: idx < installedUnits.length + onProgressUnits.length - 1 ? '1px solid rgba(255,255,255,0.03)' : 'none' }}>
                          <i className={`bi ${u.statusPasang === 'ON PROGRESS' ? 'bi-tools' : 'bi-check-circle-fill'}`} style={{ fontSize: 11, color: u.statusPasang === 'ON PROGRESS' ? '#F59E0B' : '#22C55E', flexShrink: 0 }}></i>
                          <span style={{ fontWeight: 700, fontSize: 12, color: 'var(--text-primary)', minWidth: 90 }}>{u.nopol}</span>
                          <span style={{ fontSize: 10, color: 'var(--text-secondary)', flex: 1, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{u.pool || u.location}</span>
                          <span style={{ fontSize: 9, padding: '2px 6px', borderRadius: 10, background: u.statusPasang === 'DONE' ? 'rgba(34,197,94,0.1)' : u.statusPasang === 'ON PROGRESS' ? 'rgba(245,158,11,0.1)' : 'rgba(99,102,241,0.1)', color: u.statusPasang === 'DONE' ? '#22C55E' : u.statusPasang === 'ON PROGRESS' ? '#F59E0B' : '#818CF8', fontWeight: 600, flexShrink: 0 }}>{u.statusPasang}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                  {/* RIGHT: Belum */}
                  <div>
                    <div style={{ padding: '8px 14px', background: 'rgba(239,68,68,0.05)', borderBottom: '1px solid var(--border-color)', fontSize: 11, fontWeight: 700, color: '#EF4444', display: 'flex', alignItems: 'center', gap: 6 }}>
                      <i className="bi bi-clock"></i> BELUM DIPASANG ({belumUnits.length})
                    </div>
                    <div style={{ maxHeight: 200, overflowY: 'auto', padding: '6px 0' }}>
                      {belumUnits.length === 0 ? (
                        <div style={{ textAlign: 'center', padding: '16px 0', color: '#22C55E', fontSize: 11 }}>
                          <i className="bi bi-check-circle-fill" style={{ marginRight: 6 }}></i>Semua unit sudah terpasang!
                        </div>
                      ) : belumUnits.map((u, idx) => (
                        <div key={u.id} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 14px', borderBottom: idx < belumUnits.length - 1 ? '1px solid rgba(255,255,255,0.03)' : 'none' }}>
                          <i className="bi bi-circle" style={{ fontSize: 10, color: '#64748B', flexShrink: 0 }}></i>
                          <span style={{ fontWeight: 700, fontSize: 12, color: 'var(--text-primary)', minWidth: 90 }}>{u.nopol}</span>
                          <span style={{ fontSize: 10, color: 'var(--text-secondary)', flex: 1, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{u.pool || u.location}</span>
                          <span style={{ fontSize: 9, padding: '2px 6px', borderRadius: 10, background: 'rgba(100,116,139,0.1)', color: '#64748B', fontWeight: 600, flexShrink: 0 }}>BELUM</span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            );
          })()}

          {/* Visual Pipeline Progress */}
          <div className="progress-panel" style={{ padding: '16px 20px' }}>
            <div style={{fontWeight: 700, fontSize: 13, marginBottom: 12, color: '#FFF'}}>Pipeline Status Pemasangan GPS</div>
            <div style={{
              display: 'flex', 
              justifyContent: 'space-between', 
              alignItems: 'center', 
              gap: 8,
              flexWrap: 'wrap',
              marginTop: 10
            }}>
              {[
                { label: 'Unplanned', val: stats.unplanned, color: 'var(--color-unplan)' },
                { label: 'Planned', val: stats.planned, color: 'var(--color-plan)' },
                { label: 'Installing', val: stats.progress, color: 'var(--color-progress)' },
                { label: 'Pending PIC', val: stats.teknisiSubmitted, color: 'var(--color-delay)' },
                { label: 'Pending IT', val: stats.picVerified, color: '#8b5cf6' },
                { label: 'Pending CMT', val: stats.itVerified + (stats.cmtPending || 0), color: '#ec4899' },
                { label: 'Complete', val: stats.done, color: 'var(--color-done)' }
              ].map((step, idx) => (
                <div key={idx} style={{
                  flex: 1, 
                  minWidth: 90, 
                  background: 'rgba(255,255,255,0.02)', 
                  border: '1px solid var(--border-color)', 
                  borderRadius: 'var(--radius-sm)', 
                  padding: '10px 6px', 
                  textAlign: 'center',
                  position: 'relative'
                }}>
                  <div style={{fontSize: 18, fontWeight: 800, color: step.color}}>{step.val}</div>
                  <div style={{fontSize: 9, color: 'var(--text-secondary)', fontWeight: 600, marginTop: 4}}>{step.label}</div>
                  {idx < 6 && !isMobile && (
                    <div style={{
                      position: 'absolute', 
                      right: -10, 
                      top: '50%', 
                      transform: 'translateY(-50%)', 
                      zIndex: 10, 
                      color: 'var(--text-tertiary)',
                      fontSize: 12
                    }}>
                      <i className="bi bi-chevron-right"></i>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>

          <div className="progress-panel">
            <div className="progress-header">
              <span className="progress-title">Progress Migrasi Kumulatif</span>
              <span className="progress-stats">{stats.done} / {stats.total} Unit ({pct}%)</span>
            </div>
            <div className="progress-bar-container">
              <div className="progress-bar-fill" style={{ width: `${pct}%` }} />
            </div>
            <div className="legend-container">
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-done)'}} /> Complete ({stats.done})</div>
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-progress)'}} /> On Progress ({stats.progress})</div>
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-delay)'}} /> Pending Verif ({stats.pendingVerif})</div>
              <div className="legend-item"><span className="legend-dot" style={{background: 'var(--color-unplan)'}} /> Unplanned ({stats.unplanned})</div>
            </div>
          </div>

          <div className="dashboard-layout-grid">
            <div className="panel-card">
              <div className="panel-title"><i className="bi bi-geo-alt"></i> Unit per Lokasi</div>
              <BarChart data={locData} keys={[{key: 'Total', label: 'Total', color: 'var(--accent-light)'}, {key: 'Done', label: 'Done', color: 'var(--color-done)'}]} />
              <div style={{display:'flex', gap:12, marginTop: 16, justifyContent: 'center'}}>
                <span style={{fontSize:10, color:'var(--text-secondary)', display:'flex', alignItems:'center', gap:4}}>
                  <span style={{width:10, height:10, borderRadius:2, background:'var(--accent-light)'}}/>Total Unit
                </span>
                <span style={{fontSize:10, color:'var(--text-secondary)', display:'flex', alignItems:'center', gap:4}}>
                  <span style={{width:10, height:10, borderRadius:2, background:'var(--color-done)'}}/>Selesai Migrasi
                </span>
              </div>
            </div>

            <div className="panel-card" style={{ display: 'flex', flexDirection: 'column' }}>
              <div className="panel-title"><i className="bi bi-pie-chart"></i> Distribusi Status</div>
              <div style={{ display: 'flex', flex: 1, alignItems: 'center', justifyContent: 'space-around', padding: '10px 0' }}>
                <DonutChart data={pieData} />
                <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
                  {pieData.map(d => (
                    <div key={d.name} style={{ display: 'flex', alignItems: 'center', gap: 8, fontSize: 11, color: 'var(--text-secondary)' }}>
                      <span style={{ width: 8, height: 8, borderRadius: 2, background: d.color }} />
                      <strong style={{color: 'var(--text-primary)'}}>{d.value}</strong> {d.name}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div className="panel-card">
            <div className="panel-title"><i className="bi bi-history"></i> Aktivitas Pemasangan Terakhir</div>
            {isMobile ? (
              <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
                {recent.map(u => (
                  <div key={u.id} className="mobile-unit-card" style={{ padding: 12 }}>
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                      <strong>{u.nopol}</strong>
                      <Badge val={u.statusPasang} />
                    </div>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 6, fontSize: 11, color: 'var(--text-secondary)', marginTop: 8 }}>
                      <div>Lokasi: <strong>{u.location}</strong></div>
                      <div>Pool: <strong>{u.pool}</strong></div>
                      <div>GPS Baru: <strong>{u.modelGpsBaru || '—'}</strong></div>
                      <div>Update: <span className="text-muted" style={{ fontSize: 10 }}>{u.updatedAt || '—'}</span></div>
                    </div>
                  </div>
                ))}
                {recent.length === 0 && (
                  <div style={{ textAlign: 'center', padding: 20, color: 'var(--text-tertiary)' }}>Belum ada riwayat update data</div>
                )}
              </div>
            ) : (
              <div className="table-container" style={{boxShadow: 'none', border: 'none', margin: 0}}>
                <table className="data-table">
                  <thead>
                    <tr>
                      <th>NOPOL</th>
                      <th>LOKASI</th>
                      <th>POOL</th>
                      <th>MODEL GPS BARU</th>
                      <th>STATUS PASANG</th>
                      <th>LAST UPDATE</th>
                    </tr>
                  </thead>
                  <tbody>
                    {recent.map(u => (
                      <tr key={u.id}>
                        <td><strong>{u.nopol}</strong></td>
                        <td>{u.location}</td>
                        <td>{u.pool}</td>
                        <td>{u.modelGpsBaru || '—'}</td>
                        <td><Badge val={u.statusPasang} /></td>
                        <td className="text-muted" style={{fontSize: 11}}>{u.updatedAt || '—'}</td>
                      </tr>
                    ))}
                    {recent.length === 0 && (
                      <tr>
                        <td colSpan="6" style={{ textAlign: 'center', padding: 20, color: 'var(--text-tertiary)' }}>Belum ada riwayat update data</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>
      );
    }

    // 2. Planner View
        function PlannerView({ units, setUnits, syncUpdate, isMobile }) {
      const { users } = useContext(AuthContext);
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');
      const [poolF, setPoolF] = useState('');
      const [st, setSt] = useState('');
      const [page, setPage] = useState(1);
      const [merkF, setMerkF] = useState('');
      const [assetTypeF, setAssetTypeF] = useState('');
      
      const [selectedUnit, setSelectedUnit] = useState(null);
      const [editData, setEditData] = useState({});

      const technicians = useMemo(() => {
        return (users || []).filter(u => u.role === 'teknisi');
      }, [users]);

      const pics = useMemo(() => {
        return (users || []).filter(u => u.role === 'pic');
      }, [users]);

      const workflowStages = [
        { name: 'UNPLAN', label: 'Unplan' },
        { name: 'PLAN', label: 'Plan' },
        { name: 'INSTALLATION', label: 'Installing' },
        { name: 'TEKNISI_SUBMITTED', label: 'Teknisi' },
        { name: 'PIC_VERIFIED', label: 'PIC' },
        { name: 'IT_VERIFIED', label: 'IT' },
        { name: 'CMT', label: 'CMT' },
        { name: 'COMPLETED', label: 'Done' }
      ];

      const getUnitCurrentStage = (u) => {
        if (u.statusPlan === 'UNPLAN') return 'UNPLAN';
        if (u.statusPasang === 'ON PROGRESS') return 'INSTALLATION';
        if (u.statusPasang === 'TEKNISI SUBMITTED') return 'TEKNISI_SUBMITTED';
        if (u.statusPasang === 'PIC VERIFIED') return 'PIC_VERIFIED';
        if (u.statusPasang === 'IT VERIFIED') return 'IT_VERIFIED';
        if (u.statusPasang === 'CMT PENDING') return 'CMT';
        if (u.statusPasang === 'DONE') return 'COMPLETED';
        return 'PLAN';
      };

      const getStageStatus = (currentStage, stageName) => {
        const order = ['UNPLAN', 'PLAN', 'INSTALLATION', 'TEKNISI_SUBMITTED', 'PIC_VERIFIED', 'IT_VERIFIED', 'CMT', 'COMPLETED'];
        const currentIndex = order.indexOf(currentStage);
        const stageNameIndex = order.indexOf(stageName);
        if (currentIndex === stageNameIndex) return 'active';
        if (stageNameIndex < currentIndex) return 'past';
        return 'future';
      };

      const renderStageCell = (currentStage, stageName) => {
        const status = getStageStatus(currentStage, stageName);
        
        if (status === 'active') {
          let colorClass = 'progress-dot active';
          if (currentStage === 'INSTALLATION' || currentStage === 'TEKNISI_SUBMITTED') {
            colorClass = 'progress-dot warning animate-pulse';
          } else if (currentStage === 'COMPLETED') {
            colorClass = 'progress-dot success';
          } else {
            colorClass = 'progress-dot primary animate-pulse';
          }
          return (
            <span className={colorClass} title={`Sedang di tahap: ${stageName}`} />
          );
        }
        if (status === 'past') {
          return (
            <span className="progress-dot past" title={`Selesai: ${stageName}`} />
          );
        }
        return (
          <span className="progress-dot future" title={`Antrean: ${stageName}`} />
        );
      };

      const getLastActivityNote = (u) => {
        const stage = getUnitCurrentStage(u);
        switch (stage) {
          case 'UNPLAN':
            return { activity: 'Belum Plan', notes: 'Menunggu pembuatan jadwal pemasangan.' };
          case 'PLAN':
            return { activity: 'Jadwal Dibuat', notes: `Rencana pasang: ${u.planDate} di ${u.lokasiPasang || '—'}.` };
          case 'INSTALLATION':
            return { activity: 'Instalasi Lapangan', notes: `Sedang dipasang oleh ${u.teknisiPelaksana || 'Teknisi'}.` };
          case 'TEKNISI_SUBMITTED':
            return { activity: 'Verifikasi PIC', notes: `Instalasi selesai. Menunggu verifikasi PIC Lapangan (${u.picLapangan || '—'}).` };
          case 'PIC_VERIFIED':
            return { activity: 'Verifikasi IT', notes: 'Fisik OK. Menunggu verifikasi integrasi IT Puninar.' };
          case 'IT_VERIFIED':
            return { activity: 'Verifikasi CMT', notes: 'Integrasi data OK. Menunggu verifikasi final CMT (Terminasi).' };
          case 'COMPLETED':
            return { activity: 'Migrasi Selesai', notes: 'Unit aktif penuh dan vendor lama sudah diterminasi.' };
          default:
            return { activity: 'Update Data', notes: u.updatedAt ? `Pembaruan terakhir pada ${u.updatedAt}` : 'Data terdaftar.' };
        }
      };

      const [showAddModal, setShowAddModal] = useState(false);
      const [newUnitData, setNewUnitData] = useState({
        nopol: '', ownership: 'PUNINAR', year: '', merk: '', assetType: '', location: LOCS[0], pool: POOLS[0], dedicate: 'LOGISTICS'
      });

      const [isCustomOwnership, setIsCustomOwnership] = useState(false);
      const [isCustomMerk, setIsCustomMerk] = useState(false);
      const [isCustomAssetType, setIsCustomAssetType] = useState(false);
      const [isCustomDedicate, setIsCustomDedicate] = useState(false);

      // Auto-reset custom toggles when modal is closed
      useEffect(() => {
        if (!showAddModal) {
          setIsCustomOwnership(false);
          setIsCustomMerk(false);
          setIsCustomAssetType(false);
          setIsCustomDedicate(false);
        }
      }, [showAddModal]);

      // CSV Import States
      const [showImportModal, setShowImportModal] = useState(false);
      const [importPreviewData, setImportPreviewData] = useState([]);
      const [importError, setImportError] = useState('');
      const [isImporting, setIsImporting] = useState(false);
      const [importProgress, setImportProgress] = useState(0);
      const [dragActive, setDragActive] = useState(false);

      // Memos to get unique values for autocomplete dropdowns (datalists)
      const uniqueOwnerships = useMemo(() => {
        return [...new Set(units.map(u => u.ownership).filter(Boolean))].sort();
      }, [units]);

      const uniqueMerks = useMemo(() => {
        return [...new Set(units.map(u => u.merk).filter(Boolean))].sort();
      }, [units]);

      const uniqueAssetTypes = useMemo(() => {
        return [...new Set(units.map(u => u.assetType).filter(Boolean))].sort();
      }, [units]);

      const uniqueDedicates = useMemo(() => {
        return [...new Set(units.map(u => u.dedicate).filter(Boolean))].sort();
      }, [units]);

      // 1. Download CSV Template Helper
      const downloadCSVTemplate = () => {
        const headers = ['OWNERSHIP', 'NOPOL', 'YEAR', 'MERK', 'ASSET TYPE', 'LOCATION', 'POOL', 'DEDICATE'];
        const sampleRows = [
          ['PUNINAR', 'B 1234 ABC', '2015', 'MITSUBISHI', 'PRIME MOVER 4X2', LOCS[0] || 'JAKARTA', POOLS[0] || 'POOL A', 'LOGISTICS'],
          ['PUNINAR', 'B 5678 DEF', '2018', 'TOYOTA', 'DYNA', LOCS[0] || 'JAKARTA', POOLS[0] || 'POOL A', 'LOGISTICS']
        ];
        
        const csvContent = "\uFEFF" + [
          headers.join(','),
          ...sampleRows.map(r => r.map(val => {
            const str = String(val);
            if (str.includes(',') || str.includes('"') || str.includes('\n')) {
              return `"${str.replace(/"/g, '""')}"`;
            }
            return str;
          }).join(','))
        ].join('\n');
        
        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.setAttribute("href", url);
        link.setAttribute("download", "template_import_kendaraan.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      };

      // 2. Vanilla CSV Parser
      const parseCSVContent = (text, delimiter = ',') => {
        const lines = [];
        let row = [""];
        let inQuotes = false;
        
        for (let i = 0; i < text.length; i++) {
          const char = text[i];
          const nextChar = text[i+1];
          
          if (char === '"') {
            if (inQuotes && nextChar === '"') {
              row[row.length - 1] += '"';
              i++; // skip next quote
            } else {
              inQuotes = !inQuotes;
            }
          } else if (char === delimiter && !inQuotes) {
            row.push('');
          } else if ((char === '\r' || char === '\n') && !inQuotes) {
            if (char === '\r' && nextChar === '\n') {
              i++; // skip \n
            }
            lines.push(row);
            row = [''];
          } else {
            row[row.length - 1] += char;
          }
        }
        if (row.length > 1 || row[0] !== '') {
          lines.push(row);
        }
        return lines;
      };

      // 3. Handle CSV Upload and parse/validate rows locally
      const handleCSVUpload = (e) => {
        setImportError('');
        const file = e.target.files?.[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = (evt) => {
          try {
            let text = evt.target.result;
            
            // UTF-8 BOM cleanup
            if (text.charCodeAt(0) === 0xFEFF || text.startsWith('\uFEFF')) {
              text = text.substring(1);
            }
            
            // Detect Delimiter
            const firstLine = text.split(/\r?\n/)[0] || '';
            const commaCount = (firstLine.match(/,/g) || []).length;
            const semicolonCount = (firstLine.match(/;/g) || []).length;
            const delimiter = semicolonCount > commaCount ? ';' : ',';
            
            const rawRows = parseCSVContent(text, delimiter);
            if (rawRows.length < 2) {
              setImportError('File CSV kosong atau tidak memiliki baris data.');
              return;
            }
            
            const fileHeaders = rawRows[0].map(h => 
              h.trim().replace(/^["']|["']$/g, '').replace(/[\uFEFF\u200B]/g, '').toUpperCase()
            );
            
            const idxOwnership = fileHeaders.findIndex(h => h === 'OWNERSHIP' || h === 'OWNER');
            const idxNopol = fileHeaders.findIndex(h => h === 'NOPOL');
            const idxYear = fileHeaders.findIndex(h => h === 'YEAR' || h === 'TAHUN');
            const idxMerk = fileHeaders.findIndex(h => h === 'MERK' || h === 'MERK KENDARAAN');
            const idxAssetType = fileHeaders.findIndex(h => h === 'ASSET TYPE' || h === 'ASSET_TYPE' || h === 'MODEL' || h === 'TIPE');
            const idxLocation = fileHeaders.findIndex(h => h === 'LOCATION' || h === 'LOKASI' || h === 'SITE LOKASI' || h === 'SITE' || h === 'BUSINESS LOCATION');
            const idxPool = fileHeaders.findIndex(h => h === 'POOL' || h === 'BUSINESS POOL');
            const idxDedicate = fileHeaders.findIndex(h => h === 'DEDICATE' || h === 'BUSINESS DEDICATE');
            
            if (idxNopol === -1) {
              setImportError(`Kolom "NOPOL" tidak ditemukan di baris pertama CSV. Header terdeteksi: [${fileHeaders.join(', ')}]. Gunakan pemisah koma (,) atau titik koma (;).`);
              return;
            }
            
            const previewData = [];
            for (let i = 1; i < rawRows.length; i++) {
              const row = rawRows[i];
              if (row.length === 1 && row[0] === '') continue;
              
              const cleanCell = (val) => {
                if (!val) return '';
                return val.trim().replace(/^["']|["']$/g, '');
              };
              
              const nopolRaw = idxNopol > -1 ? row[idxNopol] : '';
              const nopol = cleanCell(nopolRaw).toUpperCase();
              const ownership = idxOwnership > -1 && row[idxOwnership] ? cleanCell(row[idxOwnership]).toUpperCase() : 'PUNINAR';
              const year = idxYear > -1 && row[idxYear] ? cleanCell(row[idxYear]) : '';
              const merk = idxMerk > -1 && row[idxMerk] ? cleanCell(row[idxMerk]).toUpperCase() : '';
              const assetType = idxAssetType > -1 && row[idxAssetType] ? cleanCell(row[idxAssetType]).toUpperCase() : '';
              const location = idxLocation > -1 && row[idxLocation] ? cleanCell(row[idxLocation]).toUpperCase() : LOCS[0];
              const pool = idxPool > -1 && row[idxPool] ? cleanCell(row[idxPool]).toUpperCase() : POOLS[0];
              const dedicate = idxDedicate > -1 && row[idxDedicate] ? cleanCell(row[idxDedicate]).toUpperCase() : 'LOGISTICS';
              
              let status = 'BARU';
              let statusText = 'Unit baru akan didaftarkan';
              
              if (!nopol) {
                status = 'INVALID';
                statusText = 'NOPOL kosong/tidak valid';
              } else {
                const isDuplicate = units.some(u => u.nopol.toUpperCase() === nopol);
                if (isDuplicate) {
                  status = 'UPDATE';
                  statusText = 'Unit sudah ada, info kendaraan akan diperbarui';
                }
              }
              
              previewData.push({
                nopol,
                ownership,
                year,
                merk,
                assetType,
                location,
                pool,
                dedicate,
                status,
                statusText
              });
            }
            
            if (previewData.length === 0) {
              setImportError('Tidak ada baris data yang valid untuk diimpor.');
            } else {
              setImportPreviewData(previewData);
            }
          } catch (err) {
            setImportError('Gagal membaca atau memproses file CSV: ' + err.message);
          }
        };
        
        reader.onloadend = () => {
          if (e.target) e.target.value = '';
        };
        
        reader.readAsText(file);
      };

      // 4. Send updates payload to Google Sheets & sync local state
      const executeImport = async () => {
        const validItems = importPreviewData.filter(item => item.status === 'BARU' || item.status === 'UPDATE');
        if (validItems.length === 0) {
          globalAddToast('Tidak ada data valid untuk diimpor!', 'error');
          return;
        }
        
        setIsImporting(true);
        setImportProgress(0);
        
        try {
          for (let i = 0; i < validItems.length; i++) {
            const item = validItems[i];
            await syncUpdate(item.nopol, {
              OWNERSHIP: item.ownership,
              YEAR: item.year,
              MERK: item.merk,
              "ASSET TYPE": item.assetType,
              "BUSINESS LOCATION": item.location,
              "BUSINESS POOL": item.pool,
              "BUSINESS DEDICATE": item.dedicate,
              "STATUS REGISTRASI": item.status === 'BARU' ? 'BELUM DIPASANG' : undefined
            });
            setImportProgress(i + 1);
          }
          
          setUnits(prev => {
            let updatedList = [...prev];
            validItems.forEach(item => {
              const existingIdx = updatedList.findIndex(u => u.nopol === item.nopol);
              if (existingIdx > -1) {
                updatedList[existingIdx] = {
                  ...updatedList[existingIdx],
                  ownership: item.ownership,
                  year: item.year,
                  merk: item.merk,
                  assetType: item.assetType,
                  location: item.location,
                  pool: item.pool,
                  dedicate: item.dedicate
                };
              } else {
                updatedList.unshift({
                  id: Date.now() + Math.random(),
                  rowIndex: updatedList.length + 2,
                  nopol: item.nopol,
                  ownership: item.ownership,
                  year: item.year,
                  merk: item.merk,
                  assetType: item.assetType,
                  location: item.location,
                  pool: item.pool,
                  dedicate: item.dedicate,
                  easygoDicopot: 'BELUM',
                  planDate: '',
                  lokasiPasang: '',
                  picLapangan: '',
                  teknisiPelaksana: '',
                  statusPlan: 'UNPLAN',
                  statusPasang: 'BELUM DIPASANG',
                  modelGpsBaru: '',
                  gps: '', buzzer: '', sos: '', sensorWing: '', camera: '',
                  statusSystem: '', statusSuspend: '',
                  updatedAt: ''
                });
              }
            });
            return updatedList;
          });
          
          const countBaru = validItems.filter(i => i.status === 'BARU').length;
          const countUpdate = validItems.filter(i => i.status === 'UPDATE').length;
          
          globalAddToast(`Impor sukses! Berhasil memproses ${validItems.length} unit (${countBaru} baru, ${countUpdate} diperbarui).`, 'success');
          setShowImportModal(false);
          setImportPreviewData([]);
          setImportError('');
        } catch (err) {
          globalAddToast('Gagal melakukan sinkronisasi impor ke Sheets: ' + err.message, 'error');
        } finally {
          setIsImporting(false);
        }
      };

      const filtered = useMemo(() => {
        return units.filter(u => 
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc) &&
          (!poolF || u.pool === poolF) &&
          (!st || u.statusPlan === st) &&
          (!merkF || u.merk === merkF) &&
          (!assetTypeF || u.assetType === assetTypeF)
        );
      }, [units, q, loc, poolF, st, merkF, assetTypeF]);

      const total = Math.ceil(filtered.length / PAGE_LIMIT);
      const slice = filtered.slice((page - 1) * PAGE_LIMIT, page * PAGE_LIMIT);

      const save = (id, overrideData = null) => {
        const unit = units.find(u => u.id === id);
        const dataToSave = overrideData || editData;
        const newStatusPlan = dataToSave.planDate ? 'PLAN' : 'UNPLAN';
        let updatedFields = {};

        if (newStatusPlan === 'UNPLAN') {
          updatedFields = {
            planDate: '', lokasiPasang: '', picLapangan: '', teknisiPelaksana: '',
            statusPlan: 'UNPLAN', statusPasang: 'BELUM DIPASANG',
            easygoDicopot: 'BELUM', modelGpsBaru: '',
            gps: '', buzzer: '', sos: '', sensorWing: '', camera: '',
            statusSystem: '', statusSuspend: '', updatedAt: '',
            gpsSerialLama: ''
          };
          syncUpdate(unit.nopol, {
            "PLAN PASANG": '', 
            "LOKASI PASANG": '', 
            "PIC LAPANGAN": '', 
            "TEKNISI PELAKSANA": '',
            "STATUS REGISTRASI": 'BELUM DIPASANG',
            "TIPE GPS BARU": '',
            "SN GPS BARU": '',
            "IMEI GPS BARU": '',
            "NOMOR KARTU GPS BARU": '',
            "PROVIDER SIM GPS BARU": '',
            "GPS": '', "BUZZER": '', "SOS": '', "SENSOR WING": '', "CAMERA": '',
            "SN GPS LAMA": ''
          });
        } else {
          updatedFields = {
            planDate: dataToSave.planDate || '',
            lokasiPasang: dataToSave.lokasiPasang || '',
            picLapangan: dataToSave.picLapangan || '',
            teknisiPelaksana: dataToSave.teknisiPelaksana || '',
            statusPlan: newStatusPlan,
            statusPasang: 'BELUM DIPASANG',
            gpsSerialLama: dataToSave.gpsSerialLama || ''
          };
          syncUpdate(unit.nopol, {
            "PLAN PASANG": dataToSave.planDate || '',
            "LOKASI PASANG": dataToSave.lokasiPasang || '',
            "PIC LAPANGAN": dataToSave.picLapangan || '',
            "TEKNISI PELAKSANA": dataToSave.teknisiPelaksana || '',
            "STATUS REGISTRASI": 'BELUM DIPASANG',
            "SN GPS LAMA": dataToSave.gpsSerialLama || ''
          });
        }

        setUnits(prev => prev.map(u => u.id === id ? { ...u, ...updatedFields } : u));
        setSelectedUnit(null);
        globalAddToast(
          newStatusPlan === 'UNPLAN' 
            ? `Jadwal NOPOL ${unit.nopol} berhasil dihapus!` 
            : `Jadwal NOPOL ${unit.nopol} berhasil disimpan!`, 
          'success'
        );
      };

      const handleAddUnit = (e) => {
        e.preventDefault();
        const cleanNopol = newUnitData.nopol.trim().toUpperCase();
        if (!cleanNopol) {
          globalAddToast('NOPOL wajib diisi!', 'error');
          return;
        }

        const isDuplicate = units.some(u => u.nopol.toUpperCase() === cleanNopol);
        if (isDuplicate) {
          globalAddToast(`NOPOL ${cleanNopol} sudah terdaftar di database!`, 'error');
          return;
        }

        const newUnit = {
          id: Date.now(),
          rowIndex: units.length + 2,
          nopol: cleanNopol,
          ownership: newUnitData.ownership.trim().toUpperCase(),
          year: newUnitData.year.trim(),
          merk: newUnitData.merk.trim().toUpperCase(),
          assetType: newUnitData.assetType.trim().toUpperCase(),
          location: newUnitData.location,
          pool: newUnitData.pool,
          dedicate: newUnitData.dedicate.trim().toUpperCase() || 'LOGISTICS',
          easygoDicopot: 'BELUM',
          planDate: '',
          lokasiPasang: '',
          picLapangan: '',
          teknisiPelaksana: '',
          statusPlan: 'UNPLAN',
          statusPasang: 'BELUM DIPASANG',
          modelGpsBaru: '',
          gps: '', buzzer: '', sos: '', sensorWing: '', camera: '',
          statusSystem: '', statusSuspend: '',
          updatedAt: ''
        };

        setUnits(prev => [newUnit, ...prev]);
        setShowAddModal(false);
        setNewUnitData({
          nopol: '', ownership: 'PUNINAR', year: '', merk: '', assetType: '', location: LOCS[0], pool: POOLS[0], dedicate: 'LOGISTICS'
        });

        // Initialize all 39 columns correctly in spreadsheet for the new row
        syncUpdate(newUnit.nopol, {
          OWNERSHIP: newUnit.ownership,
          YEAR: newUnit.year,
          MERK: newUnit.merk,
          "ASSET TYPE": newUnit.assetType,
          "BUSINESS LOCATION": newUnit.location,
          "BUSINESS POOL": newUnit.pool,
          "BUSINESS DEDICATE": newUnit.dedicate,
          "STATUS REGISTRASI": 'BELUM DIPASANG',
          "PLAN PASANG": '',
          "LOKASI PASANG": '',
          "PIC LAPANGAN": '',
          "TEKNISI PELAKSANA": '',
          "TIPE GPS BARU": '',
          "SN GPS BARU": '',
          "IMEI GPS BARU": '',
          "NOMOR KARTU GPS BARU": '',
          "PROVIDER SIM GPS BARU": '',
          "GPS": '', "BUZZER": '', "SOS": '', "SENSOR WING": '', "CAMERA": '',
          "FOTO KENDARAAN (NOPOL)": '',
          "FOTO SERIAL GPS LAMA (DICABUT)": '',
          "FOTO GPS BARU (SN TERLIHAT)": '',
          "FOTO HASIL INSTALASI": '',
          "CEK FISIK GPS LAMA": '',
          "CEK FISIK GPS BARU": '',
          "CEK KONDISI UNIT SELESAI INSTALASI": '',
          "CEK FITUR (SENSOR, SOS, CAMERA)": '',
          "FOTO BUKTI PENYERAHAN GPS LAMA": '',
          "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT": '',
          "FOTO INTEGRASI DATA GPS KE PUNINAR": '',
          "FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR": '',
          "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT": '',
          "FOTO TERIMA FISIK GPS LAMA": '',
          "FOTO BUKTI TERMINASI GPS LAMA": ''
        });

        globalAddToast(`Unit baru ${cleanNopol} berhasil ditambahkan!`, 'success');
      };

      return (
        <div className="fade-in">
          <div className="role-banner planner">
            <i className="bi bi-calendar"></i>
            <span><strong>Role: Planner Logistics</strong> — Atur tanggal rencana migrasi, site lokasi pemasangan, dan daftarkan unit baru.</span>
          </div>


          <FilterRow>
            <div className="search-input-wrapper">
              <i className="bi bi-search"></i>
              <input type="text" value={q} onChange={e => { setQ(e.target.value); setPage(1); }} className="search-input" placeholder="Cari NOPOL..." />
            </div>
            <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Lokasi</option>
              {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
            </select>
            <select value={poolF} onChange={e => { setPoolF(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Pool</option>
              {POOLS.map(p => <option key={p} value={p}>{p}</option>)}
            </select>
            <select value={merkF} onChange={e => { setMerkF(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Merk</option>
              {uniqueMerks.map(m => <option key={m} value={m}>{m}</option>)}
            </select>
            <select value={assetTypeF} onChange={e => { setAssetTypeF(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Asset Type</option>
              {uniqueAssetTypes.map(a => <option key={a} value={a}>{a}</option>)}
            </select>
            <select value={st} onChange={e => { setSt(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Status Plan</option>
              <option value="PLAN">PLAN</option>
              <option value="UNPLAN">UNPLAN</option>
            </select>
            <button className="btn btn-primary" onClick={() => setShowAddModal(true)} title="Tambah Unit Baru">
              <i className="bi bi-plus"></i> Tambah Unit
            </button>
            <button className="btn btn-secondary" onClick={() => setShowImportModal(true)} title="Impor Massal dari CSV">
              <i className="bi bi-upload"></i> Impor CSV
            </button>
            <button className="btn btn-secondary" onClick={() => exportToCSV(filtered, 'rekap_gps_planner_filtered.csv')} title="Ekspor ke CSV">
              <i className="bi bi-download"></i> Ekspor CSV
            </button>
            <span className="unit-count-tag">{filtered.length} Unit ditemukan</span>
          </FilterRow>

          <>
              {isMobile ? (
                <div style={{ display: 'flex', flexDirection: 'column', gap: 12, marginTop: 10 }}>
                  {slice.map((u, i) => (
                    <div key={u.id} className="mobile-unit-card" style={{ padding: 14 }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                        <strong style={{ fontSize: 15 }}>{u.nopol}</strong>
                        <Badge val={u.statusPlan} />
                      </div>
                      
                      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8, fontSize: 11, color: 'var(--text-secondary)', marginTop: 8 }}>
                        <div>Ownership: <strong>{u.ownership || '—'}</strong></div>
                        <div>Year: <strong>{u.year || '—'}</strong></div>
                        <div>Merk: <strong>{u.merk || '—'}</strong></div>
                        <div>Asset Type: <strong>{u.assetType || '—'}</strong></div>
                        <div>Site: <strong>{u.location}</strong></div>
                        <div>Pool: <strong>{u.pool}</strong></div>
                        <div style={{ gridColumn: 'span 2' }}>Dedicate: <strong>{u.dedicate || '—'}</strong></div>
                        <div style={{ gridColumn: 'span 2', borderTop: '1px solid var(--border-color)', paddingTop: 6, marginTop: 4 }}>
                          Rencana Tanggal: <strong>{u.planDate || 'Belum diplan'}</strong>
                        </div>
                        <div style={{ gridColumn: 'span 2' }}>
                          Pool Pasang: <strong>{u.lokasiPasang || '—'}</strong>
                        </div>
                        <div>PIC Lapangan: <strong>{u.picLapangan || '—'}</strong></div>
                        <div>Teknisi: <strong>{u.teknisiPelaksana || '—'}</strong></div>
                        <div style={{ gridColumn: 'span 2' }}>GPS Lama: <strong>{u.gpsSerialLama || '—'}</strong></div>
                      </div>

                      <div style={{ marginTop: 12, display: 'flex', gap: 8 }}>
                        {u.statusPlan === 'PLAN' ? (
                          <button 
                            className="btn btn-secondary btn-sm" 
                            onClick={() => { 
                              setSelectedUnit(u); 
                              setEditData({ planDate: u.planDate, lokasiPasang: u.lokasiPasang, picLapangan: u.picLapangan || '', teknisiPelaksana: u.teknisiPelaksana || '', gpsSerialLama: u.gpsSerialLama || '' }); 
                            }}
                            style={{ flex: 1, justifyContent: 'center', height: 36 }}
                          >
                            <i className="bi bi-eye"></i> Jadwal
                          </button>
                        ) : (
                          <button 
                            className="btn btn-primary btn-sm" 
                            onClick={() => { 
                              setSelectedUnit(u); 
                              setEditData({ planDate: u.planDate, lokasiPasang: u.lokasiPasang, picLapangan: u.picLapangan || '', teknisiPelaksana: u.teknisiPelaksana || '', gpsSerialLama: u.gpsSerialLama || '' }); 
                            }}
                            style={{ flex: 1, justifyContent: 'center', height: 36 }}
                          >
                            <i className="bi bi-calendar-plus"></i> Plan
                          </button>
                        )}
                        {u.statusPasang === 'DONE' && (
                          <button 
                            type="button"
                            className="btn btn-secondary btn-sm"
                            onClick={() => downloadDOCReport(u, true)}
                            style={{ width: 44, justifyContent: 'center', height: 36, display: 'inline-flex', alignItems: 'center' }}
                            title="Unduh Laporan Word (.doc)"
                          >
                            <i className="bi bi-file-earmark-word" style={{ color: '#2B579A' }}></i>
                          </button>
                        )}
                      </div>
                    </div>
                  ))}
                  {slice.length === 0 && (
                    <div style={{ textAlign: 'center', padding: 32, color: 'var(--text-tertiary)' }}>Tidak ada data unit yang sesuai filter</div>
                  )}
                </div>
              ) : (
                <div className="table-container">
                  <table className="data-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>NOPOL</th>
                        <th>MERK / TIPE</th>
                        <th>LOKASI</th>
                        <th>POOL</th>
                        <th className="text-center">STATUS PLAN</th>
                        <th>PLAN PASANG</th>
                        <th>TEKNISI</th>
                        <th>GPS LAMA</th>
                        <th style={{width: 140}}>AKSI</th>
                      </tr>
                    </thead>
                    <tbody>
                      {slice.map((u, i) => (
                        <tr key={u.id}>
                          <td className="text-muted">{(page - 1) * PAGE_LIMIT + i + 1}</td>
                          <td><strong>{u.nopol}</strong></td>
                          <td>{u.merk ? `${u.merk} ${u.assetType || ''}`.trim() : <span style={{color:'var(--text-tertiary)'}}>—</span>}</td>
                          <td>{u.location}</td>
                          <td>{u.pool}</td>
                          <td className="text-center"><Badge val={u.statusPlan} /></td>
                          <td>{u.planDate || <span style={{color:'var(--text-tertiary)'}}>Belum diplan</span>}</td>
                          <td>{u.teknisiPelaksana || <span style={{color:'var(--text-tertiary)'}}>—</span>}</td>
                          <td>{u.gpsSerialLama || <span style={{color:'var(--text-tertiary)'}}>—</span>}</td>
                          <td>
                            <div style={{ display: 'flex', gap: 6 }}>
                              {u.statusPlan === 'PLAN' ? (
                                <button 
                                  className="btn btn-secondary btn-sm" 
                                  onClick={() => { 
                                    setSelectedUnit(u); 
                                    setEditData({ planDate: u.planDate, lokasiPasang: u.lokasiPasang, picLapangan: u.picLapangan || '', teknisiPelaksana: u.teknisiPelaksana || '', gpsSerialLama: u.gpsSerialLama || '' }); 
                                  }}
                                  title="Lihat Rincian Jadwal"
                                  style={{ display: 'inline-flex', alignItems: 'center', gap: 4, flex: 1 }}
                                >
                                  <i className="bi bi-eye" style={{ fontSize: 13 }}></i> Jadwal
                                </button>
                              ) : (
                                <button 
                                  className="btn btn-primary btn-sm" 
                                  onClick={() => { 
                                    setSelectedUnit(u); 
                                    setEditData({ planDate: u.planDate, lokasiPasang: u.lokasiPasang, picLapangan: u.picLapangan || '', teknisiPelaksana: u.teknisiPelaksana || '', gpsSerialLama: u.gpsSerialLama || '' }); 
                                  }}
                                  title="Buat Jadwal Baru"
                                  style={{ display: 'inline-flex', alignItems: 'center', gap: 4, flex: 1 }}
                                >
                                  <i className="bi bi-calendar-plus" style={{ fontSize: 13 }}></i> Plan
                                </button>
                              )}
                              {u.statusPasang === 'DONE' && (
                                <button
                                  type="button"
                                  className="btn btn-secondary btn-sm"
                                  onClick={() => downloadDOCReport(u, true)}
                                  title="Unduh Laporan Word (.doc)"
                                  style={{ padding: '0 8px', height: 28, display: 'inline-flex', alignItems: 'center', justifyContent: 'center' }}
                                >
                                  <i className="bi bi-file-earmark-word" style={{ fontSize: 13, color: '#2B579A' }}></i>
                                </button>
                              )}
                            </div>
                          </td>
                        </tr>
                      ))}
                      {slice.length === 0 && (
                        <tr>
                          <td colSpan="10" style={{ textAlign: 'center', padding: 32, color: 'var(--text-tertiary)' }}>Tidak ada data unit yang sesuai filter</td>
                        </tr>
                      )}
                    </tbody>
                  </table>
                </div>
              )}
              
              <Pager page={page} total={total} onChange={p => setPage(Math.max(1, Math.min(p, total)))} />
            </>

          {/* Modal Tambah Unit Baru */}
          {showAddModal && (
            <div className="modal-overlay" onClick={() => setShowAddModal(false)}>
              <div className="modal-card" onClick={e => e.stopPropagation()}>
                <div className="modal-drag-handle"></div>
                <div className="modal-header">
                  <span className="modal-title">Tambah Unit Baru</span>
                  <button className="modal-close" onClick={() => setShowAddModal(false)}><i className="bi bi-x"></i></button>
                </div>
                <form onSubmit={handleAddUnit}>
                  <div className="modal-body">
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
                      <div className="input-group">
                        <label className="input-label">Ownership</label>
                        {!isCustomOwnership ? (
                          <select 
                            value={newUnitData.ownership} 
                            onChange={e => {
                              if (e.target.value === '__NEW__') {
                                setIsCustomOwnership(true);
                                setNewUnitData(d => ({ ...d, ownership: '' }));
                              } else {
                                setNewUnitData(d => ({ ...d, ownership: e.target.value }));
                              }
                            }} 
                            className="filter-select" 
                            style={{width:'100%', height:'38px'}} 
                            required
                          >
                            <option value="">— Pilih Ownership —</option>
                            {uniqueOwnerships.map(o => <option key={o} value={o}>{o}</option>)}
                            <option value="__NEW__">+ Tambah Ownership Baru...</option>
                          </select>
                        ) : (
                          <div style={{ display: 'flex', gap: 6 }}>
                            <input 
                              type="text" 
                              value={newUnitData.ownership} 
                              onChange={e => setNewUnitData(d => ({ ...d, ownership: e.target.value }))} 
                              className="input-field" 
                              placeholder="Ketik Ownership Baru" 
                              required 
                              autoFocus 
                            />
                            <button 
                              type="button" 
                              className="btn btn-secondary btn-sm" 
                              onClick={() => {
                                setIsCustomOwnership(false);
                                setNewUnitData(d => ({ ...d, ownership: 'PUNINAR' }));
                              }}
                              style={{ padding: '0 8px', height: '38px', minWidth: '38px' }}
                              title="Pilih dari daftar"
                            >
                              <i className="bi bi-list"></i>
                            </button>
                          </div>
                        )}
                      </div>
                      <div className="input-group">
                        <label className="input-label">NOPOL (Nomor Polisi)</label>
                        <input type="text" value={newUnitData.nopol} onChange={e => setNewUnitData(d => ({ ...d, nopol: e.target.value }))} className="input-field" placeholder="cth. B 1234 PQR" required autoFocus />
                      </div>
                    </div>

                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
                      <div className="input-group">
                        <label className="input-label">Tahun (Year)</label>
                        <input type="text" value={newUnitData.year} onChange={e => setNewUnitData(d => ({ ...d, year: e.target.value }))} className="input-field" placeholder="cth. 2018" />
                      </div>
                      <div className="input-group">
                        <label className="input-label">Merk Kendaraan</label>
                        {!isCustomMerk ? (
                          <select 
                            value={newUnitData.merk} 
                            onChange={e => {
                              if (e.target.value === '__NEW__') {
                                setIsCustomMerk(true);
                                setNewUnitData(d => ({ ...d, merk: '' }));
                              } else {
                                setNewUnitData(d => ({ ...d, merk: e.target.value }));
                              }
                            }} 
                            className="filter-select" 
                            style={{width:'100%', height:'38px'}} 
                            required
                          >
                            <option value="">— Pilih Merk —</option>
                            {uniqueMerks.map(m => <option key={m} value={m}>{m}</option>)}
                            <option value="__NEW__">+ Tambah Merk Baru...</option>
                          </select>
                        ) : (
                          <div style={{ display: 'flex', gap: 6 }}>
                            <input 
                              type="text" 
                              value={newUnitData.merk} 
                              onChange={e => setNewUnitData(d => ({ ...d, merk: e.target.value }))} 
                              className="input-field" 
                              placeholder="Ketik Merk Baru" 
                              required 
                              autoFocus 
                            />
                            <button 
                              type="button" 
                              className="btn btn-secondary btn-sm" 
                              onClick={() => {
                                setIsCustomMerk(false);
                                setNewUnitData(d => ({ ...d, merk: '' }));
                              }}
                              style={{ padding: '0 8px', height: '38px', minWidth: '38px' }}
                              title="Pilih dari daftar"
                            >
                              <i className="bi bi-list"></i>
                            </button>
                          </div>
                        )}
                      </div>
                    </div>
                    
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
                      <div className="input-group">
                        <label className="input-label">Asset Type</label>
                        {!isCustomAssetType ? (
                          <select 
                            value={newUnitData.assetType} 
                            onChange={e => {
                              if (e.target.value === '__NEW__') {
                                setIsCustomAssetType(true);
                                setNewUnitData(d => ({ ...d, assetType: '' }));
                              } else {
                                setNewUnitData(d => ({ ...d, assetType: e.target.value }));
                              }
                            }} 
                            className="filter-select" 
                            style={{width:'100%', height:'38px'}} 
                            required
                          >
                            <option value="">— Pilih Asset Type —</option>
                            {uniqueAssetTypes.map(m => <option key={m} value={m}>{m}</option>)}
                            <option value="__NEW__">+ Tambah Asset Type Baru...</option>
                          </select>
                        ) : (
                          <div style={{ display: 'flex', gap: 6 }}>
                            <input 
                              type="text" 
                              value={newUnitData.assetType} 
                              onChange={e => setNewUnitData(d => ({ ...d, assetType: e.target.value }))} 
                              className="input-field" 
                              placeholder="Ketik Asset Type Baru" 
                              required 
                              autoFocus 
                            />
                            <button 
                              type="button" 
                              className="btn btn-secondary btn-sm" 
                              onClick={() => {
                                setIsCustomAssetType(false);
                                setNewUnitData(d => ({ ...d, assetType: '' }));
                              }}
                              style={{ padding: '0 8px', height: '38px', minWidth: '38px' }}
                              title="Pilih dari daftar"
                            >
                              <i className="bi bi-list"></i>
                            </button>
                          </div>
                        )}
                      </div>
                      <div className="input-group">
                        <label className="input-label">Site Lokasi</label>
                        <select value={newUnitData.location} onChange={e => setNewUnitData(d => ({ ...d, location: e.target.value }))} className="filter-select" style={{width:'100%', height:'38px'}}>
                          {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                        </select>
                      </div>
                    </div>

                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
                      <div className="input-group">
                        <label className="input-label">Pool</label>
                        <select value={newUnitData.pool} onChange={e => setNewUnitData(d => ({ ...d, pool: e.target.value }))} className="filter-select" style={{width:'100%', height:'38px'}}>
                          {POOLS.map(p => <option key={p} value={p}>{p}</option>)}
                        </select>
                      </div>
                      <div className="input-group">
                        <label className="input-label">Dedicate</label>
                        {!isCustomDedicate ? (
                          <select 
                            value={newUnitData.dedicate} 
                            onChange={e => {
                              if (e.target.value === '__NEW__') {
                                setIsCustomDedicate(true);
                                setNewUnitData(d => ({ ...d, dedicate: '' }));
                              } else {
                                setNewUnitData(d => ({ ...d, dedicate: e.target.value }));
                              }
                            }} 
                            className="filter-select" 
                            style={{width:'100%', height:'38px'}} 
                            required
                          >
                            <option value="">— Pilih Dedicate —</option>
                            {uniqueDedicates.map(d => <option key={d} value={d}>{d}</option>)}
                            <option value="__NEW__">+ Tambah Dedicate Baru...</option>
                          </select>
                        ) : (
                          <div style={{ display: 'flex', gap: 6 }}>
                            <input 
                              type="text" 
                              value={newUnitData.dedicate} 
                              onChange={e => setNewUnitData(d => ({ ...d, dedicate: e.target.value }))} 
                              className="input-field" 
                              placeholder="Ketik Dedicate Baru" 
                              required 
                              autoFocus 
                            />
                            <button 
                              type="button" 
                              className="btn btn-secondary btn-sm" 
                              onClick={() => {
                                setIsCustomDedicate(false);
                                setNewUnitData(d => ({ ...d, dedicate: '' }));
                              }}
                              style={{ padding: '0 8px', height: '38px', minWidth: '38px' }}
                              title="Pilih dari daftar"
                            >
                              <i className="bi bi-list"></i>
                            </button>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                  <div className="modal-footer">
                    <button type="button" className="btn btn-secondary" onClick={() => setShowAddModal(false)}>Batal</button>
                    <button type="submit" className="btn btn-primary">Simpan Unit</button>
                  </div>
                </form>
              </div>
            </div>
          )}

          {/* Modal Buat Jadwal Pemasangan */}
          {selectedUnit && (
            <div className="modal-overlay" onClick={() => setSelectedUnit(null)}>
              <div className="modal-card" onClick={e => e.stopPropagation()}>
                <div className="modal-drag-handle"></div>
                <div className="modal-header">
                  <span className="modal-title">
                    {selectedUnit.statusPlan === 'PLAN' ? (
                      <>
                        <i className="bi bi-eye" style={{ marginRight: 6, color: 'var(--text-secondary)' }}></i>
                        Lihat/Edit Jadwal Pemasangan
                      </>
                    ) : (
                      <>
                        <i className="bi bi-calendar-plus" style={{ marginRight: 6, color: 'var(--accent)' }}></i>
                        Buat Jadwal Pemasangan
                      </>
                    )}
                  </span>
                  <button className="modal-close" onClick={() => setSelectedUnit(null)}><i className="bi bi-x"></i></button>
                </div>
                <form onSubmit={(e) => { e.preventDefault(); save(selectedUnit.id); }}>
                  <div className="modal-body">
                    <div className="input-group">
                      <label className="input-label">Nomor Polisi (NOPOL)</label>
                      <input type="text" value={selectedUnit.nopol} className="input-field" disabled style={{ background: 'var(--bg-secondary)', fontWeight: 'bold' }} />
                    </div>

                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, marginBottom: 16, padding: 12, background: 'var(--bg-secondary)', borderRadius: 'var(--radius-md)', fontSize: 12 }}>
                      <div>
                        <span style={{ color: 'var(--text-secondary)' }}>Ownership / Year:</span>
                        <div style={{ fontWeight: 600 }}>{selectedUnit.ownership || '—'} / {selectedUnit.year || '—'}</div>
                      </div>
                      <div>
                        <span style={{ color: 'var(--text-secondary)' }}>Merk / Asset Type:</span>
                        <div style={{ fontWeight: 600 }}>{selectedUnit.merk || '—'} / {selectedUnit.assetType || '—'}</div>
                      </div>
                      <div style={{ gridColumn: 'span 2', marginTop: 4 }}>
                        <span style={{ color: 'var(--text-secondary)' }}>Site Location / Pool / Dedicate:</span>
                        <div style={{ fontWeight: 600 }}>{selectedUnit.location} / {selectedUnit.pool} / {selectedUnit.dedicate || '—'}</div>
                      </div>
                    </div>

                    <div className="input-group">
                      <label className="input-label">Tanggal Rencana Pemasangan</label>
                      <input 
                        type="date" 
                        value={toISODate(editData.planDate || '')} 
                        onChange={e => setEditData(d => ({ ...d, planDate: fromISODate(e.target.value) }))} 
                        className="input-field" 
                        required 
                      />
                    </div>

                    <div className="input-group">
                      <label className="input-label">Pool Pemasangan (Lokasi Pasang)</label>
                      <select 
                        value={editData.lokasiPasang || ''} 
                        onChange={e => setEditData(d => ({ ...d, lokasiPasang: e.target.value }))} 
                        className="filter-select" 
                        style={{ width: '100%', height: '38px' }}
                        required
                      >
                        <option value="">— Pilih Pool Pemasangan —</option>
                        {LOKASI_OPTS.map(o => <option key={o} value={o}>{o}</option>)}
                      </select>
                    </div>

                    <div className="input-group">
                      <label className="input-label">PIC Lapangan <span style={{ fontWeight: 400, color: 'var(--text-tertiary)', fontSize: 10 }}>(opsional — PIC bisa klaim sendiri)</span></label>
                      <select 
                        value={editData.picLapangan || ''} 
                        onChange={e => setEditData(d => ({ ...d, picLapangan: e.target.value }))} 
                        className="filter-select" 
                        style={{ width: '100%', height: '38px' }}
                      >
                        <option value="">— Belum ditentukan (PIC klaim sendiri) —</option>
                        {pics.map(p => <option key={p.id} value={p.name}>{p.name}</option>)}
                      </select>
                    </div>

                    <div className="input-group">
                      <label className="input-label">Teknisi Pelaksana</label>
                      <select 
                        value={editData.teknisiPelaksana || ''} 
                        onChange={e => setEditData(d => ({ ...d, teknisiPelaksana: e.target.value }))} 
                        className="filter-select" 
                        style={{ width: '100%', height: '38px' }}
                      >
                        <option value="">— Pilih Pilih Teknisi (Opsional) —</option>
                        {technicians.map(t => <option key={t.id} value={t.name}>{t.name}</option>)}
                      </select>
                    </div>

                    <div className="input-group">
                      <label className="input-label">No GPS Lama (Dicabut)</label>
                      <input 
                        type="text" 
                        value={editData.gpsSerialLama || ''} 
                        onChange={e => setEditData(d => ({ ...d, gpsSerialLama: e.target.value }))} 
                        className="input-field" 
                        placeholder="Contoh: EG-12345 (Opsional)"
                      />
                    </div>
                  </div>
                  <div className="modal-footer">
                    <button type="button" className="btn btn-secondary" onClick={() => setSelectedUnit(null)}>Batal</button>
                    {selectedUnit.planDate && (
                      <button 
                        type="button" 
                        className="btn btn-danger" 
                        onClick={() => {
                          if (confirm(`Apakah Anda yakin ingin menghapus jadwal untuk NOPOL ${selectedUnit.nopol}?`)) {
                            save(selectedUnit.id, { planDate: '', lokasiPasang: '', picLapangan: '', teknisiPelaksana: '', gpsSerialLama: '' });
                          }
                        }}
                        style={{ marginRight: 'auto' }}
                      >
                        Hapus Jadwal
                      </button>
                    )}
                    {selectedUnit.statusPasang === 'DONE' && (
                      <button 
                        type="button" 
                        className="btn btn-secondary"
                        onClick={() => downloadDOCReport(selectedUnit, true)}
                        style={{ display: 'inline-flex', alignItems: 'center', gap: 6, marginLeft: selectedUnit.planDate ? 0 : 'auto' }}
                        title="Unduh Laporan Word (.doc)"
                      >
                        <i className="bi bi-file-earmark-word" style={{ color: '#2B579A' }}></i> Unduh Word
                      </button>
                    )}
                    <button type="submit" className="btn btn-primary">Simpan Jadwal</button>
                  </div>
                </form>
              </div>
            </div>
          )}

          {/* Modal Impor Data Massal (CSV) */}
          {showImportModal && (
            <div className="modal-overlay" onClick={() => { if (!isImporting) setShowImportModal(false); }}>
              <div className="modal-card" style={{ maxWidth: 650 }} onClick={e => e.stopPropagation()}>
                <div className="modal-drag-handle"></div>
                <div className="modal-header">
                  <span className="modal-title">Impor Massal Data Kendaraan</span>
                  <button className="modal-close" disabled={isImporting} onClick={() => { setShowImportModal(false); setImportPreviewData([]); setImportError(''); }}><i className="bi bi-x"></i></button>
                </div>
                <div className="modal-body">
                  <span style={{ fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 6 }}>Langkah 1: Format & Unduh Template</span>
                  <p className="text-muted" style={{ fontSize: 11, marginBottom: 8 }}>
                    Format file impor wajib menggunakan file CSV dengan baris pertama berupa nama kolom (headers) berikut:
                  </p>
                  
                  <div className="import-instruction-list">
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>OWNERSHIP</strong> (cth: PUNINAR)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>NOPOL</strong> (wajib, cth: B 1234 XYZ)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>YEAR</strong> (cth: 2018)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>MERK</strong> (cth: MITSUBISHI)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>ASSET TYPE</strong> (cth: FUSO)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>LOCATION</strong> (cth: JAKARTA, SUBANG)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>POOL</strong> (cth: POOL A)</span>
                    </div>
                    <div className="import-instruction-item">
                      <i className="bi bi-check-circle"></i>
                      <span><strong>DEDICATE</strong> (cth: LOGISTICS)</span>
                    </div>
                  </div>
                  
                  <button type="button" className="btn btn-secondary btn-sm" onClick={downloadCSVTemplate} style={{ marginBottom: 16 }}>
                    <i className="bi bi-download"></i> Unduh Template CSV (.csv)
                  </button>
                  
                  <span style={{ fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 6 }}>Langkah 2: Unggah File CSV</span>
                  
                  <div 
                    className={`csv-dropzone ${dragActive ? 'drag-active' : ''}`}
                    onDragEnter={e => { e.preventDefault(); e.stopPropagation(); setDragActive(true); }}
                    onDragOver={e => { e.preventDefault(); e.stopPropagation(); setDragActive(true); }}
                    onDragLeave={e => { e.preventDefault(); e.stopPropagation(); setDragActive(false); }}
                    onDrop={e => {
                      e.preventDefault();
                      e.stopPropagation();
                      setDragActive(false);
                      if (isImporting) return;
                      const file = e.dataTransfer.files?.[0];
                      if (file) {
                        const fakeEvent = { target: { files: [file] } };
                        handleCSVUpload(fakeEvent);
                      }
                    }}
                    onClick={() => { if (!isImporting) document.getElementById('csv-file-input').click(); }}
                  >
                    <i className="bi bi-cloud-upload"></i>
                    <span className="csv-dropzone-text">Tarik & lepas file CSV Anda di sini, atau klik untuk memilih file</span>
                    <span className="csv-dropzone-subtext">Hanya menerima format file .csv (UTF-8)</span>
                    <input 
                      type="file" 
                      id="csv-file-input" 
                      accept=".csv" 
                      onChange={handleCSVUpload} 
                      style={{ display: 'none' }} 
                      disabled={isImporting}
                    />
                  </div>
                  
                  {importError && (
                    <div className="toast error" style={{ position: 'static', marginTop: 12, width: '100%', display: 'flex', boxShadow: 'none' }}>
                      <i className="bi bi-exclamation-triangle" style={{ fontSize: 18, marginRight: 8 }}></i>
                      <span>{importError}</span>
                    </div>
                  )}
                  
                  {importPreviewData.length > 0 && (
                    <div style={{ marginTop: 16 }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 8 }}>
                        <span style={{ fontSize: 12, fontWeight: 600 }}>Pratinjau Impor ({importPreviewData.length} baris)</span>
                        <button className="btn btn-secondary btn-sm" disabled={isImporting} onClick={() => setImportPreviewData([])}>Bersihkan</button>
                      </div>
                      
                      <div style={{ maxHeight: 200, overflowY: 'auto', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-sm)' }}>
                        <table className="data-table" style={{ fontSize: 11, margin: 0 }}>
                          <thead>
                            <tr style={{ background: 'var(--bg-secondary)', position: 'sticky', top: 0, zIndex: 1 }}>
                              <th>NOPOL</th>
                              <th>OWNERSHIP</th>
                              <th>YEAR</th>
                              <th>MERK</th>
                              <th>ASSET TYPE</th>
                              <th>LOKASI</th>
                              <th>STATUS</th>
                            </tr>
                          </thead>
                          <tbody>
                            {importPreviewData.map((row, idx) => (
                              <tr key={idx} style={{ opacity: row.status === 'INVALID' ? 0.6 : 1 }}>
                                <td><strong>{row.nopol || '—'}</strong></td>
                                <td>{row.ownership || '—'}</td>
                                <td>{row.year || '—'}</td>
                                <td>{row.merk || '—'}</td>
                                <td>{row.assetType || '—'}</td>
                                <td>{row.location} ({row.pool})</td>
                                <td>
                                  <span className={`badge ${row.status === 'BARU' ? 'success' : row.status === 'UPDATE' ? 'primary' : 'danger'}`} style={{ fontSize: 9, padding: '2px 6px' }}>
                                    {row.status}
                                  </span>
                                </td>
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                      
                      {isImporting ? (
                        <div style={{ marginTop: 14 }}>
                          <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 11, marginBottom: 4 }}>
                            <span>Sedang mengimpor data ke cloud...</span>
                            <strong>{importProgress} / {importPreviewData.filter(item => item.status === 'BARU' || item.status === 'UPDATE').length}</strong>
                          </div>
                          <div style={{ height: 6, background: 'var(--bg-secondary)', borderRadius: 3, overflow: 'hidden' }}>
                            <div 
                              style={{ 
                                width: `${Math.round((importProgress / importPreviewData.filter(item => item.status === 'BARU' || item.status === 'UPDATE').length) * 100)}%`, 
                                height: '100%', 
                                background: 'var(--accent)',
                                transition: 'width 0.2s ease'
                              }} 
                            />
                          </div>
                        </div>
                      ) : (
                        <button 
                          type="button" 
                          className="btn btn-primary" 
                          onClick={executeImport} 
                          style={{ width: '100%', marginTop: 14, justifyContent: 'center', height: 40 }}
                        >
                          <i className="bi bi-upload"></i> Proses & Impor {importPreviewData.filter(item => item.status === 'BARU' || item.status === 'UPDATE').length} Unit
                        </button>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>
          )}
        </div>
      );
    }

    // 2.5 Progress Monitoring View
    function ProgressMonitoringView({ units, isMobile }) {
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');
      const [poolF, setPoolF] = useState('');
      const [st, setSt] = useState('');
      const [merkF, setMerkF] = useState('');
      const [assetTypeF, setAssetTypeF] = useState('');
      const [page, setPage] = useState(1);
      const PAGE_LIMIT = 50;

      const uniqueMerks = useMemo(() => {
        return [...new Set(units.map(u => u.merk).filter(Boolean))].sort();
      }, [units]);

      const uniqueAssetTypes = useMemo(() => {
        return [...new Set(units.map(u => u.assetType).filter(Boolean))].sort();
      }, [units]);

      const workflowStages = [
        { name: 'UNPLAN', label: 'Unplan' },
        { name: 'PLAN', label: 'Plan' },
        { name: 'INSTALLATION', label: 'Installing' },
        { name: 'TEKNISI_SUBMITTED', label: 'Teknisi' },
        { name: 'PIC_VERIFIED', label: 'PIC' },
        { name: 'IT_VERIFIED', label: 'IT' },
        { name: 'CMT', label: 'CMT' },
        { name: 'COMPLETED', label: 'Done' }
      ];

      const getUnitCurrentStage = (u) => {
        if (u.statusPlan === 'UNPLAN') return 'UNPLAN';
        if (u.statusPasang === 'ON PROGRESS') return 'INSTALLATION';
        if (u.statusPasang === 'TEKNISI SUBMITTED') return 'TEKNISI_SUBMITTED';
        if (u.statusPasang === 'PIC VERIFIED') return 'PIC_VERIFIED';
        if (u.statusPasang === 'IT VERIFIED') return 'IT_VERIFIED';
        if (u.statusPasang === 'CMT PENDING') return 'CMT';
        if (u.statusPasang === 'DONE') return 'COMPLETED';
        return 'PLAN';
      };

      const getStageStatus = (currentStage, stageName) => {
        const order = ['UNPLAN', 'PLAN', 'INSTALLATION', 'TEKNISI_SUBMITTED', 'PIC_VERIFIED', 'IT_VERIFIED', 'CMT', 'COMPLETED'];
        const currentIndex = order.indexOf(currentStage);
        const stageNameIndex = order.indexOf(stageName);
        if (currentIndex === stageNameIndex) return 'active';
        if (stageNameIndex < currentIndex) return 'past';
        return 'future';
      };

      const renderStageCell = (currentStage, stageName) => {
        const status = getStageStatus(currentStage, stageName);
        
        if (status === 'active') {
          let colorClass = 'progress-dot active';
          if (currentStage === 'INSTALLATION' || currentStage === 'TEKNISI_SUBMITTED') {
            colorClass = 'progress-dot warning animate-pulse';
          } else if (currentStage === 'COMPLETED') {
            colorClass = 'progress-dot success';
          } else {
            colorClass = 'progress-dot primary animate-pulse';
          }
          return (
            <span className={colorClass} title={`Sedang di tahap: ${stageName}`} />
          );
        }
        if (status === 'past') {
          return (
            <span className="progress-dot past" title={`Selesai: ${stageName}`} />
          );
        }
        return (
          <span className="progress-dot future" title={`Antrean: ${stageName}`} />
        );
      };

      const getLastActivityNote = (u) => {
        const stage = getUnitCurrentStage(u);
        switch (stage) {
          case 'UNPLAN':
            return { activity: 'Belum Plan', notes: 'Menunggu pembuatan jadwal pemasangan.' };
          case 'PLAN':
            return { activity: 'Jadwal Dibuat', notes: `Rencana pasang: ${u.planDate} di ${u.lokasiPasang || '—'}.` };
          case 'INSTALLATION':
            return { activity: 'Instalasi Lapangan', notes: `Sedang dipasang oleh ${u.teknisiPelaksana || 'Teknisi'}.` };
          case 'TEKNISI_SUBMITTED':
            return { activity: 'Verifikasi PIC', notes: `Instalasi selesai. Menunggu verifikasi PIC Lapangan (${u.picLapangan || '—'}).` };
          case 'PIC_VERIFIED':
            return { activity: 'Verifikasi IT', notes: 'Fisik OK. Menunggu verifikasi integrasi IT Puninar.' };
          case 'IT_VERIFIED':
            return { activity: 'Verifikasi CMT', notes: 'Integrasi data OK. Menunggu verifikasi final CMT (Terminasi).' };
          case 'COMPLETED':
            return { activity: 'Migrasi Selesai', notes: 'Unit aktif penuh dan vendor lama sudah diterminasi.' };
          default:
            return { activity: 'Update Data', notes: u.updatedAt ? `Pembaruan terakhir pada ${u.updatedAt}` : 'Data terdaftar.' };
        }
      };

      const filtered = useMemo(() => {
        return units.filter(u => 
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc) &&
          (!poolF || u.pool === poolF) &&
          (!st || getUnitCurrentStage(u) === st) &&
          (!merkF || u.merk === merkF) &&
          (!assetTypeF || u.assetType === assetTypeF)
        );
      }, [units, q, loc, poolF, st, merkF, assetTypeF]);

      const total = Math.ceil(filtered.length / PAGE_LIMIT);
      const slice = filtered.slice((page - 1) * PAGE_LIMIT, page * PAGE_LIMIT);

      return (
        <div className="fade-in">
          <div className="role-banner verifikasi">
            <i className="ti ti-activity" style={{ fontSize: 18 }}></i>
            <span><strong>Progress Monitoring Matrix</strong> — Pantau status migrasi GPS setiap unit secara real-time dari Unplan hingga Done.</span>
          </div>

          <FilterRow>
            <div className="search-input-wrapper">
              <i className="bi bi-search"></i>
              <input type="text" value={q} onChange={e => { setQ(e.target.value); setPage(1); }} className="search-input" placeholder="Cari NOPOL..." />
            </div>
            <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Lokasi</option>
              {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
            </select>
            <select value={poolF} onChange={e => { setPoolF(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Pool</option>
              {POOLS.map(p => <option key={p} value={p}>{p}</option>)}
            </select>
            <select value={merkF} onChange={e => { setMerkF(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Merk</option>
              {uniqueMerks.map(m => <option key={m} value={m}>{m}</option>)}
            </select>
            <select value={assetTypeF} onChange={e => { setAssetTypeF(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Asset Type</option>
              {uniqueAssetTypes.map(a => <option key={a} value={a}>{a}</option>)}
            </select>
            <select value={st} onChange={e => { setSt(e.target.value); setPage(1); }} className="filter-select">
              <option value="">Semua Tahap</option>
              {workflowStages.map(ws => <option key={ws.name} value={ws.name}>{ws.label}</option>)}
            </select>
            <button className="btn btn-secondary" onClick={() => exportToCSV(filtered, 'monitoring_progress_gps.csv')} title="Ekspor ke CSV" style={{ marginLeft: 'auto' }}>
              <i className="bi bi-download"></i> Ekspor CSV
            </button>
            <span className="unit-count-tag">{filtered.length} Unit</span>
          </FilterRow>

          {isMobile ? (
            <div style={{ display: 'flex', flexDirection: 'column', gap: 12, marginTop: 10 }}>
              {slice.map((u) => {
                const currentStage = getUnitCurrentStage(u);
                const lastNote = getLastActivityNote(u);
                const stageIndex = workflowStages.findIndex(s => s.name === currentStage);
                const pct = Math.round(((stageIndex + 1) / workflowStages.length) * 100);
                
                return (
                  <div key={u.id} className="mobile-unit-card" style={{ padding: 14 }}>
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                      <div>
                        <strong>{u.nopol}</strong>
                        <div style={{ fontSize: '10px', color: 'var(--text-secondary)' }}>
                          {u.pool} • Site {u.location}
                        </div>
                      </div>
                      <Badge val={currentStage === 'COMPLETED' ? 'DONE' : currentStage === 'INSTALLATION' ? 'ON PROGRESS' : currentStage} />
                    </div>

                    <div style={{ marginTop: 10 }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 10, color: 'var(--text-secondary)', marginBottom: 4 }}>
                        <span>Progress Migrasi</span>
                        <strong>{stageIndex + 1} / {workflowStages.length} Tahap ({pct}%)</strong>
                      </div>
                      <div style={{ height: 6, background: 'var(--bg-secondary)', borderRadius: 3, overflow: 'hidden' }}>
                        <div style={{ width: `${pct}%`, height: '100%', background: currentStage === 'COMPLETED' ? 'var(--color-done)' : 'var(--accent)' }} />
                      </div>
                    </div>

                    <div style={{ borderTop: '1px dashed var(--border-color)', paddingTop: 10, marginTop: 10, fontSize: 11 }}>
                      <span style={{ fontWeight: 700, color: 'var(--text-primary)' }}>{lastNote.activity}: </span>
                      <span style={{ color: 'var(--text-secondary)' }}>{lastNote.notes}</span>
                    </div>
                  </div>
                );
              })}
              {slice.length === 0 && (
                <div style={{ textAlign: 'center', padding: 32, color: 'var(--text-tertiary)' }}>Tidak ada unit yang sedang dimonitor</div>
              )}
            </div>
          ) : (
            <div className="table-container" style={{ overflowX: 'auto', marginTop: 10 }}>
              <table className="data-table" style={{ textAlign: 'center' }}>
                <thead>
                  <tr>
                    <th style={{ textAlign: 'left', width: '150px' }}>NOPOL</th>
                    {workflowStages.map((stage) => (
                      <th key={stage.name} style={{ fontSize: '11px', padding: '12px 6px', fontWeight: 'bold' }}>
                        {stage.label}
                      </th>
                    ))}
                    <th style={{ textAlign: 'right', width: '280px' }}>CATATAN AKTIVITAS TERAKHIR</th>
                  </tr>
                </thead>
                <tbody>
                  {slice.map((u) => {
                    const currentStage = getUnitCurrentStage(u);
                    const lastNote = getLastActivityNote(u);
                    return (
                      <tr key={u.id} style={{ height: '48px' }}>
                        <td style={{ textAlign: 'left' }}>
                          <strong>{u.nopol}</strong>
                          <div style={{ fontSize: '9px', color: 'var(--text-tertiary)', fontWeight: '600', marginTop: '2px' }}>
                            {u.pool} • Site {u.location}
                          </div>
                        </td>
                        {workflowStages.map((stage) => (
                          <td key={stage.name} style={{ verticalAlign: 'middle' }}>
                            {renderStageCell(currentStage, stage.name)}
                          </td>
                        ))}
                        <td style={{ textAlign: 'right', fontSize: '11px', color: 'var(--text-secondary)', textOverflow: 'ellipsis', whiteSpace: 'nowrap', overflow: 'hidden' }}>
                          <span style={{ fontWeight: '700', color: 'var(--text-primary)' }}>{lastNote.activity}: </span>
                          <span title={lastNote.notes}>{lastNote.notes}</span>
                        </td>
                      </tr>
                    );
                  })}
                  {slice.length === 0 && (
                    <tr>
                      <td colSpan={10} style={{ padding: 32, color: 'var(--text-tertiary)' }}>
                        Tidak ada unit yang sedang dimonitor
                      </td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          )}
          
          <Pager page={page} total={total} onChange={p => setPage(Math.max(1, Math.min(p, total)))} />
        </div>
      );
    }

      function TeknisiView({ units, setUnits, syncUpdate, isMobile }) {
      const { user, logout } = useContext(AuthContext);
      const [subTab, setSubTab] = useState(() => {
        try {
          return localStorage.getItem('teknisi_active_subtab') || 'today';
        } catch (e) {
          return 'today';
        }
      });
      const [activeUnitId, setActiveUnitId] = useState(() => {
        try {
          const saved = localStorage.getItem('teknisi_active_unit_id');
          return saved ? (isNaN(Number(saved)) ? saved : Number(saved)) : null;
        } catch (e) {
          return null;
        }
      });

      const [completedLocally, setCompletedLocally] = useState(() => {
        try {
          const saved = localStorage.getItem('teknisi_completed_locally');
          return saved ? JSON.parse(saved) : {};
        } catch (e) {
          return {};
        }
      });
      
      // Form fields
      const [noGpsLama, setNoGpsLama] = useState('');
      const [gpsSerialBaru, setGpsSerialBaru] = useState('');
      const [gpsImeiBaru, setGpsImeiBaru] = useState('');
      const [nomorSIM, setNomorSIM] = useState('');
      const [provider, setProvider] = useState('Telkomsel');
      const [catatanPasang, setCatatanPasang] = useState('');
      const [historyReviewUnit, setHistoryReviewUnit] = useState(null);
      
      // Device test states
      const [modelGpsBaru, setModelGpsBaru] = useState('GEOTAB');
      const [gps, setGps] = useState('TERPASANG');
      const [buzzer, setBuzzer] = useState('TERPASANG');
      const [sos, setSos] = useState('TERPASANG');
      const [sensorWing, setSensorWing] = useState('TIDAK TERPASANG');
      const [camera, setCamera] = useState('TIDAK TERPASANG');
      const [statusPasang, setStatusPasang] = useState('ON PROGRESS');
      
      // Photo states (Base64)
      const [fotoKendaraan, setFotoKendaraan] = useState('');
      const [fotoGPSLama, setFotoGPSLama] = useState('');
      const [fotoGPSBaru, setFotoGPSBaru] = useState('');
      const [fotoHasilInstalasi, setFotoHasilInstalasi] = useState('');
      const [fotoOdometer, setFotoOdometer] = useState('');

      // Claim and submit loading states
      const [loadingClaim, setLoadingClaim] = useState(false);
      const [loadingSubmit, setLoadingSubmit] = useState(false);

      // Scanner states
      const [isScannerOpen, setIsScannerOpen] = useState(false);
      const [activeScanField, setActiveScanField] = useState(''); // 'gpsLama', 'gpsBaru', 'gpsImei'

      // Wizard step state
      const [activeStep, setActiveStep] = useState(1);

      // Search & Filters for List
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');

      // Cache-adjusted units where locally completed tasks are shown with their completed status
      const computedUnits = useMemo(() => {
        return units.map(u => {
          if (completedLocally[u.id]) {
            return { ...u, statusPasang: completedLocally[u.id] };
          }
          return u;
        });
      }, [units, completedLocally]);

      // Cleanup completed locally cache when server catches up
      useEffect(() => {
        let changed = false;
        const nextCompleted = { ...completedLocally };
        for (const id in nextCompleted) {
          const unit = units.find(u => String(u.id) === String(id));
          if (unit && unit.statusPasang === nextCompleted[id]) {
            delete nextCompleted[id];
            changed = true;
          }
        }
        if (changed) {
          setCompletedLocally(nextCompleted);
          try {
            localStorage.setItem('teknisi_completed_locally', JSON.stringify(nextCompleted));
          } catch (e) {}
        }
      }, [units, completedLocally]);

      // Find the active unit object
      const activeUnit = useMemo(() => {
        return computedUnits.find(u => u.id === activeUnitId);
      }, [computedUnits, activeUnitId]);

      // Ref to track whether form has been initialized for the current active unit
      const initializedUnitIdRef = React.useRef(null);

      // Save subTab to localStorage
      useEffect(() => {
        try {
          localStorage.setItem('teknisi_active_subtab', subTab);
        } catch (e) {
          console.error(e);
        }
      }, [subTab]);

      // Save activeUnitId to localStorage
      useEffect(() => {
        try {
          if (activeUnitId) {
            localStorage.setItem('teknisi_active_unit_id', String(activeUnitId));
          } else {
            localStorage.removeItem('teknisi_active_unit_id');
          }
        } catch (e) {
          console.error(e);
        }
      }, [activeUnitId]);

      // Save form state to localStorage whenever fields change
      useEffect(() => {
        try {
          // Only save to localStorage if the active unit has been fully initialized in state
          if (activeUnitId && initializedUnitIdRef.current === activeUnitId) {
            const stateToSave = {
              noGpsLama,
              gpsSerialBaru,
              gpsImeiBaru,
              nomorSIM,
              provider,
              catatanPasang,
              modelGpsBaru,
              gps,
              buzzer,
              sos,
              sensorWing,
              camera,
              statusPasang,
              fotoKendaraan,
              fotoGPSLama,
              fotoGPSBaru,
              fotoHasilInstalasi,
        fotoOdometer,
              activeStep
            };
            localStorage.setItem('active_install_form_' + activeUnitId, JSON.stringify(stateToSave));
          }
        } catch (e) {
          console.error(e);
        }
      }, [
        activeUnitId,
        noGpsLama,
        gpsSerialBaru,
        gpsImeiBaru,
        nomorSIM,
        provider,
        catatanPasang,
        modelGpsBaru,
        gps,
        buzzer,
        sos,
        sensorWing,
        camera,
        statusPasang,
        fotoKendaraan,
        fotoGPSLama,
        fotoGPSBaru,
        fotoHasilInstalasi,
        fotoOdometer,
        activeStep
      ]);

      // If activeUnitId changes, initialize form states (with localStorage loading fallback)
      useEffect(() => {
        if (activeUnitId) {
          if (activeUnit && initializedUnitIdRef.current !== activeUnitId) {
            let savedData = null;
            try {
              const savedDataStr = localStorage.getItem('active_install_form_' + activeUnitId);
              if (savedDataStr) {
                savedData = JSON.parse(savedDataStr);
              }
            } catch (e) {
              console.error("Failed to load saved state from localStorage:", e);
            }

            if (savedData) {
              setNoGpsLama(String(savedData.noGpsLama ?? ''));
              setGpsSerialBaru(String(savedData.gpsSerialBaru ?? ''));
              setGpsImeiBaru(String(savedData.gpsImeiBaru ?? ''));
              setNomorSIM(String(savedData.nomorSIM ?? ''));
              setProvider(String(savedData.provider ?? 'Telkomsel'));
              setCatatanPasang(String(savedData.catatanPasang ?? ''));
              
              setModelGpsBaru(String(savedData.modelGpsBaru ?? 'GEOTAB'));
              setGps(String(savedData.gps ?? 'TERPASANG'));
              setBuzzer(String(savedData.buzzer ?? 'TERPASANG'));
              setSos(String(savedData.sos ?? 'TERPASANG'));
              setSensorWing(String(savedData.sensorWing ?? 'TIDAK TERPASANG'));
              setCamera(String(savedData.camera ?? 'TIDAK TERPASANG'));
              setStatusPasang(String(savedData.statusPasang ?? 'ON PROGRESS'));
              
              setFotoKendaraan(String(savedData.fotoKendaraan ?? ''));
              setFotoGPSLama(String(savedData.fotoGPSLama ?? ''));
              setFotoGPSBaru(String(savedData.fotoGPSBaru ?? ''));
              setFotoHasilInstalasi(String(savedData.fotoHasilInstalasi ?? ''));
              setFotoOdometer(String(savedData.fotoOdometer ?? ''));

              setActiveStep(Number(savedData.activeStep ?? 1));
            } else {
              setNoGpsLama(String(activeUnit.gpsSerialLama ?? ''));
              setGpsSerialBaru(String(activeUnit.gpsSerialBaru ?? ''));
              setGpsImeiBaru(String(activeUnit.gpsImeiBaru ?? ''));
              setNomorSIM(String(activeUnit.nomorSIM ?? ''));
              setProvider(String(activeUnit.provider ?? 'Telkomsel'));
              setCatatanPasang(String(activeUnit.catatanPasang ?? ''));
              
              setModelGpsBaru(String(activeUnit.modelGpsBaru ?? 'GEOTAB'));
              setGps(String(activeUnit.gps ?? 'TERPASANG'));
              setBuzzer(String(activeUnit.buzzer ?? 'TERPASANG'));
              setSos(String(activeUnit.sos ?? 'TERPASANG'));
              setSensorWing(String(activeUnit.sensorWing ?? 'TIDAK TERPASANG'));
              setCamera(String(activeUnit.camera ?? 'TIDAK TERPASANG'));
              setStatusPasang(String(activeUnit.statusPasang ?? 'ON PROGRESS'));
              
              setFotoKendaraan(String(activeUnit.fotoKendaraan ?? ''));
              setFotoGPSLama(String(activeUnit.fotoGPSLama ?? ''));
              setFotoGPSBaru(String(activeUnit.fotoGPSBaru ?? ''));
              setFotoHasilInstalasi(String(activeUnit.fotoHasilInstalasi ?? ''));
              setFotoOdometer(String(activeUnit.fotoOdometer ?? ''));

              setActiveStep(1); // Reset wizard to step 1
            }
            initializedUnitIdRef.current = activeUnitId; // Mark as initialized for this ID
          }
        } else {
          initializedUnitIdRef.current = null;
        }
      }, [activeUnitId, activeUnit]);

      // Helper to cancel/batal current unit and delete localStorage backup
      const cancelActiveUnit = () => {
        try {
          if (activeUnitId) {
            localStorage.removeItem('active_install_form_' + activeUnitId);
            localStorage.removeItem('teknisi_active_unit_id');
          }
        } catch (e) {
          console.error(e);
        }
        setActiveUnitId(null);
        setSubTab('today');
      };

      // Helper to just go back to tab Tugas without deleting the local draft
      const goBackToList = () => {
        setSubTab('today');
      };

      const nameMatch = user.name || user.username;

      // Extract User Initials
      const initials = useMemo(() => {
        if (!nameMatch) return 'AF';
        const parts = nameMatch.trim().split(' ');
        if (parts.length >= 2) {
          return (parts[0][0] + parts[1][0]).toUpperCase();
        }
        return nameMatch.slice(0, 2).toUpperCase();
      }, [nameMatch]);

      // Check if technician currently has an active task in progress
      const hasActiveTask = useMemo(() => {
        return computedUnits.some(u => 
          u.statusPasang === 'ON PROGRESS' &&
          u.teknisiPelaksana && u.teknisiPelaksana.toLowerCase() === nameMatch.toLowerCase()
        );
      }, [computedUnits, nameMatch]);

      // Find the specific active unit claimed by this technician
      const myActiveUnit = useMemo(() => {
        return computedUnits.find(u => 
          u.statusPasang === 'ON PROGRESS' &&
          u.teknisiPelaksana && u.teknisiPelaksana.toLowerCase() === nameMatch.toLowerCase()
        );
      }, [computedUnits, nameMatch]);

      // Filtered queue units: planned, unclaimed/assigned to me, not yet completed
      const queueUnits = useMemo(() => {
        return computedUnits.filter(u => 
          u.statusPlan === 'PLAN' &&
          u.statusPasang === 'BELUM DIPASANG' &&
          (!u.teknisiPelaksana || u.teknisiPelaksana.trim() === '' || u.teknisiPelaksana.toLowerCase() === nameMatch.toLowerCase()) &&
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc)
        );
      }, [computedUnits, q, loc, nameMatch]);

      // History units: completed by this technician
      const historyUnits = useMemo(() => {
        return computedUnits.filter(u => 
          u.teknisiPelaksana && u.teknisiPelaksana.toLowerCase() === nameMatch.toLowerCase() &&
          ['TEKNISI SUBMITTED', 'PIC VERIFIED', 'IT VERIFIED', 'DONE'].includes(u.statusPasang)
        );
      }, [computedUnits, nameMatch]);

      // Automatically set activeUnitId if they have an active task and switch to installations
      useEffect(() => {
        if (subTab === 'installations' && !activeUnitId) {
          const task = computedUnits.find(u => 
            u.statusPasang === 'ON PROGRESS' &&
            u.teknisiPelaksana && u.teknisiPelaksana.toLowerCase() === nameMatch.toLowerCase()
          );
          if (task) {
            setActiveUnitId(task.id);
          }
        }
      }, [subTab, computedUnits, nameMatch, activeUnitId]);

      // Claim unit logic with concurrency collision check & single active task restriction
      const claimUnit = async (u) => {
        if (hasActiveTask) {
          globalAddToast('Selesaikan tugas aktif Anda di My Installs terlebih dahulu!', 'warning');
          return;
        }

        setLoadingClaim(true);
        globalAddToast('Memeriksa ketersediaan unit...', 'info');
        
        try {
          const res = await fetch(WEBAPP_URL);
          const json = await res.json();
          if (json.success) {
            const fresh = json.data.find(row => (row.NOPOL || row.nopol || '').toUpperCase() === u.nopol.toUpperCase());
            const freshClaimer = fresh ? (fresh.TEKNISI_PELAKSANA || fresh['TEKNISI PELAKSANA'] || fresh.TEKNISI || '') : '';
            if (fresh && freshClaimer.trim() !== '') {
              const currentClaimer = freshClaimer;
              globalAddToast(`Gagal: Unit ini sudah diklaim oleh ${currentClaimer}!`, 'danger');
              setUnits(prev => prev.map(item => item.nopol === u.nopol ? { ...item, teknisiPelaksana: currentClaimer } : item));
              setLoadingClaim(false);
              return;
            }
          }

          // Safe to claim
          const now = new Date();
          const dd = n => String(n).padStart(2, '0');
          const ts = `${dd(now.getDate())}-${dd(now.getMonth() + 1)}-${now.getFullYear()} ${dd(now.getHours())}:${dd(now.getMinutes())}`;
          
          const updates = {
            "TEKNISI PELAKSANA": nameMatch,
            "STATUS REGISTRASI": 'ON PROGRESS'
          };

          await syncUpdate(u.nopol, updates);
          
          // Update local react state
          setUnits(prev => prev.map(item => item.nopol === u.nopol ? { 
            ...item, 
            teknisiPelaksana: nameMatch, 
            statusPasang: 'ON PROGRESS', 
            updatedAt: ts 
          } : item));

          setActiveUnitId(u.id);
          setSubTab('installations');
          globalAddToast(`Berhasil mengklaim unit ${u.nopol}!`, 'success');
        } catch (err) {
          console.error(err);
          globalAddToast('Gagal mengklaim unit: ' + String(err), 'danger');
        } finally {
          setLoadingClaim(false);
        }
      };

      // Release/batal claim back to pool
      const releaseClaim = async (u) => {
        if (!confirm(`Apakah Anda yakin ingin membatalkan klaim untuk unit ${u.nopol}? Unit ini akan dikembalikan ke daftar tugas agar bisa diklaim oleh teknisi lain.`)) {
          return;
        }

        setLoadingClaim(true);
        globalAddToast('Membatalkan klaim unit...', 'info');
        
        try {
          const now = new Date();
          const dd = n => String(n).padStart(2, '0');
          const ts = `${dd(now.getDate())}-${dd(now.getMonth() + 1)}-${now.getFullYear()} ${dd(now.getHours())}:${dd(now.getMinutes())}`;

          const updates = {
            "TEKNISI PELAKSANA": '',
            "STATUS REGISTRASI": 'BELUM DIPASANG'
          };

          await syncUpdate(u.nopol, updates);
          
          // Update local react state
          setUnits(prev => prev.map(item => item.nopol === u.nopol ? { 
            ...item, 
            teknisiPelaksana: '', 
            statusPasang: 'BELUM DIPASANG', 
            updatedAt: ts 
          } : item));

          // Clear local storage draft
          try {
            localStorage.removeItem('active_install_form_' + u.id);
            localStorage.removeItem('teknisi_active_unit_id');
          } catch (e) {}

          setActiveUnitId(null);
          globalAddToast(`Klaim unit ${u.nopol} berhasil dibatalkan!`, 'success');
        } catch (err) {
          console.error(err);
          globalAddToast('Gagal membatalkan klaim unit: ' + String(err), 'danger');
        } finally {
          setLoadingClaim(false);
        }
      };

      // Image Compression & Conversion to Base64
      const handlePhotoChange = (fieldName, file) => {
        if (!file) return;
        globalAddToast('Mengompresi foto...', 'info');

        const reader = new FileReader();
        reader.onload = (e) => {
          const originalBase64 = e.target.result;
          const img = new Image();
          
          img.onload = () => {
            try {
              const maxDim = 800;
              let w = img.width;
              let h = img.height;
              if (w > maxDim || h > maxDim) {
                if (w > h) {
                  h = Math.round((h * maxDim) / w);
                  w = maxDim;
                } else {
                  w = Math.round((w * maxDim) / h);
                  h = maxDim;
                }
              }

              const canvas = document.createElement('canvas');
              canvas.width = w;
              canvas.height = h;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, w, h);

              const compressedBase64 = canvas.toDataURL('image/jpeg', 0.7);

              if (fieldName === 'fotoKendaraan') setFotoKendaraan(compressedBase64);
              if (fieldName === 'fotoGPSLama') setFotoGPSLama(compressedBase64);
              if (fieldName === 'fotoGPSBaru') setFotoGPSBaru(compressedBase64);
              if (fieldName === 'fotoHasilInstalasi') setFotoHasilInstalasi(compressedBase64);
              if (fieldName === 'fotoOdometer') setFotoOdometer(compressedBase64);
              
              globalAddToast('Foto berhasil ditambahkan!', 'success');
            } catch (canvasErr) {
              console.warn("Canvas compress failed, fallback to raw base64:", canvasErr);
              if (fieldName === 'fotoKendaraan') setFotoKendaraan(originalBase64);
              if (fieldName === 'fotoGPSLama') setFotoGPSLama(originalBase64);
              if (fieldName === 'fotoGPSBaru') setFotoGPSBaru(originalBase64);
              if (fieldName === 'fotoHasilInstalasi') setFotoHasilInstalasi(originalBase64);
            if (fieldName === 'fotoOdometer') setFotoOdometer(originalBase64);
              globalAddToast('Foto berhasil ditambahkan (tanpa kompresi)!', 'success');
            }
          };

          img.onerror = () => {
            if (fieldName === 'fotoKendaraan') setFotoKendaraan(originalBase64);
            if (fieldName === 'fotoGPSLama') setFotoGPSLama(originalBase64);
            if (fieldName === 'fotoGPSBaru') setFotoGPSBaru(originalBase64);
            if (fieldName === 'fotoHasilInstalasi') setFotoHasilInstalasi(originalBase64);
            if (fieldName === 'fotoOdometer') setFotoOdometer(originalBase64);
            globalAddToast('Foto berhasil ditambahkan!', 'success');
          };

          img.src = originalBase64;
        };
        reader.readAsDataURL(file);
      };

      // Scanner functions using HTML5 Qrcode
      const startScanning = (fieldName) => {
        setActiveScanField(fieldName);
        setIsScannerOpen(true);
        
        setTimeout(() => {
          try {
            const html5QrCode = new Html5Qrcode("scanner-view");
            window.activeScanner = html5QrCode;
            
            const qrSuccess = (decodedText) => {
              if (fieldName === 'gpsLama') setNoGpsLama(decodedText);
              if (fieldName === 'gpsBaru') setGpsSerialBaru(decodedText);
              if (fieldName === 'gpsImei') setGpsImeiBaru(decodedText);
              globalAddToast('Scan sukses: ' + decodedText, 'success');
              stopScanning();
            };

            html5QrCode.start(
              { facingMode: "environment" },
              { fps: 10, qrbox: { width: 250, height: 250 } },
              qrSuccess
            ).catch(err => {
              console.warn("Scan camera failed to start: ", err);
            });
          } catch (e) {
            console.error("Scanner error:", e);
          }
        }, 350);
      };

      const stopScanning = () => {
        if (window.activeScanner) {
          try {
            window.activeScanner.stop().then(() => {
              window.activeScanner = null;
              const el = document.getElementById("scanner-view");
              if (el) el.innerHTML = '';
            }).catch(e => {
              console.error("Error stopping scanner", e);
              window.activeScanner = null;
              const el = document.getElementById("scanner-view");
              if (el) el.innerHTML = '';
            });
          } catch (e) {
            window.activeScanner = null;
          }
        }
        setIsScannerOpen(false);
        setActiveScanField('');
      };

      const simulateScan = () => {
        const mockVal = "SN" + Math.floor(100000000 + Math.random() * 900000000);
        if (activeScanField === 'gpsLama') setNoGpsLama(mockVal);
        if (activeScanField === 'gpsBaru') setGpsSerialBaru(mockVal);
        if (activeScanField === 'gpsImei') setGpsImeiBaru("IMEI" + Math.floor(100000000000000 + Math.random() * 90000000000000));
        
        globalAddToast('Simulasi scan barcode berhasil!', 'success');
        stopScanning();
      };

      const isWingboxUnit = activeUnit && (
        (activeUnit.pool && activeUnit.pool.toLowerCase().includes('wingbox')) ||
        (activeUnit.assetType && activeUnit.assetType.toLowerCase().includes('wingbox')) ||
        (activeUnit.dedicate && activeUnit.dedicate.toLowerCase().includes('wingbox'))
      );

      const submitInstallation = async () => {
        if (loadingSubmit) return;

        // Hardware details validation
        if (!String(noGpsLama || '').trim()) {
          globalAddToast('Kesalahan: Kolom No GPS Lama wajib diisi!', 'danger');
          return;
        }
        if (!String(gpsSerialBaru || '').trim()) {
          globalAddToast('Kesalahan: Kolom Serial GPS Baru wajib diisi!', 'danger');
          return;
        }
        if (!String(gpsImeiBaru || '').trim()) {
          globalAddToast('Kesalahan: Kolom IMEI GPS Baru wajib diisi!', 'danger');
          return;
        }
        // GPS mandatory check
        if (gps !== 'TERPASANG') {
          globalAddToast('Kesalahan: GPS wajib Terpasang!', 'danger');
          return;
        }

        // Wingbox mandatory sensor check
        if (isWingboxUnit && sensorWing !== 'TERPASANG') {
          globalAddToast('Kesalahan: Unit adalah Wingbox! Sensor Wingbox wajib Terpasang!', 'danger');
          return;
        }

        // Document photos validation
        if (!fotoKendaraan) {
          globalAddToast('Kesalahan: Foto Kendaraan wajib diunggah!', 'danger');
          return;
        }
        if (!fotoGPSLama) {
          globalAddToast('Kesalahan: Foto GPS Lama wajib diunggah!', 'danger');
          return;
        }
        if (!fotoGPSBaru) {
          globalAddToast('Kesalahan: Foto GPS Baru wajib diunggah!', 'danger');
          return;
        }
        if (!fotoHasilInstalasi) {
          globalAddToast('Kesalahan: Foto Hasil Instalasi wajib diunggah!', 'danger');
          return;
        }
        if (!fotoOdometer) {
          globalAddToast('Kesalahan: Foto Odometer wajib diunggah!', 'danger');
          return;
        }

        setLoadingSubmit(true);
        globalAddToast('Mengunggah foto-foto ke server...', 'info');

        let urlFotoKendaraan = fotoKendaraan;
        let urlFotoGPSLama = fotoGPSLama;
        let urlFotoGPSBaru = fotoGPSBaru;
        let urlFotoHasilInstalasi = fotoHasilInstalasi;
        let urlFotoOdometer = fotoOdometer;

        try {
          urlFotoKendaraan = await uploadImageToSupabaseStorage(fotoKendaraan, activeUnit.nopol, 'fotoKendaraan');
          urlFotoGPSLama = await uploadImageToSupabaseStorage(fotoGPSLama, activeUnit.nopol, 'fotoGPSLama');
          urlFotoGPSBaru = await uploadImageToSupabaseStorage(fotoGPSBaru, activeUnit.nopol, 'fotoGPSBaru');
          urlFotoHasilInstalasi = await uploadImageToSupabaseStorage(fotoHasilInstalasi, activeUnit.nopol, 'fotoHasilInstalasi');
          urlFotoOdometer = await uploadImageToSupabaseStorage(fotoOdometer, activeUnit.nopol, 'fotoOdometer');
        } catch (e) {
          console.warn("Upload storage gagal, menggunakan base64 fallback:", e);
        }

        const now = new Date();
        const dd = n => String(n).padStart(2, '0');
        const ts = `${dd(now.getDate())}-${dd(now.getMonth() + 1)}-${now.getFullYear()} ${dd(now.getHours())}:${dd(now.getMinutes())}`;

        const updates = {
          "STATUS REGISTRASI": 'TEKNISI SUBMITTED',
          "TIPE GPS BARU": modelGpsBaru,
          "TEKNISI PELAKSANA": nameMatch,
          "GPS": gps,
          "BUZZER": buzzer,
          "SOS": sos,
          "SENSOR WING": sensorWing,
          "CAMERA": camera,
          "SN GPS BARU": gpsSerialBaru,
          "IMEI GPS BARU": gpsImeiBaru,
          "NOMOR KARTU GPS BARU": nomorSIM,
          "PROVIDER SIM GPS BARU": provider,
          "FOTO KENDARAAN (NOPOL)": urlFotoKendaraan,
          "FOTO SERIAL GPS LAMA (DICABUT)": urlFotoGPSLama,
          "FOTO GPS BARU (SN TERLIHAT)": urlFotoGPSBaru,
          "FOTO HASIL INSTALASI": urlFotoHasilInstalasi,
          "FOTO ODOMETER": urlFotoOdometer,
          "SN GPS LAMA": noGpsLama
        };

        try {
          await syncUpdate(activeUnit.nopol, updates);
          
          setUnits(prev => prev.map(item => item.id === activeUnit.id ? {
            ...item,
            ...updates,
            fotoOdometer: urlFotoOdometer,
            gpsSerialLama: noGpsLama,
            easygoDicopot: 'SUDAH',
            statusSystem: 'BELUM DITEST',
            updatedAt: ts
          } : item));

          globalAddToast(`Laporan unit ${activeUnit.nopol} berhasil dikirim!`, 'success');
          try {
            localStorage.removeItem('active_install_form_' + activeUnit.id);
            localStorage.removeItem('teknisi_active_unit_id');
          } catch (e) {
            console.error(e);
          }
          setCompletedLocally(prev => {
            const next = { ...prev, [activeUnit.id]: 'TEKNISI SUBMITTED' };
            try {
              localStorage.setItem('teknisi_completed_locally', JSON.stringify(next));
            } catch (e) {}
            return next;
          });
          setActiveUnitId(null);
          setSubTab('today');
        } catch (err) {
          console.error(err);
          globalAddToast('Gagal mengirim ke cloud, data disimpan secara lokal.', 'warning');
          
          setUnits(prev => prev.map(item => item.id === activeUnit.id ? {
            ...item,
            ...updates,
            gpsSerialLama: noGpsLama,
            easygoDicopot: 'SUDAH',
            statusSystem: 'BELUM DITEST',
            updatedAt: ts
          } : item));
          try {
            localStorage.removeItem('active_install_form_' + activeUnit.id);
            localStorage.removeItem('teknisi_active_unit_id');
          } catch (e) {
            console.error(e);
          }
          setCompletedLocally(prev => {
            const next = { ...prev, [activeUnit.id]: 'TEKNISI SUBMITTED' };
            try {
              localStorage.setItem('teknisi_completed_locally', JSON.stringify(next));
            } catch (e) {}
            return next;
          });
          setActiveUnitId(null);
          setSubTab('today');
        } finally {
          setLoadingSubmit(false);
        }
      };

      const handleLogout = () => {
        if (confirm('Apakah Anda yakin ingin keluar dari aplikasi?')) {
          logout();
        }
      };

      return (
        <div className="teknisi-wrapper">
          {/* Top Navigation for Desktop */}
          {!isMobile && (
            <div style={{ display: 'flex', gap: 10, marginBottom: 20, borderBottom: '1px solid var(--border-color)', paddingBottom: 12 }}>
              <button 
                className={`btn ${subTab === 'today' ? 'btn-primary' : 'btn-secondary'}`}
                onClick={() => { if (isScannerOpen) stopScanning(); setSubTab('today'); }}
                style={{ display: 'flex', alignItems: 'center', gap: 8, height: 38, padding: '0 16px', fontSize: 13, fontWeight: 600 }}
              >
                <i className="bi bi-clipboard-data" style={{ fontSize: 16 }}></i>
                Tugas Hari Ini
              </button>
              <button 
                className={`btn ${subTab === 'installations' ? 'btn-primary' : 'btn-secondary'}`}
                onClick={() => { if (isScannerOpen) stopScanning(); setSubTab('installations'); }}
                style={{ display: 'flex', alignItems: 'center', gap: 8, height: 38, padding: '0 16px', fontSize: 13, fontWeight: 600 }}
              >
                <i className="bi bi-wrench" style={{ fontSize: 16 }}></i>
                My Installs
              </button>
              <button 
                className={`btn ${subTab === 'history' ? 'btn-primary' : 'btn-secondary'}`}
                onClick={() => { if (isScannerOpen) stopScanning(); setSubTab('history'); }}
                style={{ display: 'flex', alignItems: 'center', gap: 8, height: 38, padding: '0 16px', fontSize: 13, fontWeight: 600 }}
              >
                <i className="bi bi-check-circle" style={{ fontSize: 16 }}></i>
                History
              </button>
            </div>
          )}
          {/* Header Bar */}
          <div className="teknisi-header" style={{ display: isMobile ? 'flex' : 'none' }}>
            <div className="teknisi-profile">
              <div className="teknisi-avatar">
                {initials}
              </div>
              <div className="teknisi-profile-info">
                <span className="teknisi-name">{nameMatch}</span>
                <span className="teknisi-role">Technician</span>
              </div>
            </div>
            
            <div className="teknisi-header-right">
              <div className="teknisi-status-pill">
                <i className="bi bi-wifi teknisi-status-icon"></i>
                <span>ONLINE</span>
              </div>
              <div className="teknisi-header-btn">
                <i className="bi bi-sun"></i>
              </div>
              <div className="teknisi-header-btn">
                <i className="bi bi-bell"></i>
              </div>
            </div>
          </div>

          {/* TAB 1: Tugas Hari Ini (Today) */}
          {subTab === 'today' && (
            <div>
              {/* Hero Banner Card */}
              <div className="teknisi-hero-card">
                <div className="teknisi-hero-title">
                  <i className="bi bi-clipboard-data" style={{fontSize: 18}}></i>
                  <span>Tugas Hari Ini</span>
                </div>
                <p className="teknisi-hero-desc">
                  Berikut adalah daftar armada kendaraan yang ditugaskan kepada Anda hari ini.
                </p>
              </div>

              {/* Pinned Active Task Section */}
              {myActiveUnit && (
                <div className="teknisi-active-card">
                  <div className="teknisi-active-badge">
                    <span className="badge-dot"></span>
                    <span>Pemasangan Aktif Anda</span>
                  </div>
                  <div className="teknisi-card-header">
                    <span className="teknisi-card-label">NOMOR POLISI</span>
                    <span className="teknisi-pool-badge">
                      <i className="bi bi-geo-alt"></i> {myActiveUnit.pool || myActiveUnit.location || 'Nagrak Pool'}
                    </span>
                  </div>

                  <div className="teknisi-vehicle-nopol" style={{ marginBottom: 4 }}>
                    {myActiveUnit.nopol}
                  </div>

                  <div style={{ fontSize: 11, color: '#94A3B8', marginBottom: 12 }}>
                    Tipe: <strong>{myActiveUnit.merk} {myActiveUnit.assetType}</strong>
                  </div>

                  {myActiveUnit.keteranganPlanner && (
                    <div className="teknisi-quote-box" style={{ marginBottom: 12 }}>
                      &ldquo;{myActiveUnit.keteranganPlanner}&rdquo;
                    </div>
                  )}

                  <div className="teknisi-card-buttons">
                    <button 
                      className="teknisi-btn-play"
                      style={{ flex: 1.8 }}
                      onClick={() => {
                        setActiveUnitId(myActiveUnit.id);
                        setSubTab('installations');
                      }}
                    >
                      <i className="bi bi-play"></i> Lanjutkan Pemasangan
                    </button>
                    <button 
                      className="teknisi-btn-danger-outline"
                      disabled={loadingClaim}
                      onClick={() => releaseClaim(myActiveUnit)}
                    >
                      <i className="bi bi-arrow-counterclockwise"></i> Lepas Klaim
                    </button>
                  </div>
                </div>
              )}

              {!isMobile ? (
                <>
                  <FilterRow>
                    <div className="search-input-wrapper">
                      <i className="bi bi-search"></i>
                      <input 
                        type="text" 
                        value={q} 
                        onChange={e => setQ(e.target.value)} 
                        className="search-input"
                        placeholder="Cari NOPOL..." 
                      />
                    </div>
                    <select value={loc} onChange={e => setLoc(e.target.value)} className="filter-select">
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                    <span className="unit-count-tag">{queueUnits.length} Tugas Tersedia</span>
                  </FilterRow>

                  {queueUnits.length === 0 ? (
                    <div style={{ textAlign: 'center', padding: 48, color: 'var(--text-tertiary)', background: 'var(--bg-card)', borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)', marginTop: 12 }}>
                      <i className="bi bi-list-check" style={{ fontSize: 32, display: 'block', marginBottom: 10, color: 'var(--text-tertiary)' }}></i>
                      Tidak ada tugas pemasangan yang tersedia hari ini.
                    </div>
                  ) : (
                    <div className="table-container" style={{ marginTop: 12 }}>
                      <table className="data-table">
                        <thead>
                          <tr>
                            <th style={{ width: '50px' }}>#</th>
                            <th style={{ width: '120px' }}>NOPOL</th>
                            <th style={{ width: '180px' }}>SITE / POOL</th>
                            <th style={{ width: '220px' }}>DETAIL KENDARAAN</th>
                            <th>KETERANGAN PLANNER</th>
                            <th style={{ width: '180px', textAlign: 'center' }}>AKSI</th>
                          </tr>
                        </thead>
                        <tbody>
                          {queueUnits.map((u, idx) => (
                            <tr key={u.id}>
                              <td>{idx + 1}</td>
                              <td><strong>{u.nopol}</strong></td>
                              <td>
                                <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
                                  <i className="bi bi-geo-alt" style={{ color: 'var(--accent)' }}></i>
                                  {u.pool || u.location || 'Nagrak Pool'}
                                </div>
                              </td>
                              <td>
                                <span style={{ fontSize: 12 }}>{u.ownership}</span> • {u.merk} ({u.assetType})
                              </td>
                              <td>
                                {u.keteranganPlanner ? (
                                  <span style={{ fontStyle: 'italic', fontSize: 12, color: 'var(--text-secondary)' }}>
                                    &ldquo;{u.keteranganPlanner}&rdquo;
                                  </span>
                                ) : '—'}
                              </td>
                              <td style={{ textAlign: 'center' }}>
                                <button 
                                  className="btn btn-primary btn-sm"
                                  disabled={loadingClaim || hasActiveTask}
                                  onClick={() => claimUnit(u)}
                                  style={{ gap: 6, display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: '100%' }}
                                >
                                  <i className="bi bi-play-fill"></i> Mulai Pasang
                                </button>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </>
              ) : (
                <>
                  {/* Available Tasks Header */}
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 10, marginTop: myActiveUnit ? 24 : 0 }}>
                    <span style={{ fontSize: 10, fontWeight: 700, color: '#94A3B8', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                      Tugas Tersedia ({queueUnits.length})
                    </span>
                  </div>

                  {/* Search filter for mobile ease */}
                  <div style={{marginBottom: 16, display: 'flex', gap: 8}}>
                    <input 
                      type="text" 
                      value={q} 
                      onChange={e => setQ(e.target.value)} 
                      placeholder="Cari NOPOL..." 
                      style={{flex: 1}}
                    />
                    <select value={loc} onChange={e => setLoc(e.target.value)} style={{maxWidth: 130}}>
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                  </div>

                  {/* List of vehicle cards */}
                  {queueUnits.map(u => {
                    return (
                      <div key={u.id} className="teknisi-vehicle-card">
                        <div className="teknisi-card-header">
                          <span className="teknisi-card-label">NOMOR POLISI</span>
                          <span className="teknisi-pool-badge">
                            <i className="bi bi-geo-alt"></i> {u.pool || u.location || 'Nagrak Pool'}
                          </span>
                        </div>

                        <div className="teknisi-vehicle-nopol">
                          {u.nopol}
                        </div>

                        {u.keteranganPlanner && (
                          <div className="teknisi-quote-box">
                            &ldquo;{u.keteranganPlanner}&rdquo;
                          </div>
                        )}

                        <button 
                          className="teknisi-btn-play"
                          disabled={loadingClaim}
                          style={hasActiveTask ? { background: 'var(--bg-secondary)', color: '#94A3B8', opacity: 0.6 } : {}}
                          onClick={() => claimUnit(u)}
                        >
                          <i className="bi bi-play"></i> Mulai Pemasangan
                        </button>
                      </div>
                    );
                  })}

                  {queueUnits.length === 0 && (
                    <div style={{textAlign: 'center', padding: '30px 10px', background: 'var(--bg-secondary)', borderRadius: 16, border: '1px solid var(--border-color)', color: '#94A3B8', fontSize: 11}}>
                      Tidak ada armada kendaraan yang ditugaskan hari ini.
                    </div>
                  )}
                </>
              )}
            </div>
          )}

          {/* TAB 2: My Installs (Installations Form) */}
          {subTab === 'installations' && (
            <div>
              {!activeUnit ? (
                <div style={{textAlign: 'center', padding: '40px 20px', background: '#111827', borderRadius: 16, border: '1px solid rgba(255,255,255,0.05)', color: '#94A3B8', fontSize: 12}}>
                  <i className="bi bi-wrench" style={{fontSize: 28, display: 'block', marginBottom: 10, color: '#5850EC'}}></i>
                  Tidak ada pemasangan aktif.<br />
                  Silakan pilih unit dari tab <strong>Tugas</strong> terlebih dahulu.
                </div>
              ) : (
                <div className="teknisi-vehicle-card" style={{margin: 0}}>
                  {/* Form Header */}
                  <div style={{display: 'flex', gap: 10, alignItems: 'center', marginBottom: 16, paddingBottom: 12, borderBottom: '1px solid rgba(255,255,255,0.08)'}}>
                    <button className="btn btn-secondary btn-sm" style={{padding: '4px 8px'}} onClick={goBackToList}>
                      &larr; Kembali
                    </button>
                    <strong style={{color: '#FFF', fontSize: 14}}>{activeUnit.nopol} ({activeUnit.merk} {activeUnit.assetType})</strong>
                  </div>

                    {/* Step Progress Indicator */}
                    <div>
                      <div style={{display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20, paddingBottom: 12, borderBottom: '1px solid rgba(255,255,255,0.08)'}}>
                        {[
                          { step: 1, label: 'Hardware', icon: 'ti-qrcode' },
                          { step: 2, label: 'Pengujian', icon: 'ti-settings' },
                          { step: 3, label: 'Foto', icon: 'ti-camera' },
                          { step: 4, label: 'Review', icon: 'ti-circle-check' }
                        ].map((s) => {
                          const isActive = activeStep === s.step;
                          const isCompleted = activeStep > s.step;
                          return (
                            <div key={s.step} style={{display: 'flex', flexDirection: 'column', alignItems: 'center', flex: 1, position: 'relative'}}>
                              <div style={{
                                width: 28,
                                height: 28,
                                borderRadius: '50%',
                                background: isActive ? '#5850EC' : isCompleted ? '#10B981' : '#1F2937',
                                color: '#FFF',
                                display: 'flex',
                                alignItems: 'center',
                                justifyContent: 'center',
                                fontSize: 12,
                                fontWeight: 700,
                                border: isActive ? '2px solid rgba(88,80,236,0.3)' : '1px solid rgba(255,255,255,0.08)',
                                marginBottom: 4,
                                zIndex: 2,
                                transition: 'all 0.3s ease'
                              }}>
                                {isCompleted ? <i className="bi bi-check" style={{fontSize: 14}}></i> : <i className={`ti ${s.icon}`} style={{fontSize: 12}}></i>}
                              </div>
                              <span style={{
                                fontSize: 9, 
                                color: isActive ? '#FFF' : '#94A3B8', 
                                fontWeight: isActive ? 700 : 500,
                                transition: 'all 0.3s ease'
                              }}>
                                {s.label}
                              </span>
                            </div>
                          );
                        })}
                      </div>

                      {activeStep === 1 && (
                        <div className="form-section" style={{borderTop: 'none', marginTop: 0, paddingTop: 0}}>
                          <div className="form-section-title">Step 1: Identitas Hardware GPS & SIM</div>
                          <div style={{display: 'flex', flexDirection: 'column', gap: 12}}>
                            <div className="input-group">
                              <label className="input-label">No GPS Lama (Dicabut) *</label>
                              <div style={{display: 'flex', gap: 8}}>
                                <input type="text" value={noGpsLama} onChange={e => setNoGpsLama(e.target.value)} className="input-field" placeholder="Masukkan serial GPS dicabut" />
                                <button type="button" className="btn btn-secondary btn-sm" onClick={() => startScanning('gpsLama')}><i className="bi bi-qr-code"></i> Scan</button>
                              </div>
                            </div>

                            <div className="input-group">
                              <label className="input-label">Serial GPS Baru (SN Barcode) *</label>
                              <div style={{display: 'flex', gap: 8}}>
                                <input type="text" value={gpsSerialBaru} onChange={e => setGpsSerialBaru(e.target.value)} className="input-field" placeholder="Masukkan serial GPS baru" />
                                <button type="button" className="btn btn-secondary btn-sm" onClick={() => startScanning('gpsBaru')}><i className="bi bi-qr-code"></i> Scan</button>
                              </div>
                            </div>

                            <div className="input-group">
                              <label className="input-label">IMEI GPS Baru (IMEI Barcode) *</label>
                              <div style={{display: 'flex', gap: 8}}>
                                <input type="text" value={gpsImeiBaru} onChange={e => setGpsImeiBaru(e.target.value)} className="input-field" placeholder="Masukkan IMEI GPS baru" />
                                <button type="button" className="btn btn-secondary btn-sm" onClick={() => startScanning('gpsImei')}><i className="bi bi-qr-code"></i> Scan</button>
                              </div>
                            </div>



                            <div className="input-group">
                              <label className="input-label">Catatan Pemasangan</label>
                              <textarea value={catatanPasang} onChange={e => setCatatanPasang(e.target.value)} placeholder="Catatan lokasi penempatan GPS, dll..." rows="2" />
                            </div>
                          </div>

                          {/* Navigation buttons */}
                          <div style={{marginTop: 24, display: 'flex', gap: 10}}>
                            <button type="button" className="teknisi-btn-secondary" onClick={goBackToList}>Tutup</button>
                            <button type="button" className="teknisi-btn-danger-outline" onClick={() => releaseClaim(activeUnit)}>Batal Klaim</button>
                            <button 
                              type="button"
                              className="btn btn-primary" 
                              style={{flex: 1.5, background: '#5850EC', border: 'none'}}
                              onClick={() => {
                                if (!String(noGpsLama || '').trim()) {
                                  globalAddToast('Kesalahan: Kolom No GPS Lama wajib diisi!', 'danger');
                                  return;
                                }
                                if (!String(gpsSerialBaru || '').trim()) {
                                  globalAddToast('Kesalahan: Kolom Serial GPS Baru wajib diisi!', 'danger');
                                  return;
                                }
                                if (!String(gpsImeiBaru || '').trim()) {
                                  globalAddToast('Kesalahan: Kolom IMEI GPS Baru wajib diisi!', 'danger');
                                  return;
                                }
                                setActiveStep(2);
                              }}
                            >
                              Lanjut &rarr;
                            </button>
                          </div>
                        </div>
                      )}

                      {activeStep === 2 && (
                        <div className="form-section" style={{borderTop: 'none', marginTop: 0, paddingTop: 0}}>
                          <div className="form-section-title">Step 2: Pengujian Fitur</div>
                          
                          {isWingboxUnit && (
                            <div className="teknisi-wingbox-alert">
                              <i className="bi bi-exclamation-triangle"></i>
                              <div>
                                <strong>Unit Wingbox Terdeteksi:</strong> Sensor Wingbox wajib Terpasang agar dapat menyelesaikan migrasi.
                              </div>
                            </div>
                          )}

                          <div style={{display: 'flex', flexDirection: 'column', gap: 14}}>
                            <div className="input-group">
                              <label className="input-label">Model GPS Baru</label>
                              <div className="teknisi-btn-group">
                                {['GEOTAB', 'SMA-TRACK'].map(m => (
                                  <button 
                                    type="button"
                                    key={m} 
                                    className={`teknisi-btn-option ${modelGpsBaru === m ? 'active' : ''}`}
                                    onClick={() => setModelGpsBaru(m)}
                                  >
                                    {m}
                                  </button>
                                ))}
                              </div>
                            </div>

                            <div className="input-group">
                              <label className="input-label">GPS Status *</label>
                              <div className="teknisi-btn-group">
                                {['TERPASANG', 'TIDAK TERPASANG'].map(opt => (
                                  <button 
                                    type="button"
                                    key={opt} 
                                    className={`teknisi-btn-option ${gps === opt ? (opt === 'TERPASANG' ? 'active' : 'active danger') : ''}`}
                                    onClick={() => setGps(opt)}
                                  >
                                    {opt}
                                  </button>
                                ))}
                              </div>
                            </div>

                            <div className="input-group">
                              <label className="input-label">Buzzer *</label>
                              <div className="teknisi-btn-group">
                                {['TERPASANG', 'TIDAK TERPASANG'].map(opt => (
                                  <button 
                                    type="button"
                                    key={opt} 
                                    className={`teknisi-btn-option ${buzzer === opt ? (opt === 'TERPASANG' ? 'active' : 'active danger') : ''}`}
                                    onClick={() => setBuzzer(opt)}
                                  >
                                    {opt}
                                  </button>
                                ))}
                              </div>
                            </div>

                            <div className="input-group">
                              <label className="input-label">Tombol SOS *</label>
                              <div className="teknisi-btn-group">
                                {['TERPASANG', 'TIDAK TERPASANG'].map(opt => (
                                  <button 
                                    type="button"
                                    key={opt} 
                                    className={`teknisi-btn-option ${sos === opt ? (opt === 'TERPASANG' ? 'active' : 'active danger') : ''}`}
                                    onClick={() => setSos(opt)}
                                  >
                                    {opt}
                                  </button>
                                ))}
                              </div>
                            </div>

                            {isWingboxUnit && (
                            <div className="input-group">
                              <label className="input-label" style={{ textTransform: 'uppercase' }}>Sensor Wingbox</label>
                              <div className="teknisi-btn-group">
                                {['TERPASANG', 'TIDAK TERPASANG'].map(opt => {
                                  const isActive = sensorWing === opt;
                                  const activeClass = opt === 'TIDAK TERPASANG' ? 'active danger' : 'active';
                                  return (
                                    <button 
                                      type="button"
                                      key={opt} 
                                      className={`teknisi-btn-option ${isActive ? activeClass : ''}`}
                                      style={{ textTransform: 'uppercase' }}
                                      onClick={() => setSensorWing(opt)}
                                    >
                                      {opt}
                                    </button>
                                  );
                                })}
                              </div>
                            </div>
                            )}

                            <div className="input-group">
                              <label className="input-label" style={{ textTransform: 'uppercase' }}>Camera Status *</label>
                              <div className="teknisi-btn-group">
                                {['TERPASANG', 'TIDAK TERPASANG'].map(opt => {
                                  const isActive = camera === opt;
                                  const activeClass = opt === 'TIDAK TERPASANG' ? 'active danger' : 'active';
                                  return (
                                    <button 
                                      type="button"
                                      key={opt} 
                                      className={`teknisi-btn-option ${isActive ? activeClass : ''}`}
                                      style={{ textTransform: 'uppercase' }}
                                      onClick={() => setCamera(opt)}
                                    >
                                      {opt}
                                    </button>
                                  );
                                })}
                              </div>
                            </div>
                          </div>

                          {/* Navigation buttons */}
                          <div style={{marginTop: 24, display: 'flex', gap: 10}}>
                            <button type="button" className="btn btn-secondary" style={{flex: 1}} onClick={() => setActiveStep(1)}>&larr; Kembali</button>
                            <button 
                              type="button"
                              className="btn btn-primary" 
                              style={{flex: 1.5, background: '#5850EC', border: 'none'}}
                              onClick={() => {
                                if (gps !== 'TERPASANG') {
                                  globalAddToast('Kesalahan: GPS wajib Terpasang!', 'danger');
                                  return;
                                }
                                if (isWingboxUnit && sensorWing !== 'TERPASANG') {
                                  globalAddToast('Kesalahan: Unit adalah Wingbox! Sensor Wingbox wajib Terpasang!', 'danger');
                                  return;
                                }
                                setActiveStep(3);
                              }}
                            >
                              Lanjut &rarr;
                            </button>
                          </div>
                        </div>
                      )}

                      {activeStep === 3 && (
                        <div className="form-section" style={{borderTop: 'none', marginTop: 0, paddingTop: 0}}>
                          <div className="form-section-title">Step 3: Upload Foto Dokumentasi *</div>
                          <div className="photo-grid">
                            <div className="photo-card">
                              {fotoKendaraan ? (
                                <div style={{width:'100%'}}>
                                  <a href={fotoKendaraan} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '80px', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, border: '1px dashed #3B82F6', color: '#60A5FA' }}>
                                    <i className="bi bi-link-45deg" style={{ fontSize: 18, marginBottom: 4 }}></i>
                                    <span style={{ fontSize: 9, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO</span>
                                  </a>
                                  <button type="button" className="btn btn-secondary btn-sm" style={{marginTop: 6, color: '#EF4444', width: '100%', border: 'none', background: 'rgba(239,68,68,0.1)'}} onClick={() => setFotoKendaraan('')}>Hapus</button>
                                </div>
                              ) : (
                                <label style={{cursor: 'pointer', display: 'block', padding: '10px 0', width: '100%'}}>
                                  <i className="bi bi-camera" style={{fontSize: 18, color: '#94A3B8'}}></i>
                                  <span style={{display: 'block', fontSize: 9, fontWeight: 'bold', marginTop: 4, color: '#FFF'}}>Foto Kendaraan *</span>
                                  <span style={{display: 'block', fontSize: 7, color: '#94A3B8'}}>(Nopol Kelihatan)</span>
                                  <input type="file" accept="image/*" capture="environment" style={{display: 'none'}} onChange={e => handlePhotoChange('fotoKendaraan', e.target.files[0])} />
                                </label>
                              )}
                            </div>

                            <div className="photo-card">
                              {fotoGPSLama ? (
                                <div style={{width:'100%'}}>
                                  <a href={fotoGPSLama} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '80px', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, border: '1px dashed #3B82F6', color: '#60A5FA' }}>
                                    <i className="bi bi-link-45deg" style={{ fontSize: 18, marginBottom: 4 }}></i>
                                    <span style={{ fontSize: 9, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO</span>
                                  </a>
                                  <button type="button" className="btn btn-secondary btn-sm" style={{marginTop: 6, color: '#EF4444', width: '100%', border: 'none', background: 'rgba(239,68,68,0.1)'}} onClick={() => setFotoGPSLama('')}>Hapus</button>
                                </div>
                              ) : (
                                <label style={{cursor: 'pointer', display: 'block', padding: '10px 0', width:'100%'}}>
                                  <i className="bi bi-camera" style={{fontSize: 18, color: '#94A3B8'}}></i>
                                  <span style={{display: 'block', fontSize: 9, fontWeight: 'bold', marginTop: 4, color: '#FFF'}}>Foto GPS Lama *</span>
                                  <span style={{display: 'block', fontSize: 7, color: '#94A3B8'}}>(Dicabut)</span>
                                  <input type="file" accept="image/*" capture="environment" style={{display: 'none'}} onChange={e => handlePhotoChange('fotoGPSLama', e.target.files[0])} />
                                </label>
                              )}
                            </div>

                            <div className="photo-card">
                              {fotoGPSBaru ? (
                                <div style={{width:'100%'}}>
                                  <a href={fotoGPSBaru} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '80px', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, border: '1px dashed #3B82F6', color: '#60A5FA' }}>
                                    <i className="bi bi-link-45deg" style={{ fontSize: 18, marginBottom: 4 }}></i>
                                    <span style={{ fontSize: 9, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO</span>
                                  </a>
                                  <button type="button" className="btn btn-secondary btn-sm" style={{marginTop: 6, color: '#EF4444', width: '100%', border: 'none', background: 'rgba(239,68,68,0.1)'}} onClick={() => setFotoGPSBaru('')}>Hapus</button>
                                </div>
                              ) : (
                                <label style={{cursor: 'pointer', display: 'block', padding: '10px 0', width:'100%'}}>
                                  <i className="bi bi-camera" style={{fontSize: 18, color: '#94A3B8'}}></i>
                                  <span style={{display: 'block', fontSize: 9, fontWeight: 'bold', marginTop: 4, color: '#FFF'}}>Foto GPS Baru *</span>
                                  <span style={{display: 'block', fontSize: 7, color: '#94A3B8'}}>(Barcode SN Jelas)</span>
                                  <input type="file" accept="image/*" capture="environment" style={{display: 'none'}} onChange={e => handlePhotoChange('fotoGPSBaru', e.target.files[0])} />
                                </label>
                              )}
                            </div>

                            <div className="photo-card">
                              {fotoHasilInstalasi ? (
                                <div style={{width:'100%'}}>
                                  <a href={fotoHasilInstalasi} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '80px', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, border: '1px dashed #3B82F6', color: '#60A5FA' }}>
                                    <i className="bi bi-link-45deg" style={{ fontSize: 18, marginBottom: 4 }}></i>
                                    <span style={{ fontSize: 9, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO</span>
                                  </a>
                                  <button type="button" className="btn btn-secondary btn-sm" style={{marginTop: 6, color: '#EF4444', width: '100%', border: 'none', background: 'rgba(239,68,68,0.1)'}} onClick={() => setFotoHasilInstalasi('')}>Hapus</button>
                                </div>
                              ) : (
                                <label style={{cursor: 'pointer', display: 'block', padding: '10px 0', width:'100%'}}>
                                  <i className="bi bi-camera" style={{fontSize: 18, color: '#94A3B8'}}></i>
                                  <span style={{display: 'block', fontSize: 9, fontWeight: 'bold', marginTop: 4, color: '#FFF'}}>Hasil Instalasi *</span>
                                  <span style={{display: 'block', fontSize: 7, color: '#94A3B8'}}>(Posisi Terpasang)</span>
                                  <input type="file" accept="image/*" capture="environment" style={{display: 'none'}} onChange={e => handlePhotoChange('fotoHasilInstalasi', e.target.files[0])} />
                                </label>
                              )}
                            </div>

                            <div className="photo-card">
                              {fotoOdometer ? (
                                <div style={{width:'100%'}}>
                                  <a href={fotoOdometer} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '80px', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, border: '1px dashed #3B82F6', color: '#60A5FA' }}>
                                    <i className="bi bi-link-45deg" style={{ fontSize: 18, marginBottom: 4 }}></i>
                                    <span style={{ fontSize: 9, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO</span>
                                  </a>
                                  <button type="button" className="btn btn-secondary btn-sm" style={{marginTop: 6, color: '#EF4444', width: '100%', border: 'none', background: 'rgba(239,68,68,0.1)'}} onClick={() => setFotoOdometer('')}>Hapus</button>
                                </div>
                              ) : (
                                <label style={{cursor: 'pointer', display: 'block', padding: '10px 0', width:'100%'}}>
                                  <i className="bi bi-camera" style={{fontSize: 18, color: '#94A3B8'}}></i>
                                  <span style={{display: 'block', fontSize: 9, fontWeight: 'bold', marginTop: 4, color: '#FFF'}}>Foto Odometer *</span>
                                  <span style={{display: 'block', fontSize: 7, color: '#94A3B8'}}>(Angka Jelas)</span>
                                  <input type="file" accept="image/*" capture="environment" style={{display: 'none'}} onChange={e => handlePhotoChange('fotoOdometer', e.target.files[0])} />
                                </label>
                              )}
                            </div>
                          </div>

                          {/* Navigation buttons */}
                          <div style={{marginTop: 24, display: 'flex', gap: 10}}>
                            <button type="button" className="btn btn-secondary" style={{flex: 1}} onClick={() => setActiveStep(2)}>&larr; Kembali</button>
                            <button 
                              type="button"
                              className="btn btn-primary" 
                              style={{flex: 1.5, background: '#5850EC', border: 'none'}}
                              onClick={() => {
                                if (!fotoKendaraan) {
                                  globalAddToast('Kesalahan: Foto Kendaraan wajib diunggah!', 'danger');
                                  return;
                                }
                                if (!fotoGPSLama) {
                                  globalAddToast('Kesalahan: Foto GPS Lama wajib diunggah!', 'danger');
                                  return;
                                }
                                if (!fotoGPSBaru) {
                                  globalAddToast('Kesalahan: Foto GPS Baru wajib diunggah!', 'danger');
                                  return;
                                }
                                if (!fotoHasilInstalasi) {
                                  globalAddToast('Kesalahan: Foto Hasil Instalasi wajib diunggah!', 'danger');
                                  return;
                                }
                                if (!fotoOdometer) {
                                  globalAddToast('Kesalahan: Foto Odometer wajib diunggah!', 'danger');
                                  return;
                                }
                                setActiveStep(4);
                              }}
                            >
                              Lanjut &rarr;
                            </button>
                          </div>
                        </div>
                      )}

                      {activeStep === 4 && (
                        <div className="form-section" style={{borderTop: 'none', marginTop: 0, paddingTop: 0}}>
                          <div className="form-section-title">Step 4: Review Laporan Pemasangan</div>
                          
                          <div style={{background: 'rgba(255,255,255,0.02)', borderRadius: 8, padding: 12, border: '1px solid rgba(255,255,255,0.05)', display: 'flex', flexDirection: 'column', gap: 12, fontSize: 11}}>
                            
                            <div>
                              <div style={{color: '#64748B', fontWeight: 700, fontSize: 8, textTransform: 'uppercase', marginBottom: 2}}>Identitas Kendaraan & GPS</div>
                              <div style={{color: '#FFF'}}>{activeUnit.nopol} ({activeUnit.merk} {activeUnit.assetType})</div>
                              <div style={{color: '#94A3B8'}}>GPS Lama: <span style={{color: '#FFF', fontWeight: 600}}>{noGpsLama}</span></div>
                              <div style={{color: '#94A3B8'}}>GPS Baru (SN): <span style={{color: '#FFF', fontWeight: 600}}>{gpsSerialBaru}</span></div>
                              <div style={{color: '#94A3B8'}}>GPS Baru (IMEI): <span style={{color: '#FFF', fontWeight: 600}}>{gpsImeiBaru}</span></div>
                            </div>

                            <div style={{borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: 10}}>
                              <div style={{color: '#64748B', fontWeight: 700, fontSize: 8, textTransform: 'uppercase', marginBottom: 2}}>Pengujian Fitur & Status</div>
                              <div style={{display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 6}}>
                                <div style={{color: '#94A3B8'}}>Model GPS: <span style={{color: '#FFF'}}>{modelGpsBaru}</span></div>
                                <div style={{color: '#94A3B8'}}>Status Pasang: <span style={{color: '#F59E0B', fontWeight: 600}}>SUBMITTED</span></div>
                                <div style={{color: '#94A3B8'}}>GPS Status: <span style={{color: gps === 'TERPASANG' ? '#22C55E' : '#EF4444'}}>{gps}</span></div>
                                <div style={{color: '#94A3B8'}}>Buzzer: <span style={{color: buzzer === 'TERPASANG' ? '#22C55E' : '#EF4444'}}>{buzzer}</span></div>
                                <div style={{color: '#94A3B8'}}>Tombol SOS: <span style={{color: sos === 'TERPASANG' ? '#22C55E' : '#EF4444'}}>{sos}</span></div>
                                <div style={{color: '#94A3B8'}}>Sensor Wing: <span style={{color: sensorWing === 'TERPASANG' ? '#22C55E' : '#EF4444'}}>{sensorWing}</span></div>
                                <div style={{color: '#94A3B8'}}>Camera: <span style={{color: camera === 'OK' ? '#22C55E' : '#EF4444'}}>{camera}</span></div>
                              </div>
                            </div>

                            {catatanPasang.trim() && (
                              <div style={{borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: 10}}>
                                <div style={{color: '#64748B', fontWeight: 700, fontSize: 8, textTransform: 'uppercase', marginBottom: 2}}>Catatan Pemasangan</div>
                                <div style={{color: '#FFF', fontStyle: 'italic'}}>&ldquo;{catatanPasang}&rdquo;</div>
                              </div>
                            )}

                            <div style={{borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: 10}}>
                              <div style={{color: '#64748B', fontWeight: 700, fontSize: 8, textTransform: 'uppercase', marginBottom: 6}}>Dokumentasi Foto</div>
                              <div style={{display: 'grid', gridTemplateColumns: 'repeat(5, 1fr)', gap: 6}}>
                                <div style={{textAlign: 'center'}}>
                                  {fotoKendaraan ? (
                                    <a href={fotoKendaraan} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                                      <img src={fotoKendaraan} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Kendaraan" />
                                    </a>
                                  ) : '—'}
                                  <div style={{fontSize: 6, color: '#94A3B8', marginTop: 2}}>Kendaraan</div>
                                </div>
                                <div style={{textAlign: 'center'}}>
                                  {fotoGPSLama ? (
                                    <a href={fotoGPSLama} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                                      <img src={fotoGPSLama} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Lama" />
                                    </a>
                                  ) : '—'}
                                  <div style={{fontSize: 6, color: '#94A3B8', marginTop: 2}}>GPS Lama</div>
                                </div>
                                <div style={{textAlign: 'center'}}>
                                  {fotoGPSBaru ? (
                                    <a href={fotoGPSBaru} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                                      <img src={fotoGPSBaru} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Baru" />
                                    </a>
                                  ) : '—'}
                                  <div style={{fontSize: 6, color: '#94A3B8', marginTop: 2}}>GPS Baru</div>
                                </div>
                                <div style={{textAlign: 'center'}}>
                                  {fotoHasilInstalasi ? (
                                    <a href={fotoHasilInstalasi} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                                      <img src={fotoHasilInstalasi} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Instalasi" />
                                    </a>
                                  ) : '—'}
                                  <div style={{fontSize: 6, color: '#94A3B8', marginTop: 2}}>Instalasi</div>
                                </div>
                                <div style={{textAlign: 'center'}}>
                                  {fotoOdometer ? (
                                    <a href={fotoOdometer} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                                      <img src={fotoOdometer} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Odometer" />
                                    </a>
                                  ) : '—'}
                                  <div style={{fontSize: 6, color: '#94A3B8', marginTop: 2}}>Odometer</div>
                                </div>
                              </div>
                            </div>

                          </div>

                          {/* Navigation buttons */}
                          <div style={{marginTop: 24, display: 'flex', gap: 10}}>
                            <button type="button" className="btn btn-secondary" style={{flex: 1}} onClick={() => setActiveStep(3)}>&larr; Kembali</button>
                            <button 
                              type="button"
                              className="btn btn-primary" 
                              style={{flex: 2, background: '#22C55E', border: 'none'}}
                              disabled={loadingSubmit}
                              onClick={submitInstallation}
                            >
                              {loadingSubmit ? 'Mengirim...' : 'Kirim'}
                            </button>
                          </div>
                        </div>
                      )}
                    </div>
                </div>
              )}
            </div>
          )}

          {/* TAB 3: Riwayat (History) */}
          {subTab === 'history' && (
            <div>
              <div className="teknisi-hero-card">
                <div className="teknisi-hero-title" style={{color: '#10B981'}}>
                  <i className="bi bi-history" style={{fontSize: 18}}></i>
                  <span>Riwayat Pemasangan</span>
                </div>
                <p className="teknisi-hero-desc">
                  Berikut adalah daftar armada kendaraan yang telah selesai Anda pasang dan kirim ke IT.
                </p>
              </div>

              {!isMobile ? (
                <>
                  <FilterRow>
                    <div className="search-input-wrapper">
                      <i className="bi bi-search"></i>
                      <input 
                        type="text" 
                        value={q} 
                        onChange={e => setQ(e.target.value)} 
                        className="search-input"
                        placeholder="Cari NOPOL..." 
                      />
                    </div>
                    <select value={loc} onChange={e => setLoc(e.target.value)} className="filter-select">
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                    <span className="unit-count-tag">{historyUnits.length} Riwayat</span>
                  </FilterRow>

                  {historyUnits.length === 0 ? (
                    <div style={{ textAlign: 'center', padding: 48, color: 'var(--text-tertiary)', background: 'var(--bg-card)', borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)', marginTop: 12 }}>
                      <i className="bi bi-list-check" style={{ fontSize: 32, display: 'block', marginBottom: 10, color: 'var(--text-tertiary)' }}></i>
                      Belum ada riwayat pemasangan GPS yang Anda laporkan.
                    </div>
                  ) : (
                    <div className="table-container" style={{ marginTop: 12 }}>
                      <table className="data-table">
                        <thead>
                          <tr>
                            <th style={{ width: '50px' }}>#</th>
                            <th style={{ width: '120px' }}>NOPOL</th>
                            <th style={{ width: '150px' }}>SITE / POOL</th>
                            <th style={{ width: '120px' }}>TIPE GPS</th>
                            <th style={{ width: '150px' }}>SN GPS BARU</th>
                            <th style={{ width: '180px' }}>SIM CARD</th>
                            <th style={{ width: '180px' }}>TANGGAL SELESAI</th>
                            <th style={{ width: '120px', textAlign: 'center' }}>STATUS</th>
                            <th style={{ width: '200px', textAlign: 'center' }}>AKSI</th>
                          </tr>
                        </thead>
                        <tbody>
                          {historyUnits.map((u, idx) => (
                            <tr key={u.id}>
                              <td>{idx + 1}</td>
                              <td><strong>{u.nopol}</strong></td>
                              <td>{u.pool || u.location}</td>
                              <td>{u.modelGpsBaru || 'GEOTAB'}</td>
                              <td><code>{u.gpsSerialBaru}</code></td>
                              <td>
                                <div>{u.nomorSIM}</div>
                                <div style={{ fontSize: 10, color: 'var(--text-secondary)' }}>{u.provider}</div>
                              </td>
                              <td>{u.updatedAt}</td>
                              <td style={{ textAlign: 'center' }}><Badge val={u.statusPasang} /></td>
                              <td style={{ textAlign: 'center' }}>
                                <div style={{ display: 'flex', gap: 6, justifyContent: 'center' }}>
                                  <button 
                                    className="btn btn-secondary btn-sm"
                                    onClick={() => setHistoryReviewUnit(u)}
                                    style={{ gap: 4, display: 'inline-flex', alignItems: 'center' }}
                                  >
                                    <i className="bi bi-eye"></i> Detail
                                  </button>
                                  <button 
                                    className="btn btn-secondary btn-sm"
                                    onClick={() => downloadDOCReport(u, false)}
                                    style={{ gap: 4, display: 'inline-flex', alignItems: 'center' }}
                                    title="Unduh Laporan Word 1 Halaman"
                                  >
                                    <i className="bi bi-file-earmark-word"></i> Word
                                  </button>
                                </div>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </>
              ) : (
                <>
                  {historyUnits.map(u => (
                    <div key={u.id} className="teknisi-vehicle-card" style={{borderLeft: '4px solid #10B981'}}>
                      <div className="teknisi-card-header">
                        <span className="teknisi-card-label" style={{color: '#10B981'}}>SUCCESSFUL</span>
                        <span className="teknisi-pool-badge">{u.pool || u.location}</span>
                      </div>
                      <div className="teknisi-vehicle-nopol">{u.nopol}</div>
                      <div style={{fontSize: 11, color: 'var(--text-secondary)', display: 'flex', flexDirection: 'column', gap: 4, marginBottom: 12}}>
                        <div>Model GPS: <strong>{u.modelGpsBaru || 'GEOTAB'}</strong></div>
                        <div>SIM Card: <strong>{u.nomorSIM} ({u.provider})</strong></div>
                        <div>Tgl Selesai: <strong>{u.updatedAt}</strong></div>
                      </div>
                      <button 
                        className="btn btn-secondary btn-sm" 
                        style={{ width: '100%', justifyContent: 'center', background: 'var(--bg-secondary)', border: '1px solid var(--border-color)', height: 34, color: 'var(--text-primary)' }}
                        onClick={() => setHistoryReviewUnit(u)}
                      >
                        <i className="bi bi-eye" style={{marginRight: 4}}></i> Detail Pekerjaan & Foto
                      </button>
                    </div>
                  ))}

                  {historyUnits.length === 0 && (
                    <div style={{textAlign: 'center', padding: '30px 10px', background: 'var(--bg-secondary)', borderRadius: 16, border: '1px solid var(--border-color)', color: '#94A3B8', fontSize: 11}}>
                      Belum ada riwayat pemasangan GPS yang Anda laporkan.
                    </div>
                  )}

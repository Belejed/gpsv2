              )}
            </div>
          )}

          {/* HISTORY DETAIL REVIEW MODAL */}
          {historyReviewUnit && (
            <div className="modal-overlay" onClick={() => setHistoryReviewUnit(null)} style={{ zIndex: 99998 }}>
              <div className="modal-card" onClick={e => e.stopPropagation()} style={{ width: '92%', maxWidth: '480px' }}>
                <div className="modal-drag-handle"></div>
                <div className="modal-header">
                  <span className="modal-title" style={{ fontSize: 14 }}>
                    <i className="bi bi-history" style={{ marginRight: 6, color: '#10B981' }}></i>
                    Review Pekerjaan: {historyReviewUnit.nopol}
                  </span>
                  <button className="modal-close" onClick={() => setHistoryReviewUnit(null)}><i className="bi bi-x"></i></button>
                </div>
                <div className="modal-body" style={{ display: 'flex', flexDirection: 'column', gap: 14, maxHeight: 'calc(100vh - 220px)', overflowY: 'auto', padding: '16px 20px' }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                    <span style={{ fontSize: 11, color: '#94A3B8' }}>Status Registrasi:</span>
                    <Badge val={historyReviewUnit.statusPasang} />

    let globalAddToast = () => {};

    // Helper untuk mengonversi Google Drive file URL menjadi thumbnail image URL
    function getImageUrl(val) {
      if (!val) return '';
      if (val.indexOf('data:image/') === 0) {
        return val;
      }
      if (val.indexOf('http') === 0) {
        const match = val.match(/(?:id=|\/d\/)([a-zA-Z0-9-_]{25,50})/);
        if (match && match[1]) {
          return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w300`;
        }
        return val;
      }
      return '';
    }

    // Helper functions
    function mapFromSheet(json) {
      if (!json || !Array.isArray(json.data)) return [];
      return json.data.map((u, i) => {
        const nopol = u['NOPOL'] || u['nopol'] || '';
        const ownership = u['OWNERSHIP'] || u['ownership'] || '';
        const year = u['YEAR'] || u['year'] || '';
        const merk = u['MERK'] || u['merk'] || '';
        const assetType = u['ASSET TYPE'] || u['MODEL'] || u['assetType'] || '';
        const location = u['BUSINESS LOCATION'] || u['LOCATION'] || u['location'] || '';
        const pool = u['BUSINESS POOL'] || u['POOL'] || u['pool'] || '';
        const dedicate = u['BUSINESS DEDICATE'] || u['DEDICATE'] || u['dedicate'] || '';
        const planDate = u['PLAN PASANG'] || u['PLAN_TGL'] || u['planDate'] || '';
        const lokasiPasang = u['LOKASI PASANG'] || u['LOKASI_PASANG'] || u['lokasiPasang'] || '';
        const picLapangan = u['PIC LAPANGAN'] || u['picLapangan'] || '';
        const teknisiPelaksana = u['TEKNISI PELAKSANA'] || u['TEKNISI_PELAKSANA'] || u['TEKNISI'] || '';
        const modelGpsBaru = u['TIPE GPS BARU'] || u['MODEL_GPS_BARU'] || '';
        const gpsSerialBaru = u['SN GPS BARU'] || u['gpsSerialBaru'] || '';
        const gpsImeiBaru = u['IMEI GPS BARU'] || u['gpsImeiBaru'] || '';
        const nomorSIM = u['NOMOR KARTU GPS BARU'] || u['nomorSIM'] || '';
        const provider = u['PROVIDER SIM GPS BARU'] || u['provider'] || '';
        const gps = u['GPS'] || '';
        const buzzer = u['BUZZER'] || '';
        const sos = u['SOS'] || '';
        const sensorWing = u['SENSOR WING'] || u['SENSOR_WING'] || '';
        const camera = u['CAMERA'] || '';
        const fotoKendaraan = u['FOTO KENDARAAN (NOPOL)'] || u['FOTO_KENDARAAN'] || '';
        const fotoGPSLama = u['FOTO SERIAL GPS LAMA (DICABUT)'] || u['FOTO_GPS_LAMA'] || '';
        const fotoGPSBaru = u['FOTO GPS BARU (SN TERLIHAT)'] || u['FOTO_GPS_BARU'] || '';
        const fotoHasilInstalasi = u['FOTO HASIL INSTALASI'] || u['FOTO_HASIL_INSTALASI'] || '';
        const fotoOdometer = u['FOTO ODOMETER'] || u['fotoOdometer'] || u['FOTO_ODOMETER'] || '';
        const statusPasang = u['STATUS REGISTRASI'] || u['STATUS_PASANG'] || 'BELUM DIPASANG';
        const picCekFisikLama = u['CEK FISIK GPS LAMA'] || u['CEK_FISIK_GPS_LAMA'] || '';
        const picCekFisikBaru = u['CEK FISIK GPS BARU'] || u['CEK_FISIK_GPS_BARU'] || '';
        const picCekKondisiSelesai = u['CEK KONDISI UNIT SELESAI INSTALASI'] || u['CEK_KONDISI_UNIT_SELESAI_INSTALASI'] || '';
        const picCekFitur = u['CEK FITUR (SENSOR, SOS, CAMERA)'] || u['CEK_FITUR_SENSOR_SOS_CAMERA'] || '';
        const picFotoSerahTerima = u['FOTO BUKTI PENYERAHAN GPS LAMA'] || u['FOTO_BUKTI_PENYERAHAN_GPS_LAMA'] || '';
        const itCekAplikasi = u['CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT'] || u['CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK)'] || '';
        const itFotoIntegrasi = u['FOTO INTEGRASI DATA GPS KE PUNINAR'] || u['FOTO_INTEGRASI_DATA_GPS_KE_PUNINAR'] || '';
        const itFotoAbnormality = u['FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR'] || u['FOTO_INTEGRASI_DATA_ABNORMALITY_KE_PUNINAR'] || '';
        const cmtCekAplikasi = u['CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT'] || '';
        const cmtFotoTerimaFisik = u['FOTO TERIMA FISIK GPS LAMA'] || u['FOTO_TERIMA_FISIK_GPS_LAMA'] || '';
        const cmtFotoTerminasi = u['FOTO BUKTI TERMINASI GPS LAMA'] || u['FOTO_BUKTI_TERMINASI_GPS_LAMA'] || '';
        const updatedAt = u['LAST_UPDATE'] || u['updatedAt'] || '';
        const easygoDicopot = u['STATUS_EASYGO_DICOPOT'] || '';
        const statusPlan = (planDate) ? 'PLAN' : 'UNPLAN';

        return {
          id: i + 1,
          rowIndex: u.rowIndex,
          ownership,
          nopol,
          year,
          merk,
          assetType,
          location,
          pool,
          dedicate,
          planDate,
          lokasiPasang,
          picLapangan,

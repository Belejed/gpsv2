                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10, background: 'var(--bg-secondary)', padding: 12, borderRadius: 8, border: '1px solid var(--border-color)', fontSize: 11 }}>
                    <div>Nopol: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.nopol}</strong></div>
                    <div>Tipe: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.merk || '—'} {historyReviewUnit.assetType || '—'}</strong></div>
                    <div>Site: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.location || '—'}</strong></div>
                    <div>Pool: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.pool || '—'}</strong></div>
                    <div>SIM: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.nomorSIM || '—'}</strong></div>
                    <div>Provider: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.provider || '—'}</strong></div>
                    <div style={{ gridColumn: 'span 2' }}>Tgl Selesai: <strong style={{ color: 'var(--text-primary)' }}>{historyReviewUnit.updatedAt || '—'}</strong></div>
                  </div>

                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10, background: 'var(--bg-secondary)', padding: 12, borderRadius: 8, border: '1px solid var(--border-color)', fontSize: 11 }}>
                    <div style={{ gridColumn: 'span 2' }}>
                      <span style={{ color: '#94A3B8' }}>Model GPS Baru:</span>
                      <div style={{ fontWeight: 700, fontSize: 12, color: '#FFF', marginTop: 2 }}>{historyReviewUnit.modelGpsBaru || 'GEOTAB'}</div>
                    </div>
                    <div>
                      <span style={{ color: '#94A3B8' }}>SN GPS Lama:</span>
                      <div style={{ fontWeight: 600, fontFamily: 'monospace', color: '#FFF' }}>{historyReviewUnit.gpsSerialLama || '—'}</div>
                    </div>
                    <div>
                      <span style={{ color: '#94A3B8' }}>SN GPS Baru:</span>
                      <div style={{ fontWeight: 600, fontFamily: 'monospace', color: '#FFF' }}>{historyReviewUnit.gpsSerialBaru || '—'}</div>
                    </div>
                    <div style={{ gridColumn: 'span 2' }}>
                      <span style={{ color: '#94A3B8' }}>IMEI GPS Baru:</span>
                      <div style={{ fontWeight: 600, fontFamily: 'monospace', color: '#FFF' }}>{historyReviewUnit.gpsImeiBaru || '—'}</div>
                    </div>
                  </div>

                  {historyReviewUnit.catatanPasang && (
                    <div style={{ background: 'var(--bg-secondary)', padding: 12, borderRadius: 8, border: '1px solid var(--border-color)', fontSize: 11 }}>
                      <span style={{ color: '#94A3B8', display: 'block', marginBottom: 4 }}>Catatan Pemasangan:</span>
                      <div style={{ color: '#FFF', fontStyle: 'italic' }}>&ldquo;{historyReviewUnit.catatanPasang}&rdquo;</div>
                    </div>
                  )}

                  <div style={{ background: 'var(--bg-secondary)', padding: 12, borderRadius: 8, border: '1px solid var(--border-color)' }}>
                    <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 8, textTransform: 'uppercase' }}>Pengujian Fitur</span>
                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8, overflowX: 'hidden' }}>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 8, color: '#94A3B8', display: 'block', marginBottom: 2 }}>GPS</span>
                        <Badge val={historyReviewUnit.gps} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 8, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Buzzer</span>
                        <Badge val={historyReviewUnit.buzzer} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 8, color: '#94A3B8', display: 'block', marginBottom: 2 }}>SOS</span>
                        <Badge val={historyReviewUnit.sos} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 8, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Wingbox</span>
                        <Badge val={historyReviewUnit.sensorWing} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 8, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Camera</span>
                        <Badge val={historyReviewUnit.camera} />
                      </div>
                    </div>
                  </div>

                  <div style={{ background: 'var(--bg-secondary)', padding: 12, borderRadius: 8, border: '1px solid var(--border-color)' }}>
                    <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 8, textTransform: 'uppercase' }}>Dokumentasi Foto</span>
                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(5, 1fr)', gap: 6 }}>
                      <div style={{ textAlign: 'center' }}>
                        {historyReviewUnit.fotoKendaraan ? (
                          <a href={historyReviewUnit.fotoKendaraan} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={historyReviewUnit.fotoKendaraan} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Kendaraan" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Kendaraan</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {historyReviewUnit.fotoGPSLama ? (
                          <a href={historyReviewUnit.fotoGPSLama} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={historyReviewUnit.fotoGPSLama} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Lama" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>GPS Lama</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {historyReviewUnit.fotoGPSBaru ? (
                          <a href={historyReviewUnit.fotoGPSBaru} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={historyReviewUnit.fotoGPSBaru} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Baru" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>GPS Baru</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {historyReviewUnit.fotoHasilInstalasi ? (
                          <a href={historyReviewUnit.fotoHasilInstalasi} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={historyReviewUnit.fotoHasilInstalasi} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Instalasi" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Instalasi</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {historyReviewUnit.fotoOdometer ? (
                          <a href={historyReviewUnit.fotoOdometer} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={historyReviewUnit.fotoOdometer} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Odometer" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Odometer</div>
                      </div>
                    </div>
                  </div>
                </div>
                <div className="modal-footer" style={{ borderTop: '1px solid rgba(255,255,255,0.08)' }}>
                  <button className="btn btn-secondary" style={{ width: '100%', height: 36 }} onClick={() => setHistoryReviewUnit(null)}>Tutup</button>
                </div>
              </div>
            </div>
          )}

          {/* BARCODE SCANNER MODAL VIEW */}
          {isScannerOpen && (
            <div style={{
              position: 'fixed',
              top: 0, left: 0, right: 0, bottom: 0,
              background: 'rgba(5,11,26,0.95)',
              zIndex: 99999,
              display: 'flex',
              justifyContent: 'center',
              alignItems: 'center',
              padding: 16
            }}>
              <div className="teknisi-vehicle-card" style={{width: '100%', maxWidth: 380, margin: 0}}>
                <div style={{display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 12, paddingBottom: 8, borderBottom: '1px solid rgba(255,255,255,0.08)'}}>
                  <strong style={{fontSize: 13, color: '#FFF'}}>Scan Barcode SN / IMEI</strong>
                  <button style={{background: 'none', border: 'none', color: '#94A3B8', cursor: 'pointer', fontSize: 18}} onClick={stopScanning}>
                    <i className="bi bi-x"></i>
                  </button>
                </div>
                <div id="scanner-view" style={{width: '100%', minHeight: 230, background: '#000', borderRadius: 8, overflow: 'hidden'}}></div>
                <div style={{display: 'flex', gap: 10, marginTop: 16}}>
                  <button className="btn btn-secondary" style={{flex: 1, height: 36}} onClick={simulateScan}>Simulasi Scan</button>
                  <button className="btn btn-secondary" style={{flex: 1, height: 36, color: '#EF4444'}} onClick={stopScanning}>Batal</button>
                </div>
              </div>
            </div>
          )}

          {/* Fixed Premium Bottom Navigation Bar (Matches screenshot layout) */}
          <div className="teknisi-nav-bar">
            <button 
              className={`teknisi-nav-item ${subTab === 'today' ? 'active' : ''}`} 
              onClick={() => {
                if (isScannerOpen) stopScanning();
                setSubTab('today');
              }}
            >
              <i className="bi bi-clipboard-data"></i>
              <span>Tugas</span>
            </button>
            <button 
              className={`teknisi-nav-item ${subTab === 'installations' ? 'active' : ''}`} 
              onClick={() => {
                if (isScannerOpen) stopScanning();
                setSubTab('installations');
              }}
            >
              <i className="bi bi-wrench"></i>
              <span>My Installs</span>
            </button>
            <button 
              className={`teknisi-nav-item ${subTab === 'history' ? 'active' : ''}`} 
              onClick={() => {
                if (isScannerOpen) stopScanning();
                setSubTab('history');
              }}
            >
              <i className="bi bi-check-circle"></i>
              <span>History</span>
            </button>
            <button 
              className="teknisi-nav-item" 
              onClick={handleLogout}
            >
              <i className="bi bi-box-arrow-right"></i>
              <span>Logout</span>
            </button>
          </div>
        </div>
      );
    }


    


    


    


    


    


    


    


    


    


    


    


    


    


    


    


    

    // 4. Verifikasi View

    

      

      

        // 4. Verifikasi View
    // 4. PIC Lapangan View
    function PICLapanganView({ units, setUnits, syncUpdate, isMobile }) {
      const { user, logout } = useContext(AuthContext);
      const nameMatch = user.name || user.username;

      const [subTab, setSubTab] = useState(() => {
        try {
          return localStorage.getItem('pic_active_subtab') || 'queue';
        } catch (e) {
          return 'queue';
        }
      });
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');
      const [page, setPage] = useState(1);
      const [loadingClaim, setLoadingClaim] = useState(false);
      const [loadingSubmit, setLoadingSubmit] = useState(false);
      const [picReviewUnit, setPicReviewUnit] = useState(null);

      // Form states
      const [picCekFisikLama, setPicCekFisikLama] = useState('OK');
      const [picCekFisikBaru, setPicCekFisikBaru] = useState('OK');
      const [picCekKondisiSelesai, setPicCekKondisiSelesai] = useState('OK');
      const [picCekFitur, setPicCekFitur] = useState('OK');
      const [picFotoSerahTerima, setPicFotoSerahTerima] = useState('');

      // Filtering units based on sub-tab
      const queueUnits = useMemo(() => {
        return units.filter(u => 
          u.statusPasang === 'TEKNISI SUBMITTED' &&
          (!u.picLapangan || u.picLapangan.trim() === '')
        );
      }, [units, nameMatch]);

      const claimedByOther = useMemo(() => {
        return units.filter(u =>
          u.statusPasang === 'TEKNISI SUBMITTED' &&
          u.picLapangan && u.picLapangan.trim() !== '' &&
          u.picLapangan.toLowerCase() !== nameMatch.toLowerCase()
        );
      }, [units, nameMatch]);

      const myClaimsUnits = useMemo(() => {
        return units.filter(u => 
          u.statusPasang === 'TEKNISI SUBMITTED' &&
          u.picLapangan && u.picLapangan.toLowerCase() === nameMatch.toLowerCase()
        );
      }, [units, nameMatch]);

      const myHistoryUnits = useMemo(() => {
        return units.filter(u => 
          u.picLapangan && u.picLapangan.toLowerCase() === nameMatch.toLowerCase() &&
          ['PIC VERIFIED', 'IT VERIFIED', 'DONE'].includes(u.statusPasang)
        );
      }, [units, nameMatch]);

      const activeClaimUnit = myClaimsUnits[0];

      // Save subTab to localStorage
      useEffect(() => {
        try {
          localStorage.setItem('pic_active_subtab', subTab);
        } catch (e) {}
      }, [subTab]);

      // Load draft when activeClaimUnit changes
      useEffect(() => {
        if (activeClaimUnit) {
          try {
            const savedForm = localStorage.getItem('active_pic_form_' + activeClaimUnit.id);
            if (savedForm) {
              const parsed = JSON.parse(savedForm);
              setPicCekFisikLama(parsed.picCekFisikLama || 'OK');
              setPicCekFisikBaru(parsed.picCekFisikBaru || 'OK');
              setPicCekKondisiSelesai(parsed.picCekKondisiSelesai || 'OK');
              setPicCekFitur(parsed.picCekFitur || 'OK');
              setPicFotoSerahTerima(parsed.picFotoSerahTerima || '');
              return;
            }
          } catch (e) {}

          // Fallback to unit values
          setPicCekFisikLama(activeClaimUnit.picCekFisikLama || 'OK');
          setPicCekFisikBaru(activeClaimUnit.picCekFisikBaru || 'OK');
          setPicCekKondisiSelesai(activeClaimUnit.picCekKondisiSelesai || 'OK');
          setPicCekFitur(activeClaimUnit.picCekFitur || 'OK');
          setPicFotoSerahTerima(activeClaimUnit.picFotoSerahTerima || '');
        }
      }, [activeClaimUnit]);

      // Save draft whenever form values change
      useEffect(() => {
        if (activeClaimUnit) {
          try {
            const stateToSave = {
              picCekFisikLama,
              picCekFisikBaru,
              picCekKondisiSelesai,
              picCekFitur,
              picFotoSerahTerima
            };
            localStorage.setItem('active_pic_form_' + activeClaimUnit.id, JSON.stringify(stateToSave));
          } catch (e) {}
        }
      }, [activeClaimUnit, picCekFisikLama, picCekFisikBaru, picCekKondisiSelesai, picCekFitur, picFotoSerahTerima]);

      // Active list based on selected subTab (queue, history)
      const activeList = useMemo(() => {
        let baseList = [];
        if (subTab === 'queue') baseList = queueUnits;
        else if (subTab === 'history') baseList = myHistoryUnits;

        // Apply search query and location filters
        return baseList.filter(u => 
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc)
        );
      }, [subTab, queueUnits, myHistoryUnits, q, loc]);

      const total = Math.ceil(activeList.length / PAGE_LIMIT);
      const slice = activeList.slice((page - 1) * PAGE_LIMIT, page * PAGE_LIMIT);

      const claimUnit = async (u) => {
        const hasActiveClaim = units.some(unit => 
          unit.statusPasang === 'TEKNISI SUBMITTED' &&
          unit.picLapangan && unit.picLapangan.toLowerCase() === nameMatch.toLowerCase()
        );
        if (hasActiveClaim) {
          globalAddToast('Selesaikan tugas klaim aktif Anda terlebih dahulu!', 'warning');
          return;
        }

        setLoadingClaim(true);
        globalAddToast('Memeriksa ketersediaan unit...', 'info');
        try {
          // Server-side concurrency check
          let freshPicClaimer = '';
          try {
            const res = await fetch(WEBAPP_URL);
            const json = await res.json();
            if (json.success) {
              const fresh = json.data.find(row => (row.NOPOL || row.nopol || '').toUpperCase() === u.nopol.toUpperCase());
              freshPicClaimer = fresh ? (fresh['PIC LAPANGAN'] || fresh.PIC_LAPANGAN || '') : '';
            }
          } catch (fetchErr) {
            console.warn('Server check failed, proceeding with local state:', fetchErr);
          }

          if (freshPicClaimer && freshPicClaimer.trim() !== '') {
            globalAddToast(`Gagal: Unit ini sudah diklaim oleh PIC ${freshPicClaimer}!`, 'danger');
            setUnits(prev => prev.map(item => item.nopol === u.nopol ? { ...item, picLapangan: freshPicClaimer } : item));
            setLoadingClaim(false);
            return;
          }

          const updates = {
            "PIC LAPANGAN": nameMatch
          };
          await syncUpdate(u.nopol, updates);
          
          setUnits(prev => prev.map(item => item.nopol === u.nopol ? {
            ...item,
            picLapangan: nameMatch
          } : item));
          
          setSubTab('my_claims');
          setPicCekFisikLama('OK');
          setPicCekFisikBaru('OK');
          setPicCekKondisiSelesai('OK');
          setPicCekFitur('OK');
          setPicFotoSerahTerima('');

          globalAddToast(`Berhasil mengklaim unit ${u.nopol}!`, 'success');
        } catch (err) {
          console.error(err);
          globalAddToast('Gagal mengklaim unit: ' + String(err), 'danger');
        } finally {
          setLoadingClaim(false);
        }
      };

      const releaseClaim = async (u) => {
        if (!confirm(`Apakah Anda yakin ingin membatalkan klaim untuk unit ${u.nopol}?`)) {
          return;
        }

        setLoadingClaim(true);
        globalAddToast('Membatalkan klaim...', 'info');
        try {
          const updates = {
            "PIC LAPANGAN": ''
          };
          await syncUpdate(u.nopol, updates);
          
          setUnits(prev => prev.map(item => item.nopol === u.nopol ? {
            ...item,
            picLapangan: ''
          } : item));
          
          setSubTab('queue');
          globalAddToast(`Klaim unit ${u.nopol} berhasil dibatalkan!`, 'success');
        } catch (err) {
          console.error(err);
          globalAddToast('Gagal membatalkan klaim: ' + String(err), 'danger');
        } finally {
          setLoadingClaim(false);
        }
      };

      const handlePhotoChange = (file) => {
        if (!file) return;
        globalAddToast('Mengompresi foto...', 'info');
        const reader = new FileReader();
        reader.onload = (e) => {
          const originalBase64 = e.target.result;
          const img = new Image();
          img.onload = () => {
            try {
              const maxDim = 800;
              let w = img.width;
              let h = img.height;
              if (w > maxDim || h > maxDim) {
                if (w > h) {
                  h = Math.round((h * maxDim) / w);
                  w = maxDim;
                } else {
                  w = Math.round((w * maxDim) / h);
                  h = maxDim;
                }
              }
              const canvas = document.createElement('canvas');
              canvas.width = w;
              canvas.height = h;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, w, h);
              const compressedBase64 = canvas.toDataURL('image/jpeg', 0.7);
              setPicFotoSerahTerima(compressedBase64);
              globalAddToast('Foto berhasil ditambahkan!', 'success');
            } catch (canvasErr) {
              setPicFotoSerahTerima(originalBase64);
              globalAddToast('Foto berhasil ditambahkan (tanpa kompresi)!', 'success');
            }
          };
          img.onerror = () => {
            setPicFotoSerahTerima(originalBase64);
            globalAddToast('Foto berhasil ditambahkan!', 'success');
          };
          img.src = originalBase64;
        };
        reader.readAsDataURL(file);
      };

      const save = async (id) => {
        const unit = units.find(u => u.id === id);
        if (!picFotoSerahTerima) {
          globalAddToast('Kesalahan: Foto bukti penyerahan GPS lama wajib diunggah!', 'danger');
          return;
        }

        setLoadingSubmit(true);
        globalAddToast('Mengunggah foto verifikasi ke server...', 'info');

        let urlFotoSerahTerima = picFotoSerahTerima;
        try {
          urlFotoSerahTerima = await uploadImageToSupabaseStorage(picFotoSerahTerima, unit.nopol, 'picFotoSerahTerima');
        } catch (e) {
          console.warn("Upload storage gagal, menggunakan base64 fallback:", e);
        }

        const now = new Date();
        const dd = n => String(n).padStart(2, '0');
        const ts = `${now.getFullYear()}-${dd(now.getMonth() + 1)}-${dd(now.getDate())} ${dd(now.getHours())}:${dd(now.getMinutes())}`;

        const updates = {
          "STATUS REGISTRASI": 'PIC VERIFIED',
          "CEK FISIK GPS LAMA": picCekFisikLama,
          "CEK FISIK GPS BARU": picCekFisikBaru,
          "CEK KONDISI UNIT SELESAI INSTALASI": picCekKondisiSelesai,
          "CEK FITUR (SENSOR, SOS, CAMERA)": picCekFitur,
          "FOTO BUKTI PENYERAHAN GPS LAMA": urlFotoSerahTerima,
          "PIC LAPANGAN": nameMatch
        };

        try {
          await syncUpdate(unit.nopol, updates);
          setUnits(prev => prev.map(u => u.id === id ? {
            ...u,
            statusPasang: 'PIC VERIFIED',
            picCekFisikLama,
            picCekFisikBaru,
            picCekKondisiSelesai,
            picCekFitur,
            picFotoSerahTerima: urlFotoSerahTerima,
            picLapangan: nameMatch,
            updatedAt: ts
          } : u));
          
          // Clear draft from localStorage
          try {
            localStorage.removeItem('active_pic_form_' + id);
          } catch (e) {}

          setSubTab('history');
          globalAddToast(`Verifikasi PIC Lapangan NOPOL ${unit.nopol} berhasil dikirim!`, 'success');
        } catch (err) {
          console.error(err);
          globalAddToast('Gagal mengirim verifikasi: ' + String(err), 'danger');
        } finally {
          setLoadingSubmit(false);
        }
      };

      const handleLogout = () => {
        if (confirm('Apakah Anda yakin ingin logout?')) {
          logout();
        }
      };

      const initials = useMemo(() => {
        if (!nameMatch) return 'PC';
        const parts = nameMatch.trim().split(/\s+/);
        if (parts.length === 1) return parts[0].substring(0, 2).toUpperCase();
        return (parts[0][0] + parts[1][0]).toUpperCase();
      }, [nameMatch]);

      return (
        <div className="teknisi-wrapper">
          {/* Top Navigation for Desktop */}
          {!isMobile && (
            <div style={{ display: 'flex', gap: 10, marginBottom: 20, borderBottom: '1px solid var(--border-color)', paddingBottom: 12 }}>
              <button 
                className={`btn ${subTab === 'queue' ? 'btn-primary' : 'btn-secondary'}`}
                onClick={() => { setSubTab('queue'); setPage(1); }}
                style={{ display: 'flex', alignItems: 'center', gap: 8, height: 38, padding: '0 16px', fontSize: 13, fontWeight: 600 }}
              >
                <i className="bi bi-clipboard-data" style={{ fontSize: 16 }}></i>
                Antrean
              </button>
              <button 
                className={`btn ${subTab === 'my_claims' ? 'btn-primary' : 'btn-secondary'}`}
                onClick={() => { setSubTab('my_claims'); setPage(1); }}
                style={{ display: 'flex', alignItems: 'center', gap: 8, height: 38, padding: '0 16px', fontSize: 13, fontWeight: 600 }}
              >
                <i className="bi bi-clipboard-check" style={{ fontSize: 16 }}></i>
                Klaim Aktif
              </button>
              <button 
                className={`btn ${subTab === 'history' ? 'btn-primary' : 'btn-secondary'}`}
                onClick={() => { setSubTab('history'); setPage(1); }}
                style={{ display: 'flex', alignItems: 'center', gap: 8, height: 38, padding: '0 16px', fontSize: 13, fontWeight: 600 }}
              >
                <i className="bi bi-history" style={{ fontSize: 16 }}></i>
                Riwayat
              </button>
            </div>
          )}
          {/* Header Bar */}
          <div className="teknisi-header" style={{ display: isMobile ? 'flex' : 'none' }}>
            <div className="teknisi-profile">
              <div className="teknisi-avatar" style={{ background: '#059669' }}>
                {initials}
              </div>
              <div className="teknisi-profile-info">
                <span className="teknisi-name">{nameMatch}</span>
                <span className="teknisi-role">PIC Lapangan</span>
              </div>
            </div>
            
            <div className="teknisi-header-right">
              <div className="teknisi-status-pill" style={{ background: 'rgba(16,185,129,0.1)', color: '#10B981' }}>
                <i className="bi bi-shield-check teknisi-status-icon"></i>
                <span>PIC ROLE</span>
              </div>
            </div>
          </div>

          {/* TAB 1: Antrean (queue) */}
          {subTab === 'queue' && (
            <div>
              {/* Hero Banner Card */}
              <div className="teknisi-hero-card" style={{ background: 'linear-gradient(135deg, #1E1B4B 0%, #0F172A 100%)' }}>
                <div className="teknisi-hero-title">
                  <i className="bi bi-clipboard-data" style={{fontSize: 18}}></i>
                  <span>Unit Siap Diverifikasi</span>
                </div>
                <p className="teknisi-hero-desc">
                  Kendaraan yang sudah selesai dipasang GPS oleh teknisi dan menunggu verifikasi fisik PIC Lapangan.
                </p>
                <div style={{ display: 'flex', gap: 12, marginTop: 10 }}>
                  <div style={{ background: 'rgba(16,185,129,0.12)', borderRadius: 8, padding: '6px 12px', textAlign: 'center', flex: 1 }}>
                    <div style={{ fontSize: 18, fontWeight: 800, color: '#10B981' }}>{queueUnits.length}</div>
                    <div style={{ fontSize: 9, color: '#6EE7B7', textTransform: 'uppercase', fontWeight: 600 }}>Tersedia</div>
                  </div>
                  {claimedByOther.length > 0 && (
                    <div style={{ background: 'rgba(245,158,11,0.1)', borderRadius: 8, padding: '6px 12px', textAlign: 'center', flex: 1 }}>
                      <div style={{ fontSize: 18, fontWeight: 800, color: '#F59E0B' }}>{claimedByOther.length}</div>
                      <div style={{ fontSize: 9, color: '#FCD34D', textTransform: 'uppercase', fontWeight: 600 }}>Diklaim PIC Lain</div>
                    </div>
                  )}
                  <div style={{ background: 'rgba(99,102,241,0.1)', borderRadius: 8, padding: '6px 12px', textAlign: 'center', flex: 1 }}>
                    <div style={{ fontSize: 18, fontWeight: 800, color: '#818CF8' }}>{myClaimsUnits.length}</div>
                    <div style={{ fontSize: 9, color: '#A5B4FC', textTransform: 'uppercase', fontWeight: 600 }}>Klaim Saya</div>
                  </div>
                </div>
              </div>

              {/* Search & Site Filter */}
              {!isMobile ? (
                <>
                  <FilterRow>
                    <div className="search-input-wrapper">
                      <i className="bi bi-search"></i>
                      <input 
                        type="text" 
                        value={q} 
                        onChange={e => { setQ(e.target.value); setPage(1); }} 
                        className="search-input"
                        placeholder="Cari NOPOL..." 
                      />
                    </div>
                    <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                    <span className="unit-count-tag">{activeList.length} Antrean</span>
                  </FilterRow>

                  {activeList.length === 0 ? (
                    <div style={{ textAlign: 'center', padding: 48, color: 'var(--text-tertiary)', background: 'var(--bg-card)', borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)', marginTop: 12 }}>
                      <i className="bi bi-list-check" style={{ fontSize: 32, display: 'block', marginBottom: 10, color: 'var(--text-tertiary)' }}></i>
                      {claimedByOther.length > 0
                        ? `Semua unit sedang diklaim PIC lain (${claimedByOther.length} unit). Tidak ada yang tersedia saat ini.`
                        : 'Tidak ada laporan teknisi yang menunggu klaim saat ini.'}
                    </div>
                  ) : (
                    <div className="table-container" style={{ marginTop: 12 }}>
                      <table className="data-table">
                        <thead>
                          <tr>
                            <th style={{ width: '50px' }}>#</th>
                            <th style={{ width: '120px' }}>NOPOL</th>
                            <th style={{ width: '150px' }}>SITE / POOL</th>
                            <th style={{ width: '180px' }}>DETAIL KENDARAAN</th>
                            <th style={{ width: '150px' }}>TEKNISI</th>
                            <th style={{ width: '150px' }}>SN GPS BARU</th>
                            <th style={{ width: '150px' }}>TGL PLAN</th>
                            <th style={{ width: '180px', textAlign: 'center' }}>AKSI</th>
                          </tr>
                        </thead>
                        <tbody>
                          {slice.map((u, idx) => (
                            <tr key={u.id}>
                              <td>{(page - 1) * PAGE_LIMIT + idx + 1}</td>
                              <td><strong>{u.nopol}</strong></td>
                              <td>{u.pool || u.location}</td>
                              <td>{u.ownership} • {u.merk} ({u.assetType})</td>
                              <td><strong>{u.teknisiPelaksana || '—'}</strong></td>
                              <td><code>{u.gpsSerialBaru || '—'}</code></td>
                              <td>{u.planDate || '—'}</td>
                              <td style={{ textAlign: 'center' }}>
                                <button 
                                  className="btn btn-primary btn-sm"
                                  disabled={loadingClaim}
                                  onClick={() => claimUnit(u)}
                                  style={{ gap: 6, display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: '100%' }}
                                >
                                  <i className="bi bi-hand-index-fill"></i> Klaim Verifikasi
                                </button>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </>
              ) : (
                <>
                  <div style={{marginBottom: 12, display: 'flex', gap: 8, flexWrap: 'wrap'}}>
                    <div className="search-input-wrapper" style={{flex: 1, minWidth: 160}}>
                      <i className="bi bi-search"></i>
                      <input 
                        type="text" 
                        value={q} 
                        onChange={e => { setQ(e.target.value); setPage(1); }} 
                        className="search-input"
                        placeholder="Cari NOPOL..." 
                      />
                    </div>
                    <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select" style={{maxWidth: 140}}>
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                    <span className="unit-count-tag">{activeList.length} Unit</span>
                  </div>

                  {slice.map(u => (
                    <div key={u.id} className="teknisi-vehicle-card">
                      <div className="teknisi-card-header">
                        <span className="teknisi-card-label">NOMOR POLISI</span>
                        <span className="teknisi-pool-badge">
                          <i className="bi bi-geo-alt"></i> {u.pool || u.location || 'Nagrak Pool'}
                        </span>
                      </div>

                      <div className="teknisi-vehicle-nopol">
                        {u.nopol}
                      </div>
                      
                      <div style={{ fontSize: 11, color: 'var(--text-secondary)', marginBottom: 12, display: 'flex', flexDirection: 'column', gap: 4 }}>
                        <div>Tipe: <strong>{u.merk} {u.assetType}</strong></div>
                        <div>Teknisi: <strong>{u.teknisiPelaksana || '—'}</strong></div>
                        <div>GPS Baru: <code>{u.gpsSerialBaru || '—'}</code></div>
                        {u.planDate && <div>Tgl Plan: <strong>{u.planDate}</strong></div>}
                      </div>

                      <button 
                        className="teknisi-btn-play"
                        disabled={loadingClaim}
                        onClick={() => claimUnit(u)}
                      >
                        <i className="bi bi-hand-index"></i> Klaim Verifikasi
                      </button>
                    </div>
                  ))}

                  {activeList.length === 0 && (
                    <div style={{textAlign: 'center', padding: '30px 10px', background: 'var(--bg-secondary)', borderRadius: 16, border: '1px solid var(--border-color)', color: '#94A3B8', fontSize: 11}}>
                      <i className="bi bi-emoji-smile" style={{fontSize: 28, display: 'block', marginBottom: 8, color: '#10B981'}}></i>
                      {claimedByOther.length > 0
                        ? `Semua unit sedang diklaim PIC lain (${claimedByOther.length} unit). Tidak ada yang tersedia saat ini.`
                        : 'Tidak ada laporan teknisi yang menunggu klaim saat ini.'}
                    </div>
                  )}
                </>
              )}
              
              {activeList.length > 0 && <Pager page={page} total={total} onChange={p => setPage(p)} />}
            </div>
          )}

          {/* TAB 2: Klaim Saya / Klaim Aktif (my_claims) */}
          {subTab === 'my_claims' && (
            <div>
              {!activeClaimUnit ? (
                <div style={{textAlign: 'center', padding: '40px 20px', background: '#111827', borderRadius: 16, border: '1px solid rgba(255,255,255,0.05)', color: '#94A3B8', fontSize: 12}}>
                  <i className="bi bi-clipboard-check" style={{fontSize: 28, display: 'block', marginBottom: 10, color: '#059669'}}></i>
                  Tidak ada klaim aktif.<br />
                  Silakan pilih unit dari tab <strong>Antrean</strong> terlebih dahulu.
                </div>
              ) : (
                <div className="teknisi-vehicle-card" style={{margin: 0}}>
                  {/* Form Header */}
                  <div style={{display: 'flex', gap: 10, alignItems: 'center', marginBottom: 16, paddingBottom: 12, borderBottom: '1px solid rgba(255,255,255,0.08)'}}>
                    <button className="teknisi-btn-back" onClick={() => setSubTab('queue')} style={{background: 'none', border: 'none', color: '#94A3B8', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', width: 32, height: 32, borderRadius: '50%', background: 'rgba(255,255,255,0.03)'}}>
                      <i className="bi bi-arrow-left" style={{fontSize: 18}}></i>
                    </button>
                    <div>
                      <h3 style={{margin: 0, fontSize: 14, color: '#FFF'}}>Verifikasi Unit: {activeClaimUnit.nopol}</h3>
                      <span style={{fontSize: 10, color: '#94A3B8'}}>Teknisi: {activeClaimUnit.teknisiPelaksana}</span>
                    </div>
                  </div>

                  {/* Rangkuman Pekerjaan Teknisi */}
                  <div style={{ background: 'rgba(255,255,255,0.02)', borderRadius: 8, padding: 12, border: '1px solid rgba(255,255,255,0.05)', fontSize: 11, marginBottom: 16 }}>
                    <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 8, textTransform: 'uppercase' }}>Rangkuman Pekerjaan Teknisi</span>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8, marginBottom: 12 }}>
                      <div>Nopol: <strong style={{ color: 'var(--text-primary)' }}>{activeClaimUnit.nopol}</strong></div>
                      <div>Model GPS: <strong style={{ color: 'var(--text-primary)' }}>{activeClaimUnit.modelGpsBaru}</strong></div>
                      <div>No GPS Lama: <code style={{ color: 'var(--text-primary)' }}>{activeClaimUnit.gpsSerialLama || '—'}</code></div>
                      <div>No GPS Baru: <code style={{ color: 'var(--text-primary)' }}>{activeClaimUnit.gpsSerialBaru}</code></div>
                      <div>IMEI GPS Baru: <code style={{ color: 'var(--text-primary)' }}>{activeClaimUnit.gpsImeiBaru}</code></div>
                      <div>No SIM: <strong style={{ color: 'var(--text-primary)' }}>{activeClaimUnit.nomorSIM} ({activeClaimUnit.provider})</strong></div>
                      <div style={{ gridColumn: 'span 2' }}>Catatan Teknisi: <span style={{ color: '#94A3B8', fontStyle: 'italic' }}>{activeClaimUnit.catatanPasang || '—'}</span></div>
                    </div>
                    
                    {/* Teknisi Checklist Badges */}
                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 6, borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: 8, marginBottom: 12, overflowX: 'hidden' }}>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>GPS</span>
                        <Badge val={activeClaimUnit.gps} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Buzzer</span>
                        <Badge val={activeClaimUnit.buzzer} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>SOS</span>
                        <Badge val={activeClaimUnit.sos} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Wingbox</span>
                        <Badge val={activeClaimUnit.sensorWing} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Camera</span>
                        <Badge val={activeClaimUnit.camera} />
                      </div>
                    </div>

                    {/* Teknisi Photos */}
                    <div style={{ borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: 8 }}>
                      <span style={{ fontSize: 8, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 6, textTransform: 'uppercase' }}>Foto Pemasangan</span>
                      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(5, 1fr)', gap: 6 }}>
                        <div style={{ textAlign: 'center' }}>
                          {activeClaimUnit.fotoKendaraan ? (
                            <a href={activeClaimUnit.fotoKendaraan} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 36, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                              <img src={activeClaimUnit.fotoKendaraan} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Kendaraan" />
                            </a>
                          ) : <span style={{ color: '#4B5563', fontSize: 10 }}>—</span>}
                          <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Kendaraan</div>
                        </div>
                        <div style={{ textAlign: 'center' }}>
                          {activeClaimUnit.fotoGPSLama ? (
                            <a href={activeClaimUnit.fotoGPSLama} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 36, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                              <img src={activeClaimUnit.fotoGPSLama} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Lama" />
                            </a>
                          ) : <span style={{ color: '#4B5563', fontSize: 10 }}>—</span>}
                          <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>GPS Lama</div>
                        </div>
                        <div style={{ textAlign: 'center' }}>
                          {activeClaimUnit.fotoGPSBaru ? (
                            <a href={activeClaimUnit.fotoGPSBaru} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 36, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                              <img src={activeClaimUnit.fotoGPSBaru} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Baru" />
                            </a>
                          ) : <span style={{ color: '#4B5563', fontSize: 10 }}>—</span>}
                          <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>GPS Baru</div>
                        </div>
                        <div style={{ textAlign: 'center' }}>
                          {activeClaimUnit.fotoHasilInstalasi ? (
                            <a href={activeClaimUnit.fotoHasilInstalasi} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 36, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                              <img src={activeClaimUnit.fotoHasilInstalasi} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Instalasi" />
                            </a>
                          ) : <span style={{ color: '#4B5563', fontSize: 10 }}>—</span>}
                          <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Instalasi</div>
                        </div>
                        <div style={{ textAlign: 'center' }}>
                          {activeClaimUnit.fotoOdometer ? (
                            <a href={activeClaimUnit.fotoOdometer} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 36, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                              <img src={activeClaimUnit.fotoOdometer} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Odometer" />
                            </a>
                          ) : <span style={{ color: '#4B5563', fontSize: 10 }}>—</span>}
                          <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Odometer</div>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Form Verifikasi PIC */}
                  <div style={{ display: 'flex', flexDirection: 'column', gap: 14, marginBottom: 16 }}>
                    <div className="input-group" style={{ margin: 0 }}>
                      <label className="input-label" style={{ fontSize: 11, marginBottom: 6 }}>Cek Fisik GPS Lama (Cabutan) *</label>
                      <div className="teknisi-btn-group">
                        {['OK', 'NOT OK'].map(o => (
                          <button type="button" key={o} className={`teknisi-btn-option ${picCekFisikLama === o ? (o === 'OK' ? 'active' : 'active danger') : ''}`} style={{ padding: '8px 12px', fontSize: 11 }} onClick={() => setPicCekFisikLama(o)}>
                            {o}
                          </button>
                        ))}
                      </div>
                    </div>

                    <div className="input-group" style={{ margin: 0 }}>
                      <label className="input-label" style={{ fontSize: 11, marginBottom: 6 }}>Cek Fisik GPS Baru *</label>
                      <div className="teknisi-btn-group">
                        {['OK', 'NOT OK'].map(o => (
                          <button type="button" key={o} className={`teknisi-btn-option ${picCekFisikBaru === o ? (o === 'OK' ? 'active' : 'active danger') : ''}`} style={{ padding: '8px 12px', fontSize: 11 }} onClick={() => setPicCekFisikBaru(o)}>
                            {o}
                          </button>
                        ))}
                      </div>
                    </div>

                    <div className="input-group" style={{ margin: 0 }}>
                      <label className="input-label" style={{ fontSize: 11, marginBottom: 6 }}>Cek Kondisi Unit Selesai Pemasangan *</label>
                      <div className="teknisi-btn-group">
                        {['OK', 'NOT OK'].map(o => (
                          <button type="button" key={o} className={`teknisi-btn-option ${picCekKondisiSelesai === o ? (o === 'OK' ? 'active' : 'active danger') : ''}`} style={{ padding: '8px 12px', fontSize: 11 }} onClick={() => setPicCekKondisiSelesai(o)}>
                            {o}
                          </button>
                        ))}
                      </div>
                    </div>

                    <div className="input-group" style={{ margin: 0 }}>
                      <label className="input-label" style={{ fontSize: 11, marginBottom: 6 }}>Cek Fitur (Sensor, SOS, Camera) *</label>
                      <div className="teknisi-btn-group">
                        {['OK', 'NOT OK'].map(o => (
                          <button type="button" key={o} className={`teknisi-btn-option ${picCekFitur === o ? (o === 'OK' ? 'active' : 'active danger') : ''}`} style={{ padding: '8px 12px', fontSize: 11 }} onClick={() => setPicCekFitur(o)}>
                            {o}
                          </button>
                        ))}
                      </div>
                    </div>
                  </div>

                  {/* Upload Bukti Penyerahan GPS Lama */}
                  <div className="photo-card" style={{ height: 180, display: 'flex', alignItems: 'center', justifyContent: 'center', border: '2px dashed rgba(255,255,255,0.1)', borderRadius: 8, background: 'rgba(255,255,255,0.01)', marginBottom: 20 }}>
                    {picFotoSerahTerima ? (
                      <div style={{ width: '100%', height: '100%', position: 'relative', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                        <a href={picFotoSerahTerima} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '100%', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, color: '#60A5FA' }}>
                          <i className="bi bi-link-45deg" style={{ fontSize: 24, marginBottom: 6 }}></i>
                          <span style={{ fontSize: 11, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO BUKTI PENYERAHAN</span>
                        </a>
                        <button type="button" className="btn btn-secondary btn-sm" style={{ position: 'absolute', bottom: 8, right: 8, color: '#EF4444', border: 'none', background: 'rgba(239,68,68,0.2)', padding: '4px 8px', fontSize: 10 }} onClick={() => setPicFotoSerahTerima('')}>Hapus</button>
                      </div>
                    ) : (
                      <label style={{ cursor: 'pointer', textAlign: 'center', padding: 20, width: '100%' }}>
                        <i className="bi bi-camera" style={{ fontSize: 24, color: '#94A3B8', marginBottom: 6, display: 'block' }}></i>
                        <span style={{ fontSize: 11, fontWeight: 600, color: '#FFF' }}>
                          Upload Bukti Penyerahan GPS Lama *
                        </span>
                        <input type="file" accept="image/*" capture="environment" style={{ display: 'none' }} onChange={e => handlePhotoChange(e.target.files[0])} />
                      </label>
                    )}
                  </div>

                  {/* Actions */}
                  <div style={{ display: 'flex', gap: 10 }}>
                    <button className="teknisi-btn-danger-outline" style={{ flex: 1 }} onClick={() => releaseClaim(activeClaimUnit)}>
                      Batal Klaim
                    </button>
                    <button className="teknisi-btn-play" style={{ flex: 1.5 }} disabled={loadingSubmit || !picFotoSerahTerima} onClick={() => save(activeClaimUnit.id)}>
                      {loadingSubmit ? 'Mengirim...' : 'Kirim Verifikasi'}
                    </button>
                  </div>
                </div>
              )}
            </div>
          )}

          {/* TAB 3: Riwayat (history) */}
          {subTab === 'history' && (
            <div>
              {/* Hero Banner Card */}
              <div className="teknisi-hero-card" style={{ background: 'linear-gradient(135deg, #064E3B 0%, #022C22 100%)' }}>
                <div className="teknisi-hero-title">
                  <i className="bi bi-check-circle" style={{fontSize: 18}}></i>
                  <span>Riwayat Verifikasi ({myHistoryUnits.length})</span>
                </div>
                <p className="teknisi-hero-desc">
                  Daftar armada kendaraan yang telah selesai Anda verifikasi.
                </p>
              </div>

              {!isMobile ? (
                <>
                  <FilterRow>
                    <div className="search-input-wrapper">
                      <i className="bi bi-search"></i>
                      <input 
                        type="text" 
                        value={q} 
                        onChange={e => { setQ(e.target.value); setPage(1); }} 
                        className="search-input"
                        placeholder="Cari NOPOL..." 
                      />
                    </div>
                    <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                    <span className="unit-count-tag">{activeList.length} Riwayat</span>
                  </FilterRow>

                  {activeList.length === 0 ? (
                    <div style={{ textAlign: 'center', padding: 48, color: 'var(--text-tertiary)', background: 'var(--bg-card)', borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)', marginTop: 12 }}>
                      <i className="bi bi-list-check" style={{ fontSize: 32, display: 'block', marginBottom: 10, color: 'var(--text-tertiary)' }}></i>
                      Belum ada riwayat verifikasi yang Anda selesaikan.
                    </div>
                  ) : (
                    <div className="table-container" style={{ marginTop: 12 }}>
                      <table className="data-table">
                        <thead>
                          <tr>
                            <th style={{ width: '50px' }}>#</th>
                            <th style={{ width: '120px' }}>NOPOL</th>
                            <th style={{ width: '150px' }}>SITE / POOL</th>
                            <th style={{ width: '180px' }}>DETAIL KENDARAAN</th>
                            <th style={{ width: '150px' }}>TEKNISI</th>
                            <th style={{ width: '180px' }}>TANGGAL VERIFIKASI</th>
                            <th style={{ width: '150px', textAlign: 'center' }}>STATUS</th>
                            <th style={{ width: '180px', textAlign: 'center' }}>AKSI</th>
                          </tr>
                        </thead>
                        <tbody>
                          {slice.map((u, idx) => (
                            <tr key={u.id}>
                              <td>{(page - 1) * PAGE_LIMIT + idx + 1}</td>
                              <td><strong>{u.nopol}</strong></td>
                              <td>{u.pool || u.location}</td>
                              <td>{u.ownership} • {u.merk} ({u.assetType})</td>
                              <td><strong>{u.teknisiPelaksana || '—'}</strong></td>
                              <td>{u.updatedAt || '—'}</td>
                              <td style={{ textAlign: 'center' }}><Badge val={u.statusPasang} /></td>
                              <td style={{ textAlign: 'center' }}>
                                <button 
                                  className="btn btn-secondary btn-sm"
                                  onClick={() => setPicReviewUnit(u)}
                                  style={{ gap: 4, display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: '100%' }}
                                >
                                  <i className="bi bi-info-circle"></i> Detail & Foto
                                </button>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </>
              ) : (
                <>
                  <div style={{marginBottom: 12, display: 'flex', gap: 8, flexWrap: 'wrap'}}>
                    <div className="search-input-wrapper" style={{flex: 1, minWidth: 160}}>
                      <i className="bi bi-search"></i>
                      <input 
                        type="text" 
                        value={q} 
                        onChange={e => { setQ(e.target.value); setPage(1); }} 
                        className="search-input"
                        placeholder="Cari NOPOL..." 
                      />
                    </div>
                    <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select" style={{maxWidth: 140}}>
                      <option value="">Semua Site</option>
                      {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                    </select>
                    <span className="unit-count-tag">{activeList.length} Unit</span>
                  </div>

                  {slice.map(u => (
                    <div key={u.id} className="teknisi-vehicle-card">
                      <div className="teknisi-card-header">
                        <span className="teknisi-card-label">NOMOR POLISI</span>
                        <span className="teknisi-pool-badge" style={{ background: 'rgba(16, 185, 129, 0.1)', color: '#10B981' }}>
                          <i className="bi bi-check-circle"></i> {u.statusPasang}
                        </span>
                      </div>

                      <div className="teknisi-vehicle-nopol">
                        {u.nopol}
                      </div>

                      <div style={{ fontSize: 11, color: 'var(--text-secondary)', marginBottom: 12, display: 'flex', flexDirection: 'column', gap: 4 }}>
                        <div>Teknisi: <strong>{u.teknisiPelaksana || '—'}</strong></div>
                        <div>Verifikasi: <strong>{u.updatedAt || '—'}</strong></div>
                      </div>

                      <button 
                        className="teknisi-btn-play"
                        style={{ background: 'var(--bg-secondary)', color: 'var(--text-primary)', border: '1px solid var(--border-color)' }}
                        onClick={() => setPicReviewUnit(u)}
                      >
                        <i className="bi bi-info-circle"></i> Detail Pekerjaan & Foto
                      </button>
                    </div>
                  ))}

                  {activeList.length === 0 && (
                    <div style={{textAlign: 'center', padding: '30px 10px', background: 'var(--bg-secondary)', borderRadius: 16, border: '1px solid var(--border-color)', color: '#94A3B8', fontSize: 11}}>
                      Belum ada riwayat verifikasi yang Anda selesaikan.
                    </div>
                  )}
                </>
              )}
              
              {activeList.length > 0 && <Pager page={page} total={total} onChange={p => setPage(p)} />}
            </div>
          )}



          {/* POPUP MODAL FOR REVIEW (Detail Pekerjaan & Foto) */}
          {picReviewUnit && (
            <div className="modal-overlay" onClick={() => setPicReviewUnit(null)} style={{ zIndex: 99998 }}>
              <div className="modal-card" onClick={e => e.stopPropagation()} style={{ width: '95%', maxWidth: 420 }}>
                <div className="modal-drag-handle"></div>
                <div className="modal-header">
                  <strong style={{ fontSize: 13, color: '#FFF' }}>
                    Review Pekerjaan: {picReviewUnit.nopol}
                  </strong>
                  <button className="modal-close" onClick={() => setPicReviewUnit(null)} style={{ background: 'none', border: 'none', color: '#94A3B8', cursor: 'pointer', fontSize: 16 }}><i className="bi bi-x"></i></button>
                </div>
                
                <div className="modal-body" style={{ padding: 16, display: 'flex', flexDirection: 'column', gap: 12, maxHeight: '70vh', overflowY: 'auto' }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                    <span style={{ fontSize: 10, color: '#94A3B8' }}>STATUS INSTALASI</span>
                    <Badge val={picReviewUnit.statusPasang} />
                  </div>

                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8, fontSize: 11, background: 'rgba(255,255,255,0.01)', padding: 10, borderRadius: 8, border: '1px solid rgba(255,255,255,0.04)' }}>
                    <div>Nopol: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.nopol}</strong></div>
                    <div>Tipe: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.merk || '-'} {picReviewUnit.assetType || '-'}</strong></div>
                    <div>Site: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.location || '-'}</strong></div>
                    <div>Pool: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.pool || '-'}</strong></div>
                    <div>SIM: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.nomorSIM || '-'}</strong></div>
                    <div>Provider: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.provider || '-'}</strong></div>
                    <div>Teknisi: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.teknisiPelaksana || '-'}</strong></div>
                    <div>PIC Lapangan: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.picLapangan || '-'}</strong></div>
                    <div style={{ gridColumn: 'span 2' }}>Tgl Update: <strong style={{ color: 'var(--text-primary)' }}>{picReviewUnit.updatedAt || '-'}</strong></div>
                  </div>

                  <div style={{ background: 'rgba(255,255,255,0.01)', padding: 10, borderRadius: 8, border: '1px solid rgba(255,255,255,0.04)' }}>
                    <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 6, textTransform: 'uppercase' }}>Detail Hardware (Teknisi)</span>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1.2fr', gap: 6, fontSize: 11 }}>
                      <div>GPS Model:</div>
                      <div style={{ fontWeight: 700, color: '#FFF' }}>{picReviewUnit.modelGpsBaru || 'GEOTAB'}</div>
                      <div>SN GPS Lama:</div>
                      <div style={{ fontWeight: 600, fontFamily: 'monospace', color: '#FFF' }}>{picReviewUnit.gpsSerialLama || '-'}</div>
                      <div>SN GPS Baru:</div>
                      <div style={{ fontWeight: 600, fontFamily: 'monospace', color: '#FFF' }}>{picReviewUnit.gpsSerialBaru || '-'}</div>
                      <div>IMEI GPS Baru:</div>
                      <div style={{ fontWeight: 600, fontFamily: 'monospace', color: '#FFF' }}>{picReviewUnit.gpsImeiBaru || '-'}</div>
                    </div>
                  </div>

                  {picReviewUnit.catatanPasang && (
                    <div style={{ background: 'rgba(255,255,255,0.01)', padding: 10, borderRadius: 8, border: '1px solid rgba(255,255,255,0.04)', fontSize: 11 }}>
                      <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 4 }}>CATATAN TEKNISI</span>
                      <div style={{ color: '#FFF', fontStyle: 'italic' }}>&ldquo;{picReviewUnit.catatanPasang}&rdquo;</div>
                    </div>
                  )}

                  <div style={{ background: 'rgba(255,255,255,0.01)', padding: 10, borderRadius: 8, border: '1px solid rgba(255,255,255,0.04)' }}>
                    <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 6, textTransform: 'uppercase' }}>Checklist Fungsi (Teknisi)</span>
                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 4, overflowX: 'hidden' }}>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>GPS</span>
                        <Badge val={picReviewUnit.gps} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Buzzer</span>
                        <Badge val={picReviewUnit.buzzer} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>SOS</span>
                        <Badge val={picReviewUnit.sos} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Wingbox</span>
                        <Badge val={picReviewUnit.sensorWing} />
                      </div>
                      <div style={{ minWidth: 0, overflow: 'hidden' }}>
                        <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Camera</span>
                        <Badge val={picReviewUnit.camera} />
                      </div>
                    </div>
                  </div>

                  <div style={{ background: 'rgba(255,255,255,0.01)', padding: 10, borderRadius: 8, border: '1px solid rgba(255,255,255,0.04)' }}>
                    <span style={{ fontSize: 9, fontWeight: 700, color: '#94A3B8', display: 'block', marginBottom: 8, textTransform: 'uppercase' }}>Dokumentasi Foto (Teknisi)</span>
                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(5, 1fr)', gap: 6 }}>
                      <div style={{ textAlign: 'center' }}>
                        {picReviewUnit.fotoKendaraan ? (
                          <a href={picReviewUnit.fotoKendaraan} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={picReviewUnit.fotoKendaraan} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Kendaraan" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Kendaraan</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {picReviewUnit.fotoGPSLama ? (
                          <a href={picReviewUnit.fotoGPSLama} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={picReviewUnit.fotoGPSLama} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Lama" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>GPS Lama</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {picReviewUnit.fotoGPSBaru ? (
                          <a href={picReviewUnit.fotoGPSBaru} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={picReviewUnit.fotoGPSBaru} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="GPS Baru" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>GPS Baru</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {picReviewUnit.fotoHasilInstalasi ? (
                          <a href={picReviewUnit.fotoHasilInstalasi} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={picReviewUnit.fotoHasilInstalasi} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Instalasi" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Instalasi</div>
                      </div>
                      <div style={{ textAlign: 'center' }}>
                        {picReviewUnit.fotoOdometer ? (
                          <a href={picReviewUnit.fotoOdometer} target="_blank" rel="noopener noreferrer" style={{ display: 'block', width: '100%', height: 40, borderRadius: 4, border: '1px solid var(--border-color)', overflow: 'hidden' }}>
                            <img src={picReviewUnit.fotoOdometer} style={{ width: '100%', height: '100%', objectFit: 'cover' }} alt="Odometer" />
                          </a>
                        ) : '—'}
                        <div style={{ fontSize: 6, color: '#94A3B8', marginTop: 2 }}>Odometer</div>
                      </div>
                    </div>
                  </div>

                  {/* PIC Lapangan Verification Details */}
                  {picReviewUnit.picLapangan && (
                    <div style={{ background: 'rgba(16, 185, 129, 0.03)', padding: 10, borderRadius: 8, border: '1px solid rgba(16, 185, 129, 0.15)' }}>
                      <span style={{ fontSize: 9, fontWeight: 700, color: '#10B981', display: 'block', marginBottom: 6, textTransform: 'uppercase' }}>Verifikasi PIC Lapangan ({picReviewUnit.picLapangan})</span>
                      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: 4, marginBottom: 8 }}>
                        <div>
                          <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Cek Fisik Lm</span>
                          <Badge val={picReviewUnit.picCekFisikLama || 'OK'} />
                        </div>
                        <div>
                          <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Cek Fisik Br</span>
                          <Badge val={picReviewUnit.picCekFisikBaru || 'OK'} />
                        </div>
                        <div>
                          <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Kondisi Sls</span>
                          <Badge val={picReviewUnit.picCekKondisiSelesai || 'OK'} />
                        </div>
                        <div>
                          <span style={{ fontSize: 7, color: '#94A3B8', display: 'block', marginBottom: 2 }}>Fitur</span>
                          <Badge val={picReviewUnit.picCekFitur || 'OK'} />
                        </div>
                      </div>
                      
                      {picReviewUnit.picFotoSerahTerima && (
                        <div style={{ marginTop: 8 }}>
                          <span style={{ fontSize: 8, color: '#94A3B8', display: 'block', marginBottom: 4 }}>Bukti Penyerahan GPS Lama</span>
                          <a href={picReviewUnit.picFotoSerahTerima} target="_blank" rel="noopener noreferrer" style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', padding: '6px 12px', background: 'rgba(16, 185, 129, 0.08)', borderRadius: 4, border: '1px dashed #10B981', color: '#10B981', fontSize: 8, fontWeight: 'bold', textDecoration: 'none' }}>
                            LIHAT FOTO SERAH TERIMA
                          </a>
                        </div>
                      )}
                    </div>
                  )}

                </div>
                <div className="modal-footer" style={{ borderTop: '1px solid var(--border-color)', padding: 12 }}>
                  <button className="btn btn-secondary" style={{ width: '100%', height: 36 }} onClick={() => setPicReviewUnit(null)}>Tutup</button>
                </div>
              </div>
            </div>
          )}

          {/* Premium Bottom Navigation Bar */}
          <div className="teknisi-nav-bar">
            <button 
              className={`teknisi-nav-item ${subTab === 'queue' ? 'active' : ''}`} 
              onClick={() => {
                setSubTab('queue');
                setPage(1);
              }}
            >
              <i className="bi bi-clipboard-data"></i>
              <span>Antrean</span>
            </button>
            <button 
              className={`teknisi-nav-item ${subTab === 'my_claims' ? 'active' : ''}`} 
              onClick={() => {
                setSubTab('my_claims');
                setPage(1);
              }}
            >
              <i className="bi bi-clipboard-check"></i>
              <span>Klaim Aktif</span>
            </button>
            <button 
              className={`teknisi-nav-item ${subTab === 'history' ? 'active' : ''}`} 
              onClick={() => {
                setSubTab('history');
                setPage(1);
              }}
            >
              <i className="bi bi-history"></i>
              <span>Riwayat</span>
            </button>

            <button 
              className="teknisi-nav-item" 
              onClick={handleLogout}
            >
              <i className="bi bi-box-arrow-right"></i>
              <span>Logout</span>
            </button>
          </div>
        </div>
      );
    }

    // 4b. IT View
    function ITView({ units, setUnits, syncUpdate, isMobile }) {
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');
      const [page, setPage] = useState(1);
      
      const [editId, setEditId] = useState(null);
      
      // Form states
      const [itCekAplikasi, setItCekAplikasi] = useState('OK');
      const [itFotoIntegrasi, setItFotoIntegrasi] = useState('');
      const [itFotoAbnormality, setItFotoAbnormality] = useState('');
      const [loadingSubmit, setLoadingSubmit] = useState(false);
      const [loadingDraft, setLoadingDraft] = useState(false);

      // Load draft when editId changes (IT view)
      React.useEffect(() => {
        if (editId) {
          try {
            const saved = localStorage.getItem('it_draft_' + editId);
            if (saved) {
              const p = JSON.parse(saved);
              setItCekAplikasi(p.itCekAplikasi || 'OK');
              if (p.itFotoIntegrasi) setItFotoIntegrasi(p.itFotoIntegrasi);
              if (p.itFotoAbnormality) setItFotoAbnormality(p.itFotoAbnormality);
            }
          } catch (e) {}
        }
      }, [editId]);

      const saveDraft = () => {
        if (!editId) return;
        try {
          localStorage.setItem('it_draft_' + editId, JSON.stringify({
            itCekAplikasi, itFotoIntegrasi, itFotoAbnormality
          }));
          globalAddToast('Draft IT berhasil disimpan!', 'success');
        } catch (e) {
          globalAddToast('Gagal menyimpan draft!', 'danger');
        }
      };

      const filtered = useMemo(() => {
        return units.filter(u => 
          u.statusPasang === 'PIC VERIFIED' &&
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc)
        );
      }, [units, q, loc]);

      const total = Math.ceil(filtered.length / PAGE_LIMIT);
      const slice = filtered.slice((page - 1) * PAGE_LIMIT, page * PAGE_LIMIT);

      const handlePhotoChange = (fieldName, file) => {
        if (!file) return;
        globalAddToast('Mengompresi foto...', 'info');
        const reader = new FileReader();
        reader.onload = (e) => {
          const originalBase64 = e.target.result;
          const img = new Image();
          img.onload = () => {
            try {
              const maxDim = 800;
              let w = img.width;
              let h = img.height;
              if (w > maxDim || h > maxDim) {
                if (w > h) {
                  h = Math.round((h * maxDim) / w);
                  w = maxDim;
                } else {
                  w = Math.round((w * maxDim) / h);
                  h = maxDim;
                }
              }
              const canvas = document.createElement('canvas');
              canvas.width = w;
              canvas.height = h;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, w, h);
              const compressedBase64 = canvas.toDataURL('image/jpeg', 0.7);
              if (fieldName === 'itFotoIntegrasi') setItFotoIntegrasi(compressedBase64);
              if (fieldName === 'itFotoAbnormality') setItFotoAbnormality(compressedBase64);
              globalAddToast('Foto berhasil ditambahkan!', 'success');
            } catch (canvasErr) {
              if (fieldName === 'itFotoIntegrasi') setItFotoIntegrasi(originalBase64);
              if (fieldName === 'itFotoAbnormality') setItFotoAbnormality(originalBase64);
              globalAddToast('Foto berhasil ditambahkan (tanpa kompresi)!', 'success');
            }
          };
          img.onerror = () => {
            if (fieldName === 'itFotoIntegrasi') setItFotoIntegrasi(originalBase64);
            if (fieldName === 'itFotoAbnormality') setItFotoAbnormality(originalBase64);
            globalAddToast('Foto berhasil ditambahkan!', 'success');
          };
          img.src = originalBase64;
        };
        reader.readAsDataURL(file);
      };

      const save = async (id) => {
        const unit = units.find(u => u.id === id);
        if (!itFotoIntegrasi) {
          globalAddToast('Kesalahan: Foto integrasi data GPS wajib diunggah!', 'danger');
          return;
        }
        if (!itFotoAbnormality) {
          globalAddToast('Kesalahan: Foto integrasi data abnormality wajib diunggah!', 'danger');
          return;
        }

        setLoadingSubmit(true);
        globalAddToast('Mengunggah foto integrasi IT ke server...', 'info');

        let urlItFotoIntegrasi = itFotoIntegrasi;
        let urlItFotoAbnormality = itFotoAbnormality;

        try {
          urlItFotoIntegrasi = await uploadImageToSupabaseStorage(itFotoIntegrasi, unit.nopol, 'itFotoIntegrasi');
          urlItFotoAbnormality = await uploadImageToSupabaseStorage(itFotoAbnormality, unit.nopol, 'itFotoAbnormality');
        } catch (e) {
          console.warn("Upload storage gagal, menggunakan base64 fallback:", e);
        }

        const now = new Date();
        const dd = n => String(n).padStart(2, '0');
        const ts = `${dd(now.getDate())}-${dd(now.getMonth() + 1)}-${now.getFullYear()} ${dd(now.getHours())}:${dd(now.getMinutes())}`;

        const updates = {
          "STATUS REGISTRASI": 'IT VERIFIED',
          "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT": itCekAplikasi,
          "FOTO INTEGRASI DATA GPS KE PUNINAR": urlItFotoIntegrasi,
          "FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR": urlItFotoAbnormality
        };

        try {
          await syncUpdate(unit.nopol, updates);
          setUnits(prev => prev.map(u => u.id === id ? {
            ...u,
            statusPasang: 'IT VERIFIED',
            itCekAplikasi,
            itFotoIntegrasi: urlItFotoIntegrasi,
            itFotoAbnormality: urlItFotoAbnormality,
            updatedAt: ts
          } : u));
          setEditId(null);
          setItFotoIntegrasi('');
          setItFotoAbnormality('');
          try { localStorage.removeItem('it_draft_' + id); } catch(e) {}
          globalAddToast(`Verifikasi IT NOPOL ${unit.nopol} berhasil dikirim!`, 'success');
        } catch (err) {
          console.error(err);
        } finally {
          setLoadingSubmit(false);
        }
      };

      const editingUnit = units.find(u => u.id === editId);

      return (
        <div className="fade-in">
          <div className="role-banner it">
            <i className="bi bi-display"></i>
            <span><strong>Role: IT Puninar</strong> — Verifikasi integrasi data GPS (Temon / Geotab / Smatrack) ke database internal Puninar.</span>
          </div>

          {!editId ? (
            <>
              <FilterRow>
                <div className="search-input-wrapper">
                  <i className="bi bi-search"></i>
                  <input type="text" value={q} onChange={e => { setQ(e.target.value); setPage(1); }} className="search-input" placeholder="Cari NOPOL..." />
                </div>
                <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
                  <option value="">Semua Lokasi</option>
                  {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                </select>
                <span className="unit-count-tag">{filtered.length} Unit Menunggu IT</span>
              </FilterRow>

              {filtered.length === 0 ? (
                <div style={{ textAlign: 'center', padding: 48, color: 'var(--text-tertiary)', background: 'var(--bg-card)', borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)', marginTop: 12 }}>
                  <i className="bi bi-list-check" style={{ fontSize: 32, display: 'block', marginBottom: 10, color: 'var(--text-tertiary)' }}></i>
                  Tidak ada unit berstatus PIC VERIFIED yang membutuhkan verifikasi IT.
                </div>
              ) : isMobile ? (
                <div style={{ display: 'flex', flexDirection: 'column', gap: 12, marginTop: 12 }}>
                  {slice.map(u => (
                    <div key={u.id} className="mobile-unit-card" style={{ padding: 14 }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                        <strong style={{ fontSize: 15 }}>{u.nopol}</strong>
                        <Badge val={u.statusPasang} />
                      </div>
                      <div style={{ fontSize: 11, color: 'var(--text-secondary)', marginTop: 6 }}>
                        <div>Site: {u.location} • Pool: {u.pool}</div>
                        <div>PIC Lapangan: <strong>{u.picLapangan || '—'}</strong></div>
                      </div>
                      <button className="btn btn-primary btn-sm" style={{ width: '100%', marginTop: 12, justifyContent: 'center' }} onClick={() => { setEditId(u.id); setItCekAplikasi('OK'); setItFotoIntegrasi(''); setItFotoAbnormality(''); }}>
                        <i className="bi bi-clipboard-check"></i> Mulai Verifikasi IT
                      </button>
                    </div>
                  ))}
                </div>
              ) : (
                <div className="table-container" style={{ marginTop: 12 }}>
                  <table className="data-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>NOPOL</th>
                        <th>LOCATION</th>
                        <th>PIC LAPANGAN</th>
                        <th>TEKNISI</th>
                        <th>SN GPS BARU</th>
                        <th>AKSI</th>
                      </tr>
                    </thead>
                    <tbody>
                      {slice.map((u, i) => (
                        <tr key={u.id}>
                          <td className="text-muted">{(page - 1) * PAGE_LIMIT + i + 1}</td>
                          <td><strong>{u.nopol}</strong></td>
                          <td>{u.location}</td>
                          <td>{u.picLapangan || '—'}</td>
                          <td>{u.teknisiPelaksana || '—'}</td>
                          <td><code>{u.gpsSerialBaru || '—'}</code></td>
                          <td>
                            <button className="btn btn-primary btn-sm" onClick={() => { setEditId(u.id); setItCekAplikasi('OK'); setItFotoIntegrasi(''); setItFotoAbnormality(''); }}>
                              <i className="bi bi-clipboard-check"></i> Verifikasi IT
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              {filtered.length > 0 && <Pager page={page} total={total} onChange={p => setPage(p)} />}
            </>
          ) : (
            <div className="panel-card fade-in" style={{ padding: 20 }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16, paddingBottom: 12, borderBottom: '1px solid var(--border-color)' }}>
                <span style={{ fontWeight: 700, fontSize: 15 }}>Form Verifikasi IT: {editingUnit.nopol}</span>
                <button className="btn btn-secondary btn-sm" onClick={() => setEditId(null)}>Batal</button>
              </div>

              <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : '1.2fr 1fr', gap: 24 }}>
                <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
                  <div style={{ background: 'rgba(255,255,255,0.02)', borderRadius: 8, padding: 14, border: '1px solid var(--border-color)', fontSize: 12 }}>
                    <h4 style={{ margin: '0 0 10px 0', fontSize: 13, borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: 6 }}>Rangkuman Lapangan</h4>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>
                      <div>Nopol: <strong>{editingUnit.nopol}</strong></div>
                      <div>Tipe: <strong>{editingUnit.merk} {editingUnit.assetType}</strong></div>
                      <div>GPS Baru: <code>{editingUnit.gpsSerialBaru}</code></div>
                      <div>Teknisi: <strong>{editingUnit.teknisiPelaksana}</strong></div>
                      <div>PIC Lapangan: <strong>{editingUnit.picLapangan}</strong></div>
                      <div>Cek Fisik GPS Lama: <Badge val={editingUnit.picCekFisikLama} /></div>
                      <div>Cek Fisik GPS Baru: <Badge val={editingUnit.picCekFisikBaru} /></div>
                      <div>Cek Fitur Lapangan: <Badge val={editingUnit.picCekFitur} /></div>
                    </div>
                  </div>

                  <div className="input-group">
                    <label className="input-label">Cek Unit di Aplikasi (TEMON / GEOTAB / SMATRACK) *</label>
                    <div className="teknisi-btn-group">
                      {['OK', 'NOT OK'].map(o => (
                        <button type="button" key={o} className={`teknisi-btn-option ${itCekAplikasi === o ? (o === 'OK' ? 'active' : 'active danger') : ''}`} onClick={() => setItCekAplikasi(o)}>
                          {o}
                        </button>
                      ))}
                    </div>
                  </div>
                </div>

                <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
                  <div className="photo-grid" style={{ gridTemplateColumns: '1fr', gap: 12 }}>
                    <div className="photo-card" style={{ height: 130, display: 'flex', alignItems: 'center', justifyContent: 'center', border: '2px dashed var(--border-color)', borderRadius: 8, background: 'var(--bg-primary)' }}>
                      {itFotoIntegrasi ? (
                        <div style={{ width: '100%', height: '100%', position: 'relative', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                          <a href={itFotoIntegrasi} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '100%', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, color: '#60A5FA' }}>
                            <i className="bi bi-link-45deg" style={{ fontSize: 24, marginBottom: 4 }}></i>
                            <span style={{ fontSize: 10, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO INTEGRASI</span>
                          </a>
                          <button type="button" className="btn btn-secondary btn-sm" style={{ position: 'absolute', bottom: 8, right: 8, color: '#EF4444', border: 'none', background: 'rgba(239,68,68,0.2)' }} onClick={() => setItFotoIntegrasi('')}>Hapus</button>
                        </div>
                      ) : (
                        <label style={{ cursor: 'pointer', textAlign: 'center', padding: 10 }}>
                          <i className="bi bi-camera" style={{ fontSize: 24, color: 'var(--text-secondary)', marginBottom: 4, display: 'block' }}></i>
                          <span style={{ fontSize: 10, fontWeight: 700, color: '#FFF' }}>Foto Integrasi Data GPS *</span>
                          <input type="file" accept="image/*" capture="environment" style={{ display: 'none' }} onChange={e => handlePhotoChange('itFotoIntegrasi', e.target.files[0])} />
                        </label>
                      )}
                    </div>

                    <div className="photo-card" style={{ height: 130, display: 'flex', alignItems: 'center', justifyContent: 'center', border: '2px dashed var(--border-color)', borderRadius: 8, background: 'var(--bg-primary)' }}>
                      {itFotoAbnormality ? (
                        <div style={{ width: '100%', height: '100%', position: 'relative', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                          <a href={itFotoAbnormality} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '100%', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, color: '#60A5FA' }}>
                            <i className="bi bi-link-45deg" style={{ fontSize: 24, marginBottom: 4 }}></i>
                            <span style={{ fontSize: 10, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO ABNORMALITY</span>
                          </a>
                          <button type="button" className="btn btn-secondary btn-sm" style={{ position: 'absolute', bottom: 8, right: 8, color: '#EF4444', border: 'none', background: 'rgba(239,68,68,0.2)' }} onClick={() => setItFotoAbnormality('')}>Hapus</button>
                        </div>
                      ) : (
                        <label style={{ cursor: 'pointer', textAlign: 'center', padding: 10 }}>
                          <i className="bi bi-camera" style={{ fontSize: 24, color: 'var(--text-secondary)', marginBottom: 4, display: 'block' }}></i>
                          <span style={{ fontSize: 10, fontWeight: 700, color: '#FFF' }}>Foto Integrasi Abnormality *</span>
                          <input type="file" accept="image/*" capture="environment" style={{ display: 'none' }} onChange={e => handlePhotoChange('itFotoAbnormality', e.target.files[0])} />
                        </label>
                      )}
                    </div>
                  </div>

                  <div style={{ marginTop: 'auto', display: 'flex', gap: 10, flexWrap: 'wrap' }}>
                    <button className="btn btn-secondary" style={{ flex: 1, justifyContent: 'center' }} onClick={() => setEditId(null)}>Batal</button>
                    <button className="btn btn-secondary" style={{ flex: 1, justifyContent: 'center', borderColor: '#F59E0B', color: '#F59E0B' }} onClick={saveDraft} disabled={loadingDraft}>
                      <i className="bi bi-floppy" style={{ marginRight: 6 }}></i>Simpan Draft
                    </button>
                    <button className="btn btn-primary" style={{ flex: 1.5, justifyContent: 'center' }} disabled={loadingSubmit || !itFotoIntegrasi || !itFotoAbnormality} onClick={() => save(editingUnit.id)}>
                      {loadingSubmit ? 'Mengirim...' : 'Kirim IT Verifikasi'}
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      );
    }

    // 4c. CMT View
    function CMTView({ units, setUnits, syncUpdate, isMobile }) {
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');
      const [page, setPage] = useState(1);
      
      const [editId, setEditId] = useState(null);
      
      // Form states
      const [cmtCekAplikasi, setCmtCekAplikasi] = useState('OK');
      const [cmtStatusPenyerahan, setCmtStatusPenyerahan] = useState('BELUM');
      const [cmtFotoTerimaFisik, setCmtFotoTerimaFisik] = useState('');
      const [cmtFotoSerahTerima, setCmtFotoSerahTerima] = useState('');
      const [loadingSubmit, setLoadingSubmit] = useState(false);
      const [loadingDraftCmt, setLoadingDraftCmt] = useState(false);

      // Load draft when editId changes (CMT view)
      React.useEffect(() => {
        if (editId) {
          try {
            const saved = localStorage.getItem('cmt_draft_' + editId);
            if (saved) {
              const p = JSON.parse(saved);
              setCmtCekAplikasi(p.cmtCekAplikasi || 'OK');
              setCmtStatusPenyerahan(p.cmtStatusPenyerahan || 'BELUM');
              if (p.cmtFotoTerimaFisik) setCmtFotoTerimaFisik(p.cmtFotoTerimaFisik);
              if (p.cmtFotoSerahTerima) setCmtFotoSerahTerima(p.cmtFotoSerahTerima);
            }
          } catch (e) {}
        }
      }, [editId]);

      const saveDraftCmt = () => {
        if (!editId) return;
        try {
          localStorage.setItem('cmt_draft_' + editId, JSON.stringify({
            cmtCekAplikasi, cmtStatusPenyerahan, cmtFotoTerimaFisik, cmtFotoSerahTerima
          }));
          globalAddToast('Draft CMT berhasil disimpan!', 'success');
        } catch (e) {
          globalAddToast('Gagal menyimpan draft!', 'danger');
        }
      };

      const filtered = useMemo(() => {
        return units.filter(u => 
          u.statusPasang === 'IT VERIFIED' &&
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc)
        );
      }, [units, q, loc]);

      const total = Math.ceil(filtered.length / PAGE_LIMIT);
      const slice = filtered.slice((page - 1) * PAGE_LIMIT, page * PAGE_LIMIT);

      const handlePhotoChange = (fieldName, file) => {
        if (!file) return;
        globalAddToast('Mengompresi foto...', 'info');
        const reader = new FileReader();
        reader.onload = (e) => {
          const originalBase64 = e.target.result;
          const img = new Image();
          img.onload = () => {
            try {
              const maxDim = 800;
              let w = img.width;
              let h = img.height;
              if (w > maxDim || h > maxDim) {
                if (w > h) {
                  h = Math.round((h * maxDim) / w);
                  w = maxDim;
                } else {
                  w = Math.round((w * maxDim) / h);
                  h = maxDim;
                }
              }
              const canvas = document.createElement('canvas');
              canvas.width = w;
              canvas.height = h;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, w, h);
              const compressedBase64 = canvas.toDataURL('image/jpeg', 0.7);
              if (fieldName === 'cmtFotoTerimaFisik') setCmtFotoTerimaFisik(compressedBase64);
              if (fieldName === 'cmtFotoSerahTerima') setCmtFotoSerahTerima(compressedBase64);
              globalAddToast('Foto berhasil ditambahkan!', 'success');
            } catch (canvasErr) {
              if (fieldName === 'cmtFotoTerimaFisik') setCmtFotoTerimaFisik(originalBase64);
              if (fieldName === 'cmtFotoSerahTerima') setCmtFotoSerahTerima(originalBase64);
              globalAddToast('Foto berhasil ditambahkan (tanpa kompresi)!', 'success');
            }
          };
          img.onerror = () => {
            if (fieldName === 'cmtFotoTerimaFisik') setCmtFotoTerimaFisik(originalBase64);
            if (fieldName === 'cmtFotoSerahTerima') setCmtFotoSerahTerima(originalBase64);
            globalAddToast('Foto berhasil ditambahkan!', 'success');
          };
          img.src = originalBase64;
        };
        reader.readAsDataURL(file);
      };

      const save = async (id) => {
        const unit = units.find(u => u.id === id);
        if (!cmtFotoTerimaFisik) {
          globalAddToast('Kesalahan: Foto terima fisik GPS lama wajib diunggah!', 'danger');
          return;
        }
        if (!cmtFotoSerahTerima) {
          globalAddToast('Kesalahan: Foto dokumen serah terima GPS lama wajib diunggah!', 'danger');
          return;
        }

        // Jika GPS lama belum diserahkan ke vendor, status tetap menunggu (bukan DONE)
        const finalStatus = cmtStatusPenyerahan === 'SUDAH' ? 'DONE' : 'CMT PENDING';

        setLoadingSubmit(true);
        globalAddToast('Mengunggah foto verifikasi CMT ke server...', 'info');

        let urlCmtFotoTerimaFisik = cmtFotoTerimaFisik;
        let urlCmtFotoSerahTerima = cmtFotoSerahTerima;

        try {
          urlCmtFotoTerimaFisik = await uploadImageToSupabaseStorage(cmtFotoTerimaFisik, unit.nopol, 'cmtFotoTerimaFisik');
          urlCmtFotoSerahTerima = await uploadImageToSupabaseStorage(cmtFotoSerahTerima, unit.nopol, 'cmtFotoSerahTerima');
        } catch (e) {
          console.warn("Upload storage gagal, menggunakan base64 fallback:", e);
        }

        const now = new Date();
        const dd = n => String(n).padStart(2, '0');
        const ts = `${dd(now.getDate())}-${dd(now.getMonth() + 1)}-${now.getFullYear()} ${dd(now.getHours())}:${dd(now.getMinutes())}`;

        const updates = {
          "STATUS REGISTRASI": finalStatus,
          "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT": cmtCekAplikasi,
          "FOTO TERIMA FISIK GPS LAMA": urlCmtFotoTerimaFisik,
          "FOTO BUKTI TERMINASI GPS LAMA": urlCmtFotoSerahTerima
        };

        try {
          await syncUpdate(unit.nopol, updates);
          setUnits(prev => prev.map(u => u.id === id ? {
            ...u,
            statusPasang: finalStatus,
            cmtCekAplikasi,
            cmtFotoTerimaFisik: urlCmtFotoTerimaFisik,
            cmtFotoTerminasi: urlCmtFotoSerahTerima,
            updatedAt: ts
          } : u));
          setEditId(null);
          setCmtFotoTerimaFisik('');
          setCmtFotoSerahTerima('');
          try { localStorage.removeItem('cmt_draft_' + id); } catch(e) {}
          if (finalStatus === 'DONE') {
            globalAddToast(`Verifikasi CMT NOPOL ${unit.nopol} berhasil diselesaikan! Migrasi Lengkap.`, 'success');
          } else {
            globalAddToast(`CMT NOPOL ${unit.nopol} tersimpan — menunggu penyerahan GPS lama ke vendor.`, 'warning');
          }
        } catch (err) {
          console.error(err);
        } finally {
          setLoadingSubmit(false);
        }
      };

      const editingUnit = units.find(u => u.id === editId);

      return (
        <div className="fade-in">
          <div className="role-banner cmt">
            <i className="bi bi-check-circle"></i>
            <span><strong>Role: CMT</strong> — Verifikasi final penerimaan fisik GPS lama, terminasi sistem GPS lama, dan penutupan migrasi GPS.</span>
          </div>

          {!editId ? (
            <>
              <FilterRow>
                <div className="search-input-wrapper">
                  <i className="bi bi-search"></i>
                  <input type="text" value={q} onChange={e => { setQ(e.target.value); setPage(1); }} className="search-input" placeholder="Cari NOPOL..." />
                </div>
                <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
                  <option value="">Semua Lokasi</option>
                  {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                </select>
                <span className="unit-count-tag">{filtered.length} Unit Menunggu CMT</span>
              </FilterRow>

              {filtered.length === 0 ? (
                <div style={{ textAlign: 'center', padding: 48, color: 'var(--text-tertiary)', background: 'var(--bg-card)', borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)', marginTop: 12 }}>
                  <i className="bi bi-list-check" style={{ fontSize: 32, display: 'block', marginBottom: 10, color: 'var(--text-tertiary)' }}></i>
                  Tidak ada unit berstatus IT VERIFIED yang membutuhkan verifikasi final CMT.
                </div>
              ) : isMobile ? (
                <div style={{ display: 'flex', flexDirection: 'column', gap: 12, marginTop: 12 }}>
                  {slice.map(u => (
                    <div key={u.id} className="mobile-unit-card" style={{ padding: 14 }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                        <strong style={{ fontSize: 15 }}>{u.nopol}</strong>
                        <Badge val={u.statusPasang} />
                      </div>
                      <div style={{ fontSize: 11, color: 'var(--text-secondary)', marginTop: 6 }}>
                        <div>Site: {u.location} • Pool: {u.pool}</div>
                        <div>IT Verified By: <strong>IT Team</strong></div>
                      </div>
                      <button className="btn btn-primary btn-sm" style={{ width: '100%', marginTop: 12, justifyContent: 'center' }} onClick={() => { setEditId(u.id); setCmtCekAplikasi('OK'); setCmtStatusPenyerahan('BELUM'); setCmtFotoTerimaFisik(''); setCmtFotoSerahTerima(''); }}>
                        <i className="bi bi-clipboard-check"></i> Mulai Verifikasi Final
                      </button>
                    </div>
                  ))}
                </div>
              ) : (
                <div className="table-container" style={{ marginTop: 12 }}>
                  <table className="data-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>NOPOL</th>
                        <th>LOCATION</th>
                        <th>POOL</th>
                        <th>TEKNISI</th>
                        <th>PIC</th>
                        <th>IT STATUS</th>
                        <th>AKSI</th>
                      </tr>
                    </thead>
                    <tbody>
                      {slice.map((u, i) => (
                        <tr key={u.id}>
                          <td className="text-muted">{(page - 1) * PAGE_LIMIT + i + 1}</td>
                          <td><strong>{u.nopol}</strong></td>
                          <td>{u.location}</td>
                          <td>{u.pool}</td>
                          <td>{u.teknisiPelaksana || '—'}</td>
                          <td>{u.picLapangan || '—'}</td>
                          <td className="text-center"><Badge val={u.itCekAplikasi} /></td>
                          <td>
                            <button className="btn btn-primary btn-sm" onClick={() => { setEditId(u.id); setCmtCekAplikasi('OK'); setCmtStatusPenyerahan('BELUM'); setCmtFotoTerimaFisik(''); setCmtFotoSerahTerima(''); }}>
                              <i className="bi bi-clipboard-check"></i> Verifikasi CMT
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              {filtered.length > 0 && <Pager page={page} total={total} onChange={p => setPage(p)} />}
            </>
          ) : (
            <div className="panel-card fade-in" style={{ padding: 20 }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16, paddingBottom: 12, borderBottom: '1px solid var(--border-color)' }}>
                <span style={{ fontWeight: 700, fontSize: 15 }}>Form Verifikasi Final CMT: {editingUnit.nopol}</span>
                <button className="btn btn-secondary btn-sm" onClick={() => setEditId(null)}>Batal</button>
              </div>

              <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : '1.2fr 1fr', gap: 24 }}>
                <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
                  <div style={{ background: 'rgba(255,255,255,0.02)', borderRadius: 8, padding: 14, border: '1px solid var(--border-color)', fontSize: 12 }}>
                    <h4 style={{ margin: '0 0 10px 0', fontSize: 13, borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: 6 }}>Riwayat Alur Migrasi</h4>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>
                      <div>Nopol: <strong>{editingUnit.nopol}</strong></div>
                      <div>Tipe: <strong>{editingUnit.merk} {editingUnit.assetType}</strong></div>
                      <div>SN GPS Baru: <code>{editingUnit.gpsSerialBaru}</code></div>
                      <div>IMEI GPS Baru: <code>{editingUnit.gpsImeiBaru}</code></div>
                      <div>Teknisi: <strong>{editingUnit.teknisiPelaksana}</strong></div>
                      <div>PIC Lapangan: <strong>{editingUnit.picLapangan}</strong></div>
                      <div>Cek Fisik GPS Lama: <Badge val={editingUnit.picCekFisikLama} /></div>
                      <div>Cek Fisik GPS Baru: <Badge val={editingUnit.picCekFisikBaru} /></div>
                      <div>Cek Fitur Lapangan: <Badge val={editingUnit.picCekFitur} /></div>
                      <div>Cek IT Aplikasi: <Badge val={editingUnit.itCekAplikasi} /></div>
                    </div>
                  </div>

                  <div className="input-group">
                    <label className="input-label">Cek Unit di Aplikasi (TEMON / GEOTAB / SMATRACK) *</label>
                    <div className="teknisi-btn-group">
                      {['OK', 'NOT OK'].map(o => (
                        <button type="button" key={o} className={`teknisi-btn-option ${cmtCekAplikasi === o ? (o === 'OK' ? 'active' : 'active danger') : ''}`} onClick={() => setCmtCekAplikasi(o)}>
                          {o}
                        </button>
                      ))}
                    </div>
                  </div>

                  <div className="input-group">
                    <label className="input-label">Status Penyerahan GPS Lama ke Vendor *</label>
                    <div style={{ marginBottom: 6 }}>
                      <div className="teknisi-btn-group">
                        {['SUDAH', 'BELUM'].map(o => (
                          <button
                            type="button"
                            key={o}
                            className={`teknisi-btn-option ${cmtStatusPenyerahan === o ? (o === 'SUDAH' ? 'active' : 'active danger') : ''}`}
                            onClick={() => setCmtStatusPenyerahan(o)}
                          >
                            {o === 'SUDAH' ? '✓ Sudah Diserahkan' : '✗ Belum Diserahkan'}
                          </button>
                        ))}
                      </div>
                      {cmtStatusPenyerahan === 'BELUM' && (
                        <div style={{ marginTop: 8, padding: '8px 12px', background: 'rgba(245,158,11,0.1)', border: '1px solid rgba(245,158,11,0.3)', borderRadius: 6, fontSize: 11, color: '#F59E0B' }}>
                          <i className="bi bi-exclamation-triangle" style={{ marginRight: 6 }}></i>
                          GPS lama belum diserahkan — status akan disimpan sebagai <strong>CMT PENDING</strong> (belum DONE)
                        </div>
                      )}
                    </div>
                  </div>
                </div>

                <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
                  <div className="photo-grid" style={{ gridTemplateColumns: '1fr', gap: 12 }}>
                    <div className="photo-card" style={{ height: 130, display: 'flex', alignItems: 'center', justifyContent: 'center', border: '2px dashed var(--border-color)', borderRadius: 8, background: 'var(--bg-primary)' }}>
                      {cmtFotoTerimaFisik ? (
                        <div style={{ width: '100%', height: '100%', position: 'relative', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                          <a href={cmtFotoTerimaFisik} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '100%', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, color: '#60A5FA' }}>
                            <i className="bi bi-link-45deg" style={{ fontSize: 24, marginBottom: 4 }}></i>
                            <span style={{ fontSize: 10, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO TERIMA FISIK</span>
                          </a>
                          <button type="button" className="btn btn-secondary btn-sm" style={{ position: 'absolute', bottom: 8, right: 8, color: '#EF4444', border: 'none', background: 'rgba(239,68,68,0.2)' }} onClick={() => setCmtFotoTerimaFisik('')}>Hapus</button>
                        </div>
                      ) : (
                        <label style={{ cursor: 'pointer', textAlign: 'center', padding: 10 }}>
                          <i className="bi bi-camera" style={{ fontSize: 24, color: 'var(--text-secondary)', marginBottom: 4, display: 'block' }}></i>
                          <span style={{ fontSize: 10, fontWeight: 700, color: '#FFF' }}>Foto Terima Fisik GPS Lama *</span>
                          <input type="file" accept="image/*" capture="environment" style={{ display: 'none' }} onChange={e => handlePhotoChange('cmtFotoTerimaFisik', e.target.files[0])} />
                        </label>
                      )}
                    </div>

                    <div className="photo-card" style={{ height: 130, display: 'flex', alignItems: 'center', justifyContent: 'center', border: '2px dashed var(--border-color)', borderRadius: 8, background: 'var(--bg-primary)' }}>
                      {cmtFotoSerahTerima ? (
                        <div style={{ width: '100%', height: '100%', position: 'relative', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                          <a href={cmtFotoSerahTerima} target="_blank" rel="noopener noreferrer" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', width: '100%', height: '100%', textDecoration: 'none', background: 'rgba(59, 130, 246, 0.08)', borderRadius: 6, color: '#60A5FA' }}>
                            <i className="bi bi-link-45deg" style={{ fontSize: 24, marginBottom: 4 }}></i>
                            <span style={{ fontSize: 10, fontWeight: 700, textTransform: 'uppercase' }}>LIHAT FOTO BUKTI TERMINASI</span>
                          </a>
                          <button type="button" className="btn btn-secondary btn-sm" style={{ position: 'absolute', bottom: 8, right: 8, color: '#EF4444', border: 'none', background: 'rgba(239,68,68,0.2)' }} onClick={() => setCmtFotoSerahTerima('')}>Hapus</button>
                        </div>
                      ) : (
                        <label style={{ cursor: 'pointer', textAlign: 'center', padding: 10 }}>
                          <i className="bi bi-camera" style={{ fontSize: 24, color: 'var(--text-secondary)', marginBottom: 4, display: 'block' }}></i>
                          <span style={{ fontSize: 10, fontWeight: 700, color: '#FFF' }}>Foto Dokumen Serah Terima GPS Lama *</span>
                          <input type="file" accept="image/*" capture="environment" style={{ display: 'none' }} onChange={e => handlePhotoChange('cmtFotoSerahTerima', e.target.files[0])} />
                        </label>
                      )}
                    </div>
                  </div>

                  <div style={{ marginTop: 'auto', display: 'flex', gap: 10, flexWrap: 'wrap' }}>
                    <button className="btn btn-secondary" style={{ flex: 1, justifyContent: 'center' }} onClick={() => setEditId(null)}>Batal</button>
                    <button className="btn btn-secondary" style={{ flex: 1, justifyContent: 'center', borderColor: '#F59E0B', color: '#F59E0B' }} onClick={saveDraftCmt} disabled={loadingDraftCmt}>
                      <i className="bi bi-floppy" style={{ marginRight: 6 }}></i>Simpan Draft
                    </button>
                    <button className="btn btn-primary" style={{ flex: 1.5, justifyContent: 'center' }} disabled={loadingSubmit || !cmtFotoTerimaFisik || !cmtFotoSerahTerima} onClick={() => save(editingUnit.id)}>
                      {loadingSubmit ? 'Mengirim...' : cmtStatusPenyerahan === 'SUDAH' ? 'Selesaikan Migrasi ✓' : 'Simpan (GPS Belum Diserahkan)'}
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      );
    }
    function RekapView({ units, isMobile }) {
      const [subTab, setSubTab] = useState('summary');
      const [q, setQ] = useState('');
      const [loc, setLoc] = useState('');
      const [statusFilter, setStatusFilter] = useState('');
      const [page, setPage] = useState(1);

      const rekapData = useMemo(() => {
        return LOCS.map(loc => {
          const all = units.filter(u => u.location === loc);
          const plan = all.filter(u => u.statusPlan === 'PLAN').length;
          const done = all.filter(u => u.statusPasang === 'DONE').length;
          const activeProgress = all.filter(u => ['ON PROGRESS', 'TEKNISI SUBMITTED', 'PIC VERIFIED', 'IT VERIFIED'].includes(u.statusPasang)).length;
          const pct = all.length ? Math.round((done / all.length) * 100) : 0;
          return { loc, total: all.length, plan, unplan: all.length - plan, done, prog: activeProgress, pct };
        });
      }, [units]);

      const filteredUnits = useMemo(() => {
        return units.filter(u => 
          (!q || u.nopol.toLowerCase().includes(q.toLowerCase())) &&
          (!loc || u.location === loc) &&
          (!statusFilter || u.statusPasang === statusFilter)
        );
      }, [units, q, loc, statusFilter]);

      const totalPages = Math.ceil(filteredUnits.length / PAGE_LIMIT);
      const paginatedUnits = filteredUnits.slice((page - 1) * PAGE_LIMIT, page * PAGE_LIMIT);

      return (
        <div className="fade-in" style={{ display: 'flex', flexDirection: 'column', gap: 20 }}>
          <div style={{ display: 'flex', gap: 10, borderBottom: '1px solid var(--border-color)', paddingBottom: 10 }}>
            <button className={`btn ${subTab === 'summary' ? 'btn-primary' : 'btn-secondary'}`} onClick={() => setSubTab('summary')} style={{ height: 36, display: 'flex', alignItems: 'center', gap: 6 }}>
              <i className="bi bi-bar-chart"></i> Ringkasan per Site
            </button>
            <button className={`btn ${subTab === 'details' ? 'btn-primary' : 'btn-secondary'}`} onClick={() => { setSubTab('details'); setPage(1); }} style={{ height: 36, display: 'flex', alignItems: 'center', gap: 6 }}>
              <i className="bi bi-table"></i> Detail 39 Kolom Database
            </button>
          </div>

          {subTab === 'summary' ? (
            <div className="panel-card">
              <div className="panel-title" style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', width: '100%', flexWrap: 'wrap', gap: 10 }}>
                <span style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <i className="bi bi-file-earmark-text"></i> Rekap Migrasi GPS per Site Lokasi
                </span>
                <button className="btn btn-secondary" onClick={() => exportToCSV(units, 'semua_data_migrasi_gps.csv')} title="Ekspor Semua Data ke CSV">
                  <i className="bi bi-download"></i> Ekspor Semua GPS (CSV)
                </button>
              </div>
              {isMobile ? (
                <div className="mobile-unit-list" style={{ marginTop: 10 }}>
                  {rekapData.map(d => (
                    <div key={d.loc} className="mobile-unit-card" style={{ padding: '14px 16px', background: 'var(--bg-card)', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-md)', marginBottom: 12 }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 10 }}>
                        <span style={{ fontSize: 14, fontWeight: 700, color: 'var(--accent)' }}>{d.loc}</span>
                        <span className="badge info" style={{ fontSize: 10, padding: '2px 8px', fontWeight: 600 }}>{d.total} Unit</span>
                      </div>
                      
                      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '8px 12px', fontSize: 11, borderTop: '1px solid var(--border-color)', paddingTop: 10, paddingBottom: 10, marginBottom: 10 }}>
                        <div>
                          <span style={{ color: 'var(--text-tertiary)', display: 'block', fontSize: 9, fontWeight: 600 }}>PLAN / UNPLAN</span>
                          <strong>{d.plan}</strong> <span style={{ color: 'var(--text-tertiary)' }}>/ {d.unplan}</span>
                        </div>
                        <div>
                          <span style={{ color: 'var(--text-tertiary)', display: 'block', fontSize: 9, fontWeight: 600 }}>DONE MIGRASI</span>
                          <strong style={{ color: 'var(--color-done)' }}>{d.done}</strong>
                        </div>
                        <div>
                          <span style={{ color: 'var(--text-tertiary)', display: 'block', fontSize: 9, fontWeight: 600 }}>ON PROGRESS / VERIF</span>
                          <strong style={{ color: 'var(--color-progress)' }}>{d.prog}</strong>
                        </div>
                      </div>
                      
                      <div style={{ borderTop: '1px solid var(--bg-secondary)', paddingTop: 8 }}>
                        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 10, fontWeight: 600, marginBottom: 4 }}>
                          <span style={{ color: 'var(--text-secondary)' }}>Persentase Selesai</span>
                          <span style={{ color: 'var(--color-done)' }}>{d.pct}%</span>
                        </div>
                        <div style={{ height: 6, background: 'var(--bg-secondary)', borderRadius: 3, overflow: 'hidden' }}>
                          <div style={{ width: `${d.pct}%`, height: '100%', background: 'var(--color-done)' }} />
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div className="table-container" style={{boxShadow:'none', border:'none', margin:0}}>
                  <table className="data-table">
                    <thead>
                      <tr>
                        <th>LOKASI SITE</th>
                        <th className="text-center">TOTAL UNIT</th>
                        <th className="text-center">PLAN</th>
                        <th className="text-center">UNPLAN</th>
                        <th className="text-center">DONE (MIGRASI)</th>
                        <th className="text-center">ON PROGRESS / VERIF</th>
                        <th style={{ width: 180 }}>PERSENTASE SELESAI</th>
                      </tr>
                    </thead>
                    <tbody>
                      {rekapData.map(d => (
                        <tr key={d.loc}>
                          <td><strong>{d.loc}</strong></td>
                          <td className="text-center" style={{fontWeight:600}}>{d.total}</td>
                          <td className="text-center">{d.plan}</td>
                          <td className="text-center text-muted">{d.unplan}</td>
                          <td className="text-center" style={{color:'var(--color-done)', fontWeight:700}}>{d.done}</td>
                          <td className="text-center" style={{color:'var(--color-progress)'}}>{d.prog}</td>
                          <td>
                            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                              <div style={{ flex: 1, height: 6, background: 'var(--bg-secondary)', borderRadius: 3, overflow: 'hidden', minWidth: 60 }}>
                                <div style={{ width: `${d.pct}%`, height: '100%', background: 'var(--color-done)' }} />
                              </div>
                              <span style={{ fontSize: 11, fontWeight: 600, minWidth: 32, textAlign: 'right' }}>{d.pct}%</span>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          ) : (
            <div className="panel-card">
              <div className="panel-title" style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', width: '100%', flexWrap: 'wrap', gap: 10 }}>
                <span><i className="bi bi-table"></i> Detail Database Migrasi GPS (39 Kolom)</span>
                <button className="btn btn-secondary" onClick={() => exportToCSV(filteredUnits, 'detail_data_migrasi_gps_filtered.csv')} title="Ekspor data tersaring">
                  <i className="bi bi-download"></i> Ekspor CSV Tersaring
                </button>
              </div>

              <FilterRow>
                <div className="search-input-wrapper">
                  <i className="bi bi-search"></i>
                  <input type="text" value={q} onChange={e => { setQ(e.target.value); setPage(1); }} className="search-input" placeholder="Cari NOPOL..." />
                </div>
                <select value={loc} onChange={e => { setLoc(e.target.value); setPage(1); }} className="filter-select">
                  <option value="">Semua Lokasi</option>
                  {LOCS.map(l => <option key={l} value={l}>{l}</option>)}
                </select>
                <select value={statusFilter} onChange={e => { setStatusFilter(e.target.value); setPage(1); }} className="filter-select">
                  <option value="">Semua Status</option>
                  <option value="UNPLANNED">UNPLANNED</option>
                  <option value="BELUM DIPASANG">BELUM DIPASANG</option>
                  <option value="ON PROGRESS">ON PROGRESS</option>
                  <option value="TEKNISI SUBMITTED">TEKNISI SUBMITTED</option>
                  <option value="PIC VERIFIED">PIC VERIFIED</option>
                  <option value="IT VERIFIED">IT VERIFIED</option>
                  <option value="DONE">DONE</option>
                </select>
                <span className="unit-count-tag">{filteredUnits.length} Unit</span>
              </FilterRow>

              <div className="table-container" style={{ overflowX: 'auto', maxHeight: 500, marginTop: 12 }}>
                <table className="data-table" style={{ minWidth: 2600 }}>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>NOPOL</th>
                      <th>OWNERSHIP</th>
                      <th>YEAR</th>
                      <th>MERK</th>
                      <th>ASSET TYPE</th>
                      <th>BUSINESS LOCATION</th>
                      <th>POOL</th>
                      <th>DEDICATE</th>
                      <th>STATUS REGISTRASI</th>
                      <th>PLAN PASANG</th>
                      <th>LOKASI PASANG</th>
                      <th>PIC LAPANGAN</th>
                      <th>TEKNISI PELAKSANA</th>
                      <th>TIPE GPS BARU</th>
                      <th>SN GPS BARU</th>
                      <th>IMEI GPS BARU</th>
                      <th>NOMOR SIM</th>
                      <th>PROVIDER</th>
                      <th>GPS</th>
                      <th>BUZZER</th>
                      <th>SOS</th>
                      <th>SENSOR WING</th>
                      <th>CAMERA</th>
                      <th>CEK FISIK GPS LAMA</th>
                      <th>CEK FISIK GPS BARU</th>
                      <th>CEK KONDISI UNIT</th>
                      <th>CEK FITUR</th>
                      <th>CEK IT APLIKASI</th>
                      <th>CEK CMT APLIKASI</th>
                      <th>LAST UPDATE</th>
                    </tr>
                  </thead>
                  <tbody>
                    {paginatedUnits.map((u, idx) => (
                      <tr key={u.id}>
                        <td className="text-muted">{(page - 1) * PAGE_LIMIT + idx + 1}</td>
                        <td><strong>{u.nopol}</strong></td>
                        <td>{u.ownership}</td>
                        <td>{u.year}</td>
                        <td>{u.merk}</td>
                        <td>{u.assetType}</td>
                        <td>{u.location}</td>
                        <td>{u.pool}</td>
                        <td>{u.dedicate}</td>
                        <td><Badge val={u.statusPasang} /></td>
                        <td>{u.planDate || '—'}</td>
                        <td>{u.lokasiPasang || '—'}</td>
                        <td>{u.picLapangan || '—'}</td>
                        <td>{u.teknisiPelaksana || '—'}</td>
                        <td>{u.modelGpsBaru || '—'}</td>
                        <td><code>{u.gpsSerialBaru || '—'}</code></td>
                        <td><code>{u.gpsImeiBaru || '—'}</code></td>
                        <td>{u.nomorSIM || '—'}</td>
                        <td>{u.provider || '—'}</td>
                        <td><Badge val={u.gps} /></td>
                        <td><Badge val={u.buzzer} /></td>
                        <td><Badge val={u.sos} /></td>
                        <td><Badge val={u.sensorWing} /></td>
                        <td><Badge val={u.camera} /></td>
                        <td><Badge val={u.picCekFisikLama} /></td>
                        <td><Badge val={u.picCekFisikBaru} /></td>
                        <td><Badge val={u.picCekKondisiSelesai} /></td>
                        <td><Badge val={u.picCekFitur} /></td>
                        <td><Badge val={u.itCekAplikasi} /></td>
                        <td><Badge val={u.cmtCekAplikasi} /></td>
                        <td className="text-muted" style={{ fontSize: 10 }}>{u.updatedAt || '—'}</td>
                      </tr>
                    ))}
                    {paginatedUnits.length === 0 && (
                      <tr>
                        <td colSpan="31" style={{ textAlign: 'center', padding: 24, color: 'var(--text-tertiary)' }}>Tidak ada data unit migrasi</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>

              {totalPages > 1 && (
                <Pager page={page} total={totalPages} onChange={p => setPage(p)} />
              )}
            </div>
          )}
        </div>
      );
    }

    // 6. Admin Panel View (User & Role Management)
    function AdminView({ units = [] }) {
      const { users, createUser, deleteUser, updateUser, restoreUsers, loadingUsers } = useContext(AuthContext);
      
      const [username, setUsername] = useState('');
      const [password, setPassword] = useState('');
      const [name, setName] = useState('');
      const [role, setRole] = useState('teknisi');
      
      const [editUser, setEditUser] = useState(null);
      const [showGASGuide, setShowGASGuide] = useState(false);
      const [isPending, setIsPending] = useState(false);

      const handleCreateUser = async (e) => {
        e.preventDefault();
        if (!username || !password || !name) {
          globalAddToast('Semua field wajib diisi!', 'error');
          return;
        }

        const isDuplicate = users.some(u => u.username.toLowerCase() === username.toLowerCase());
        if (isDuplicate) {
          globalAddToast('Username sudah terdaftar!', 'error');
          return;
        }

        setIsPending(true);
        const success = await createUser({
          username,
          password,
          name,
          role
        });
        setIsPending(false);

        if (success) {
          globalAddToast(`User ${name} dengan role ${role} berhasil dibuat!`, 'success');
          // Reset form
          setUsername('');
          setPassword('');
          setName('');
          setRole('teknisi');
        }
      };

      const handleDeleteUser = async (id, uName) => {
        if (uName === 'admin') {
          globalAddToast('User admin utama tidak dapat dihapus!', 'error');
          return;
        }
        if (confirm(`Apakah Anda yakin ingin menghapus user ${uName}?`)) {
          setIsPending(true);
          const success = await deleteUser(id);
          setIsPending(false);
          if (success) {
            globalAddToast('User berhasil dihapus!', 'success');
          }
        }
      };

      const handleSaveEdit = async () => {
        if (!editUser.password || !editUser.name) {
          globalAddToast('Nama dan password tidak boleh kosong!', 'error');
          return;
        }
        
        setIsPending(true);
        const success = await updateUser(editUser);
        setIsPending(false);

        if (success) {
          setEditUser(null);
          globalAddToast('Data user berhasil diperbarui!', 'success');
        }
      };

      // Backup JSON
      const exportUsersJSON = () => {
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(users, null, 2));
        const dlAnchorElem = document.createElement('a');
        dlAnchorElem.setAttribute("href", dataStr);
        dlAnchorElem.setAttribute("download", "gps_app_users_backup.json");
        dlAnchorElem.click();
        globalAddToast('Backup user berhasil diunduh!', 'success');
      };

      // Restore JSON
      const importUsersJSON = (e) => {
        const fileReader = new FileReader();
        if (e.target.files.length === 0) return;
        
        fileReader.readAsText(e.target.files[0], "UTF-8");
        fileReader.onload = async (event) => {
          try {
            const parsed = JSON.parse(event.target.result);
            if (Array.isArray(parsed) && parsed.length > 0 && parsed[0].username) {
              setIsPending(true);
              const success = await restoreUsers(parsed);
              setIsPending(false);
              if (success) {
                globalAddToast('Database user berhasil dipulihkan!', 'success');
              }
            } else {
              globalAddToast('Format file backup tidak valid!', 'error');
            }
          } catch (err) {
            globalAddToast('Gagal membaca file JSON!', 'error');
          }
        };
      };

      return (
        <div className="fade-in">
          <div className="role-banner admin">
            <i className="bi bi-gear"></i>
            <span><strong>Role: System Administrator</strong> — Buat user baru, atur level hak akses, dan lakukan backup database user.</span>
          </div>

          <div className="dashboard-layout-grid" style={{marginBottom: 20}}>
            {/* Create User Form */}
            <div className="panel-card">
              <div className="panel-title"><i className="bi bi-person-plus"></i> Tambah User Baru</div>
              <form onSubmit={handleCreateUser} style={{display:'flex', flexDirection:'column', gap: 14}}>
                <div className="input-group">
                  <label className="input-label">Nama Lengkap</label>
                  <input type="text" value={name} onChange={e => setName(e.target.value)} className="input-field" placeholder="cth. Muhammad Iqbal" required />
                </div>
                <div style={{display:'grid', gridTemplateColumns:'1fr 1fr', gap: 12}}>
                  <div className="input-group">
                    <label className="input-label">Username</label>
                    <input type="text" value={username} onChange={e => setUsername(e.target.value)} className="input-field" placeholder="cth. iqbal123" required />
                  </div>
                  <div className="input-group">
                    <label className="input-label">Password</label>
                    <input type="text" value={password} onChange={e => setPassword(e.target.value)} className="input-field" placeholder="Password login" required />
                  </div>
                </div>
                <div className="input-group">
                  <label className="input-label">Role Akses</label>
                  <select value={role} onChange={e => setRole(e.target.value)} className="filter-select" style={{width:'100%'}}>
                    <option value="planner">Planner (Jadwal & Site)</option>
                    <option value="teknisi">Teknisi (Instalasi Lapangan)</option>
                    <option value="pic">PIC Lapangan (Verifikasi Fisik)</option>
                    <option value="it">IT Puninar (Verifikasi Sistem)</option>
                    <option value="cmt">CMT (Verifikasi Final)</option>
                    <option value="admin">System Admin (Full Kontrol)</option>
                  </select>
                </div>
                <button type="submit" className="btn btn-primary" style={{marginTop: 10, justifyContent: 'center'}}>
                  <i className="bi bi-plus"></i> Daftarkan User
                </button>
              </form>
            </div>

            {/* Backup/Restore & DB Stats */}
            <div className="panel-card" style={{display:'flex', flexDirection:'column', justifyContent:'space-between'}}>
              <div>
                <div className="panel-title"><i className="bi bi-database"></i> Utilitas Database & Backup</div>
                <p style={{fontSize: 12, color: 'var(--text-secondary)', marginBottom: 16, lineHeight: 1.5}}>
                  Karena aplikasi ini berjalan tanpa server backend, data user disimpan pada browser lokal. Gunakan fitur backup JSON untuk mengamankan database user dan membagikannya ke perangkat teknisi lainnya.
                </p>
                <div style={{display:'flex', gap: 10, flexWrap: 'wrap', marginBottom: 20}}>
                  <button className="btn btn-secondary" onClick={exportUsersJSON}>
                    <i className="bi bi-download"></i> Ekspor User (JSON)
                  </button>
                  <label className="btn btn-secondary" style={{cursor: 'pointer'}}>
                    <i className="bi bi-upload"></i> Impor User
                    <input type="file" onChange={importUsersJSON} accept=".json" style={{display:'none'}} />
                  </label>
                </div>
              </div>

              <div style={{background: 'var(--bg-secondary)', padding: 14, borderRadius: 'var(--radius-md)', border: '1px solid var(--border-color)'}}>
                <div style={{fontSize: 12, fontWeight: 600, marginBottom: 8}}>Statistik User Terdaftar</div>
                <div style={{display:'grid', gridTemplateColumns:'repeat(3, 1fr)', gap: '10px 6px', textAlign:'center'}}>
                  <div>
                    <div style={{fontSize: 14, fontWeight: 700}}>{users.filter(u=>u.role==='admin').length}</div>
                    <div style={{fontSize: 9, color: 'var(--text-secondary)'}}>Admin</div>
                  </div>
                  <div>
                    <div style={{fontSize: 14, fontWeight: 700}}>{users.filter(u=>u.role==='planner').length}</div>
                    <div style={{fontSize: 9, color: 'var(--text-secondary)'}}>Planner</div>
                  </div>
                  <div>
                    <div style={{fontSize: 14, fontWeight: 700}}>{users.filter(u=>u.role==='teknisi').length}</div>
                    <div style={{fontSize: 9, color: 'var(--text-secondary)'}}>Teknisi</div>
                  </div>
                  <div>
                    <div style={{fontSize: 14, fontWeight: 700}}>{users.filter(u=>u.role==='pic').length}</div>
                    <div style={{fontSize: 9, color: 'var(--text-secondary)'}}>PIC Lapangan</div>
                  </div>
                  <div>
                    <div style={{fontSize: 14, fontWeight: 700}}>{users.filter(u=>u.role==='it').length}</div>
                    <div style={{fontSize: 9, color: 'var(--text-secondary)'}}>IT Puninar</div>
                  </div>
                  <div>
                    <div style={{fontSize: 14, fontWeight: 700}}>{users.filter(u=>u.role==='cmt').length}</div>
                    <div style={{fontSize: 9, color: 'var(--text-secondary)'}}>CMT</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* User List Panel */}
          <div className="panel-card" style={{marginBottom: 20}}>
            <div className="panel-title"><i className="bi bi-people"></i> Daftar User Terdaftar</div>
            <div className="user-grid">
              {users.map(u => (
                <div key={u.id} className="user-card">
                  <div className="sidebar-avatar" style={{width: 32, height: 32, fontSize: 12}}>
                    {u.name.charAt(0).toUpperCase()}
                  </div>
                  <div>
                    <div style={{fontSize: 13, fontWeight: 700}}>{u.name}</div>
                    <div style={{fontSize: 11, color: 'var(--text-secondary)'}}>@{u.username} • <Badge val={u.role} /></div>
                  </div>
                  <div className="user-card-actions">
                    <button className="btn btn-secondary btn-sm" onClick={() => setEditUser(u)}>
                      <i className="bi bi-pencil"></i>
                    </button>
                    {u.username !== 'admin' && (
                      <button className="btn btn-danger btn-sm" onClick={() => handleDeleteUser(u.id, u.username)}>
                        <i className="bi bi-trash"></i>
                      </button>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>


          {/* ── DASHBOARD TEKNISI ── */}
          {(() => {
            const teknisiUsers = users.filter(u => u.role === 'teknisi');
            if (teknisiUsers.length === 0) return null;
            return (
              <div className="panel-card" style={{ marginBottom: 20 }}>
                <div className="panel-title" style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <span><i className="bi bi-tools" style={{ marginRight: 6, color: '#3B82F6' }}></i>Dashboard Teknisi</span>
                  <span style={{ fontSize: 11, fontWeight: 400, color: 'var(--text-secondary)' }}>{teknisiUsers.length} teknisi aktif</span>
                </div>
                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(220px, 1fr))', gap: 12 }}>
                  {teknisiUsers.map(tek => {
                    const claimed   = units.filter(u => u.teknisiPelaksana === tek.name && u.statusPasang === 'ON PROGRESS').length;
                    const submitted = units.filter(u => u.teknisiPelaksana === tek.name && u.statusPasang === 'TEKNISI SUBMITTED').length;
                    const done      = units.filter(u => u.teknisiPelaksana === tek.name && ['PIC VERIFIED','IT VERIFIED','DONE'].includes(u.statusPasang)).length;
                    const total     = units.filter(u => u.teknisiPelaksana === tek.name).length;
                    const pctDone   = total ? Math.round((done / total) * 100) : 0;
                    return (
                      <div key={tek.id} style={{ background: 'var(--bg-secondary)', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-md)', padding: 14 }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 10 }}>
                          <div style={{ width: 34, height: 34, borderRadius: '50%', background: 'linear-gradient(135deg, #3B82F6, #1D4ED8)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 14, fontWeight: 700, color: '#FFF', flexShrink: 0 }}>
                            {tek.name.charAt(0).toUpperCase()}
                          </div>
                          <div style={{ minWidth: 0 }}>
                            <div style={{ fontWeight: 700, fontSize: 13, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{tek.name}</div>
                            <div style={{ fontSize: 10, color: 'var(--text-secondary)' }}>@{tek.username}</div>
                          </div>
                        </div>
                        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 4, marginBottom: 10, textAlign: 'center' }}>
                          <div style={{ background: 'rgba(59,130,246,0.08)', borderRadius: 6, padding: '6px 4px' }}>
                            <div style={{ fontSize: 16, fontWeight: 800, color: '#3B82F6' }}>{claimed}</div>
                            <div style={{ fontSize: 8, color: 'var(--text-secondary)', fontWeight: 600, textTransform: 'uppercase' }}>On Progress</div>
                          </div>
                          <div style={{ background: 'rgba(245,158,11,0.08)', borderRadius: 6, padding: '6px 4px' }}>
                            <div style={{ fontSize: 16, fontWeight: 800, color: '#F59E0B' }}>{submitted}</div>
                            <div style={{ fontSize: 8, color: 'var(--text-secondary)', fontWeight: 600, textTransform: 'uppercase' }}>Submitted</div>
                          </div>
                          <div style={{ background: 'rgba(16,185,129,0.08)', borderRadius: 6, padding: '6px 4px' }}>
                            <div style={{ fontSize: 16, fontWeight: 800, color: '#10B981' }}>{done}</div>
                            <div style={{ fontSize: 8, color: 'var(--text-secondary)', fontWeight: 600, textTransform: 'uppercase' }}>Verified</div>
                          </div>
                        </div>
                        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', fontSize: 10, color: 'var(--text-secondary)', marginBottom: 4 }}>
                          <span>{total} total unit dikerjakan</span>
                          <span style={{ fontWeight: 700, color: pctDone > 70 ? '#10B981' : pctDone > 30 ? '#F59E0B' : 'var(--text-secondary)' }}>{pctDone}%</span>
                        </div>
                        <div style={{ height: 4, borderRadius: 4, background: 'var(--bg-tertiary)', overflow: 'hidden' }}>
                          <div style={{ height: '100%', width: `${pctDone}%`, borderRadius: 4, background: pctDone > 70 ? '#10B981' : pctDone > 30 ? '#F59E0B' : '#3B82F6', transition: 'width 0.4s ease' }} />
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })()}

          {/* ── DASHBOARD PIC LAPANGAN ── */}
          {(() => {
            const picUsers = users.filter(u => u.role === 'pic');
            if (picUsers.length === 0) return null;
            return (
              <div className="panel-card" style={{ marginBottom: 20 }}>
                <div className="panel-title" style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <span><i className="bi bi-clipboard-check" style={{ marginRight: 6, color: '#10B981' }}></i>Dashboard PIC Lapangan</span>
                  <span style={{ fontSize: 11, fontWeight: 400, color: 'var(--text-secondary)' }}>{picUsers.length} PIC aktif</span>
                </div>
                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(220px, 1fr))', gap: 12 }}>
                  {picUsers.map(pic => {
                    const pending  = units.filter(u => u.picLapangan === pic.name && u.statusPasang === 'TEKNISI SUBMITTED').length;
                    const verified = units.filter(u => u.picLapangan === pic.name && ['PIC VERIFIED','IT VERIFIED','DONE'].includes(u.statusPasang)).length;
                    const total    = units.filter(u => u.picLapangan === pic.name).length;
                    const pctVerif = total ? Math.round((verified / total) * 100) : 0;
                    return (
                      <div key={pic.id} style={{ background: 'var(--bg-secondary)', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-md)', padding: 14 }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 10 }}>
                          <div style={{ width: 34, height: 34, borderRadius: '50%', background: 'linear-gradient(135deg, #10B981, #059669)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 14, fontWeight: 700, color: '#FFF', flexShrink: 0 }}>
                            {pic.name.charAt(0).toUpperCase()}
                          </div>
                          <div style={{ minWidth: 0 }}>
                            <div style={{ fontWeight: 700, fontSize: 13, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{pic.name}</div>
                            <div style={{ fontSize: 10, color: 'var(--text-secondary)' }}>@{pic.username}</div>
                          </div>
                        </div>
                        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 4, marginBottom: 10, textAlign: 'center' }}>
                          <div style={{ background: 'rgba(16,185,129,0.05)', borderRadius: 6, padding: '6px 4px', border: '1px solid rgba(16,185,129,0.1)' }}>
                            <div style={{ fontSize: 16, fontWeight: 800, color: 'var(--text-primary)' }}>{total}</div>
                            <div style={{ fontSize: 8, color: 'var(--text-secondary)', fontWeight: 600, textTransform: 'uppercase' }}>Total Area</div>
                          </div>
                          <div style={{ background: 'rgba(245,158,11,0.08)', borderRadius: 6, padding: '6px 4px' }}>
                            <div style={{ fontSize: 16, fontWeight: 800, color: '#F59E0B' }}>{pending}</div>
                            <div style={{ fontSize: 8, color: 'var(--text-secondary)', fontWeight: 600, textTransform: 'uppercase' }}>Perlu Cek</div>
                          </div>
                          <div style={{ background: 'rgba(16,185,129,0.08)', borderRadius: 6, padding: '6px 4px' }}>
                            <div style={{ fontSize: 16, fontWeight: 800, color: '#10B981' }}>{verified}</div>
                            <div style={{ fontSize: 8, color: 'var(--text-secondary)', fontWeight: 600, textTransform: 'uppercase' }}>Terverifikasi</div>
                          </div>
                        </div>
                        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', fontSize: 10, color: 'var(--text-secondary)', marginBottom: 4 }}>
                          <span>{pending > 0 ? `${pending} unit menunggu verifikasi` : 'Semua unit terverifikasi ✓'}</span>
                          <span style={{ fontWeight: 700, color: pctVerif > 70 ? '#10B981' : pctVerif > 30 ? '#F59E0B' : 'var(--text-secondary)' }}>{pctVerif}%</span>
                        </div>
                        <div style={{ height: 4, borderRadius: 4, background: 'var(--bg-tertiary)', overflow: 'hidden' }}>
                          <div style={{ height: '100%', width: `${pctVerif}%`, borderRadius: 4, background: pctVerif > 70 ? '#10B981' : pctVerif > 30 ? '#F59E0B' : '#3B82F6', transition: 'width 0.4s ease' }} />
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })()}

          {/* Apps Script Guide */}
          <div className="instruction-box">
            <div className="instruction-header" onClick={() => setShowGASGuide(!showGASGuide)}>
              <span><i className="bi bi-code" style={{marginRight: 6}}></i> Panduan Google Apps Script Backend</span>
              <i className={`ti ${showGASGuide ? 'ti-chevron-up' : 'ti-chevron-down'}`}></i>
            </div>
            {showGASGuide && (
              <div className="instruction-body">
                <p>Aplikasi ini membaca dan menulis data ke Google Sheets Anda secara langsung dari browser. Agar sinkronisasi berjalan lancar, pastikan Apps Script Anda memiliki kode berikut:</p>
                <div className="code-snippet">
{`// =========================================================================
// 1. FUNGSI SETUP (Jalankan fungsi ini SEKALI setelah menempelkan kode ini)
//    Fungsi ini otomatis membuat sheet "DATABASE" dan 39 kolom header yang sesuai.
// =========================================================================
function setupDatabase() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("DATABASE");
  if (!sheet) {
    sheet = ss.insertSheet("DATABASE");
    var sheet1 = ss.getSheetByName("Sheet1");
    if (sheet1 && sheet1.getLastRow() === 0) {
      ss.deleteSheet(sheet1);
    }
  }
  
  // 39 Kolom Header lengkap sesuai kebutuhan Web App & Excel Master
  var headers = [
    "NO", "OWNERSHIP", "NOPOL", "YEAR", "MERK", "ASSET TYPE", "BUSINESS LOCATION", "BUSINESS POOL", "BUSINESS DEDICATE",
    "PLAN PASANG", "LOKASI PASANG", "PIC LAPANGAN", "TEKNISI PELAKSANA", "TIPE GPS BARU", "SN GPS BARU", "IMEI GPS BARU",
    "NOMOR KARTU GPS BARU", "PROVIDER SIM GPS BARU", "GPS", "BUZZER", "SOS", "SENSOR WING", "CAMERA",
    "FOTO KENDARAAN (NOPOL)", "FOTO SERIAL GPS LAMA (DICABUT)", "FOTO GPS BARU (SN TERLIHAT)", "FOTO HASIL INSTALASI", "STATUS REGISTRASI",
    "CEK FISIK GPS LAMA", "CEK FISIK GPS BARU", "CEK KONDISI UNIT SELESAI INSTALASI", "CEK FITUR (SENSOR, SOS, CAMERA)", "FOTO BUKTI PENYERAHAN GPS LAMA",
    "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK)", "FOTO INTEGRASI DATA GPS KE PUNINAR", "FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR",
    "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK)", "FOTO TERIMA FISIK GPS LAMA", "FOTO BUKTI TERMINASI GPS LAMA", "LAST_UPDATE"
  ];
  
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  
  sheet.getRange(1, 1, 1, headers.length)
    .setFontWeight("bold")
    .setBackground("#f3f4f6")
    .setHorizontalAlignment("center");
  sheet.setFrozenRows(1);
  
  Logger.log("DATABASE sheet setup sukses dengan " + headers.length + " kolom!");
}

// Helper untuk mencari atau membuat folder "image GPS"
function getOrCreateImageFolder(ss) {
  var fileId = ss.getId();
  var file = DriveApp.getFileById(fileId);
  var parents = file.getParents();
  var parentFolder = null;
  if (parents.hasNext()) {
    parentFolder = parents.next();
  } else {
    parentFolder = DriveApp.getRootFolder();
  }
  
  var folderName = "image GPS";
  var folders = parentFolder.getFoldersByName(folderName);
  if (folders.hasNext()) {
    return folders.next();
  } else {
    var newFolder = parentFolder.createFolder(folderName);
    return newFolder;
  }
}

// =========================================================================
// 2. FUNGSI GET (Membaca data dari Spreadsheet untuk Web App)
// =========================================================================
function doGet(e) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("DATABASE");
  
  if (!sheet) {
    setupDatabase();
    sheet = ss.getSheetByName("DATABASE");
  }
  
  var displayValues = sheet.getDataRange().getDisplayValues();
  var formulas = sheet.getDataRange().getFormulas();
  var headers = displayValues[0];
  var jsonArray = [];
  
  if (displayValues.length <= 1) {
    return ContentService.createTextOutput(JSON.stringify({ 
      success: true, 
      spreadsheetId: ss.getId(),
      spreadsheetName: ss.getName(),
      data: [] 
    })).setMimeType(ContentService.MimeType.JSON);
  }
  
  for (var i = 1; i < displayValues.length; i++) {
    var obj = { rowIndex: i + 1 };
    for (var j = 0; j < headers.length; j++) {
      var key = headers[j];
      if (j === 33) {
        key = "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT";
      } else if (j === 36) {
        key = "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT";
      }
      
      var val = displayValues[i][j];
      var formula = formulas[i][j];
      if (formula && formula.indexOf('=HYPERLINK') === 0) {
        var parts = formula.split('"');
        if (parts.length < 2) {
          parts = formula.split("'");
        }
        if (parts.length >= 2) {
          val = parts[1];
        }
      }
      obj[key] = val;
    }
    jsonArray.push(obj);
  }
  
  return ContentService.createTextOutput(JSON.stringify({ 
    success: true, 
    spreadsheetId: ss.getId(),
    spreadsheetName: ss.getName(),
    data: jsonArray 
  }))
  .setMimeType(ContentService.MimeType.JSON);
}

// =========================================================================
// 3. FUNGSI POST (Menulis / Mengupdate data dari Web App ke Spreadsheet)
// =========================================================================
function doPost(e) {
  var params = JSON.parse(e.postData.contents);
  
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("DATABASE");
  if (!sheet) {
    setupDatabase();
    sheet = ss.getSheetByName("DATABASE");
  }
  
  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  var nowStr = Utilities.formatDate(new Date(), "GMT+7", "dd-MM-yyyy HH:mm");
  var updateCol = headers.indexOf("LAST_UPDATE");
  
  var items = [];
  if (params.batch && Array.isArray(params.batch)) {
    items = params.batch;
  } else {
    items = [params];
  }
  
  var folder = null; // lazy load folder Drive
  
  for (var idx = 0; idx < items.length; idx++) {
    var item = items[idx];
    var nopol = item.nopol;
    var updates = item.updates;
    if (!nopol) continue;
    
    var nopolCol = headers.indexOf("NOPOL");
    if (nopolCol === -1) nopolCol = 2; // fallback ke indeks 2
    
    var row = -1;
    var cleanNopol = String(nopol).trim().toUpperCase();
    for (var i = 1; i < data.length; i++) {
      var sheetNopol = String(data[i][nopolCol]).trim().toUpperCase();
      if (sheetNopol === cleanNopol) {
        row = i + 1;
        break;
      }
    }
    
    if (row === -1) {
      row = sheet.getLastRow() + 1;
      sheet.getRange(row, nopolCol + 1).setValue(cleanNopol);
    }
    
    for (var key in updates) {
      var colIndex = -1;
      
      if (key === "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT") {
        colIndex = 33;
      } else if (key === "CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT") {
        colIndex = 36;
      } else {
        colIndex = headers.indexOf(key);
        if (colIndex === -1) {
          if (key === "STATUS_PASANG" || key === "STATUS REGISTRASI") colIndex = headers.indexOf("STATUS REGISTRASI");
          else if (key === "TEKNISI_PELAKSANA" || key === "TEKNISI PELAKSANA" || key === "TEKNISI") colIndex = headers.indexOf("TEKNISI PELAKSANA");
          else if (key === "PLAN_TGL" || key === "PLAN PASANG") colIndex = headers.indexOf("PLAN PASANG");
          else if (key === "LOKASI_PASANG" || key === "LOKASI PASANG") colIndex = headers.indexOf("LOKASI PASANG");
          else if (key === "MODEL_GPS_BARU" || key === "TIPE GPS BARU") colIndex = headers.indexOf("TIPE GPS BARU");
          else if (key === "GPS_SERIAL_BARU" || key === "SN GPS BARU") colIndex = headers.indexOf("SN GPS BARU");
          else if (key === "GPS_IMEI_BARU" || key === "IMEI GPS BARU") colIndex = headers.indexOf("IMEI GPS BARU");
          else if (key === "NOMOR_SIM" || key === "NOMOR KARTU GPS BARU") colIndex = headers.indexOf("NOMOR KARTU GPS BARU");
          else if (key === "PROVIDER" || key === "PROVIDER SIM GPS BARU") colIndex = headers.indexOf("PROVIDER SIM GPS BARU");
          else if (key === "CATATAN_PASANG" || key === "CATATAN PEMAASANGAN") colIndex = headers.indexOf("CATATAN PEMAASANGAN");
          else if (key === "FOTO_KENDARAAN" || key === "FOTO KENDARAAN (NOPOL)") colIndex = headers.indexOf("FOTO KENDARAAN (NOPOL)");
          else if (key === "FOTO_GPS_LAMA" || key === "FOTO SERIAL GPS LAMA (DICABUT)") colIndex = headers.indexOf("FOTO SERIAL GPS LAMA (DICABUT)");
          else if (key === "FOTO_GPS_BARU" || key === "FOTO GPS BARU (SN TERLIHAT)") colIndex = headers.indexOf("FOTO GPS BARU (SN TERLIHAT)");
          else if (key === "FOTO_HASIL_INSTALASI" || key === "FOTO HASIL INSTALASI") colIndex = headers.indexOf("FOTO HASIL INSTALASI");
          else if (key === "CEK_FISIK_GPS_LAMA" || key === "CEK FISIK GPS LAMA") colIndex = headers.indexOf("CEK FISIK GPS LAMA");
          else if (key === "CEK_FISIK_GPS_BARU" || key === "CEK FISIK GPS BARU") colIndex = headers.indexOf("CEK FISIK GPS BARU");
          else if (key === "CEK_KONDISI_UNIT_SELESAI_INSTALASI" || key === "CEK KONDISI UNIT SELESAI INSTALASI") colIndex = headers.indexOf("CEK KONDISI UNIT SELESAI INSTALASI");
          else if (key === "CEK_FITUR_SENSOR_SOS_CAMERA" || key === "CEK FITUR (SENSOR, SOS, CAMERA)") colIndex = headers.indexOf("CEK FITUR (SENSOR, SOS, CAMERA)");
          else if (key === "FOTO_BUKTI_PENYERAHAN_GPS_LAMA" || key === "FOTO BUKTI PENYERAHAN GPS LAMA") colIndex = headers.indexOf("FOTO BUKTI PENYERAHAN GPS LAMA");
          else if (key === "FOTO_INTEGRASI_DATA_GPS_KE_PUNINAR" || key === "FOTO INTEGRASI DATA GPS KE PUNINAR") colIndex = headers.indexOf("FOTO INTEGRASI DATA GPS KE PUNINAR");
          else if (key === "FOTO_INTEGRASI_DATA_ABNORMALITY_KE_PUNINAR" || key === "FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR") colIndex = headers.indexOf("FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR");
          else if (key === "FOTO_TERIMA_FISIK_GPS_LAMA" || key === "FOTO TERIMA FISIK GPS LAMA") colIndex = headers.indexOf("FOTO TERIMA FISIK GPS LAMA");
          else if (key === "FOTO_BUKTI_TERMINASI_GPS_LAMA" || key === "FOTO BUKTI TERMINASI GPS LAMA") colIndex = headers.indexOf("FOTO BUKTI TERMINASI GPS LAMA");
        }
      }
      
      if (colIndex > -1) {
        var value = updates[key];
        if (typeof value === 'string' && value.indexOf('data:image/') === 0) {
          if (!folder) {
            folder = getOrCreateImageFolder(ss);
          }
          var mimeType = value.substring(value.indexOf(':') + 1, value.indexOf(';'));
          var base64Data = value.substring(value.indexOf('base64,') + 7);
          var blob = Utilities.newBlob(Utilities.base64Decode(base64Data), mimeType);
          
          var ext = "jpg";
          if (mimeType.indexOf("png") !== -1) ext = "png";
          else if (mimeType.indexOf("gif") !== -1) ext = "gif";
          else if (mimeType.indexOf("webp") !== -1) ext = "webp";
          
          var timestamp = Utilities.formatDate(new Date(), "GMT+7", "yyyyMMdd_HHmmss");
          var safeKey = "";
          for (var k = 0; k < key.length; k++) {
            var charCode = key.charCodeAt(k);
            if ((charCode >= 65 && charCode <= 90) || (charCode >= 97 && charCode <= 122) || (charCode >= 48 && charCode <= 57) || key[k] === " " || key[k] === "(" || key[k] === ")" || key[k] === "-") {
              safeKey += key[k];
            } else {
              safeKey += "_";
            }
          }
          var filename = cleanNopol + " - " + safeKey + " - " + timestamp + "." + ext;
          blob.setName(filename);
          
          var file = folder.createFile(blob);
          file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
          
          var fileUrl = file.getUrl();
          var formula = '=HYPERLINK("' + fileUrl + '", "Lihat Foto")';
          sheet.getRange(row, colIndex + 1).setFormula(formula);
        } else if (typeof value === 'string' && value.indexOf('http') === 0) {
          var formula = '=HYPERLINK("' + value + '", "Lihat Foto")';
          sheet.getRange(row, colIndex + 1).setFormula(formula);
        } else {
          sheet.getRange(row, colIndex + 1).setValue(value);
        }
      }
    }
    
    if (updateCol > -1) {
      sheet.getRange(row, updateCol + 1).setValue(nowStr);
    }
  }
  
  return ContentService.createTextOutput(JSON.stringify({ 
    success: true,
    spreadsheetId: ss.getId(),
    spreadsheetName: ss.getName()
  }))
  .setMimeType(ContentService.MimeType.JSON);
}
}`}                </div>
                <p style={{marginTop: 8}}><strong>Cara Pasang & Inisialisasi:</strong></p>
                <ol style={{paddingLeft: 20, marginTop: 4, display:'flex', flexDirection:'column', gap:4}}>
                  <li>Buka Spreadsheet tempat data GPS berada.</li>
                  <li>Buka menu <strong>Ekstensi</strong> → <strong>Apps Script</strong>.</li>
                  <li>Hapus semua kode bawaan, lalu paste kode di atas ke dalam editor script.</li>
                  <li>Pilih fungsi <strong>setupDatabase</strong> di toolbar atas editor, lalu klik <strong>Jalankan (Run)</strong> untuk membuat sheet "DATABASE" beserta 33 kolom header secara otomatis!</li>
                  <li>Klik <strong>Terapkan (Deploy)</strong> → <strong>Penerapan baru (New deployment)</strong>.</li>
                  <li>Pilih jenis <strong>Aplikasi Web (Web App)</strong>. Atur hak akses <em>Who has access</em> ke <strong>Anyone</strong> (Penting agar Web App dapat mengakses).</li>
                  <li>Klik Deploy/Terapkan, setujui izin akses (Authorize), lalu copy URL Web App yang dihasilkan.</li>
                  <li>Buka file HTML ini, cari variabel <code>WEBAPP_URL</code> (sekitar baris 1253), dan ganti dengan URL Web App tersebut.</li>
                </ol>
              </div>
            )}
          </div>

          {/* Edit User Modal */}
          {editUser !== null && (
            <div className="modal-overlay">
              <div className="modal-card">
                <div className="modal-drag-handle"></div>
                <div className="modal-header">
                  <span className="modal-title">Edit User Account: @{editUser.username}</span>
                  <button className="modal-close" onClick={() => setEditUser(null)}><i className="bi bi-x"></i></button>
                </div>
                <div className="modal-body">
                  <div className="input-group">
                    <label className="input-label">Nama Lengkap</label>
                    <input type="text" value={editUser.name} onChange={e => setEditUser({ ...editUser, name: e.target.value })} className="input-field" required />
                  </div>
                  <div className="input-group">
                    <label className="input-label">Ubah Password</label>
                    <input type="text" value={editUser.password} onChange={e => setEditUser({ ...editUser, password: e.target.value })} className="input-field" required />
                  </div>
                  {editUser.username !== 'admin' && (
                    <div className="input-group">
                      <label className="input-label">Role Akses</label>
                      <select value={editUser.role} onChange={e => setEditUser({ ...editUser, role: e.target.value })} className="filter-select" style={{width:'100%'}}>
                        <option value="planner">Planner (Jadwal & Site)</option>
                        <option value="teknisi">Teknisi (Instalasi Lapangan)</option>
                        <option value="pic">PIC Lapangan (Verifikasi Fisik)</option>
                        <option value="it">IT Puninar (Verifikasi Sistem)</option>
                        <option value="cmt">CMT (Verifikasi Final)</option>
                        <option value="admin">System Admin</option>
                      </select>
                    </div>
                  )}
                </div>
                <div className="modal-footer">
                  <button className="btn btn-secondary" onClick={() => setEditUser(null)}>Batal</button>
                  <button className="btn btn-primary" onClick={handleSaveEdit}>Simpan</button>
                </div>
              </div>
            </div>
          )}
        </div>
      );
    }

    // ----------------------------------------------------
    // MAIN APP LAYOUT CONTROLLER
    // ----------------------------------------------------
    function App() {
      const { user, logout } = useContext(AuthContext);
      
      const [tab, setTab] = useState(() => {
        const items = [
          { id: 'dashboard', roles: ['admin', 'planner', 'it', 'cmt'] },
          { id: 'progress', roles: ['admin', 'planner'] },
          { id: 'planner', roles: ['admin', 'planner'] },
          { id: 'teknisi', roles: ['admin', 'teknisi'] },
          { id: 'pic', roles: ['admin', 'pic'] },
          { id: 'it', roles: ['admin', 'it'] },
          { id: 'cmt', roles: ['admin', 'cmt'] },
          { id: 'rekap', roles: ['admin', 'planner', 'it', 'cmt'] },
          { id: 'admin', roles: ['admin'] }
        ];
        const allowed = items.filter(item => item.roles.includes(user.role));
        return allowed[0]?.id || 'dashboard';
      });
      const [units, setUnits] = useState(() => {
        try {
          const localData = localStorage.getItem('puninar_gps_units');
          return localData ? JSON.parse(localData) : [];
        } catch (e) {
          return [];
        }
      });
      const [loading, setLoading] = useState(true);
      const [error, setError] = useState(null);
      const [syncState, setSyncState] = useState('success'); // 'syncing', 'success', 'error'

      useEffect(() => {
        if (units && units.length > 0) {
          localStorage.setItem('puninar_gps_units', JSON.stringify(units));
        }
      }, [units]);
      
      const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

      const [width, setWidth] = useState(window.innerWidth);
      useEffect(() => {
        const handleResize = () => setWidth(window.innerWidth);
        window.addEventListener('resize', handleResize);
        return () => window.removeEventListener('resize', handleResize);
      }, []);
      const isMobile = width < 768;

      // Helper to map mixed-case updates keys to DB columns
      const mapKeysToColumns = (updates) => {
        const mapped = {};
        for (const key in updates) {
          if (updates[key] === undefined) continue;
          
          let col = key;
          // Normalization
          const normKey = key.trim().toUpperCase();
          if (normKey === 'OWNERSHIP') col = 'ownership';
          else if (normKey === 'NOPOL') col = 'nopol';
          else if (normKey === 'YEAR') col = 'year';
          else if (normKey === 'MERK') col = 'merk';
          else if (normKey === 'ASSET TYPE' || normKey === 'MODEL' || normKey === 'ASSETTYPE') col = 'assetType';
          else if (normKey === 'BUSINESS LOCATION' || normKey === 'LOCATION') col = 'location';
          else if (normKey === 'BUSINESS POOL' || normKey === 'POOL') col = 'pool';
          else if (normKey === 'BUSINESS DEDICATE' || normKey === 'DEDICATE') col = 'dedicate';
          else if (normKey === 'PLAN PASANG' || normKey === 'PLAN_TGL' || normKey === 'PLANDATE') col = 'planDate';
          else if (normKey === 'LOKASI PASANG' || normKey === 'LOKASI_PASANG' || normKey === 'LOKASIPASANG') col = 'lokasiPasang';
          else if (normKey === 'PIC LAPANGAN' || normKey === 'PICLAPANGAN') col = 'picLapangan';
          else if (normKey === 'TEKNISI PELAKSANA' || normKey === 'TEKNISI_PELAKSANA' || normKey === 'TEKNISI' || normKey === 'TEKNISIPELAKSANA') col = 'teknisiPelaksana';
          else if (normKey === 'SN GPS LAMA' || normKey === 'NO GPS LAMA' || normKey === 'GPSSERIALLAMA' || normKey === 'NOGPSLAMA') col = 'gpsSerialLama';
          else if (normKey === 'TIPE GPS BARU' || normKey === 'MODEL_GPS_BARU' || normKey === 'MODELGPSBARU') col = 'modelGpsBaru';
          else if (normKey === 'SN GPS BARU' || normKey === 'GPS_SERIAL_BARU' || normKey === 'GPSSERIALBARU') col = 'gpsSerialBaru';
          else if (normKey === 'IMEI GPS BARU' || normKey === 'GPS_IMEI_BARU' || normKey === 'GPSIMEIBARU') col = 'gpsImeiBaru';
          else if (normKey === 'NOMOR KARTU GPS BARU' || normKey === 'NOMOR_SIM' || normKey === 'NOMORSIM') col = 'nomorSIM';
          else if (normKey === 'PROVIDER SIM GPS BARU' || normKey === 'PROVIDER' || normKey === 'PROVIDERSIM') col = 'provider';
          else if (normKey === 'GPS') col = 'gps';
          else if (normKey === 'BUZZER') col = 'buzzer';
          else if (normKey === 'SOS') col = 'sos';
          else if (normKey === 'SENSOR WING' || normKey === 'SENSOR_WING' || normKey === 'SENSORWING') col = 'sensorWing';
          else if (normKey === 'CAMERA') col = 'camera';
          else if (normKey === 'FOTO KENDARAAN (NOPOL)' || normKey === 'FOTO_KENDARAAN' || normKey === 'FOTOKENDARAAN') col = 'fotoKendaraan';
          else if (normKey === 'FOTO SERIAL GPS LAMA (DICABUT)' || normKey === 'FOTO_GPS_LAMA' || normKey === 'FOTOGPSLAMA') col = 'fotoGPSLama';
          else if (normKey === 'FOTO GPS BARU (SN TERLIHAT)' || normKey === 'FOTO_GPS_BARU' || normKey === 'FOTOGPSBARU') col = 'fotoGPSBaru';
          else if (normKey === 'FOTO HASIL INSTALASI' || normKey === 'FOTO_HASIL_INSTALASI' || normKey === 'FOTOHASILINSTALASI') col = 'fotoHasilInstalasi';
          else if (normKey === 'STATUS REGISTRASI' || normKey === 'STATUS_PASANG' || normKey === 'STATUSREGISTRASI' || normKey === 'STATUSPASANG') col = 'statusPasang';
          else if (normKey === 'CEK FISIK GPS LAMA' || normKey === 'CEK_FISIK_GPS_LAMA' || normKey === 'CEKFISIKGPSLAMA') col = 'picCekFisikLama';
          else if (normKey === 'CEK FISIK GPS BARU' || normKey === 'CEK_FISIK_GPS_BARU' || normKey === 'CEKFISIKGPSBARU') col = 'picCekFisikBaru';
          else if (normKey === 'CEK KONDISI UNIT SELESAI INSTALASI' || normKey === 'CEK_KONDISI_UNIT_SELESAI_INSTALASI' || normKey === 'CEKKONDISIUNITSELESAIINSTALASI') col = 'picCekKondisiSelesai';
          else if (normKey === 'CEK FITUR (SENSOR, SOS, CAMERA)' || normKey === 'CEK_FITUR_SENSOR_SOS_CAMERA' || normKey === 'CEKFITURSENSORSOSCAMERA') col = 'picCekFitur';
          else if (normKey === 'FOTO BUKTI PENYERAHAN GPS LAMA' || normKey === 'FOTO_BUKTI_PENYERAHAN_GPS_LAMA' || normKey === 'FOTOBUKTIPENYERAHANGPSLAMA') col = 'picFotoSerahTerima';
          else if (normKey === 'CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - IT' || normKey === 'CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK)') col = 'itCekAplikasi';
          else if (normKey === 'FOTO INTEGRASI DATA GPS KE PUNINAR' || normKey === 'FOTO_INTEGRASI_DATA_GPS_KE_PUNINAR' || normKey === 'FOTOINTEGRASIDATAGPSKEPUNINAR') col = 'itFotoIntegrasi';
          else if (normKey === 'FOTO INTEGRASI DATA ABNORMALITY KE PUNINAR' || normKey === 'FOTO_INTEGRASI_DATA_ABNORMALITY_KE_PUNINAR' || normKey === 'FOTOINTEGRASIDATAABNORMALITYKEPUNINAR') col = 'itFotoAbnormality';
          else if (normKey === 'CEK UNIT DI APLIKASI (TEMON /GEOTAB / SMATRACK) - CMT') col = 'cmtCekAplikasi';
          else if (normKey === 'FOTO TERIMA FISIK GPS LAMA' || normKey === 'FOTO_TERIMA_FISIK_GPS_LAMA' || normKey === 'FOTOTERIMAFISIKGPSLAMA') col = 'cmtFotoTerimaFisik';
          else if (normKey === 'FOTO BUKTI TERMINASI GPS LAMA' || normKey === 'FOTO_BUKTI_TERMINASI_GPS_LAMA' || normKey === 'FOTOBUKTITERMINASIGPSLAMA') col = 'cmtFotoTerminasi';
          else if (normKey === 'STATUS_EASYGO_DICOPOT' || normKey === 'EASYGODICOPOT') col = 'easygoDicopot';
          else if (normKey === 'LAST_UPDATE' || normKey === 'UPDATEDAT') col = 'updatedAt';
          
          mapped[col] = updates[key];
        }
        return mapped;
      };

      // Load Data from Supabase
      const loadData = async (silent = false) => {
        const isSilent = silent === true;
        if (!isSilent) {
          setLoading(true);
          setError(null);
        }
        setSyncState('syncing');
        try {
          const { data, error } = await supabaseClient
            .from('units')
            .select('*')
            .order('id', { ascending: true });
          
          if (error) throw error;
          
          const mappedList = (data || []).map(row => ({
            ...row,
            statusPlan: row.planDate ? 'PLAN' : 'UNPLAN'
          }));
          
          setUnits(mappedList);
          setSyncState('success');
          if (!isSilent) {
            globalAddToast('Data berhasil disinkronisasi dari Supabase!', 'success');
          }
        } catch (err) {
          setSyncState('error');
          if (!isSilent) {
            setError(String(err));
            globalAddToast('Gagal memuat data dari Supabase: ' + String(err), 'error');
          }
        } finally {
          if (!isSilent) {
            setLoading(false);
          }
        }
      };

      useEffect(() => {
        loadData();
        
        // Auto refresh data every 15 seconds if tab is active
        const intervalId = setInterval(() => {
          if (document.visibilityState === 'visible') {
            loadData(true);
          }
        }, 15000);
        
        return () => clearInterval(intervalId);
      }, []);

      // Realtime push update helper using upsert (insert-or-update by nopol)
      const syncUpdate = async (nopol, updates) => {
        setSyncState('syncing');
        
        try {
          // Normalize and map keys
          const mappedUpdates = mapKeysToColumns(updates);
          mappedUpdates.nopol = String(nopol).trim().toUpperCase(); // Ensure uppercase NOPOL
          
          if (!mappedUpdates.updatedAt) {
            const now = new Date();
            const dd = n => String(n).padStart(2, '0');
            const ts = `${now.getFullYear()}-${dd(now.getMonth() + 1)}-${dd(now.getDate())} ${dd(now.getHours())}:${dd(now.getMinutes())}`;
            mappedUpdates.updatedAt = ts;
          }
          
          const { data, error } = await supabaseClient
            .from('units')
            .upsert([mappedUpdates], { onConflict: 'nopol' });
            
          if (error) throw error;
          
          setSyncState('success');
          return { success: true };
        } catch (err) {
          setSyncState('error');
          console.error("Sync error details:", err);
          globalAddToast('Gagal sinkron data ke Supabase!', 'error');
          throw err;
        }
      };

      // Navigation Items based on User Roles
      const tabs = useMemo(() => {
        const items = [
          { id: 'dashboard', label: 'Dashboard', icon: 'ti-layout-dashboard', roles: ['admin', 'planner', 'it', 'cmt'] },
          { id: 'progress', label: 'Progress Migrasi', icon: 'ti-activity', roles: ['admin', 'planner'] },
          { id: 'planner', label: 'Planner', icon: 'ti-calendar', roles: ['admin', 'planner'] },
          { id: 'teknisi', label: 'Teknisi Lapangan', icon: 'ti-tool', roles: ['admin', 'teknisi'] },
          { id: 'pic', label: 'PIC Lapangan', icon: 'ti-clipboard-check', roles: ['admin', 'pic'] },
          { id: 'it', label: 'Verifikasi IT', icon: 'ti-device-desktop-analytics', roles: ['admin', 'it'] },
          { id: 'cmt', label: 'Verifikasi CMT', icon: 'ti-circle-check', roles: ['admin', 'cmt'] },
          { id: 'rekap', label: 'Rekap Migrasi', icon: 'ti-report', roles: ['admin', 'planner', 'it', 'cmt'] },
          { id: 'admin', label: 'Admin Panel', icon: 'ti-settings', roles: ['admin'] }
        ];
        
        // Filter based on user role
        return items.filter(item => item.roles.includes(user.role));
      }, [user.role]);

      // Fallback to first allowed tab if current tab is invalid
      useEffect(() => {
        const allowedIds = tabs.map(t => t.id);
        if (user && !allowedIds.includes(tab)) {
          setTab(allowedIds[0] || 'dashboard');
        }
      }, [user.role, tabs, tab]);

      // Calculate simple done stats for header bar
      const doneStats = useMemo(() => {
        const total = units.length;
        const done = units.filter(u => u.statusPasang === 'DONE').length;
        const pct = total ? Math.round((done / total) * 100) : 0;
        return { total, done, pct };
      }, [units]);

      if (loading && units.length === 0) {
        return (
          <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', minHeight: '100vh', gap: 14 }}>
            <i className="bi bi-arrow-repeat" style={{ fontSize: 32, color: 'var(--accent)', animation: 'spin 1.2s linear infinite' }}></i>
            <div style={{ fontSize: 13, color: 'var(--text-secondary)', fontWeight: 500 }}>Memuat database migrasi GPS...</div>
          </div>
        );
      }

      if (error && units.length === 0) {
        return (
          <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', minHeight: '100vh', gap: 16, padding: 24, textAlign: 'center', background: 'var(--bg-primary)' }}>
            <i className="bi bi-exclamation-triangle" style={{ fontSize: 36, color: 'var(--color-delay)' }}></i>
            <div style={{ fontSize: 15, fontWeight: 700 }}>Gagal Memuat Data</div>
            <div style={{ fontSize: 13, color: 'var(--text-secondary)', maxWidth: 460, lineHeight: 1.6 }}>
              Detail Error: <code style={{ background: 'var(--bg-secondary)', padding: '2px 6px', borderRadius: 4, color: 'var(--color-delay)' }}>{error}</code>
            </div>
            <div style={{ fontSize: 11, color: 'var(--text-tertiary)', maxWidth: 460, lineHeight: 1.6 }}>
              Pastikan: (1) URL Apps Script (<code>WEBAPP_URL</code>) sudah benar, (2) Setelan deployment Apps Script "Who has access" adalah "Anyone", dan (3) Koneksi internet Anda aktif.
            </div>
            <div style={{ display: 'flex', gap: 10, marginTop: 10, flexWrap: 'wrap', justifyContent: 'center' }}>
              <button className="btn btn-primary" onClick={loadData}>Coba Lagi</button>
              <button className="btn btn-secondary" onClick={() => {
                setError(null);
                setUnits(Array.from({ length: 15 }, (_, i) => ({
                  id: i + 1,
                  rowIndex: i + 2,
                  nopol: `B ${1000 + i * 23} ABC`,
                  merk: i % 2 === 0 ? 'MITSUBISHI' : 'ISUZU',
                  model: i % 2 === 0 ? 'FUSO' : 'ELF',
                  location: LOCS[i % LOCS.length],
                  pool: POOLS[i % POOLS.length],
                  dedicate: 'LOGISTICS',
                  easygoDicopot: 'BELUM',
                  planDate: i % 3 === 0 ? '15-06-2026' : '',
                  lokasiPasang: i % 3 === 0 ? `POOL ${LOCS[i % LOCS.length]}` : '',
                  keteranganPlanner: i % 3 === 0 ? 'Tolong pasang di dashboard kiri' : '',
                  teknisiPelaksana: '',
                  statusPlan: i % 3 === 0 ? 'PLAN' : 'UNPLAN',
                  statusPasang: 'BELUM DIPASANG',
                  modelGpsBaru: '',
                  gps: '', buzzer: '', sos: '', sensorWing: '',
                  statusSystem: '', statusSuspend: '',
                  updatedAt: ''
                })));
                globalAddToast('Berjalan dalam Mode Offline (Demo)!', 'info');
              }}>Jalankan Offline</button>
              <button className="btn btn-danger" onClick={logout}>Keluar</button>
            </div>
          </div>
        );
      }

      return (
        <div className={`app-wrapper ${isMobile && (user.role === 'teknisi' || user.role === 'pic') ? 'mobile-only' : ''}`}>
          {/* Sidebar Navigation */}
          {(!isMobile || (user.role !== 'teknisi' && user.role !== 'pic')) && (
            <>
              <div 
                className={`sidebar-overlay ${mobileMenuOpen ? 'open' : ''}`} 
                onClick={() => setMobileMenuOpen(false)}
              />
              <aside className={`sidebar ${mobileMenuOpen ? 'open' : ''}`}>
                <div className="sidebar-header">
                  <div className="sidebar-logo-icon">
                    <i className="bi bi-geo-alt"></i>
                  </div>
                  <div className="sidebar-brand">
                    PUNINAR
                    <span>GPS Portal v2</span>
                  </div>
                  <button className="sidebar-close-btn" onClick={() => setMobileMenuOpen(false)}>
                    <i className="bi bi-x"></i>
                  </button>
                </div>
                
                <div className="sidebar-user">
                  <div className="sidebar-avatar">
                    {user.name.charAt(0).toUpperCase()}
                  </div>
                  <div className="sidebar-user-info">
                    <div className="sidebar-username">{user.name}</div>
                    <div className="sidebar-role">{user.role} Account</div>
                  </div>
                </div>

                <nav className="sidebar-menu">
                  {tabs.map(t => (
                    <button 
                      key={t.id} 
                      onClick={() => {
                        setTab(t.id);
                        setMobileMenuOpen(false);
                      }} 
                      className={`menu-item ${tab === t.id ? 'active' : ''}`}
                    >
                      <i className={`ti ${t.icon}`}></i>
                      {t.label}
                    </button>
                  ))}
                </nav>

                <div className="sidebar-footer">
                  <button className="theme-toggle-btn" onClick={() => {
                    const cur = document.documentElement.getAttribute('data-theme');
                    const next = cur === 'dark' ? 'light' : 'dark';
                    document.documentElement.setAttribute('data-theme', next);
                    localStorage.setItem('theme', next);
                  }}>
                    <i className="bi bi-brightness-medium"></i> Ganti Tema
                  </button>
                  <button className="logout-btn" onClick={() => {
                    setMobileMenuOpen(false);
                    logout();
                  }}>
                    <i className="bi bi-box-arrow-right"></i> Logout
                  </button>
                </div>
              </aside>
            </>
          )}

          {/* Main Layout Area */}
          <div className="main-layout">
            <header className="topbar">
              <div className="topbar-left" style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
                {(!isMobile || (user.role !== 'teknisi' && user.role !== 'pic')) && (
                  <button className="menu-toggle" onClick={() => setMobileMenuOpen(true)}>
                    <i className="bi bi-list"></i>
                  </button>
                )}
                <span className="topbar-title-sec">{tabs.find(t=>t.id===tab)?.label || 'Aplikasi'}</span>
              </div>
              <div className="topbar-right">
                <div className={`sync-status ${syncState}`}>
                  <i className={`ti ${syncState === 'syncing' ? 'ti-refresh' : syncState === 'success' ? 'ti-cloud-check' : 'ti-cloud-off'}`}></i>
                  <span style={{display: isMobile ? 'none' : 'inline'}}>{syncState === 'syncing' ? 'Syncing...' : syncState === 'success' ? 'Sheets Terhubung' : 'Offline / Error'}</span>
                </div>
                <button className="refresh-icon-btn" onClick={loadData} title="Refresh data">
                  <i className="bi bi-arrow-clockwise" style={{fontSize: 16}}></i>
                </button>
                <div style={{ display: isMobile ? 'none' : 'flex', flexDirection: 'column', alignItems: 'flex-end', fontSize: 10, color: 'var(--text-secondary)' }}>
                  <span>{doneStats.done} / {doneStats.total} Done</span>
                  <span style={{ fontWeight: 700, color: 'var(--color-done)' }}>{doneStats.pct}% Selesai</span>
                </div>
                {(user.role === 'teknisi' || user.role === 'pic') && (
                  <button className="btn btn-danger btn-sm" onClick={logout} style={{ marginLeft: 6 }}>
                    <i className="bi bi-box-arrow-right"></i> Keluar
                  </button>
                )}
              </div>
            </header>

            <main className="view-content">
              {tab === 'dashboard' && <DashboardView units={units} isMobile={isMobile} />}
              {tab === 'progress' && <ProgressMonitoringView units={units} isMobile={isMobile} />}
              {tab === 'planner' && <PlannerView units={units} setUnits={setUnits} syncUpdate={syncUpdate} isMobile={isMobile} />}
              {tab === 'teknisi' && <TeknisiView units={units} setUnits={setUnits} syncUpdate={syncUpdate} isMobile={isMobile} />}
              {tab === 'pic' && <PICLapanganView units={units} setUnits={setUnits} syncUpdate={syncUpdate} isMobile={isMobile} />}
              {tab === 'it' && <ITView units={units} setUnits={setUnits} syncUpdate={syncUpdate} isMobile={isMobile} />}
              {tab === 'cmt' && <CMTView units={units} setUnits={setUnits} syncUpdate={syncUpdate} isMobile={isMobile} />}
              {tab === 'rekap' && <RekapView units={units} isMobile={isMobile} />}
              {tab === 'admin' && <AdminView units={units} />}
            </main>

            {/* Mobile Bottom Navigation Bar */}
            {(user.role !== 'teknisi' && user.role !== 'pic') && (
              <nav className="mobile-nav-bar">
                {tabs.slice(0, 4).map(t => (
                  <button key={t.id} onClick={() => setTab(t.id)} className={`mobile-nav-item ${tab === t.id ? 'active' : ''}`}>
                    <i className={`ti ${t.icon}`}></i>
                    <span>{t.label.split(' ')[0]}</span>
                  </button>
                ))}
                <button className={`mobile-nav-item ${mobileMenuOpen ? 'active' : ''}`} onClick={() => setMobileMenuOpen(!mobileMenuOpen)}>
                  <i className="bi bi-list"></i>
                  <span>Menu</span>
                </button>
              </nav>
            )}
          </div>
        </div>
      );
    }

    // ----------------------------------------------------
    // PASSWORD/LOGIN GATE VIEW
    // ----------------------------------------------------
    function LoginGate() {
      const { login, users, restoreUsers } = useContext(AuthContext);
      const [username, setUsername] = useState('');
      const [password, setPassword] = useState('');
      const [showPassword, setShowPassword] = useState(false);
      const [errMessage, setErrMessage] = useState('');
      const [loadingLogin, setLoadingLogin] = useState(false);

      const handleSubmit = async (e) => {
        e.preventDefault();
        setErrMessage('');
        
        if (!username || !password) {
          setErrMessage('Username dan Password wajib diisi!');
          return;
        }

        setLoadingLogin(true);
        try {
          const res = await login(username, password);
          if (!res.success) {
            setErrMessage(res.message);
          }
        } catch (err) {
          setErrMessage('Koneksi gagal: ' + String(err));
        } finally {
          setLoadingLogin(false);
        }
      };

      return (
        <div className="login-container">
          <form onSubmit={handleSubmit} className="login-card">
            <div className="login-logo">
              <i className="bi bi-lock"></i>
            </div>
            <div className="login-title">PUNINAR LOGISTICS</div>
            <div className="login-subtitle">Aplikasi Portal Migrasi GPS & Checklist</div>
            
            {errMessage && (
              <div style={{
                background: 'var(--color-delay-bg)',
                border: '1px solid rgba(239, 68, 68, 0.2)',
                color: 'var(--color-delay)',
                padding: '10px 12px',
                borderRadius: 'var(--radius-sm)',
                fontSize: 11,
                fontWeight: 600,
                marginBottom: 16,
                textAlign: 'center'
              }}>
                {errMessage}
              </div>
            )}

            <div className="input-group">
              <label className="input-label">USERNAME</label>
              <input type="text" value={username} onChange={e => setUsername(e.target.value)} className="input-field" placeholder="Masukkan username" required autoFocus />
            </div>

            <div className="input-group">
              <label className="input-label">PASSWORD</label>
              <input type={showPassword ? 'text' : 'password'} value={password} onChange={e => setPassword(e.target.value)} className="input-field" placeholder="Masukkan password" required />
              <button type="button" className="password-toggle" onClick={() => setShowPassword(!showPassword)}>
                <i className={`ti ${showPassword ? 'ti-eye-off' : 'ti-eye'}`}></i>
              </button>
            </div>

            <button type="submit" className="login-btn" disabled={loadingLogin}>
              {loadingLogin ? 'Memverifikasi...' : 'Masuk Aplikasi'}
            </button>

            {/* Quick Demo Credentials Helper */}
            <div style={{
              marginTop: 20, 
              paddingTop: 16, 
              borderTop: '1px dashed var(--border-color)', 
              textAlign: 'left'
            }}>
              <div style={{
                fontSize: 11, 
                fontWeight: 600, 
                color: 'var(--text-secondary)', 
                marginBottom: 8, 
                display: 'flex', 
                justifyContent: 'space-between', 
                alignItems: 'center'
              }}>
                <span style={{display: 'flex', alignItems: 'center', gap: 6}}>
                  <i className="bi bi-info-circle"></i> Akun Demo / Uji Coba:
                </span>
                <button 
                  type="button" 
                  onClick={async () => {
                    if (confirm('Reset database user ke pengaturan awal di Supabase? Semua akun tambahan akan dihapus.')) {
                      setLoadingLogin(true);
                      try {
                        await supabaseClient.from('users').delete().neq('id', 0);
                        await restoreUsers(DEFAULT_USERS);
                        alert('Database user berhasil di-reset!');
                      } catch (err) {
                        alert('Gagal reset: ' + String(err));
                      } finally {
                        setLoadingLogin(false);
                      }
                    }
                  }}
                  style={{
                    background: 'none',
                    border: 'none',
                    color: 'var(--color-delay)',
                    fontSize: 9,
                    cursor: 'pointer',
                    textDecoration: 'underline',
                    padding: 0
                  }}
                >
                  Reset DB User
                </button>
              </div>
              <div style={{
                display: 'grid', 
                gridTemplateColumns: '1fr 1fr', 
                gap: 6,
                maxHeight: 120,
                overflowY: 'auto',
                paddingRight: 4
              }}>
                {users.map(u => (
                  <button
                    key={u.id}
                    type="button"
                    onClick={() => {
                      setUsername(u.username);
                      setPassword(u.password);
                    }}
                    className="btn btn-secondary btn-sm"
                    style={{
                      fontSize: 10, 
                      padding: '6px 8px', 
                      textAlign: 'left',
                      display: 'flex',
                      flexDirection: 'column',
                      gap: 2,
                      alignItems: 'flex-start',
                      width: '100%',
                      height: 'auto',
                      justifyContent: 'center',
                      background: 'var(--bg-secondary)',
                      border: '1px solid var(--border-color)'
                    }}
                  >
                    <span style={{fontWeight: 700, fontSize: 9}}>{u.name}</span>
                    <span style={{fontSize: 8, color: 'var(--text-tertiary)'}}>u: {u.username} | p: {u.password}</span>
                  </button>
                ))}
              </div>
            </div>
            
            <div style={{marginTop: 24, fontSize: 10, color: 'var(--text-tertiary)', textAlign: 'center'}}>
              Puninar Logistics IT Team • © 2026
            </div>
          </form>
        </div>
      );
    }

    // ----------------------------------------------------
    // APP INITIALIZATION ROOT
    // ----------------------------------------------------
    function Root() {
      const { user } = useContext(AuthContext);

      useEffect(() => {
        // Theme initialization
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      }, []);

      if (!user) return <LoginGate />;
      return <App />;
    }

    ReactDOM.createRoot(document.getElementById('root')).render(
      <AuthProvider>
        <Root />
        <ToastContainer />
      </AuthProvider>
    );
  </script>
</body>
</html>
